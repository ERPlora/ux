---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodePreview from '../../components/CodePreview.astro';
---

<DocsLayout title="Pricing Card">
  <p class="text-base-content/70 mb-6">Pricing plan cards with top badge, price display, feature list, and CTA button. Extends <code>.card</code> with overflow-visible for badges and full-height layout.</p>

  <CodePreview
    title="Basic Pricing Cards"
    semantic={`<div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; max-width: 600px;">
  <!-- Free plan -->
  <div class="card pricing-card">
    <div class="card-body" style="padding: 1.5rem;">
      <h3 style="font-size: 1.25rem; font-weight: 600; margin-bottom: 0.25rem;">Free</h3>
      <p style="font-size: 0.875rem; opacity: 0.6; margin-bottom: 1rem;">For small teams</p>
      <div style="margin-bottom: 1.5rem;">
        <span class="pricing-card-price">FREE</span>
      </div>
      <div class="pricing-card-features" style="margin-bottom: 2rem;">
        <div class="pricing-card-feature">
          <span class="pricing-card-feature-icon" style="color: var(--color-success);">✓</span>
          <span class="pricing-card-feature-text">Up to 5 users</span>
        </div>
        <div class="pricing-card-feature">
          <span class="pricing-card-feature-icon" style="color: var(--color-success);">✓</span>
          <span class="pricing-card-feature-text">Basic features</span>
        </div>
        <div class="pricing-card-feature">
          <span class="pricing-card-feature-icon" style="color: var(--color-success);">✓</span>
          <span class="pricing-card-feature-text">Community support</span>
        </div>
      </div>
      <button class="btn btn-outline color-primary" style="width: 100%; margin-top: auto;">Get Started</button>
    </div>
  </div>

  <!-- Premium plan with badge -->
  <div class="card pricing-card pricing-card-featured color-primary">
    <span class="chip color-primary pricing-card-badge">Most Popular</span>
    <div class="card-body" style="padding: 1.5rem;">
      <h3 style="font-size: 1.25rem; font-weight: 600; margin-bottom: 0.25rem;">Pro</h3>
      <p style="font-size: 0.875rem; opacity: 0.6; margin-bottom: 1rem;">For growing businesses</p>
      <div style="margin-bottom: 1.5rem;">
        <span class="pricing-card-price">€49</span>
        <span class="pricing-card-period">/month</span>
      </div>
      <div class="pricing-card-features" style="margin-bottom: 2rem;">
        <div class="pricing-card-feature">
          <span class="pricing-card-feature-icon" style="color: var(--color-success);">✓</span>
          <span class="pricing-card-feature-text">Unlimited users</span>
        </div>
        <div class="pricing-card-feature">
          <span class="pricing-card-feature-icon" style="color: var(--color-success);">✓</span>
          <span class="pricing-card-feature-text">All features</span>
        </div>
        <div class="pricing-card-feature">
          <span class="pricing-card-feature-icon" style="color: var(--color-success);">✓</span>
          <span class="pricing-card-feature-text">Priority support</span>
        </div>
      </div>
      <button class="btn color-primary" style="width: 100%; margin-top: auto;">Get Started</button>
    </div>
  </div>
</div>`}
    tailwind={`<div class="grid grid-cols-2 gap-6 max-w-xl">
  <div class="card pricing-card">
    <div class="card-body p-6">
      <h3 class="text-xl font-semibold mb-1">Free</h3>
      <p class="text-sm text-base-content/60 mb-4">For small teams</p>
      <div class="mb-6">
        <span class="pricing-card-price">FREE</span>
      </div>
      <div class="pricing-card-features mb-8">
        <div class="pricing-card-feature">
          <span class="pricing-card-feature-icon text-success">✓</span>
          <span class="pricing-card-feature-text">Up to 5 users</span>
        </div>
        <div class="pricing-card-feature">
          <span class="pricing-card-feature-icon text-success">✓</span>
          <span class="pricing-card-feature-text">Basic features</span>
        </div>
      </div>
      <button class="btn btn-outline color-primary w-full mt-auto">Get Started</button>
    </div>
  </div>

  <div class="card pricing-card pricing-card-featured color-primary">
    <span class="chip color-primary pricing-card-badge">Most Popular</span>
    <div class="card-body p-6">
      <h3 class="text-xl font-semibold mb-1">Pro</h3>
      <p class="text-sm text-base-content/60 mb-4">For growing businesses</p>
      <div class="mb-6">
        <span class="pricing-card-price">€49</span>
        <span class="pricing-card-period">/month</span>
      </div>
      <div class="pricing-card-features mb-8">
        <div class="pricing-card-feature">
          <span class="pricing-card-feature-icon text-success">✓</span>
          <span class="pricing-card-feature-text">Unlimited users</span>
        </div>
        <div class="pricing-card-feature">
          <span class="pricing-card-feature-icon text-success">✓</span>
          <span class="pricing-card-feature-text">All features</span>
        </div>
      </div>
      <button class="btn color-primary w-full mt-auto">Get Started</button>
    </div>
  </div>
</div>`}
    js={`// No JavaScript required for styling
// Use .pricing-card-featured with .color-{name} to highlight a plan
// Use .pricing-card-badge with .chip for a top-edge badge`}
  />

  <CodePreview
    title="Glass Variant"
    semantic={`<div class="p-8 rounded-box" style="background: linear-gradient(135deg, #1a1a2e, #16213e);">
  <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; max-width: 900px;">
    <div class="card glass pricing-card" style="color: white;">
      <div class="card-body" style="padding: 1.5rem;">
        <h3 style="font-size: 1.25rem; font-weight: 600; margin-bottom: 0.25rem;">Starter</h3>
        <p style="font-size: 0.875rem; opacity: 0.6; margin-bottom: 1rem;">Get started</p>
        <div style="margin-bottom: 1.5rem;">
          <span class="pricing-card-price">€29</span>
          <span class="pricing-card-period">/month</span>
        </div>
        <div class="pricing-card-features" style="margin-bottom: 2rem;">
          <div class="pricing-card-feature">
            <span class="pricing-card-feature-icon" style="color: var(--color-success);">✓</span>
            <span class="pricing-card-feature-text">Basic features</span>
          </div>
          <div class="pricing-card-feature">
            <span class="pricing-card-feature-icon" style="color: var(--color-success);">✓</span>
            <span class="pricing-card-feature-text">5 users</span>
          </div>
        </div>
        <button class="btn btn-outline" style="width: 100%; margin-top: auto; color: white; border-color: rgba(255,255,255,0.3);">Choose Plan</button>
      </div>
    </div>

    <div class="card glass pricing-card pricing-card-featured" style="color: white; border-color: var(--color-primary);">
      <span class="chip color-primary pricing-card-badge">Popular</span>
      <div class="card-body" style="padding: 1.5rem;">
        <h3 style="font-size: 1.25rem; font-weight: 600; margin-bottom: 0.25rem;">Standard</h3>
        <p style="font-size: 0.875rem; opacity: 0.6; margin-bottom: 1rem;">Most popular</p>
        <div style="margin-bottom: 1.5rem;">
          <span class="pricing-card-price">€54</span>
          <span class="pricing-card-period">/month</span>
        </div>
        <div class="pricing-card-features" style="margin-bottom: 2rem;">
          <div class="pricing-card-feature">
            <span class="pricing-card-feature-icon" style="color: var(--color-success);">✓</span>
            <span class="pricing-card-feature-text">All features</span>
          </div>
          <div class="pricing-card-feature">
            <span class="pricing-card-feature-icon" style="color: var(--color-success);">✓</span>
            <span class="pricing-card-feature-text">Unlimited users</span>
          </div>
          <div class="pricing-card-feature">
            <span class="pricing-card-feature-icon" style="color: var(--color-success);">✓</span>
            <span class="pricing-card-feature-text">Priority support</span>
          </div>
        </div>
        <button class="btn color-primary" style="width: 100%; margin-top: auto;">Choose Plan</button>
      </div>
    </div>

    <div class="card glass pricing-card" style="color: white;">
      <div class="card-body" style="padding: 1.5rem;">
        <h3 style="font-size: 1.25rem; font-weight: 600; margin-bottom: 0.25rem;">Enterprise</h3>
        <p style="font-size: 0.875rem; opacity: 0.6; margin-bottom: 1rem;">Custom solutions</p>
        <div style="margin-bottom: 1.5rem;">
          <span class="pricing-card-price">€109</span>
          <span class="pricing-card-period">/month</span>
        </div>
        <div class="pricing-card-features" style="margin-bottom: 2rem;">
          <div class="pricing-card-feature">
            <span class="pricing-card-feature-icon" style="color: var(--color-success);">✓</span>
            <span class="pricing-card-feature-text">Everything in Standard</span>
          </div>
          <div class="pricing-card-feature">
            <span class="pricing-card-feature-icon" style="color: var(--color-success);">✓</span>
            <span class="pricing-card-feature-text">Dedicated support</span>
          </div>
        </div>
        <button class="btn btn-outline" style="width: 100%; margin-top: auto; color: white; border-color: rgba(255,255,255,0.3);">Contact Sales</button>
      </div>
    </div>
  </div>
</div>`}
    tailwind={`<!-- Same structure with Tailwind utility classes -->`}
    js={`// No JavaScript required`}
  />

  <CodePreview
    title="With Pricing Grid"
    semantic={`<div class="pricing-grid" style="max-width: 900px;">
  <div class="flex">
    <div class="card pricing-card" style="width: 100%;">
      <div class="card-body" style="padding: 1.5rem;">
        <h3 style="font-size: 1.25rem; font-weight: 600;">Starter</h3>
        <div style="margin: 1rem 0;">
          <span class="pricing-card-price">€29</span>
          <span class="pricing-card-period">/month</span>
        </div>
        <button class="btn btn-outline color-primary" style="width: 100%;">Choose</button>
      </div>
    </div>
  </div>
  <div class="flex">
    <div class="card pricing-card pricing-card-featured color-primary" style="width: 100%;">
      <span class="chip color-primary pricing-card-badge">Popular</span>
      <div class="card-body" style="padding: 1.5rem;">
        <h3 style="font-size: 1.25rem; font-weight: 600;">Standard</h3>
        <div style="margin: 1rem 0;">
          <span class="pricing-card-price">€54</span>
          <span class="pricing-card-period">/month</span>
        </div>
        <button class="btn color-primary" style="width: 100%;">Choose</button>
      </div>
    </div>
  </div>
  <div class="flex">
    <div class="card pricing-card" style="width: 100%;">
      <div class="card-body" style="padding: 1.5rem;">
        <h3 style="font-size: 1.25rem; font-weight: 600;">Pro</h3>
        <div style="margin: 1rem 0;">
          <span class="pricing-card-price">€109</span>
          <span class="pricing-card-period">/month</span>
        </div>
        <button class="btn btn-outline color-primary" style="width: 100%;">Choose</button>
      </div>
    </div>
  </div>
  <div class="flex">
    <div class="card pricing-card" style="width: 100%;">
      <div class="card-body" style="padding: 1.5rem;">
        <h3 style="font-size: 1.25rem; font-weight: 600;">Enterprise</h3>
        <div style="margin: 1rem 0;">
          <span class="pricing-card-price">€209</span>
          <span class="pricing-card-period">/month</span>
        </div>
        <button class="btn btn-outline color-primary" style="width: 100%;">Choose</button>
      </div>
    </div>
  </div>
  <div class="flex">
    <div class="card pricing-card" style="width: 100%;">
      <div class="card-body" style="padding: 1.5rem;">
        <h3 style="font-size: 1.25rem; font-weight: 600;">Max</h3>
        <div style="margin: 1rem 0;">
          <span class="pricing-card-price">€434</span>
          <span class="pricing-card-period">/month</span>
        </div>
        <button class="btn btn-outline color-primary" style="width: 100%;">Choose</button>
      </div>
    </div>
  </div>
</div>`}
    tailwind={`<!-- Use .pricing-grid with .pricing-card for auto-centered layouts (3+2, 3+1, etc.) -->`}
    js={`// No JavaScript required
// .pricing-grid handles responsive layout automatically
// 3 cards = 1 row, 4 = 3+1 centered, 5 = 3+2 centered, 6 = 3+3`}
  />
</DocsLayout>
