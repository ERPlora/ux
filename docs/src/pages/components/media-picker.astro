---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodePreview from '../../components/CodePreview.astro';
---

<DocsLayout title="Media Picker">
  <p class="text-base-content/70 mb-6">WordPress-style image selector with thumbnail preview, modal browser, and image grid. Pairs with the Upload component for drag-and-drop.</p>

  <CodePreview
    title="Preview Thumbnail"
    semantic={`<!-- Empty state -->
<div class="media-picker-preview">
  <svg xmlns="http://www.w3.org/2000/svg" class="size-6 opacity-30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
</div>

<!-- With image -->
<div class="media-picker-preview media-picker-preview-filled">
  <img src="https://picsum.photos/128" alt="Selected">
</div>

<!-- Circle variant (avatars) -->
<div class="media-picker-preview media-picker-preview-circle">
  <img src="https://picsum.photos/128" alt="Avatar">
</div>`}
    tailwind={`<div class="size-16 flex items-center justify-center overflow-hidden cursor-pointer border-2 border-dashed border-base-300 rounded-lg bg-base-100 hover:border-primary transition-colors">
  <svg class="size-6 opacity-30" ...></svg>
</div>`}
  />

  <CodePreview
    title="Size Variants"
    semantic={`<div class="flex items-end gap-4">
  <div class="media-picker-preview media-picker-preview-sm">
    <img src="https://picsum.photos/96" alt="">
  </div>
  <div class="media-picker-preview">
    <img src="https://picsum.photos/128" alt="">
  </div>
  <div class="media-picker-preview media-picker-preview-lg">
    <img src="https://picsum.photos/192" alt="">
  </div>
</div>`}
  />

  <CodePreview
    title="Image Grid"
    semantic={`<div class="media-grid">
  <div class="media-grid-item">
    <img src="https://picsum.photos/200?1" alt="">
    <span class="media-grid-name">photo-001.webp</span>
  </div>
  <div class="media-grid-item media-grid-item-selected">
    <img src="https://picsum.photos/200?2" alt="">
    <span class="media-grid-name">logo.png</span>
  </div>
  <div class="media-grid-item">
    <img src="https://picsum.photos/200?3" alt="">
    <span class="media-grid-name">banner.jpg</span>
  </div>
  <div class="media-grid-item">
    <img src="https://picsum.photos/200?4" alt="">
    <span class="media-grid-name">product-hero.webp</span>
  </div>
</div>`}
    tailwind={`<div class="grid grid-cols-[repeat(auto-fill,minmax(100px,1fr))] gap-3">
  <div class="relative aspect-square overflow-hidden cursor-pointer border-2 border-transparent rounded-lg bg-base-200 hover:border-primary transition-all">
    <img src="..." class="size-full object-cover" alt="">
    <span class="absolute bottom-0 inset-x-0 px-1.5 py-0.5 text-[10px] bg-base-content/70 text-base-100 truncate">photo.webp</span>
  </div>
</div>`}
  />

  <CodePreview
    title="Grid Sizes"
    semantic={`<!-- Small grid -->
<div class="media-grid media-grid-sm">
  <div class="media-grid-item"><img src="https://picsum.photos/144?1" alt=""></div>
  <div class="media-grid-item"><img src="https://picsum.photos/144?2" alt=""></div>
  <div class="media-grid-item"><img src="https://picsum.photos/144?3" alt=""></div>
  <div class="media-grid-item"><img src="https://picsum.photos/144?4" alt=""></div>
  <div class="media-grid-item"><img src="https://picsum.photos/144?5" alt=""></div>
  <div class="media-grid-item"><img src="https://picsum.photos/144?6" alt=""></div>
</div>

<!-- Large grid -->
<div class="media-grid media-grid-lg">
  <div class="media-grid-item"><img src="https://picsum.photos/280?1" alt=""></div>
  <div class="media-grid-item"><img src="https://picsum.photos/280?2" alt=""></div>
  <div class="media-grid-item"><img src="https://picsum.photos/280?3" alt=""></div>
</div>`}
  />

  <CodePreview
    title="Empty State"
    semantic={`<div class="media-grid">
  <div class="media-grid-empty col-span-full">
    <p>No images found. Upload one!</p>
  </div>
</div>`}
  />

  <CodePreview
    title="Full Picker (with Modal)"
    semantic={`<!-- Media Picker with preview + open button + modal -->
<div class="media-picker">
  <div class="flex items-center gap-3">
    <div class="media-picker-preview media-picker-preview-filled">
      <img src="https://picsum.photos/128" alt="">
    </div>
    <div class="flex flex-col gap-1">
      <button class="btn btn-sm btn-outline">Change</button>
      <button class="btn btn-sm btn-ghost text-error">Remove</button>
    </div>
  </div>

  <!-- Modal (use data-state="open" to show) -->
  <div class="modal-backdrop" data-state="open">
    <div class="modal modal-lg" style="max-height: 85vh;">
      <div class="modal-header">
        <h3 class="modal-title">Media Library</h3>
        <button class="modal-close">&times;</button>
      </div>
      <div class="flex gap-1 px-4 pt-2 border-b border-base-200">
        <button class="tab tab-active tab-bordered">Upload</button>
        <button class="tab tab-bordered">My images</button>
        <button class="tab tab-bordered">Shared</button>
      </div>
      <div class="modal-body" style="min-height: 320px; max-height: 55vh; overflow-y: auto;">
        <div class="media-grid">
          <div class="media-grid-item">
            <img src="https://picsum.photos/200?a" alt="">
            <span class="media-grid-name">photo-1.webp</span>
          </div>
          <div class="media-grid-item media-grid-item-selected">
            <img src="https://picsum.photos/200?b" alt="">
            <span class="media-grid-name">selected.png</span>
          </div>
          <div class="media-grid-item">
            <img src="https://picsum.photos/200?c" alt="">
            <span class="media-grid-name">banner.jpg</span>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-sm">Cancel</button>
        <button class="btn btn-sm color-primary">Select</button>
      </div>
    </div>
  </div>
</div>`}
    js={`// Alpine.js example:
// x-data="mediaPicker('field_name', '/media/current.jpg', 'products')"
//
// Properties:
//   selectedUrl   — currently selected image URL
//   pendingUrl    — selection in modal (before confirm)
//   isOpen        — modal visibility
//   tab           — active tab: 'upload' | 'library' | 'shared'
//
// Methods:
//   open()        — open modal
//   close()       — close modal
//   confirm()     — apply pending selection
//   clear()       — remove image
//   selectPending(url) — select an image in the grid`}
  />

  <h3 class="text-lg font-semibold mt-8 mb-4">Reference</h3>
  <div class="overflow-x-auto">
    <table class="table">
      <thead>
        <tr><th>Class</th><th>Description</th></tr>
      </thead>
      <tbody>
        <tr><td><code>.media-picker</code></td><td>Root container</td></tr>
        <tr><td><code>.media-picker-preview</code></td><td>Thumbnail preview (64px square, dashed border)</td></tr>
        <tr><td><code>.media-picker-preview-sm</code></td><td>Small preview (48px)</td></tr>
        <tr><td><code>.media-picker-preview-lg</code></td><td>Large preview (96px)</td></tr>
        <tr><td><code>.media-picker-preview-circle</code></td><td>Circular preview (for avatars)</td></tr>
        <tr><td><code>.media-picker-preview-filled</code></td><td>Solid border when image is present</td></tr>
        <tr><td><code>.media-grid</code></td><td>Auto-fill grid for images (100px min columns)</td></tr>
        <tr><td><code>.media-grid-sm</code></td><td>Smaller grid columns (72px min)</td></tr>
        <tr><td><code>.media-grid-lg</code></td><td>Larger grid columns (140px min)</td></tr>
        <tr><td><code>.media-grid-item</code></td><td>Grid cell with hover effect</td></tr>
        <tr><td><code>.media-grid-item-selected</code></td><td>Selected state (primary ring)</td></tr>
        <tr><td><code>.media-grid-name</code></td><td>Filename overlay at bottom</td></tr>
        <tr><td><code>.media-grid-empty</code></td><td>Empty state placeholder</td></tr>
      </tbody>
    </table>
  </div>
</DocsLayout>
