---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodePreview from '../../components/CodePreview.astro';
---

<DocsLayout title="Select Modal">
  <p class="text-base-content/70 mb-6">Ionic-style select that opens a modal with radio or checkbox options. Combines the trigger (styled like a select) with a modal overlay containing option items. Reuses existing <code>.modal</code>, <code>.radio</code>, <code>.checkbox</code>, and <code>.btn</code> components.</p>

  <!-- ============================================= -->
  <!-- SINGLE SELECT (radios)                        -->
  <!-- ============================================= -->

  <CodePreview
    title="Single Select (Radios)"
    height="460px"
    semantic={`<div class="modal-backdrop" data-state="open" style="position: relative; min-height: 400px; padding: 1rem; background: transparent;">
  <div class="modal modal-sm" style="position: relative; transform: none; opacity: 1;">
    <div class="modal-header">
      <h3 class="modal-title">Select Framework</h3>
      <button class="modal-close">&times;</button>
    </div>
    <div class="modal-body p-0">
      <label class="select-modal-option select-modal-option-selected">
        <input type="radio" name="fw" class="radio-input" value="React" checked>
        <span class="radio-circle"><span class="radio-dot"></span></span>
        <span class="select-modal-option-label">React</span>
      </label>
      <label class="select-modal-option">
        <input type="radio" name="fw" class="radio-input" value="Vue">
        <span class="radio-circle"><span class="radio-dot"></span></span>
        <span class="select-modal-option-label">Vue</span>
      </label>
      <label class="select-modal-option">
        <input type="radio" name="fw" class="radio-input" value="Svelte">
        <span class="radio-circle"><span class="radio-dot"></span></span>
        <span class="select-modal-option-label">Svelte</span>
      </label>
      <label class="select-modal-option">
        <input type="radio" name="fw" class="radio-input" value="Astro">
        <span class="radio-circle"><span class="radio-dot"></span></span>
        <span class="select-modal-option-label">Astro</span>
      </label>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost btn-sm">Cancel</button>
      <button class="btn btn-sm color-primary">OK</button>
    </div>
  </div>
</div>`}
    tailwind={`<!-- Trigger (styled like a native select) -->
<button class="select-modal" onclick="...">
  <span class="select-modal-placeholder">Select framework...</span>
</button>

<!-- Modal with radio options -->
<div class="modal-backdrop" data-state="open">
  <div class="modal modal-sm">
    <div class="modal-header">
      <h3 class="modal-title">Select Framework</h3>
      <button class="modal-close">&times;</button>
    </div>
    <div class="modal-body p-0">
      <label class="select-modal-option select-modal-option-selected">
        <input type="radio" name="fw" class="radio-input" value="React" checked>
        <span class="radio-circle"><span class="radio-dot"></span></span>
        <span class="select-modal-option-label">React</span>
      </label>
      <label class="select-modal-option">
        <input type="radio" name="fw" class="radio-input" value="Vue">
        <span class="radio-circle"><span class="radio-dot"></span></span>
        <span class="select-modal-option-label">Vue</span>
      </label>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost btn-sm">Cancel</button>
      <button class="btn btn-sm color-primary">OK</button>
    </div>
  </div>
</div>`}
    js={`// Open/close modal: toggle data-state="open"/"closed" on .modal-backdrop
// Update trigger text when a radio is selected:
document.querySelectorAll('.select-modal-option input[type="radio"]').forEach(input => {
  input.addEventListener('change', () => {
    // Update selected highlight
    document.querySelectorAll('.select-modal-option').forEach(opt => {
      opt.classList.toggle('select-modal-option-selected', opt.querySelector('input').checked);
    });
    // Update trigger text
    document.querySelector('.select-modal-value').textContent = input.value;
  });
});

// With Alpine.js: use x-model on radios for automatic binding
// <input type="radio" name="fw" class="radio-input" value="React" x-model="selected">`}
  />

  <!-- ============================================= -->
  <!-- TRIGGER                                       -->
  <!-- ============================================= -->

  <CodePreview
    title="Trigger (Select Button)"
    noFrame={true}
    semantic={`<div class="flex flex-col gap-3 w-full max-w-sm">
  <button class="select-modal">
    <span class="select-modal-placeholder">Select framework...</span>
  </button>
  <button class="select-modal">
    <span class="select-modal-value">React</span>
  </button>
</div>`}
    tailwind={`<div class="flex flex-col gap-3 w-full max-w-sm">
  <!-- Empty state (placeholder) -->
  <button class="select-modal">
    <span class="select-modal-placeholder">Select framework...</span>
  </button>
  <!-- With value selected -->
  <button class="select-modal">
    <span class="select-modal-value">React</span>
  </button>
</div>`}
    js={`// .select-modal-placeholder: dimmed text when nothing selected
// .select-modal-value: full-contrast text for the selected value`}
  />

  <!-- ============================================= -->
  <!-- MULTIPLE SELECT (checkboxes)                  -->
  <!-- ============================================= -->

  <CodePreview
    title="Multiple Select (Checkboxes)"
    height="460px"
    semantic={`<div class="modal-backdrop" data-state="open" style="position: relative; min-height: 400px; padding: 1rem; background: transparent;">
  <div class="modal modal-sm" style="position: relative; transform: none; opacity: 1;">
    <div class="modal-header">
      <h3 class="modal-title">Select Fruits</h3>
      <button class="modal-close">&times;</button>
    </div>
    <div class="modal-body p-0">
      <label class="select-modal-option select-modal-option-selected">
        <input type="checkbox" class="checkbox-input" value="Apple" checked>
        <span class="checkbox-box"><svg class="checkbox-mark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg></span>
        <span class="select-modal-option-label">Apple</span>
      </label>
      <label class="select-modal-option">
        <input type="checkbox" class="checkbox-input" value="Banana">
        <span class="checkbox-box"><svg class="checkbox-mark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg></span>
        <span class="select-modal-option-label">Banana</span>
      </label>
      <label class="select-modal-option select-modal-option-selected">
        <input type="checkbox" class="checkbox-input" value="Cherry" checked>
        <span class="checkbox-box"><svg class="checkbox-mark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg></span>
        <span class="select-modal-option-label">Cherry</span>
      </label>
      <label class="select-modal-option">
        <input type="checkbox" class="checkbox-input" value="Mango">
        <span class="checkbox-box"><svg class="checkbox-mark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg></span>
        <span class="select-modal-option-label">Mango</span>
      </label>
      <label class="select-modal-option">
        <input type="checkbox" class="checkbox-input" value="Orange">
        <span class="checkbox-box"><svg class="checkbox-mark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg></span>
        <span class="select-modal-option-label">Orange</span>
      </label>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost btn-sm">Cancel</button>
      <button class="btn btn-sm color-primary">OK</button>
    </div>
  </div>
</div>`}
    tailwind={`<!-- Same structure but with checkbox inputs -->
<label class="select-modal-option select-modal-option-selected">
  <input type="checkbox" class="checkbox-input" value="Apple" checked>
  <span class="checkbox-box">
    <svg class="checkbox-mark" viewBox="0 0 24 24" fill="none"
      stroke="currentColor" stroke-width="3" stroke-linecap="round"
      stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
  </span>
  <span class="select-modal-option-label">Apple</span>
</label>`}
    js={`// Toggle select-modal-option-selected on change:
document.querySelectorAll('.select-modal-option input[type="checkbox"]').forEach(cb => {
  cb.addEventListener('change', () => {
    cb.closest('.select-modal-option').classList.toggle('select-modal-option-selected', cb.checked);
  });
});

// With Alpine.js: use x-model with array binding
// <input type="checkbox" class="checkbox-input" value="Apple" x-model="selected">`}
  />

  <!-- ============================================= -->
  <!-- WITH DESCRIPTIONS                             -->
  <!-- ============================================= -->

  <CodePreview
    title="Options with Descriptions"
    height="420px"
    semantic={`<div class="modal-backdrop" data-state="open" style="position: relative; min-height: 360px; padding: 1rem; background: transparent;">
  <div class="modal modal-sm" style="position: relative; transform: none; opacity: 1;">
