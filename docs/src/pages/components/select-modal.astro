    tailwind={`<!-- No radio/checkbox — just a check SVG per option -->
<div class="select-modal-option select-modal-option-selected">
  <span class="select-modal-option-label">Dark</span>
  <svg class="select-modal-option-check" viewBox="0 0 24 24" fill="none"
