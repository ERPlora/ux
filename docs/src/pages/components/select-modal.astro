    tailwind={`<!-- Add .glass to both trigger and modal -->
<button class="select-modal glass">...</button>
<div class="modal modal-sm glass">...</div>`}
    js={`// Glass variant uses the .glass utility class
// Trigger: .select-modal.glass
// Modal: .modal.glass
// No additional JS needed`}
  />

  <!-- ============================================= -->
  <!-- SIZES                                         -->
  <!-- ============================================= -->

  <CodePreview
    title="Sizes"
    noFrame={true}
    semantic={`<div class="flex flex-col gap-3 w-full max-w-sm">
