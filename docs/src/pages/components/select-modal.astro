  <!-- ============================================= -->
  <!-- VARIANTS                                      -->
  <!-- ============================================= -->

  <CodePreview
    title="Variants"
    noFrame={true}
    semantic={`<div class="flex flex-col gap-3 w-full max-w-sm">
  <button class="select-modal">
    <span class="select-modal-placeholder">Default (bordered)</span>
