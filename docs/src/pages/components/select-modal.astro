</div>`}
    js={`// .select-modal-option-check is hidden (opacity-0) by default
// When .select-modal-option-selected is added, the check shows (opacity-100)
// Use JS to toggle select-modal-option-selected on click`}
  />

  <!-- ============================================= -->
  <!-- WITH SEARCH                                   -->
  <!-- ============================================= -->

  <CodePreview
    title="With Search"
    height="500px"
    semantic={`<div class="modal-backdrop" data-state="open" style="position: relative; min-height: 440px; padding: 1rem; background: transparent;">
