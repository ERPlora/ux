    </div>
    <div class="modal-body p-0">
      <div class="select-modal-search">
        <input type="text" class="input input-sm w-full" placeholder="Search...">
      </div>
      <label class="select-modal-option select-modal-option-selected">
        <input type="radio" name="country" class="radio-input" value="Spain" checked>
        <span class="radio-circle"><span class="radio-dot"></span></span>
        <span class="select-modal-option-label">Spain</span>
      </label>
      <label class="select-modal-option">
        <input type="radio" name="country" class="radio-input" value="France">
        <span class="radio-circle"><span class="radio-dot"></span></span>
        <span class="select-modal-option-label">France</span>
      </label>
      <label class="select-modal-option">
        <input type="radio" name="country" class="radio-input" value="Germany">
        <span class="radio-circle"><span class="radio-dot"></span></span>
        <span class="select-modal-option-label">Germany</span>
      </label>
      <label class="select-modal-option">
        <input type="radio" name="country" class="radio-input" value="Italy">
        <span class="radio-circle"><span class="radio-dot"></span></span>
        <span class="select-modal-option-label">Italy</span>
      </label>
      <label class="select-modal-option">
        <input type="radio" name="country" class="radio-input" value="UK">
        <span class="radio-circle"><span class="radio-dot"></span></span>
        <span class="select-modal-option-label">UK</span>
      </label>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost btn-sm">Cancel</button>
      <button class="btn btn-sm color-primary">OK</button>
    </div>
  </div>
</div>`}
    tailwind={`<!-- .select-modal-search sticks to the top of the scrollable area -->
<div class="select-modal-search">
  <input type="text" class="input input-sm w-full" placeholder="Search...">
</div>`}
    js={`// Filter options by search input:
const searchInput = document.querySelector('.select-modal-search input');
searchInput.addEventListener('input', () => {
  const query = searchInput.value.toLowerCase();
  document.querySelectorAll('.select-modal-option').forEach(opt => {
    const text = opt.querySelector('.select-modal-option-label').textContent;
    opt.style.display = text.toLowerCase().includes(query) ? '' : 'none';
  });
});`}
  />

  <!-- ============================================= -->
  <!-- TAGS IN TRIGGER                               -->
  <!-- ============================================= -->

  <CodePreview
    title="Tags in Trigger (Multi-select)"
    noFrame={true}
    semantic={`<div class="flex flex-col gap-3 w-full max-w-sm">
  <!-- With tags -->
  <button class="select-modal">
    <span class="select-modal-tags">
      <span class="select-modal-tag">
        <span>React</span>
        <span class="select-modal-tag-remove">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </span>
      </span>
      <span class="select-modal-tag">
        <span>Vue</span>
        <span class="select-modal-tag-remove">
