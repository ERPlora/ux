        </svg>
      </span>
    </span>
  </span>
</button>`}
    js={`// Remove tag on click (use .stop to prevent modal from opening):
// tag.querySelector('.select-modal-tag-remove').addEventListener('click', (e) => {
//   e.stopPropagation();
//   tag.remove();
// });`}
  />

