  </button>
  <button class="select-modal select-modal-success">
    <span class="select-modal-value">Success state</span>
  </button>
</div>`}
    tailwind={`<!-- .select-modal-filled: filled background, bottom border -->
<!-- .select-modal-ghost: transparent background -->
<!-- .select-modal-error: red border -->
<!-- .select-modal-success: green border -->`}
    js={`// No JavaScript needed — pure CSS classes`}
  />

  <!-- ============================================= -->
  <!-- DISABLED OPTION                               -->
  <!-- ============================================= -->

  <CodePreview
    title="Disabled Options"
    height="420px"
    semantic={`<div class="modal-backdrop" data-state="open" style="position: relative; min-height: 350px; padding: 1rem; background: transparent;">
  <div class="modal modal-sm" style="position: relative; transform: none; opacity: 1;">
    <div class="modal-header">
      <h3 class="modal-title">Select Plan</h3>
    </div>
    <div class="modal-body p-0">
      <label class="select-modal-option">
