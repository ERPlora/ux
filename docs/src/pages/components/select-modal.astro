        </span>
      </span>
    </span>
  </button>
  <!-- Empty state -->
  <button class="select-modal">
    <span class="select-modal-placeholder">Select technologies...</span>
  </button>
</div>`}
    tailwind={`<!-- .select-modal-tags: flex container for chips -->
<!-- .select-modal-tag: individual chip (primary color) -->
<!-- .select-modal-tag-remove: X button on chip -->
<button class="select-modal">
  <span class="select-modal-tags">
    <span class="select-modal-tag">
      <span>React</span>
      <span class="select-modal-tag-remove">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
