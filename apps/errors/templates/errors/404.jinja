{% extends "_base_preview.html" %}

{% from "ui/button.jinja" import button %}
{% from "ui/badge.jinja" import badge %}
{% from "ui/card.jinja" import card, card_footer %}
{% from "ui/icon.jinja" import icon %}
{% from "ui/input.jinja" import input %}
{% from "ui/field.jinja" import field %}
{% from "ui/empty.jinja" import empty %}

{% block title %}404 — Página no encontrada{% endblock %}

{% block body %}
<main class="ux-error-page ux-error-page--info">
  <div class="ux-error-page__inner" data-signals='{"q": ""}'>
    <div class="ux-error-page__illu">
      <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
    </div>
    <div class="ux-error-page__code">404 · Not found</div>
    <h1 class="ux-error-page__title">No hemos podido encontrar esta página</h1>
    <p class="ux-error-page__msg">La URL que has seguido puede estar rota o el recurso ha sido movido. Prueba a buscar lo que necesitas o vuelve al inicio.</p>

    <div class="ux-error-page__search">
      <div class="ux-search">
        <span class="ux-search__icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg></span>
        <input type="search" placeholder="Buscar en ERPlora…" data-bind:q/>
        <span class="ux-search__kbd"><kbd class="ux-kbd">⌘</kbd><kbd class="ux-kbd">K</kbd></span>
      </div>
    </div>

    <div class="ux-error-page__shortcuts">
      <a class="ux-error-page__shortcut" href="/">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M3 12 5 10 12 3l7 7 2 2v9a2 2 0 0 1-2 2h-4v-7H10v7H6a2 2 0 0 1-2-2v-9z"/></svg>
        <span class="ux-error-page__shortcut-title">Inicio</span>
      </a>
      <a class="ux-error-page__shortcut" href="/dashboard/">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 9h6v6H9z"/></svg>
        <span class="ux-error-page__shortcut-title">Dashboard</span>
      </a>
      <a class="ux-error-page__shortcut" href="/help/">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3M12 17h.01"/></svg>
        <span class="ux-error-page__shortcut-title">Centro de ayuda</span>
      </a>
      <a class="ux-error-page__shortcut" href="/status/">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
        <span class="ux-error-page__shortcut-title">Estado del sistema</span>
      </a>
    </div>

    <div class="ux-error-page__actions">
      <button class="ux-btn ux-btn--ghost" data-on:click="history.back()">← Atrás</button>
      <a class="ux-btn ux-btn--primary" href="/">Volver al inicio</a>
    </div>

    <div class="ux-error-page__meta">trace · 7a8b-4f12-2d · 2026-05-08 14:32 UTC</div>
  </div>
</main>
{% endblock %}
