{% extends "_base_preview.html" %}

{% from "ui/button.jinja" import button %}
{% from "ui/badge.jinja" import badge %}
{% from "ui/card.jinja" import card, card_footer %}
{% from "ui/icon.jinja" import icon %}
{% from "ui/input.jinja" import input %}
{% from "ui/field.jinja" import field %}
{% from "ui/empty.jinja" import empty %}

{% block title %}403 — Acceso denegado{% endblock %}

{% block body %}
<main class="ux-error-page ux-error-page--warn">
  <div class="ux-error-page__inner">
    <div class="ux-error-page__illu">
      <iconify-icon icon="lucide:lock" width="44" height="44"></iconify-icon>
    </div>
    <div class="ux-error-page__code">403 · Forbidden</div>
    <h1 class="ux-error-page__title">No tienes permisos para esta página</h1>
    <p class="ux-error-page__msg">Tu cuenta no tiene los permisos necesarios. Pídele al administrador de tu organización que te asigne un rol con acceso.</p>

    <div class="ux-error-page__shortcuts">
      <a class="ux-error-page__shortcut" href="/">
        <iconify-icon icon="lucide:home" width="18" height="18"></iconify-icon>
        <span class="ux-error-page__shortcut-title">Volver al inicio</span>
      </a>
      <a class="ux-error-page__shortcut" href="/admin/users/">
        <iconify-icon icon="lucide:users" width="18" height="18"></iconify-icon>
        <span class="ux-error-page__shortcut-title">Contactar admin</span>
      </a>
      <a class="ux-error-page__shortcut" href="/help/permissions/">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3M12 17h.01"/></svg>
        <span class="ux-error-page__shortcut-title">Cómo funcionan los permisos</span>
      </a>
    </div>

    <div class="ux-error-page__actions">
      <button class="ux-btn ux-btn--ghost" data-on:click="history.back()">← Atrás</button>
      <a class="ux-btn ux-btn--primary" href="/">Volver al inicio</a>
    </div>

    <div class="ux-error-page__meta">trace · 4f2a-3b81-9c · 2026-05-08 14:32 UTC</div>
  </div>
</main>
{% endblock %}
