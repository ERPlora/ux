{% extends "_base_preview.html" %}

{% from "ui/button.jinja" import button %}
{% from "ui/badge.jinja" import badge %}
{% from "ui/card.jinja" import card, card_footer %}
{% from "ui/icon.jinja" import icon %}
{% from "ui/input.jinja" import input %}
{% from "ui/field.jinja" import field %}
{% from "ui/empty.jinja" import empty %}

{% block title %}ERPlora Cloud · Suscripciones{% endblock %}

{% block head_extra %}
<style>
  body { background: var(--ux-bg); margin: 0; }
  .sub-card { background: var(--ux-bg-2); border: 1px solid var(--ux-line); border-radius: var(--ux-radius-xl); padding: 20px; display: flex; flex-direction: column; gap: 14px; transition: border-color var(--ux-dur-fast); position: relative; }
  .sub-card:hover { border-color: var(--ux-line-2); }
  .sub-card--reco { border-color: var(--ux-brand); box-shadow: 0 0 0 3px color-mix(in oklch, var(--ux-brand) 12%, transparent); }
  .sub-card__ribbon { position: absolute; top: -10px; right: 16px; background: var(--ux-brand); color: var(--ux-brand-fg); font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; padding: 4px 10px; border-radius: var(--ux-radius-sm); }
  .sub-card__head { display: flex; justify-content: space-between; align-items: flex-start; gap: 10px; }
  .sub-card__hub { font-family: var(--ux-font-display); font-size: 16px; font-weight: 600; letter-spacing: -0.02em; color: var(--ux-ink); }
  .sub-card__hub-meta { font-size: 12px; color: var(--ux-ink-3); margin-top: 2px; font-family: var(--ux-font-mono); }
  .sub-card__price { display: flex; align-items: baseline; gap: 4px; padding: 8px 0; border-top: 1px solid var(--ux-line); border-bottom: 1px solid var(--ux-line); }
  .sub-card__price-amt { font-family: var(--ux-font-display); font-size: 32px; font-weight: 700; letter-spacing: -0.04em; color: var(--ux-ink); font-variant-numeric: tabular-nums; }
  .sub-card__price-per { font-size: 13px; color: var(--ux-ink-3); }
  .sub-card__features { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px; font-size: 12.5px; color: var(--ux-ink-2); }
  .sub-card__features li { display: flex; gap: 8px; align-items: flex-start; }
  .sub-card__features svg { width: 14px; height: 14px; color: var(--ux-leaf); flex-shrink: 0; margin-top: 2px; }
  .sub-card__renewal { font-size: 11.5px; color: var(--ux-ink-3); display: flex; flex-direction: column; gap: 4px; }
  .sub-card__renewal-bar { height: 6px; background: var(--ux-bg-3); border-radius: 3px; overflow: hidden; }
  .sub-card__renewal-fill { height: 100%; background: var(--ux-brand); border-radius: 3px; }
  .sub-card__actions { display: flex; flex-wrap: wrap; gap: 6px; padding-top: 4px; }
</style>
{% endblock %}

