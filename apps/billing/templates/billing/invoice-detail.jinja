{% block title %}ERPlora Cloud · Factura INV-2026-0142{% endblock %}

{% block head_extra %}
<style>
  body { background: var(--ux-bg); margin: 0; }
  .invoice-layout { display: grid; grid-template-columns: 1fr 320px; gap: 22px; }
  @media (max-width: 1100px) { .invoice-layout { grid-template-columns: 1fr; } }
  .meta-card { background: var(--ux-bg-2); border: 1px solid var(--ux-line); border-radius: var(--ux-radius-xl); padding: 16px 18px; display: flex; flex-direction: column; gap: 14px; }
  .meta-card h4 { font-family: var(--ux-font-mono); font-size: 10px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--ux-ink-3); margin: 0; font-weight: 500; }
  .meta-row { display: grid; grid-template-columns: 1fr auto; gap: 8px; font-size: 12.5px; padding: 4px 0; border-bottom: 1px solid var(--ux-line); }
  .meta-row:last-child { border-bottom: none; }
  .meta-row__key { color: var(--ux-ink-3); }
  .meta-row__val { color: var(--ux-ink); font-variant-numeric: tabular-nums; }
  .meta-row__val--mono { font-family: var(--ux-font-mono); font-size: 11.5px; }
</style>
{% endblock %}

