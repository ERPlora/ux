            </div>
            <select class="ux-select ux-select--sm ux-w-auto" data-bind:status-filter>
              <option value="all">Todos los estados</option>
              <option value="Procesado">Procesado</option>
              <option value="En tránsito">En tránsito</option>
              <option value="Solicitado">Solicitado</option>
            </select>
          </div>
          <div class="ux-table-scroll">
            <table class="ux-table">
              <thead>
                <tr>
                  <th>Fecha</th>
                  <th class="ux-td--right">Importe</th>
                  <th>Método</th>
                  <th>Estado</th>
                  <th>Referencia</th>
                  <th>Recibo</th>
                </tr>
              </thead>
              <tbody>
                <tr data-show="($q === '' || 'PAYOUT-2026-0008'.toLowerCase().includes($q.toLowerCase())) && ($statusFilter === 'all' || $statusFilter === 'Procesado')">
