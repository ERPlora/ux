                </tr>
              </tbody>
            </table>
          </div>
        </main>

        <!-- Settings sticky card -->
        <aside class="ux-col-md-5 ux-col-lg-4 ux-col-sticky ux-panel">
          <div class="ux-panel__head">
            <div class="ux-panel__head-text">
              <h3 class="ux-panel__title">Configuración</h3>
              <p class="ux-panel__sub">Programación y cuenta de destino</p>
            </div>
          </div>
          <div class="ux-panel__body">
            <div class="ux-field ux-mb-3">
              <span class="ux-field__label">Frecuencia</span>
              <div style="display:flex;flex-direction:column;gap:6px;">
                <label style="display:flex;align-items:flex-start;gap:8px;padding:10px;border:1px solid var(--ux-line);border-radius:var(--ux-radius-md);cursor:pointer;" data-attr:style="$freq === 'weekly' ? 'display:flex;align-items:flex-start;gap:8px;padding:10px;border:1px solid var(--ux-brand);background:var(--ux-brand-soft);border-radius:var(--ux-radius-md);cursor:pointer;' : 'display:flex;align-items:flex-start;gap:8px;padding:10px;border:1px solid var(--ux-line);border-radius:var(--ux-radius-md);cursor:pointer;'">
                  <input type="radio" name="freq" value="weekly" data-on:change="$freq = 'weekly'" data-attr:checked="$freq === 'weekly'"/>
                  <div><div class="ux-font-medium ux-text-md">Semanal</div><div class="ux-text-xs ux-c-ink-3">Cada lunes · Recomendado</div></div>
                </label>
                <label style="display:flex;align-items:flex-start;gap:8px;padding:10px;border:1px solid var(--ux-line);border-radius:var(--ux-radius-md);cursor:pointer;" data-attr:style="$freq === 'monthly' ? 'display:flex;align-items:flex-start;gap:8px;padding:10px;border:1px solid var(--ux-brand);background:var(--ux-brand-soft);border-radius:var(--ux-radius-md);cursor:pointer;' : 'display:flex;align-items:flex-start;gap:8px;padding:10px;border:1px solid var(--ux-line);border-radius:var(--ux-radius-md);cursor:pointer;'">
                  <input type="radio" name="freq" value="monthly" data-on:change="$freq = 'monthly'" data-attr:checked="$freq === 'monthly'"/>
                  <div><div class="ux-font-medium ux-text-md">Mensual</div><div class="ux-text-xs ux-c-ink-3">Día 1 de cada mes</div></div>
                </label>
                <label style="display:flex;align-items:flex-start;gap:8px;padding:10px;border:1px solid var(--ux-line);border-radius:var(--ux-radius-md);cursor:pointer;" data-attr:style="$freq === 'manual' ? 'display:flex;align-items:flex-start;gap:8px;padding:10px;border:1px solid var(--ux-brand);background:var(--ux-brand-soft);border-radius:var(--ux-radius-md);cursor:pointer;' : 'display:flex;align-items:flex-start;gap:8px;padding:10px;border:1px solid var(--ux-line);border-radius:var(--ux-radius-md);cursor:pointer;'">
                  <input type="radio" name="freq" value="manual" data-on:change="$freq = 'manual'" data-attr:checked="$freq === 'manual'"/>
                  <div><div class="ux-font-medium ux-text-md">Manual</div><div class="ux-text-xs ux-c-ink-3">Solo bajo solicitud</div></div>
                </label>
              </div>
            </div>
            <label class="ux-field ux-mb-3" data-show="$freq === 'weekly'">
              <span class="ux-field__label">Día de la semana</span>
              <select class="ux-select">
                <option>Lunes</option><option>Martes</option><option>Miércoles</option><option>Jueves</option><option>Viernes</option>
              </select>
            </label>
            <label class="ux-field ux-mb-4">
              <span class="ux-field__label">Importe mínimo</span>
              <div class="ux-currency">
                <span class="ux-currency__symbol">€</span>
                <input class="ux-currency__input" type="number" value="100"/>
                <select class="ux-currency__currency-select"><option>EUR</option><option>USD</option><option>GBP</option></select>
              </div>
              <span class="ux-field__hint">No se transfiere si el saldo es menor a este importe</span>
            </label>

            <div style="font-size:11px;text-transform:uppercase;letter-spacing:0.06em;color:var(--ux-ink-3);font-weight:500;margin-bottom:8px;">Cuenta de destino</div>
            <article class="ux-card ux-mb-2">
              <div class="ux-card__body ux-flex ux-items-center ux-gap-3">
                <div style="width:42px;height:42px;border-radius:var(--ux-radius-sm);background:#0066b3;color:#fff;display:grid;place-items:center;font-weight:700;font-size:13px;letter-spacing:0.04em;">SAB</div>
                <div class="ux-flex-1">
                  <div class="ux-font-medium ux-text-md">Banco Sabadell</div>
                  <div style="font-family:var(--ux-font-mono);font-size:12px;color:var(--ux-ink-3);" data-text="$showIban ? 'ES12 0081 1234 5678 9012 5547' : 'ES•• •••• •••• •••• 5547'">ES•• •••• •••• •••• 5547</div>
                </div>
                <button class="ux-btn ux-btn--ghost ux-btn--sm" data-on:click="$showIban = !$showIban" aria-label="Mostrar IBAN" data-attr:aria-pressed="$showIban">
