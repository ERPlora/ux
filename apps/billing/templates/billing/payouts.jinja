                  <td class="ux-td--num">€320,00</td>
                  <td><span class="ux-tag ux-tag--neutral ux-tag--sm">Stripe · IBAN</span></td>
                  <td><span class="ux-badge ux-badge--warn"><span class="ux-badge__dot"></span>Solicitado</span></td>
                  <td class="ux-td--mono">PAYOUT-2026-MAN-01</td>
                  <td class="ux-td--muted">—</td>
                </tr>
                <tr data-show="($q === '' || 'PAYOUT-2026-0000'.toLowerCase().includes($q.toLowerCase())) && ($statusFilter === 'all' || $statusFilter === 'Procesado')">
                  <td>11 mar 2026</td>
                  <td class="ux-td--num">€620,40</td>
                  <td><span class="ux-tag ux-tag--neutral ux-tag--sm">Stripe · IBAN</span></td>
                  <td><span class="ux-badge ux-badge--ok"><span class="ux-badge__dot"></span>Procesado</span></td>
