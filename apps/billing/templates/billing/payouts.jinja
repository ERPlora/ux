                </button>
                <button class="ux-btn ux-btn--ghost ux-btn--sm">Cambiar</button>
              </div>
            </article>
          </div>
          <div class="ux-panel__footer">
            <span class="ux-text-xs ux-c-ink-3">Cambios aplicables al próximo ciclo</span>
            <button class="ux-btn ux-btn--primary ux-btn--sm">Guardar</button>
          </div>
        </aside>

      </div>

      <!-- Saldo por moneda -->
      <div class="ux-panel">
        <div class="ux-panel__head">
          <div class="ux-panel__head-text">
            <h3 class="ux-panel__title">Saldo por moneda</h3>
            <p class="ux-panel__sub">Importes pendientes de liquidar agrupados por divisa</p>
          </div>
        </div>
        <div class="ux-panel__body">
          <div class="ux-row">
            <div class="ux-col-md-6 ux-col-lg-4">
              <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:6px;">
                <span class="ux-font-medium">EUR</span>
                <span style="font-family:var(--ux-font-display);font-size:20px;font-weight:600;">€1 480,32</span>
              </div>
              <div class="ux-progress"><div class="ux-progress__bar" style="width:88%;background:var(--ux-leaf);"></div></div>
              <div style="font-size:11px;color:var(--ux-ink-3);margin-top:4px;">12 transacciones</div>
            </div>
            <div class="ux-col-md-6 ux-col-lg-4">
              <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:6px;">
                <span class="ux-font-medium">USD</span>
                <span style="font-family:var(--ux-font-display);font-size:20px;font-weight:600;">$184,40</span>
              </div>
              <div class="ux-progress"><div class="ux-progress__bar" style="width:14%;background:var(--ux-info);"></div></div>
              <div style="font-size:11px;color:var(--ux-ink-3);margin-top:4px;">2 transacciones · pendiente conversión</div>
            </div>
            <div class="ux-col-md-6 ux-col-lg-4">
              <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:6px;">
                <span class="ux-font-medium">GBP</span>
                <span style="font-family:var(--ux-font-display);font-size:20px;font-weight:600;">£62,00</span>
              </div>
              <div class="ux-progress"><div class="ux-progress__bar" style="width:5%;background:var(--ux-brand);"></div></div>
              <div style="font-size:11px;color:var(--ux-ink-3);margin-top:4px;">1 transacción</div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Manual payout modal -->
  <div class="ux-modal-root ux-hidden" data-show="$payoutOpen">
    <div class="ux-backdrop" data-on:click="$payoutOpen = false"></div>
    <div class="ux-modal" style="max-width:480px;">
      <header class="ux-modal__header">
        <h3 style="margin:0;display:flex;align-items:center;gap:8px;">
          <span style="width:28px;height:28px;border-radius:50%;background:var(--ux-brand-soft);color:var(--ux-brand-3);display:grid;place-items:center;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20M2 12h20"/></svg>
          </span>
          Solicitar pago manual
        </h3>
      </header>
      <div class="ux-modal__body">
        <p style="margin:0 0 12px;color:var(--ux-ink-2);line-height:1.5;">
          Recibirás el importe solicitado en tu cuenta bancaria registrada en <b>Banco Sabadell ES•• 5547</b> en un plazo aproximado de <b>1 día hábil</b>.
        </p>
        <label class="ux-field ux-mb-3">
          <span class="ux-field__label">Importe a transferir</span>
          <div class="ux-currency">
            <span class="ux-currency__symbol">€</span>
            <input class="ux-currency__input" type="number" min="0" max="1480" data-bind:payout-amount placeholder="0,00"/>
            <span style="padding:0 10px;color:var(--ux-ink-3);font-size:12px;">EUR</span>
          </div>
          <span class="ux-field__hint">Disponible: <b>€1 480,32</b></span>
        </label>
        <div class="ux-callout ux-callout--info" data-show="$payoutAmount > 1480">
          <span class="ux-callout__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 9v4M12 17h.01"/><circle cx="12" cy="12" r="9"/></svg></span>
          <div class="ux-callout__body">
            <div class="ux-callout__title">Importe superior al saldo disponible</div>
            <div class="ux-callout__desc">El máximo solicitable ahora mismo es €1 480,32.</div>
          </div>
        </div>
      </div>
      <footer class="ux-modal__footer">
        <button class="ux-btn ux-btn--ghost" data-on:click="$payoutOpen = false">Cancelar</button>
        <button class="ux-btn ux-btn--primary" data-attr:disabled="$payoutAmount <= 0 || $payoutAmount > 1480" data-on:click="$payoutOpen = false; $payoutAmount = 0">Solicitar transferencia</button>
      </footer>
    </div>
  </div>


  <!-- Bottom tab bar — mobile only via .ux-app__tabbar slot -->
  <nav class="ux-app__tabbar" aria-label="Navegación principal">
    <div class="ux-tabbar ux-tabbar--fixed ux-tabbar--icons">
      <a class="ux-tabbar-item" href="#" aria-current="page">
        <span class="ux-tabbar-icon"><iconify-icon icon="lucide:home" width="18" height="18"></iconify-icon></span>
        <span class="ux-tabbar-label">Inicio</span>
      </a>
      <a class="ux-tabbar-item" href="#">
        <span class="ux-tabbar-icon"><iconify-icon icon="lucide:credit-card" width="18" height="18"></iconify-icon></span>
        <span class="ux-tabbar-label">Hubs</span>
        <span class="ux-tabbar-badge">7</span>
      </a>
      <a class="ux-tabbar-item" href="#">
        <span class="ux-tabbar-icon"><iconify-icon icon="lucide:users" width="18" height="18"></iconify-icon></span>
        <span class="ux-tabbar-label">Usuarios</span>
      </a>
      <a class="ux-tabbar-item" href="#">
        <span class="ux-tabbar-icon"><iconify-icon icon="lucide:store" width="18" height="18"></iconify-icon></span>
        <span class="ux-tabbar-label">Equipo</span>
      </a>
      <a class="ux-tabbar-item" href="#">
        <span class="ux-tabbar-icon"><iconify-icon icon="lucide:user-circle" width="18" height="18"></iconify-icon></span>
        <span class="ux-tabbar-label">Perfil</span>
      </a>
    </div>
  </nav>
</div>
{% endblock %}
