      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20M5 9h14"/></svg><span class="ux-sidebar__label">Suscripciones</span></button>

      <div class="ux-sidebar__group">Desarrollador</div>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 19c-5 1.5-5-2.5-7-3"/></svg><span class="ux-sidebar__label">Repositorios</span></button>
      <button class="ux-sidebar__item"><iconify-icon icon="lucide:code" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Módulos</span></button>
