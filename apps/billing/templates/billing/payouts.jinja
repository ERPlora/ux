                <tr data-show="($q === '' || 'PAYOUT-2026-0006'.toLowerCase().includes($q.toLowerCase())) && ($statusFilter === 'all' || $statusFilter === 'Procesado')">
                  <td>22 abr 2026</td>
                  <td class="ux-td--num">€1 412,80</td>
                  <td><span class="ux-tag ux-tag--neutral ux-tag--sm">Stripe · IBAN</span></td>
                  <td><span class="ux-badge ux-badge--ok"><span class="ux-badge__dot"></span>Procesado</span></td>
                  <td class="ux-td--mono">PAYOUT-2026-0006</td>
                  <td><a href="#" class="ux-c-brand-3">PDF ↓</a></td>
                </tr>
                <tr data-show="($q === '' || 'PAYOUT-2026-0005'.toLowerCase().includes($q.toLowerCase())) && ($statusFilter === 'all' || $statusFilter === 'Procesado')">
                  <td>15 abr 2026</td>
                  <td class="ux-td--num">€2 014,20</td>
                  <td><span class="ux-tag ux-tag--neutral ux-tag--sm">Stripe · IBAN</span></td>
                  <td><span class="ux-badge ux-badge--ok"><span class="ux-badge__dot"></span>Procesado</span></td>
                  <td class="ux-td--mono">PAYOUT-2026-0005</td>
                  <td><a href="#" class="ux-c-brand-3">PDF ↓</a></td>
                </tr>
                <tr data-show="($q === '' || 'PAYOUT-2026-0004'.toLowerCase().includes($q.toLowerCase())) && ($statusFilter === 'all' || $statusFilter === 'Procesado')">
                  <td>8 abr 2026</td>
                  <td class="ux-td--num">€885,10</td>
                  <td><span class="ux-tag ux-tag--neutral ux-tag--sm">Stripe · IBAN</span></td>
                  <td><span class="ux-badge ux-badge--ok"><span class="ux-badge__dot"></span>Procesado</span></td>
                  <td class="ux-td--mono">PAYOUT-2026-0004</td>
                  <td><a href="#" class="ux-c-brand-3">PDF ↓</a></td>
                </tr>
                <tr data-show="($q === '' || 'PAYOUT-2026-0003'.toLowerCase().includes($q.toLowerCase())) && ($statusFilter === 'all' || $statusFilter === 'Procesado')">
                  <td>1 abr 2026</td>
                  <td class="ux-td--num">€1 175,30</td>
                  <td><span class="ux-tag ux-tag--neutral ux-tag--sm">Stripe · IBAN</span></td>
                  <td><span class="ux-badge ux-badge--ok"><span class="ux-badge__dot"></span>Procesado</span></td>
                  <td class="ux-td--mono">PAYOUT-2026-0003</td>
                  <td><a href="#" class="ux-c-brand-3">PDF ↓</a></td>
                </tr>
                <tr data-show="($q === '' || 'PAYOUT-2026-0002'.toLowerCase().includes($q.toLowerCase())) && ($statusFilter === 'all' || $statusFilter === 'Procesado')">
                  <td>25 mar 2026</td>
                  <td class="ux-td--num">€2 350,00</td>
                  <td><span class="ux-tag ux-tag--neutral ux-tag--sm">Stripe · IBAN</span></td>
                  <td><span class="ux-badge ux-badge--ok"><span class="ux-badge__dot"></span>Procesado</span></td>
                  <td class="ux-td--mono">PAYOUT-2026-0002</td>
                  <td><a href="#" class="ux-c-brand-3">PDF ↓</a></td>
                </tr>
                <tr data-show="($q === '' || 'PAYOUT-2026-0001'.toLowerCase().includes($q.toLowerCase())) && ($statusFilter === 'all' || $statusFilter === 'Procesado')">
                  <td>18 mar 2026</td>
                  <td class="ux-td--num">€1 080,90</td>
                  <td><span class="ux-tag ux-tag--neutral ux-tag--sm">Stripe · IBAN</span></td>
                  <td><span class="ux-badge ux-badge--ok"><span class="ux-badge__dot"></span>Procesado</span></td>
                  <td class="ux-td--mono">PAYOUT-2026-0001</td>
                  <td><a href="#" class="ux-c-brand-3">PDF ↓</a></td>
                </tr>
                <tr style="opacity:0.85;" data-show="($q === '' || 'PAYOUT-2026-0009'.toLowerCase().includes($q.toLowerCase())) && ($statusFilter === 'all' || $statusFilter === 'En tránsito')">
                  <td>13 may 2026</td>
                  <td class="ux-td--num">€1 480,32</td>
                  <td><span class="ux-tag ux-tag--neutral ux-tag--sm">Stripe · IBAN</span></td>
                  <td><span class="ux-badge ux-badge--info"><span class="ux-badge__dot"></span>En tránsito</span></td>
                  <td class="ux-td--mono">PAYOUT-2026-0009</td>
