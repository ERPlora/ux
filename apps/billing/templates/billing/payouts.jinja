        <div class="ux-kpi">
          <div class="ux-kpi__label">Disponible para retirar</div>
          <div class="ux-kpi__value">€1 480<span style="font-size:18px;color:var(--ux-ink-3);">,32</span></div>
          <span class="ux-badge ux-badge--ok"><span class="ux-badge__dot"></span>liquidable</span>
        </div>
        <div class="ux-kpi">
          <div class="ux-kpi__label">Pendiente revisión</div>
          <div class="ux-kpi__value">€240<span style="font-size:18px;color:var(--ux-ink-3);">,00</span></div>
          <span class="ux-badge ux-badge--warn"><span class="ux-badge__dot"></span>2 disputas abiertas</span>
        </div>
        <div class="ux-kpi">
          <div class="ux-kpi__label">Total pagado</div>
          <div class="ux-kpi__value">€18 420</div>
          <span class="ux-badge"><span class="ux-badge__dot"></span>desde mar 2026</span>
        </div>
        <div class="ux-kpi">
          <div class="ux-kpi__label">Próximo pago automático</div>
          <div class="ux-kpi__value" style="font-size:22px;">lun 13 may</div>
          <span class="ux-badge ux-badge--info"><span class="ux-badge__dot"></span>en 5 días</span>
        </div>
      </div>

      <!-- Stripe Connect banner -->
      <div class="ux-banner ux-banner--ok" style="border-radius:var(--ux-radius-md);margin-bottom:18px;">
        <span class="ux-banner__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4M21 12c0 4.97-4.03 9-9 9s-9-4.03-9-9 4.03-9 9-9 9 4.03 9 9z"/></svg></span>
        <div class="ux-banner__body">
