{% extends "_base_preview.html" %}

{% from "ui/button.jinja" import button %}
{% from "ui/badge.jinja" import badge %}
{% from "ui/card.jinja" import card, card_footer %}
{% from "ui/icon.jinja" import icon %}
{% from "ui/input.jinja" import input %}
{% from "ui/field.jinja" import field %}
{% from "ui/empty.jinja" import empty %}

{% block title %}Hub · Facturación{% endblock %}

{% block body %}
<div class="ux-app" id="app" data-tabbar="bottom" data-signals='{"sidebar": false}' data-attr:data-sidebar="$sidebar ? 'open' : ''">
  <aside class="ux-sidebar">
    <div class="ux-sidebar__brand">
      <div class="ux-sidebar__logo">LR</div>
      <div class="ux-sidebar__brand-text">
        <div class="ux-sidebar__brand-name">Cafetería La Rambla</div>
        <div class="ux-sidebar__brand-meta">Hub Starter</div>
      </div>
    </div>
    <div class="ux-sidebar__body">
      <div class="ux-sidebar__group">Operación</div>
      <a class="ux-sidebar__item" href="#"><iconify-icon icon="lucide:layout-dashboard" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Inicio</span></a>
      <a class="ux-sidebar__item" href="#"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="7" r="4"/><path d="M3 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/></svg><span class="ux-sidebar__label">Empleados</span></a>
      <a class="ux-sidebar__item" href="#"><iconify-icon icon="lucide:shield" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Roles</span></a>
      <a class="ux-sidebar__item" href="#"><iconify-icon icon="lucide:package" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Módulos</span></a>
      <div class="ux-sidebar__group">Plataforma</div>
      <a class="ux-sidebar__item" aria-current="page" href="#"><iconify-icon icon="lucide:credit-card" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Facturación</span><span class="ux-sidebar__badge ux-sidebar__badge--brand">1</span></a>
      <a class="ux-sidebar__item" href="#"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.6 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 1 1 0-4h.09"/></svg><span class="ux-sidebar__label">Ajustes</span></a>
    </div>
    <div class="ux-sidebar__footer">
      <div class="ux-sidebar__user">
        <span class="ux-avatar ux-avatar--sm ux-avatar--brand">JC</span>
        <div class="ux-sidebar__user-info">
          <div class="ux-sidebar__user-name">Joan Castell</div>
          <div class="ux-sidebar__user-meta">joan@larambla.es</div>
        </div>
      </div>
    </div>
  </aside>

  <div class="ux-app__main">
    <header class="ux-topbar">
        <div class="ux-topbar__left">
          <button class="ux-topbar__back-btn" aria-label="Volver"
            data-on:click="history.length > 1 ? history.back() : null">
            <iconify-icon icon="lucide:arrow-left" width="2" height="2"></iconify-icon>
          </button>
        </div>
        <h1 class="ux-topbar__page-title">Página</h1>
        
        
        <div class="ux-topbar__actions">
          <button class="ux-icon-btn" aria-label="Notificaciones"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/></svg></button>
        </div>
        <button class="ux-topbar__menu-btn" aria-label="Menú"
            data-on:click="$sidebar = !$sidebar"
            data-attr:aria-expanded="$sidebar">
            <iconify-icon icon="lucide:menu" width="2" height="2"></iconify-icon>
          </button>
      </header>

    <nav class="ux-tabs" aria-label="Sub-secciones de facturación">
      <a class="ux-tab" href="invoices.html">Facturas</a>
      <a class="ux-tab" href="subscriptions.html">Suscripciones</a>
      <a class="ux-tab" href="purchases.html">Compras</a>
      <a class="ux-tab" href="payment-history.html">Historial pagos</a>
      <a class="ux-tab" href="hub.html" aria-current="page">Hub</a>
    </nav>

    <div class="ux-app__body">
      <div class="ux-page-header">
        <div class="ux-page-header__title">
          <h1>Facturación del Hub</h1>
          <div class="ux-page-header__sub">Suscripción y facturas Stripe</div>
        </div>
        <div class="ux-page-header__actions">
          <button class="ux-btn ux-btn--secondary ux-btn--sm">Cambiar plan</button>
          <a class="ux-btn ux-btn--primary ux-btn--sm" href="#">Abrir portal Stripe</a>
        </div>
      </div>

      <!-- Banner de impago (demo) -->
      <div class="ux-banner ux-banner--warn ux-banner--inline ux-mb-4">
        <span class="ux-banner__icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg></span>
        <div class="ux-banner__body">
          <div class="ux-banner__title">Una factura pendiente</div>
          <div class="ux-banner__desc">Factura #INV-2026-0411 por 29,99 € en estado <b>Pendiente</b>. Se reintentará el cobro el 12/05/2026.</div>
        </div>
        <div class="ux-banner__actions">
          <button class="ux-banner__action ux-banner__action--primary">Pagar ahora</button>
        </div>
      </div>

      <!-- Card plan actual -->
      <div class="ux-grid-3 ux-mb-5">
        <article class="ux-card">
          <header class="ux-card__header">
            <h3 class="ux-card__title">Plan actual</h3>
            <span class="ux-badge ux-badge--brand">Starter</span>
          </header>
          <div class="ux-card__body">
            <div style="font-family:var(--ux-font-display);font-size:32px;font-weight:600;letter-spacing:-0.04em;font-variant-numeric:tabular-nums;">29,99 €<span style="color:var(--ux-ink-3);font-size:14px;font-weight:400;"> /mes</span></div>
            <div class="ux-eyebrow ux-mt-2">Renovación 01/06/2026</div>
            <ul style="list-style:none;padding:0;margin:14px 0 0;font-size:13px;color:var(--ux-ink-2);display:flex;flex-direction:column;gap:6px;">
              <li>1 sede · hasta 5 empleados</li>
              <li>POS · Empleados · Inventario</li>
              <li>Soporte estándar</li>
            </ul>
          </div>
          <footer class="ux-card__actions">
            <button class="ux-btn ux-btn--ghost ux-btn--sm">Cancelar plan</button>
            <button class="ux-btn ux-btn--primary ux-btn--sm">Mejorar a Pro</button>
          </footer>
        </article>

        <article class="ux-card">
          <header class="ux-card__header">
            <h3 class="ux-card__title">Próxima factura</h3>
            <span class="ux-badge ux-badge--ok">Programada</span>
          </header>
          <div class="ux-card__body">
            <div style="font-family:var(--ux-font-display);font-size:32px;font-weight:600;letter-spacing:-0.04em;font-variant-numeric:tabular-nums;">29,99 €</div>
            <div class="ux-eyebrow ux-mt-2">Emisión 01/06/2026</div>
            <p style="font-size:13px;color:var(--ux-ink-3);margin:14px 0 0;">Suscripción Hub Starter · Cafetería La Rambla S.L. · CIF B-65432109.</p>
          </div>
        </article>

        <article class="ux-card">
          <header class="ux-card__header">
            <h3 class="ux-card__title">Método de pago</h3>
            <button class="ux-btn ux-btn--ghost ux-btn--sm">Cambiar</button>
          </header>
          <div class="ux-card__body">
            <div class="ux-flex ux-items-center ux-gap-3">
              <div style="width:40px;height:28px;background:var(--ux-bg-3);border-radius:6px;display:flex;align-items:center;justify-content:center;font-family:var(--ux-font-display);font-weight:600;font-size:11px;color:var(--ux-ink-2);">VISA</div>
              <div>
                <div style="font-family:var(--ux-font-mono);font-size:14px;">•••• 4242</div>
                <div class="ux-eyebrow">Caduca 09/2027</div>
              </div>
            </div>
            <p style="font-size:12.5px;color:var(--ux-ink-3);margin:14px 0 0;">Titular: Joan Castell · Domicilio fiscal en Barcelona.</p>
          </div>
        </article>
      </div>

      <!-- Tabla de facturas -->
      <div class="ux-table-wrap" data-signals='{"billing": {"q": "", "view": "table", "status": ""}}'>
        <div class="ux-dt-toolbar">
          <div class="ux-search" style="flex:1 1 220px;max-width:300px">
            <svg class="ux-search__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>
            <input class="ux-input ux-input--sm" placeholder="Buscar factura, número o periodo…" data-bind:billing.q/>
          </div>
          <select class="ux-select ux-select--sm" style="width:auto;min-width:140px" data-bind:billing.status>
            <option value="">Todos los estados</option>
            <option value="paid">Pagada</option>
            <option value="pending">Pendiente</option>
            <option value="failed">Fallida</option>
            <option value="refunded">Reembolso</option>
          </select>
          <select class="ux-select ux-select--sm" style="width:auto;min-width:140px">
            <option>Todos los tipos</option>
            <option>Suscripción Hub</option>
            <option>Módulos de pago</option>
          </select>
          <label class="ux-date-range" title="Rango de fechas">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
            <span>01/01/26</span>
            <span class="ux-date-range__sep">→</span>
            <span>30/04/26</span>
          </label>
          <div class="ux-dt-toolbar__spacer"></div>
          <button class="ux-icon-btn" title="Exportar CSV"><iconify-icon icon="lucide:download" width="2" height="2"></iconify-icon></button>
        </div>

        <div class="ux-table-scroll">
          <table class="ux-table">
            <thead>
              <tr>
                <th>Factura</th>
                <th>Tipo</th>
                <th>Descripción</th>
                <th>Fecha</th>
                <th class="ux-td--right">Importe</th>
                <th>Estado</th>
                <th style="width:80px;text-align:right">PDF</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td class="ux-td--mono">INV-2026-0411</td>
                <td><span class="ux-pill"><span class="ux-pill__dot"></span>Hub</span></td>
                <td>Suscripción Hub Starter · abril 2026</td>
                <td>01/04/2026</td>
                <td class="ux-td--right ux-td--mono">29,99 €</td>
                <td><span class="ux-badge ux-badge--warn"><span class="ux-badge__dot"></span>Pendiente</span></td>
                <td class="ux-text-right"><button class="ux-icon-btn" title="Descargar PDF"><iconify-icon icon="lucide:download" width="2" height="2"></iconify-icon></button></td>
              </tr>
              <tr>
                <td class="ux-td--mono">INV-2026-0312</td>
                <td><span class="ux-pill"><span class="ux-pill__dot"></span>Hub</span></td>
                <td>Suscripción Hub Starter · marzo 2026</td>
                <td>01/03/2026</td>
                <td class="ux-td--right ux-td--mono">29,99 €</td>
                <td><span class="ux-badge ux-badge--ok"><span class="ux-badge__dot"></span>Pagada</span></td>
                <td class="ux-text-right"><button class="ux-icon-btn" title="Descargar PDF"><iconify-icon icon="lucide:download" width="2" height="2"></iconify-icon></button></td>
              </tr>
              <tr>
                <td class="ux-td--mono">INV-2026-0307</td>
                <td><span class="ux-pill ux-pill--brand"><span class="ux-pill__dot"></span>Módulo</span></td>
                <td>Verifactu ES · cuota anual</td>
                <td>15/03/2026</td>
                <td class="ux-td--right ux-td--mono">59,00 €</td>
                <td><span class="ux-badge ux-badge--ok"><span class="ux-badge__dot"></span>Pagada</span></td>
                <td class="ux-text-right"><button class="ux-icon-btn" title="Descargar PDF"><iconify-icon icon="lucide:download" width="2" height="2"></iconify-icon></button></td>
              </tr>
              <tr>
                <td class="ux-td--mono">INV-2026-0211</td>
                <td><span class="ux-pill"><span class="ux-pill__dot"></span>Hub</span></td>
                <td>Suscripción Hub Starter · febrero 2026</td>
                <td>01/02/2026</td>
                <td class="ux-td--right ux-td--mono">29,99 €</td>
                <td><span class="ux-badge ux-badge--ok"><span class="ux-badge__dot"></span>Pagada</span></td>
                <td class="ux-text-right"><button class="ux-icon-btn" title="Descargar PDF"><iconify-icon icon="lucide:download" width="2" height="2"></iconify-icon></button></td>
              </tr>
              <tr>
                <td class="ux-td--mono">INV-2026-0114</td>
                <td><span class="ux-pill"><span class="ux-pill__dot"></span>Hub</span></td>
                <td>Suscripción Hub Starter · enero 2026</td>
                <td>01/01/2026</td>
                <td class="ux-td--right ux-td--mono">29,99 €</td>
                <td><span class="ux-badge ux-badge--danger"><span class="ux-badge__dot"></span>Reembolsada</span></td>
                <td class="ux-text-right"><button class="ux-icon-btn" title="Descargar PDF"><iconify-icon icon="lucide:download" width="2" height="2"></iconify-icon></button></td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <nav class="ux-tabbar ux-app__tabbar" aria-label="Navegación principal">
    <a class="ux-tabbar-item" href="#"><span class="ux-tabbar-icon"><iconify-icon icon="lucide:layout-dashboard" width="2" height="2"></iconify-icon></span><span class="ux-tabbar-label">Inicio</span></a>
    <a class="ux-tabbar-item" href="#"><span class="ux-tabbar-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="7" r="4"/><path d="M3 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/></svg></span><span class="ux-tabbar-label">Empleados</span></a>
    <a class="ux-tabbar-item" href="#"><span class="ux-tabbar-icon"><iconify-icon icon="lucide:package" width="2" height="2"></iconify-icon></span><span class="ux-tabbar-label">Módulos</span></a>
    <a class="ux-tabbar-item" aria-current="page" href="#"><span class="ux-tabbar-icon"><iconify-icon icon="lucide:credit-card" width="2" height="2"></iconify-icon></span><span class="ux-tabbar-label">Facturas</span></a>
    <a class="ux-tabbar-item" href="#"><span class="ux-tabbar-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="5" cy="12" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="19" cy="12" r="1.5"/></svg></span><span class="ux-tabbar-label">Más</span></a>
  </nav>
</div>
{% endblock %}
