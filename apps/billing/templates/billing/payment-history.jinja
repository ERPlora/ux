{% extends "_base_preview.html" %}

{% from "ui/button.jinja" import button %}
{% from "ui/badge.jinja" import badge %}
{% from "ui/card.jinja" import card, card_footer %}
{% from "ui/icon.jinja" import icon %}
{% from "ui/input.jinja" import input %}
{% from "ui/field.jinja" import field %}
{% from "ui/empty.jinja" import empty %}

{% block title %}ERPlora Cloud · Historial de pagos{% endblock %}

{% block head_extra %}
<style>
  body { background: var(--ux-bg); margin: 0; }

  .ph-toolbar { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; margin-bottom: 14px; }

  .table-wrap { background: var(--ux-bg-2); border: 1px solid var(--ux-line); border-radius: var(--ux-radius-lg); overflow: hidden; }

  .pay-method-cell { display: inline-flex; align-items: center; gap: 8px; }
  .pay-method-cell__icon {
    width: 28px; height: 18px;
    border-radius: 3px;
    background: var(--ux-bg-3);
    border: 1px solid var(--ux-line);
    display: grid; place-items: center;
    font-family: var(--ux-font-mono); font-size: 8px;
    font-weight: 700; color: var(--ux-ink-2); letter-spacing: 0.06em;
  }
  .pay-method-cell__icon--visa { background: linear-gradient(135deg, #1a1f71, #2a3593); color: #fff; }
  .pay-method-cell__icon--mc   { background: linear-gradient(135deg, #b30100, #f9a000); color: #fff; }
  .pay-method-cell__icon--amex { background: linear-gradient(135deg, #2671b8, #0a2d6e); color: #fff; }
  .pay-method-cell__icon--sepa { background: var(--ux-info-soft); color: var(--ux-info); }

  .donut-wrap { padding: 18px; background: var(--ux-bg-2); border: 1px solid var(--ux-line); border-radius: var(--ux-radius-lg); }
  .donut-wrap__title { font-family: var(--ux-font-display); font-size: 15px; font-weight: 600; color: var(--ux-ink); margin: 0 0 14px; }
</style>
{% endblock %}

