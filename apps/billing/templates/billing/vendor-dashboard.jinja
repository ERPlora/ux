{% extends "_base_preview.html" %}

{% from "ui/button.jinja" import button %}
{% from "ui/badge.jinja" import badge %}
{% from "ui/card.jinja" import card, card_footer %}
{% from "ui/icon.jinja" import icon %}
{% from "ui/input.jinja" import input %}
{% from "ui/field.jinja" import field %}
{% from "ui/empty.jinja" import empty %}

{% block title %}ERPlora Cloud · Vendor Dashboard{% endblock %}

{% block head_extra %}
<style>
  body { background: var(--ux-bg); margin: 0; }
  .charts-row { display: grid; grid-template-columns: 1.5fr 1fr; gap: 16px; }
  @media (max-width: 1100px) { .charts-row { grid-template-columns: 1fr; } }
  .stripe-card { background: linear-gradient(135deg, color-mix(in oklch, var(--ux-info) 12%, var(--ux-bg-2)), var(--ux-bg-2)); border: 1px solid var(--ux-line); border-radius: var(--ux-radius-xl); padding: 18px 22px; display: grid; grid-template-columns: 48px 1fr auto; gap: 16px; align-items: center; }
  .stripe-card__logo { width: 48px; height: 48px; border-radius: var(--ux-radius-md); background: #635BFF; color: white; display: grid; place-items: center; font-family: var(--ux-font-display); font-weight: 700; font-size: 18px; }
  .payout-card { background: var(--ux-bg-2); border: 1px solid var(--ux-line); border-radius: var(--ux-radius-xl); padding: 22px; display: grid; grid-template-columns: 1fr auto; gap: 18px; align-items: center; }
  .payout-card__amt { font-family: var(--ux-font-display); font-size: 36px; font-weight: 700; letter-spacing: -0.04em; color: var(--ux-ink); font-variant-numeric: tabular-nums; }
</style>
{% endblock %}

{% block body %}
<div class="ux-app" id="app" data-tabbar="bottom" data-signals='{"sidebar": false}' data-attr:data-sidebar="$sidebar ? 'open' : ''">
  <div class="ux-app__sidebar-overlay" data-on:click="$sidebar = false"></div>

  <aside class="ux-sidebar">
    <div class="ux-sidebar__brand">
      <div class="ux-sidebar__logo">EX</div>
      <div class="ux-sidebar__brand-text">
        <div class="ux-sidebar__brand-name">ERPlora Cloud</div>
        <div class="ux-sidebar__brand-meta">Acme Industries SL</div>
      </div>
    </div>
    <div class="ux-sidebar__body">
      <div class="ux-sidebar__group">Cuenta</div>
      <button class="ux-sidebar__item"><iconify-icon icon="lucide:layout-dashboard" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Vista general</span></button>
      <button class="ux-sidebar__item"><iconify-icon icon="lucide:building-2" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Hubs</span><span class="ux-sidebar__badge">5</span></button>

      <div class="ux-sidebar__group">Facturación</div>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6M9 13h6M9 17h4"/></svg><span class="ux-sidebar__label">Facturas</span><span class="ux-sidebar__badge ux-sidebar__badge--brand">3</span></button>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12V7H5a2 2 0 0 1 0-4h14v4"/><path d="M3 5v14a2 2 0 0 0 2 2h16v-5"/><path d="M18 12a2 2 0 0 0 0 4h4v-4z"/></svg><span class="ux-sidebar__label">Suscripciones</span><span class="ux-sidebar__badge">5</span></button>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20M6 15h2"/></svg><span class="ux-sidebar__label">Métodos de pago</span></button>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 7h-4V3H8v4H4l8 9 8-9z"/><path d="M4 19h16"/></svg><span class="ux-sidebar__label">Mis compras</span></button>

      <div class="ux-sidebar__group">Vendor</div>
