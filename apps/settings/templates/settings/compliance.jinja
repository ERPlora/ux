{% extends "_base_preview.html" %}

{% block title %}Hub · Cumplimiento legal{% endblock %}

{% block body %}
<div class="ux-app" id="app" data-tabbar="bottom" data-signals='{"sidebar": false}' data-attr:data-sidebar="$sidebar ? 'open' : ''">
  <aside class="ux-sidebar">
    <div class="ux-sidebar__brand">
      <div class="ux-sidebar__logo">LR</div>
      <div class="ux-sidebar__brand-text">
        <div class="ux-sidebar__brand-name">Cafetería La Rambla</div>
        <div class="ux-sidebar__brand-meta">Cumplimiento</div>
      </div>
    </div>
    <div class="ux-sidebar__body">
      <a class="ux-sidebar__item" href="#"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="9"/></svg><span class="ux-sidebar__label">Inicio</span></a>
      <a class="ux-sidebar__item" href="#"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/></svg><span class="ux-sidebar__label">Ajustes</span></a>
      <a class="ux-sidebar__item" aria-current="page" href="#"><iconify-icon icon="lucide:shield" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Cumplimiento</span></a>
    </div>
  </aside>

  <div class="ux-app__main">
    <header class="ux-topbar">
        <div class="ux-topbar__left">
          <button class="ux-topbar__back-btn" aria-label="Volver"
            data-on:click="history.length > 1 ? history.back() : null">
            <iconify-icon icon="lucide:arrow-left" width="2" height="2"></iconify-icon>
          </button>
        </div>
        <h1 class="ux-topbar__page-title">Página</h1>
        
        
        <button class="ux-topbar__menu-btn" aria-label="Menú"
            data-on:click="$sidebar = !$sidebar"
            data-attr:aria-expanded="$sidebar">
            <iconify-icon icon="lucide:menu" width="2" height="2"></iconify-icon>
          </button>
      </header>

    <nav class="ux-tabs ux-tabs-scroll" aria-label="Sub-secciones de ajustes">
      <a class="ux-tab" href="preferences.html">Preferencias</a>
      <a class="ux-tab" href="hub.html">Hub</a>
      <a class="ux-tab" href="hub-config.html">Config</a>
      <a class="ux-tab" href="compliance.html" aria-current="page">Cumplimiento</a>
      <a class="ux-tab" href="devices.html">Dispositivos</a>
      <a class="ux-tab" href="printers.html">Impresoras</a>
      <a class="ux-tab" href="backup.html">Backup</a>
      <a class="ux-tab" href="files.html">Archivos</a>
      <a class="ux-tab" href="tax-classes.html">Tax</a>
      <a class="ux-tab" href="help.html">Ayuda</a>
      <a class="ux-tab" href="scheduled-tasks.html">Tareas</a>
      <a class="ux-tab" href="file-browser.html">File browser</a>
    </nav>

    <div class="ux-app__body">
      <div class="ux-page-header">
        <div class="ux-page-header__title">
          <h1>Cumplimiento legal</h1>
          <div class="ux-page-header__sub">Configura los requisitos fiscales y legales de tu negocio</div>
        </div>
      </div>

      <!-- España -->
      <article class="ux-card ux-mb-4">
        <header class="ux-card__header">
          <h3 class="ux-card__title">
            <span class="ux-inline-flex ux-items-center ux-gap-2">
              <span style="font-size:18px;">🇪🇸</span>
              España
            </span>
          </h3>
          <span class="ux-badge ux-badge--ok"><span class="ux-badge__dot"></span>Activo</span>
        </header>
        <div class="ux-card__body">

          <div class="ux-toggle-row">
            <div class="ux-toggle-row__text">
              <span class="ux-toggle-row__label">Verifactu (AEAT)</span>
              <span class="ux-toggle-row__desc">Remisión automática de facturas a Hacienda según RD 1007/2023.</span>
            </div>
            <label class="ux-toggle">
              <input type="checkbox" checked/>
              <span class="ux-toggle__track"></span>
            </label>
          </div>

          <div class="ux-toggle-row">
            <div class="ux-toggle-row__text">
              <span class="ux-toggle-row__label">SII (IVA)</span>
              <span class="ux-toggle-row__desc">Suministro Inmediato de Información de IVA. Solo grandes empresas.</span>
            </div>
            <label class="ux-toggle">
              <input type="checkbox"/>
              <span class="ux-toggle__track"></span>
            </label>
          </div>

          <div class="ux-toggle-row" style="border-bottom:none;">
            <div class="ux-toggle-row__text">
              <span class="ux-toggle-row__label">Modelo 347</span>
              <span class="ux-toggle-row__desc">Declaración anual de operaciones con terceros &gt; 3.005,06 €.</span>
            </div>
            <label class="ux-toggle">
              <input type="checkbox" checked/>
              <span class="ux-toggle__track"></span>
            </label>
          </div>

          <hr style="border:0;border-top:1px solid var(--ux-line);margin:16px 0;"/>

          <div class="ux-form-row">
            <div class="ux-field">
              <label class="ux-field__label ux-field__label--req">CIF / NIF empresa</label>
              <input class="ux-input" value="B-65432109"/>
            </div>
            <div class="ux-field">
              <label class="ux-field__label">Modelo de IVA</label>
              <select class="ux-select">
                <option selected>Régimen general</option>
                <option>Recargo de equivalencia</option>
                <option>Régimen simplificado</option>
                <option>Exento</option>
              </select>
            </div>
          </div>

          <div class="ux-field ux-mt-3">
            <label class="ux-field__label">Certificado digital (.p12 / FNMT)</label>
            <div style="display:flex;align-items:center;gap:10px;background:var(--ux-bg-3);border:1px solid var(--ux-line);border-radius:10px;padding:10px 12px;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="ux-c-leaf"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
              <div class="ux-flex-1">
                <div style="font-size:13px;font-weight:500;">cafeteria-larambla-fnmt.p12</div>
                <div class="ux-text-xs ux-c-ink-3">Caduca el 14/03/2027 · 2.4 KB</div>
              </div>
              <button class="ux-btn ux-btn--ghost ux-btn--sm">Reemplazar</button>
            </div>
            <span class="ux-field__hint">Necesario para firmar las remisiones a la AEAT.</span>
          </div>

          <hr style="border:0;border-top:1px solid var(--ux-line);margin:16px 0;"/>

          <div class="ux-grid-auto ux-grid-auto--sm">
            <div>
              <div class="ux-eyebrow">Conexión AEAT</div>
              <div style="display:flex;align-items:center;gap:6px;margin-top:4px;">
                <span class="ux-status-dot ux-status-dot--ok"></span>
                <span class="ux-font-medium ux-text-md">Operativa</span>
              </div>
            </div>
            <div>
              <div class="ux-eyebrow">Última remisión OK</div>
              <div style="font-size:13px;font-weight:500;margin-top:4px;">Hoy 14:23 · #INV-3217</div>
            </div>
            <div>
              <div class="ux-eyebrow">Pendientes</div>
              <div style="font-size:13px;font-weight:500;margin-top:4px;color:var(--ux-warn);">2 facturas</div>
            </div>
            <div>
              <div class="ux-eyebrow">Errores 30 días</div>
              <div style="font-size:13px;font-weight:500;margin-top:4px;">0</div>
            </div>
          </div>
        </div>
        <footer class="ux-card__actions">
          <button class="ux-btn ux-btn--ghost ux-btn--sm">Ver log AEAT</button>
          <button class="ux-btn ux-btn--secondary ux-btn--sm">Probar conexión</button>
        </footer>
      </article>

      <!-- Portugal -->
      <article class="ux-card ux-mb-4">
        <header class="ux-card__header">
          <h3 class="ux-card__title">
            <span class="ux-inline-flex ux-items-center ux-gap-2">
              <span style="font-size:18px;">🇵🇹</span>
              Portugal
            </span>
          </h3>
          <span class="ux-badge"><span class="ux-badge__dot"></span>No activo</span>
        </header>
        <div class="ux-card__body">
          <p style="font-size:13px;color:var(--ux-ink-3);margin:0 0 14px;">No tienes operaciones registradas en Portugal. Activa los requisitos si vendes a clientes portugueses.</p>

          <div class="ux-toggle-row">
            <div class="ux-toggle-row__text">
              <span class="ux-toggle-row__label">SAF-T (PT)</span>
              <span class="ux-toggle-row__desc">Fichero de auditoría estándar exigido por la Autoridade Tributária.</span>
            </div>
            <label class="ux-toggle">
              <input type="checkbox"/>
              <span class="ux-toggle__track"></span>
            </label>
          </div>

          <div class="ux-toggle-row" style="border-bottom:none;">
            <div class="ux-toggle-row__text">
              <span class="ux-toggle-row__label">Comunicação de Faturas</span>
              <span class="ux-toggle-row__desc">Envío mensual a la AT (e-Fatura).</span>
            </div>
            <label class="ux-toggle">
              <input type="checkbox"/>
              <span class="ux-toggle__track"></span>
            </label>
          </div>
        </div>
      </article>

      <!-- Alertas dismissed -->
      <article class="ux-card">
        <header class="ux-card__header">
          <h3 class="ux-card__title">Alertas descartadas</h3>
        </header>
        <div class="ux-card__body">
          <p style="font-size:13px;color:var(--ux-ink-3);margin:0 0 12px;">Alertas de cumplimiento que descartaste y se pueden recuperar.</p>
          <div style="display:flex;align-items:center;justify-content:space-between;padding:10px 12px;background:var(--ux-bg-3);border-radius:8px;">
            <div class="ux-flex ux-items-center ux-gap-2">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="ux-c-ink-3"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              <span style="font-size:13px;font-weight:500;">SII de IVA recomendado</span>
            </div>
            <button class="ux-btn ux-btn--ghost ux-btn--sm">Recuperar</button>
          </div>
        </div>
      </article>
    </div>
  </div>

  <nav class="ux-tabbar ux-app__tabbar" aria-label="Navegación principal">
    <a class="ux-tabbar-item" href="#"><span class="ux-tabbar-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="9"/></svg></span><span class="ux-tabbar-label">Inicio</span></a>
    <a class="ux-tabbar-item" href="#"><span class="ux-tabbar-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="7" r="4"/></svg></span><span class="ux-tabbar-label">Empleados</span></a>
    <a class="ux-tabbar-item" href="#"><span class="ux-tabbar-icon"><iconify-icon icon="lucide:package" width="2" height="2"></iconify-icon></span><span class="ux-tabbar-label">Módulos</span></a>
    <a class="ux-tabbar-item" href="#"><span class="ux-tabbar-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"/></svg></span><span class="ux-tabbar-label">Facturas</span></a>
    <a class="ux-tabbar-item" aria-current="page" href="#"><span class="ux-tabbar-icon"><iconify-icon icon="lucide:shield" width="2" height="2"></iconify-icon></span><span class="ux-tabbar-label">Cumplim.</span></a>
  </nav>
</div>
{% endblock %}
