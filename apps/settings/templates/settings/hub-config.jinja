{% extends "_base_preview.html" %}

{% block title %}Configuración · Cafetería La Rambla{% endblock %}

{% block body %}
<div class="ux-app" id="app" data-tabbar="bottom" data-signals="{sidebar: false}" data-attr:data-sidebar="$sidebar ? 'open' : ''">
  <div class="ux-app__sidebar-overlay" data-on:click="$sidebar = false"></div>

  <aside class="ux-sidebar">
    <div class="ux-sidebar__brand">
      <div class="ux-sidebar__logo">CR</div>
      <div class="ux-sidebar__brand-text">
        <div class="ux-sidebar__brand-name">Cafetería La Rambla</div>
        <div class="ux-sidebar__brand-meta">Hub · v0.0.9</div>
      </div>
    </div>
    <div class="ux-sidebar__body">
      <div class="ux-sidebar__group">Operación</div>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="9"/><rect x="14" y="3" width="7" height="5"/><rect x="14" y="12" width="7" height="9"/><rect x="3" y="16" width="7" height="5"/></svg><span class="ux-sidebar__label">Vista general</span></button>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="6" width="20" height="14" rx="2"/><path d="M2 10h20"/></svg><span class="ux-sidebar__label">POS</span></button>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg><span class="ux-sidebar__label">Facturas</span></button>

      <div class="ux-sidebar__group">Plataforma</div>
      <button class="ux-sidebar__item" aria-current="page"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.6 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 1 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 1 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 1 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg><span class="ux-sidebar__label">Configuración</span></button>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M6 8h.01M10 8h.01"/></svg><span class="ux-sidebar__label">Sistema</span></button>
    </div>
    <div class="ux-sidebar__footer">
      <div class="ux-sidebar__user">
        <span class="ux-avatar ux-avatar--sm ux-avatar--brand">JC</span>
        <div class="ux-sidebar__user-info">
          <div class="ux-sidebar__user-name">Joan Castell</div>
          <div class="ux-sidebar__user-meta">joan@larambla.es</div>
        </div>
      </div>
    </div>
  </aside>

  <div class="ux-app__main">
    <header class="ux-topbar">
        <div class="ux-topbar__left">
          <button class="ux-topbar__back-btn" aria-label="Volver"
            data-on:click="history.length > 1 ? history.back() : null">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          </button>
        </div>
        <h1 class="ux-topbar__page-title">Página</h1>
        
        
        <div class="ux-topbar__actions">
          <button class="ux-icon-btn" aria-label="Notificaciones"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/></svg></button>
        </div>
        <button class="ux-topbar__menu-btn" aria-label="Menú"
            data-on:click="$sidebar = !$sidebar"
            data-attr:aria-expanded="$sidebar">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
          </button>
      </header>

    <nav class="ux-tabs ux-tabs-scroll" aria-label="Sub-secciones de ajustes">
      <a class="ux-tab" href="preferences.html">Preferencias</a>
      <a class="ux-tab" href="hub.html">Hub</a>
      <a class="ux-tab" href="hub-config.html" aria-current="page">Config</a>
      <a class="ux-tab" href="compliance.html">Cumplimiento</a>
      <a class="ux-tab" href="devices.html">Dispositivos</a>
      <a class="ux-tab" href="printers.html">Impresoras</a>
      <a class="ux-tab" href="backup.html">Backup</a>
      <a class="ux-tab" href="files.html">Archivos</a>
      <a class="ux-tab" href="tax-classes.html">Tax</a>
      <a class="ux-tab" href="help.html">Ayuda</a>
      <a class="ux-tab" href="scheduled-tasks.html">Tareas</a>
      <a class="ux-tab" href="file-browser.html">File browser</a>
    </nav>

    <div class="ux-app__body">

      <div class="ux-page-header" style="border-bottom:1px solid var(--ux-line);margin-bottom:22px;">
        <div class="ux-page-header__title">
          <h1>Configuración</h1>
          <div class="ux-page-header__sub">Ajustes del Hub, dispositivos, fiscalidad y backup</div>
        </div>
      </div>

      <!-- TODO UX: no existe `ux-icon-tile`; uso inline styles para los tiles redondeados (color-mix con tokens). -->
      <div class="ux-grid-3" style="gap:16px;">

        <a href="profile.html" class="ux-card ux-card--interactive" tabindex="0">
          <div class="ux-card__body ux-flex ux-items-start ux-gap-3">
            <div class="ux-icon-tile" style="background:color-mix(in oklch, var(--ux-brand) 12%, transparent);color:var(--ux-brand);width:44px;height:44px;border-radius:12px;display:grid;place-items:center;flex:none;">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 21h18M5 21V7l7-4 7 4v14M9 9h.01M9 13h.01M9 17h.01M15 9h.01M15 13h.01M15 17h.01"/></svg>
            </div>
            <div>
              <h3 class="ux-card__title ux-mb-1">Cuenta y negocio</h3>
              <p class="ux-card__sub ux-m-0 ux-mb-3">Razón social, NIF, dirección, contacto y moneda.</p>
              <button class="ux-btn ux-btn--ghost ux-btn--sm">Configurar →</button>
            </div>
          </div>
        </a>

        <a href="devices.html" class="ux-card ux-card--interactive" tabindex="0">
          <div class="ux-card__body ux-flex ux-items-start ux-gap-3">
            <div class="ux-icon-tile" style="background:color-mix(in oklch, var(--ux-warn) 14%, transparent);color:var(--ux-warn);width:44px;height:44px;border-radius:12px;display:grid;place-items:center;flex:none;">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="2" width="14" height="20" rx="2"/><path d="M11 18h2"/></svg>
            </div>
            <div>
              <h3 class="ux-card__title ux-mb-1">Dispositivos de confianza</h3>
              <p class="ux-card__sub ux-m-0 ux-mb-3">Gestiona tablets, móviles y TPV autorizados al Hub.</p>
              <button class="ux-btn ux-btn--ghost ux-btn--sm">Configurar →</button>
            </div>
          </div>
        </a>

        <a href="printers.html" class="ux-card ux-card--interactive" tabindex="0">
          <div class="ux-card__body ux-flex ux-items-start ux-gap-3">
            <div class="ux-icon-tile" style="background:color-mix(in oklch, var(--ux-info) 14%, transparent);color:var(--ux-info);width:44px;height:44px;border-radius:12px;display:grid;place-items:center;flex:none;">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
            </div>
            <div>
              <h3 class="ux-card__title ux-mb-1">Impresoras</h3>
              <p class="ux-card__sub ux-m-0 ux-mb-3">Tickets, cocina, etiquetas y A4 conectadas vía Bridge.</p>
              <button class="ux-btn ux-btn--ghost ux-btn--sm">Configurar →</button>
            </div>
          </div>
        </a>

        <a href="tax-classes.html" class="ux-card ux-card--interactive" tabindex="0">
          <div class="ux-card__body ux-flex ux-items-start ux-gap-3">
            <div class="ux-icon-tile" style="background:color-mix(in oklch, var(--ux-leaf) 14%, transparent);color:var(--ux-leaf);width:44px;height:44px;border-radius:12px;display:grid;place-items:center;flex:none;">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="3" width="16" height="18" rx="2"/><path d="M8 7h8M8 11h8M8 15h4"/></svg>
            </div>
            <div>
              <h3 class="ux-card__title ux-mb-1">Impuestos</h3>
              <p class="ux-card__sub ux-m-0 ux-mb-3">Clases de IVA y tasas aplicables a tus productos.</p>
              <button class="ux-btn ux-btn--ghost ux-btn--sm">Configurar →</button>
            </div>
          </div>
        </a>

        <a href="backup.html" class="ux-card ux-card--interactive" tabindex="0">
          <div class="ux-card__body ux-flex ux-items-start ux-gap-3">
            <div class="ux-icon-tile" style="background:color-mix(in oklch, var(--ux-danger) 12%, transparent);color:var(--ux-danger);width:44px;height:44px;border-radius:12px;display:grid;place-items:center;flex:none;">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            </div>
            <div>
              <h3 class="ux-card__title ux-mb-1">Backup &amp; restauración</h3>
              <p class="ux-card__sub ux-m-0 ux-mb-3">Snapshots automáticos, manuales e historial de restauración.</p>
              <button class="ux-btn ux-btn--ghost ux-btn--sm">Configurar →</button>
            </div>
          </div>
        </a>

        <a href="file-browser.html" class="ux-card ux-card--interactive" tabindex="0">
          <div class="ux-card__body ux-flex ux-items-start ux-gap-3">
            <div class="ux-icon-tile" style="background:color-mix(in oklch, var(--ux-ink-2) 12%, transparent);color:var(--ux-ink);width:44px;height:44px;border-radius:12px;display:grid;place-items:center;flex:none;">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 7a2 2 0 0 1 2-2h4l2 2h8a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7z"/></svg>
            </div>
            <div>
              <h3 class="ux-card__title ux-mb-1">Archivos del Hub</h3>
              <p class="ux-card__sub ux-m-0 ux-mb-3">Navegador de almacenamiento del tenant: facturas, exports, logs.</p>
              <button class="ux-btn ux-btn--ghost ux-btn--sm">Abrir →</button>
            </div>
          </div>
        </a>

        <a href="../system/index.html" class="ux-card ux-card--interactive" tabindex="0">
          <div class="ux-card__body ux-flex ux-items-start ux-gap-3">
            <div class="ux-icon-tile" style="background:color-mix(in oklch, var(--ux-brand-2, var(--ux-brand)) 12%, transparent);color:var(--ux-brand);width:44px;height:44px;border-radius:12px;display:grid;place-items:center;flex:none;">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="4" width="16" height="16" rx="2"/><path d="M9 9h6v6H9z"/><path d="M9 1v3M15 1v3M9 20v3M15 20v3M1 9h3M1 15h3M20 9h3M20 15h3"/></svg>
            </div>
            <div>
              <h3 class="ux-card__title ux-mb-1">Hardware (Sistema)</h3>
              <p class="ux-card__sub ux-m-0 ux-mb-3">Bridge, cajón, scanner, balanza y mostrador cliente.</p>
              <button class="ux-btn ux-btn--ghost ux-btn--sm">Configurar →</button>
            </div>
          </div>
        </a>

        <article class="ux-card">
          <div class="ux-card__body ux-flex ux-items-start ux-gap-3">
            <div class="ux-icon-tile" style="background:color-mix(in oklch, var(--ux-ink-3) 18%, transparent);color:var(--ux-ink-3);width:44px;height:44px;border-radius:12px;display:grid;place-items:center;flex:none;">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
            </div>
            <div>
              <h3 class="ux-card__title ux-mb-1">Avanzado</h3>
              <p class="ux-card__sub ux-m-0 ux-mb-3">Logs, modo desarrollador y diagnóstico del Hub.</p>
              <button class="ux-btn ux-btn--ghost ux-btn--sm" disabled>Próximamente</button>
            </div>
          </div>
        </article>

      </div>

    </div>
  </div>

  <!-- Bottom tabbar (mobile) -->
  <nav class="ux-tabbar ux-app__tabbar" aria-label="Navegación principal">
    <a class="ux-tabbar-item" href="#"><span class="ux-tabbar-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="9"/><rect x="14" y="3" width="7" height="5"/><rect x="14" y="12" width="7" height="9"/><rect x="3" y="16" width="7" height="5"/></svg></span><span class="ux-tabbar-label">Inicio</span></a>
    <a class="ux-tabbar-item" href="#"><span class="ux-tabbar-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="6" width="20" height="14" rx="2"/><path d="M2 10h20"/></svg></span><span class="ux-tabbar-label">POS</span></a>
    <a class="ux-tabbar-item" href="#"><span class="ux-tabbar-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg></span><span class="ux-tabbar-label">Facturas</span></a>
    <a class="ux-tabbar-item" aria-current="page" href="#"><span class="ux-tabbar-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4"/></svg></span><span class="ux-tabbar-label">Ajustes</span></a>
    <a class="ux-tabbar-item" href="#"><span class="ux-tabbar-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="5" cy="12" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="19" cy="12" r="1.5"/></svg></span><span class="ux-tabbar-label">Más</span></a>
  </nav>
</div>
