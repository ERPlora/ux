{% extends "_base_preview.html" %}

{% block title %}Hub · Centro de ayuda{% endblock %}

{% block body %}
<div class="ux-app" id="app" data-tabbar="bottom" data-signals="{sidebar: false}" data-attr:data-sidebar="$sidebar ? 'open' : ''">
  <aside class="ux-sidebar">
    <div class="ux-sidebar__brand">
      <div class="ux-sidebar__logo">LR</div>
      <div class="ux-sidebar__brand-text">
        <div class="ux-sidebar__brand-name">Cafetería La Rambla</div>
        <div class="ux-sidebar__brand-meta">Centro de ayuda</div>
      </div>
    </div>
    <div class="ux-sidebar__body">
      <a class="ux-sidebar__item" href="#"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="9"/></svg><span class="ux-sidebar__label">Inicio</span></a>
      <a class="ux-sidebar__item" aria-current="page" href="#"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg><span class="ux-sidebar__label">Ayuda</span></a>
    </div>
  </aside>

  <div class="ux-app__main">
    <header class="ux-topbar">
        <div class="ux-topbar__left">
          <button class="ux-topbar__back-btn" aria-label="Volver"
            data-on:click="history.length > 1 ? history.back() : null">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          </button>
        </div>
        <h1 class="ux-topbar__page-title">Página</h1>
        
        
        <button class="ux-topbar__menu-btn" aria-label="Menú"
            data-on:click="$sidebar = !$sidebar"
            data-attr:aria-expanded="$sidebar">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
          </button>
      </header>

    <nav class="ux-tabs ux-tabs-scroll" aria-label="Sub-secciones de ajustes">
      <a class="ux-tab" href="preferences.html">Preferencias</a>
      <a class="ux-tab" href="hub.html">Hub</a>
      <a class="ux-tab" href="hub-config.html">Config</a>
      <a class="ux-tab" href="compliance.html">Cumplimiento</a>
      <a class="ux-tab" href="devices.html">Dispositivos</a>
      <a class="ux-tab" href="printers.html">Impresoras</a>
      <a class="ux-tab" href="backup.html">Backup</a>
      <a class="ux-tab" href="files.html">Archivos</a>
      <a class="ux-tab" href="tax-classes.html">Tax</a>
      <a class="ux-tab" href="help.html" aria-current="page">Ayuda</a>
      <a class="ux-tab" href="scheduled-tasks.html">Tareas</a>
      <a class="ux-tab" href="file-browser.html">File browser</a>
    </nav>

    <div class="ux-app__body" data-signals="{help: {q: '', s1: true, s2: false, s3: false, s4: false, s5: false, s6: false}, contact: false}">
      <!-- Hero search -->
      <div style="background:var(--ux-bg-2);border:1px solid var(--ux-line);border-radius:14px;padding:32px;margin-bottom:22px;text-align:center;">
        <h1 style="font-family:var(--ux-font-display);font-size:28px;font-weight:600;letter-spacing:-0.04em;margin:0 0 6px;">¿En qué podemos ayudarte?</h1>
        <p style="font-size:14px;color:var(--ux-ink-3);margin:0 0 22px;">Busca en la documentación, las FAQ y los tutoriales del Hub.</p>
        <div class="ux-search" style="max-width:520px;margin:0 auto;">
          <svg class="ux-search__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>
          <input class="ux-input ux-input--lg" placeholder="Buscar en la ayuda…" data-bind:help.q/>
          <span class="ux-search__kbd">⌘K</span>
        </div>
      </div>

      <!-- Categorías -->
      <h2 style="font-family:var(--ux-font-display);font-size:18px;font-weight:600;margin:0 0 14px;">Categorías</h2>
      <div class="ux-grid-3" style="margin-bottom:26px;">
        <article class="ux-card ux-card--interactive">
          <div class="ux-card__body ux-flex ux-items-start ux-gap-3">
            <div style="width:40px;height:40px;border-radius:10px;background:color-mix(in oklch, var(--ux-brand) 18%, transparent);color:var(--ux-brand);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09zM12 15l-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/></svg>
            </div>
            <div>
              <h3 style="font-family:var(--ux-font-display);font-size:15px;font-weight:600;margin:0 0 4px;">Empezar</h3>
              <p style="font-size:13px;color:var(--ux-ink-3);margin:0;">Setup inicial, primer empleado, primer módulo.</p>
            </div>
          </div>
        </article>
        <article class="ux-card ux-card--interactive">
          <div class="ux-card__body ux-flex ux-items-start ux-gap-3">
            <div style="width:40px;height:40px;border-radius:10px;background:color-mix(in oklch, var(--ux-info) 18%, transparent);color:var(--ux-info);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/></svg>
            </div>
            <div>
              <h3 style="font-family:var(--ux-font-display);font-size:15px;font-weight:600;margin:0 0 4px;">Facturación</h3>
              <p style="font-size:13px;color:var(--ux-ink-3);margin:0;">Suscripción, módulos de pago, métodos.</p>
            </div>
          </div>
        </article>
        <article class="ux-card ux-card--interactive">
          <div class="ux-card__body ux-flex ux-items-start ux-gap-3">
            <div style="width:40px;height:40px;border-radius:10px;background:color-mix(in oklch, var(--ux-leaf) 18%, transparent);color:var(--ux-leaf);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="7" r="4"/><path d="M3 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/></svg>
            </div>
            <div>
              <h3 style="font-family:var(--ux-font-display);font-size:15px;font-weight:600;margin:0 0 4px;">Empleados y roles</h3>
              <p style="font-size:13px;color:var(--ux-ink-3);margin:0;">Cuentas, PIN, permisos por módulo.</p>
            </div>
          </div>
        </article>
        <article class="ux-card ux-card--interactive">
          <div class="ux-card__body ux-flex ux-items-start ux-gap-3">
            <div style="width:40px;height:40px;border-radius:10px;background:color-mix(in oklch, var(--ux-warn) 18%, transparent);color:var(--ux-warn);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="6" width="20" height="14" rx="2"/></svg>
            </div>
            <div>
              <h3 style="font-family:var(--ux-font-display);font-size:15px;font-weight:600;margin:0 0 4px;">POS y caja</h3>
              <p style="font-size:13px;color:var(--ux-ink-3);margin:0;">TPV, KDS, comandero, cierre de caja.</p>
            </div>
          </div>
        </article>
        <article class="ux-card ux-card--interactive">
          <div class="ux-card__body ux-flex ux-items-start ux-gap-3">
            <div style="width:40px;height:40px;border-radius:10px;background:color-mix(in oklch, var(--ux-danger) 18%, transparent);color:var(--ux-danger);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2 4 6v6c0 5 3.5 9.5 8 10 4.5-.5 8-5 8-10V6l-8-4z"/></svg>
            </div>
            <div>
              <h3 style="font-family:var(--ux-font-display);font-size:15px;font-weight:600;margin:0 0 4px;">Cumplimiento</h3>
              <p style="font-size:13px;color:var(--ux-ink-3);margin:0;">Verifactu, AEAT, modelos fiscales.</p>
            </div>
          </div>
        </article>
        <article class="ux-card ux-card--interactive">
          <div class="ux-card__body ux-flex ux-items-start ux-gap-3">
            <div style="width:40px;height:40px;border-radius:10px;background:var(--ux-bg-3);color:var(--ux-ink-2);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M6 9h12M6 13h8"/></svg>
            </div>
            <div>
              <h3 style="font-family:var(--ux-font-display);font-size:15px;font-weight:600;margin:0 0 4px;">Bridge (hardware)</h3>
              <p style="font-size:13px;color:var(--ux-ink-3);margin:0;">Impresoras, cajón, escáner, balanzas.</p>
            </div>
          </div>
        </article>
      </div>

      <!-- FAQs accordion -->
      <h2 style="font-family:var(--ux-font-display);font-size:18px;font-weight:600;margin:0 0 14px;">Preguntas frecuentes</h2>
      <div class="ux-accordion" style="margin-bottom:26px;">
        <div class="ux-accordion__item" data-attr:data-state="$help.s1 ? 'open' : 'closed'">
          <button class="ux-accordion__trigger" data-attr:aria-expanded="$help.s1" data-on:click="$help.s1 = !$help.s1">
            <span class="ux-accordion__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/></svg></span>
            <span class="ux-accordion__title">¿Cómo configuro mi primer empleado?
              <span class="ux-accordion__sub">Crear cuenta, asignar PIN y rol</span>
            </span>
            <span class="ux-accordion__caret"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg></span>
          </button>
          <div class="ux-accordion__panel">
            <p class="ux-m-0 ux-mb-2">Ve a <b>Empleados &rarr; + Añadir empleado</b>. Rellena nombre, email y un PIN de 4 cifras. Asigna un rol predefinido o crea uno custom desde la sección Roles.</p>
            <ol style="margin:0;padding-left:20px;font-size:13px;color:var(--ux-ink-2);">
              <li>Click en "+ Añadir empleado"</li>
              <li>Rellena el formulario y elige rol</li>
              <li>Comparte el PIN inicial; el empleado podrá cambiarlo después</li>
            </ol>
          </div>
        </div>
        <div class="ux-accordion__item" data-attr:data-state="$help.s2 ? 'open' : 'closed'">
          <button class="ux-accordion__trigger" data-attr:aria-expanded="$help.s2" data-on:click="$help.s2 = !$help.s2">
            <span class="ux-accordion__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/></svg></span>
            <span class="ux-accordion__title">¿Cómo cambio mi plan o método de pago?
              <span class="ux-accordion__sub">Stripe Customer Portal</span>
            </span>
            <span class="ux-accordion__caret"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg></span>
          </button>
          <div class="ux-accordion__panel">
            Ve a <b>Facturación &rarr; Cambiar plan</b> o pulsa "Abrir portal Stripe" para gestionar tarjetas, dirección de facturación y cancelaciones.
          </div>
        </div>
        <div class="ux-accordion__item" data-attr:data-state="$help.s3 ? 'open' : 'closed'">
          <button class="ux-accordion__trigger" data-attr:aria-expanded="$help.s3" data-on:click="$help.s3 = !$help.s3">
            <span class="ux-accordion__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8"/></svg></span>
            <span class="ux-accordion__title">¿Cómo instalo un módulo del Marketplace?
              <span class="ux-accordion__sub">Verifactu, e-commerce, RRHH…</span>
            </span>
            <span class="ux-accordion__caret"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg></span>
          </button>
          <div class="ux-accordion__panel">
            Ve a <b>Módulos &rarr; Marketplace</b>, busca el módulo, pulsa "Instalar". El Hub descargará el paquete, ejecutará migraciones y lo activará automáticamente.
          </div>
        </div>
        <div class="ux-accordion__item" data-attr:data-state="$help.s4 ? 'open' : 'closed'">
          <button class="ux-accordion__trigger" data-attr:aria-expanded="$help.s4" data-on:click="$help.s4 = !$help.s4">
            <span class="ux-accordion__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2 4 6v6c0 5 3.5 9.5 8 10 4.5-.5 8-5 8-10V6l-8-4z"/></svg></span>
            <span class="ux-accordion__title">¿Cómo activo Verifactu?</span>
            <span class="ux-accordion__caret"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg></span>
          </button>
          <div class="ux-accordion__panel">
            Instala el módulo <b>Verifactu ES</b> desde el Marketplace, sube tu certificado digital FNMT en Cumplimiento &rarr; España y activa el toggle. Las facturas se enviarán automáticamente a la AEAT.
          </div>
        </div>
        <div class="ux-accordion__item" data-attr:data-state="$help.s5 ? 'open' : 'closed'">
          <button class="ux-accordion__trigger" data-attr:aria-expanded="$help.s5" data-on:click="$help.s5 = !$help.s5">
            <span class="ux-accordion__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="6" width="20" height="14" rx="2"/></svg></span>
            <span class="ux-accordion__title">Mi impresora no responde, ¿qué hago?</span>
            <span class="ux-accordion__caret"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg></span>
          </button>
          <div class="ux-accordion__panel">
            Verifica que ERPlora Bridge está conectado (Ajustes &rarr; Bridge). Reinicia la impresora, comprueba el cable y prueba imprimir desde Bridge &rarr; Test.
          </div>
        </div>
        <div class="ux-accordion__item" data-attr:data-state="$help.s6 ? 'open' : 'closed'">
          <button class="ux-accordion__trigger" data-attr:aria-expanded="$help.s6" data-on:click="$help.s6 = !$help.s6">
            <span class="ux-accordion__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z"/></svg></span>
            <span class="ux-accordion__title">¿Cómo recupero un backup?</span>
            <span class="ux-accordion__caret"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg></span>
          </button>
          <div class="ux-accordion__panel">
            Ve a <b>Ajustes &rarr; Backup &rarr; Histórico</b>, selecciona la fecha y pulsa "Restaurar". El proceso tarda 2-5 minutos y reinicia el Hub.
          </div>
        </div>
      </div>

      <!-- Contacto + recursos -->
      <div class="ux-grid-2">
        <article class="ux-card">
          <header class="ux-card__header"><h3 class="ux-card__title">Recursos externos</h3></header>
          <div class="ux-card__body ux-flex ux-col ux-gap-2">
            <a class="ux-btn ux-btn--outline ux-justify-start" href="https://docs.erplora.com" target="_blank">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2zM22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
              Documentación oficial
            </a>
            <a class="ux-btn ux-btn--outline ux-justify-start" href="https://erplora.com/changelog" target="_blank">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
              Changelog
            </a>
            <a class="ux-btn ux-btn--outline ux-justify-start" href="https://github.com/ERPlora/hub" target="_blank">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
              Repositorio en GitHub
            </a>
          </div>
        </article>

        <article class="ux-card">
          <header class="ux-card__header"><h3 class="ux-card__title">¿No encuentras la respuesta?</h3></header>
          <div class="ux-card__body">
            <p style="font-size:13px;color:var(--ux-ink-3);margin:0 0 14px;">Nuestro equipo de soporte responde en menos de 24 h en días laborables.</p>
            <button class="ux-btn ux-btn--primary" data-on:click="$contact = true">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              Contactar soporte
            </button>
          </div>
        </article>
      </div>

      <!-- Modal contactar soporte -->
      <div class="ux-modal-root" data-attr:data-state="$contact ? 'open' : 'closed'" data-show="$contact">
        <div class="ux-backdrop" data-on:click="$contact = false"></div>
        <div class="ux-modal ux-modal--md">
          <header class="ux-modal__header">
            <h3>Contactar soporte</h3>
            <button class="ux-icon-btn" data-on:click="$contact = false" aria-label="Cerrar"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
          </header>
          <div class="ux-modal__body">
            <form class="ux-form" data-on:submit="event.preventDefault(); $contact = false">
              <div class="ux-field">
                <label class="ux-field__label ux-field__label--req">Asunto</label>
                <input class="ux-input" placeholder="¿De qué se trata?"/>
              </div>
              <div class="ux-field ux-mt-3">
                <label class="ux-field__label">Categoría</label>
                <select class="ux-select">
                  <option>Pregunta general</option>
                  <option>Error / bug</option>
                  <option>Facturación</option>
                  <option>Solicitud de funcionalidad</option>
                </select>
              </div>
              <div class="ux-field ux-mt-3">
                <label class="ux-field__label ux-field__label--req">Descripción</label>
                <textarea class="ux-input" rows="5" placeholder="Cuéntanos qué pasa…"></textarea>
              </div>
            </form>
          </div>
          <footer class="ux-modal__footer">
            <button class="ux-btn ux-btn--ghost" data-on:click="$contact = false">Cancelar</button>
            <button class="ux-btn ux-btn--primary" data-on:click="$contact = false">Enviar</button>
          </footer>
        </div>
      </div>
    </div>
  </div>

  <nav class="ux-tabbar ux-app__tabbar" aria-label="Navegación principal">
    <a class="ux-tabbar-item" href="#"><span class="ux-tabbar-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="9"/></svg></span><span class="ux-tabbar-label">Inicio</span></a>
    <a class="ux-tabbar-item" href="#"><span class="ux-tabbar-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="7" r="4"/></svg></span><span class="ux-tabbar-label">Empleados</span></a>
    <a class="ux-tabbar-item" href="#"><span class="ux-tabbar-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8"/></svg></span><span class="ux-tabbar-label">Módulos</span></a>
    <a class="ux-tabbar-item" href="#"><span class="ux-tabbar-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"/></svg></span><span class="ux-tabbar-label">Facturas</span></a>
    <a class="ux-tabbar-item" aria-current="page" href="#"><span class="ux-tabbar-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/></svg></span><span class="ux-tabbar-label">Ayuda</span></a>
  </nav>
</div>
{% endblock %}
