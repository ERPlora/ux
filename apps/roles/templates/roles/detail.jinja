{% extends "_base_preview.html" %}

{% block title %}Hub · Detalle de rol · Manager{% endblock %}

{% block body %}
<div class="ux-app" id="app" data-tabbar="bottom" data-signals='{"sidebar": false}' data-attr:data-sidebar="$sidebar ? 'open' : ''">
  <aside class="ux-sidebar">
    <div class="ux-sidebar__brand">
      <div class="ux-sidebar__logo">LR</div>
      <div class="ux-sidebar__brand-text">
        <div class="ux-sidebar__brand-name">Cafetería La Rambla</div>
        <div class="ux-sidebar__brand-meta">4 roles</div>
      </div>
    </div>
    <div class="ux-sidebar__body">
      <a class="ux-sidebar__item" href="../dashboard.html"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="9"/></svg><span class="ux-sidebar__label">Inicio</span></a>
      <a class="ux-sidebar__item" href="./employees-list.html"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="7" r="4"/><path d="M3 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/></svg><span class="ux-sidebar__label">Empleados</span></a>
      <a class="ux-sidebar__item" aria-current="page" href="./roles-list.html"><iconify-icon icon="lucide:shield" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Roles</span><span class="ux-sidebar__badge">4</span></a>
    </div>
  </aside>

  <div class="ux-app__main">
    <header class="ux-topbar">
        <div class="ux-topbar__left">
          <button class="ux-topbar__back-btn" aria-label="Volver"
            data-on:click="history.length > 1 ? history.back() : null">
            <iconify-icon icon="lucide:arrow-left" width="2" height="2"></iconify-icon>
          </button>
        </div>
        <h1 class="ux-topbar__page-title">Página</h1>
        
        
        <div class="ux-topbar__actions">
          <a class="ux-btn ux-btn--ghost ux-btn--sm" href="./roles-list.html">Volver</a>
        <button class="ux-btn ux-btn--secondary ux-btn--sm" data-on:click="window.ds.signals.merge({delete: {open: true}})">Eliminar</button>
        <a class="ux-btn ux-btn--primary ux-btn--sm" href="./roles-form.html?id=2">Editar</a>
        </div>
        <button class="ux-topbar__menu-btn" aria-label="Menú"
            data-on:click="$sidebar = !$sidebar"
            data-attr:aria-expanded="$sidebar">
            <iconify-icon icon="lucide:menu" width="2" height="2"></iconify-icon>
          </button>
      </header>

    <div class="ux-app__body">
      <section class="ux-page-header">
        <div class="ux-page-header__title">
          <h1>Manager</h1>
          <div class="ux-page-header__sub">Acceso completo a operaciones de tienda · 3 usuarios asignados</div>
        </div>
      </section>

      <section class="ux-grid-2" style="--ux-grid-min:340px;">
        <article class="ux-card">
          <header class="ux-card__header"><h3 class="ux-card__title">Información</h3></header>
          <div class="ux-card__body">
            <dl class="ux-stack">
              <div class="ux-stack__row"><dt class="ux-stack__label">Nombre</dt><dd class="ux-stack__value">Manager</dd></div>
              <div class="ux-stack__row"><dt class="ux-stack__label">Slug</dt><dd class="ux-stack__value"><code class="ux-code">manager</code></dd></div>
              <div class="ux-stack__row"><dt class="ux-stack__label">Descripción</dt><dd class="ux-stack__value">Encargado de turno con acceso a ventas, inventario y empleados, sin permisos de configuración fiscal ni facturación.</dd></div>
              <div class="ux-stack__row"><dt class="ux-stack__label">Tipo</dt><dd class="ux-stack__value"><span class="ux-badge ux-badge--info">Personalizado</span></dd></div>
              <div class="ux-stack__row"><dt class="ux-stack__label">Creado</dt><dd class="ux-stack__value">12 abr 2026 · Joan Castell</dd></div>
              <div class="ux-stack__row"><dt class="ux-stack__label">Última modificación</dt><dd class="ux-stack__value">28 abr 2026 · Joan Castell</dd></div>
            </dl>
          </div>
        </article>

        <article class="ux-card">
          <header class="ux-card__header">
            <h3 class="ux-card__title">Usuarios asignados</h3>
            <span class="ux-badge">3</span>
          </header>
          <div class="ux-card__body">
            <ul class="ux-list">
              <li class="ux-list__item">
                <span class="ux-avatar ux-avatar--sm ux-avatar--brand">MS</span>
                <div class="ux-list__content">
                  <div class="ux-list__title">Marta Soler</div>
                  <div class="ux-list__meta">marta@larambla.es · Activo</div>
                </div>
                <span class="ux-status-dot ux-status-dot--ok"></span>
              </li>
              <li class="ux-list__item">
                <span class="ux-avatar ux-avatar--sm">CV</span>
                <div class="ux-list__content">
                  <div class="ux-list__title">Carles Vila</div>
                  <div class="ux-list__meta">carles@larambla.es · Activo</div>
                </div>
                <span class="ux-status-dot ux-status-dot--ok"></span>
              </li>
              <li class="ux-list__item">
                <span class="ux-avatar ux-avatar--sm">AR</span>
                <div class="ux-list__content">
                  <div class="ux-list__title">Aina Roig</div>
                  <div class="ux-list__meta">aina@larambla.es · Inactivo</div>
                </div>
                <span class="ux-status-dot ux-status-dot--off"></span>
              </li>
            </ul>
          </div>
          <footer class="ux-card__actions">
            <a class="ux-btn ux-btn--ghost ux-btn--sm" href="./employees-list.html?role=manager">Ver todos</a>
          </footer>
        </article>
      </section>

      <section class="ux-card" style="margin-block-start:var(--ux-space-4);">
        <header class="ux-card__header">
          <h3 class="ux-card__title">Permisos</h3>
          <span class="ux-pill">Solo lectura</span>
        </header>
        <div class="ux-card__body">
          <table class="ux-table ux-table--compact">
            <thead><tr><th>Módulo</th><th>Ver</th><th>Crear</th><th>Editar</th><th>Eliminar</th><th>Especiales</th></tr></thead>
            <tbody>
              <tr><td>POS / Ventas</td><td>✓</td><td>✓</td><td>✓</td><td>—</td><td>Anular ticket, descuento &gt; 10%</td></tr>
              <tr><td>Productos</td><td>✓</td><td>✓</td><td>✓</td><td>—</td><td>—</td></tr>
              <tr><td>Inventario</td><td>✓</td><td>✓</td><td>✓</td><td>—</td><td>Ajuste de stock</td></tr>
              <tr><td>Clientes</td><td>✓</td><td>✓</td><td>✓</td><td>✓</td><td>—</td></tr>
              <tr><td>Empleados</td><td>✓</td><td>—</td><td>✓</td><td>—</td><td>Solo del propio turno</td></tr>
              <tr><td>Compras</td><td>✓</td><td>✓</td><td>—</td><td>—</td><td>Aprobar &lt; €500</td></tr>
              <tr><td>Informes</td><td>✓</td><td>—</td><td>—</td><td>—</td><td>—</td></tr>
              <tr><td>Facturación</td><td>—</td><td>—</td><td>—</td><td>—</td><td>—</td></tr>
              <tr><td>VeriFactu / Fiscal</td><td>—</td><td>—</td><td>—</td><td>—</td><td>—</td></tr>
              <tr><td>Configuración</td><td>—</td><td>—</td><td>—</td><td>—</td><td>—</td></tr>
              <tr><td>Marketplace</td><td>✓</td><td>—</td><td>—</td><td>—</td><td>—</td></tr>
            </tbody>
          </table>
        </div>
        <footer class="ux-card__actions">
          <a class="ux-btn ux-btn--primary ux-btn--sm" href="./roles-form.html?id=2">Editar permisos</a>
        </footer>
      </section>
    </div>

    <nav class="ux-tabbar" data-position="bottom">
      <a class="ux-tabbar__item" href="../dashboard.html"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12 12 3l9 9"/><path d="M5 10v10h14V10"/></svg><span>Inicio</span></a>
      <a class="ux-tabbar__item" href="./employees-list.html"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="7" r="4"/></svg><span>Empleados</span></a>
      <a class="ux-tabbar__item is-active" href="./roles-list.html"><iconify-icon icon="lucide:shield" width="20" height="20"></iconify-icon><span>Roles</span></a>
      <a class="ux-tabbar__item" href="./settings.html"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/></svg><span>Más</span></a>
    </nav>
  </div>
</div>

<!-- Confirm delete modal: included for self-contained preview -->
<div class="ux-modal-root" data-signals='{"delete": {"open": false}, "confirmText": ""}' data-show="$delete.open">
  <div class="ux-backdrop" data-on:click="$delete.open = false"></div>
  <div class="ux-modal ux-modal--sm">
    <header class="ux-modal__header">
      <h3 class="ux-modal__title">Eliminar rol Manager</h3>
      <button class="ux-icon-btn" data-on:click="$delete.open = false" aria-label="Cerrar">×</button>
    </header>
    <div class="ux-modal__body">
      <div class="ux-alert ux-alert--warn">
        <strong>3 usuarios usan este rol.</strong> Al eliminarlo, esos usuarios pasarán al rol por defecto (Cajero).
      </div>
      <p>Esta acción no se puede deshacer.</p>
      <label class="ux-field">
        <span class="ux-field__label">Escribe <strong>manager</strong> para confirmar</span>
        <input class="ux-input" type="text" data-bind="confirmText" placeholder="manager"/>
      </label>
    </div>
    <footer class="ux-modal__footer">
      <button class="ux-btn ux-btn--ghost" data-on:click="$delete.open = false">Cancelar</button>
      <button class="ux-btn ux-btn--danger" data-attr:disabled="$confirmText !== 'manager'">Eliminar definitivamente</button>
    </footer>
  </div>
</div>
{% endblock %}
