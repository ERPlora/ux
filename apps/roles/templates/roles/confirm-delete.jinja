{% extends "_base_preview.html" %}

{% block title %}Hub · Eliminar rol{% endblock %}

{% block body %}
<!-- Renderiza la página de origen detrás (previews modal) -->
<div class="ux-app" id="app" data-tabbar="bottom" style="filter:blur(2px) brightness(.7);pointer-events:none;" data-signals="{sidebar: false}" data-attr:data-sidebar="$sidebar ? 'open' : ''">
  <aside class="ux-sidebar">
    <div class="ux-sidebar__brand">
      <div class="ux-sidebar__logo">LR</div>
      <div class="ux-sidebar__brand-text">
        <div class="ux-sidebar__brand-name">Cafetería La Rambla</div>
        <div class="ux-sidebar__brand-meta">4 roles</div>
      </div>
    </div>
    <div class="ux-sidebar__body">
      <a class="ux-sidebar__item" href="#"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="9"/></svg><span class="ux-sidebar__label">Inicio</span></a>
      <a class="ux-sidebar__item" aria-current="page" href="#"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2 4 6v6c0 5 3.5 9.5 8 10 4.5-.5 8-5 8-10V6l-8-4z"/></svg><span class="ux-sidebar__label">Roles</span></a>
    </div>
  </aside>
  <div class="ux-app__main">
    <div class="ux-app__body">
      <section class="ux-page-header"><div class="ux-page-header__title"><h1>Roles</h1></div></section>
    </div>
  </div>
</div>

<!-- Modal de confirmación: variante DANGER -->
<div class="ux-modal-root is-open">
  <div class="ux-backdrop"></div>
  <div class="ux-modal ux-modal--sm" role="alertdialog" aria-labelledby="del-title" aria-describedby="del-desc">
    <header class="ux-modal__header">
      <h3 class="ux-modal__title" id="del-title">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="ux-c-danger"><path d="M3 6h18"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
        Eliminar rol
      </h3>
      <a class="ux-icon-btn" href="./roles-list.html" aria-label="Cerrar">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18M6 6l12 12"/></svg>
      </a>
    </header>

    <div class="ux-modal__body" id="del-desc">
      <div class="ux-alert ux-alert--warn">
        <svg class="ux-alert__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
        <div class="ux-alert__body">
          <div class="ux-alert__title">3 usuarios tienen asignado el rol <strong>Manager</strong></div>
          <div class="ux-alert__desc">Al eliminarlo, esos usuarios serán reasignados automáticamente al rol por defecto: <strong>Cajero</strong>. Podrás revisarlos después en la lista de empleados.</div>
        </div>
      </div>

      <p style="margin-block:var(--ux-space-4) var(--ux-space-2);">
        Vas a eliminar el rol <strong>Manager</strong> creado el 12 abril 2026 por Joan Castell.
      </p>
      <p style="margin-block-end:var(--ux-space-4);color:var(--ux-text-muted);">
        Esta acción es permanente y no se puede deshacer.
      </p>

      <label class="ux-field">
        <span class="ux-field__label">Para confirmar, escribe <code class="ux-code">eliminar manager</code></span>
        <input class="ux-input" type="text" data-bind="confirmText" placeholder="eliminar manager" autocomplete="off"/>
        <span class="ux-field__hint ux-c-danger" data-show="$confirmText.length > 0 &amp;&amp; $confirmText !== 'eliminar manager'">El texto debe coincidir exactamente.</span>
      </label>
    </div>

    <footer class="ux-modal__footer">
      <a class="ux-btn ux-btn--ghost" href="./roles-list.html">Cancelar</a>
      <button class="ux-btn ux-btn--danger"
              data-attr:disabled="$confirmText !== 'eliminar manager' || $loading"
              data-on:click="$loading = true"
              data-class:is-loading="$loading">
        <svg data-show="!$loading" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/></svg>
        <span class="ux-spinner ux-spinner--sm" data-show="$loading"></span>
        <span data-text="$loading ? 'Eliminando…' : 'Eliminar definitivamente'">Eliminar definitivamente</span>
      </button>
    </footer>
  </div>
</div>
{% endblock %}
