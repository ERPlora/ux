{% extends "_base_preview.html" %}

{% from "ui/button.jinja" import button %}
{% from "ui/badge.jinja" import badge %}
{% from "ui/card.jinja" import card, card_footer %}
{% from "ui/icon.jinja" import icon %}
{% from "ui/input.jinja" import input %}
{% from "ui/field.jinja" import field %}
{% from "ui/empty.jinja" import empty %}

{% block title %}ERPlora Cloud · acme-prod · Configuración{% endblock %}

{% block head_extra %}
<style>
  body { background: var(--ux-bg); margin: 0; }
</style>
{% endblock %}

{% block body %}
<div class="ux-app" data-signals='{"sidebar": false, "tab": "general", "copied": false, "domains": ['pos.acme.com', 'tienda.acme.com'], "newDomain": "", "notifDaily": true, "notifWeekly": true, "notifMarketing": false, "intStripe": true, "intSlack": false, "intGcal": true, "intZapier": false, "autoBackup": true, "encryptBackup": true}' data-attr:data-sidebar="$sidebar ? 'open' : ''">
  <div class="ux-app__sidebar-overlay" data-on:click="$sidebar = false"></div>

  <aside class="ux-sidebar">
    <div class="ux-sidebar__brand">
      <div class="ux-sidebar__logo">EC</div>
      <div class="ux-sidebar__brand-text">
        <div class="ux-sidebar__brand-name">ERPlora Cloud</div>
        <div class="ux-sidebar__brand-meta">acme · ES</div>
      </div>
    </div>
    <div class="ux-sidebar__body">
      <div class="ux-sidebar__group">Principal</div>
      <button class="ux-sidebar__item"><iconify-icon icon="lucide:layout-dashboard" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Vista general</span></button>
      <button class="ux-sidebar__item" aria-current="page"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><path d="M3.27 6.96 12 12.01l8.73-5.05M12 22.08V12"/></svg><span class="ux-sidebar__label">Hubs</span><span class="ux-sidebar__badge">7</span></button>
      <button class="ux-sidebar__item"><iconify-icon icon="lucide:building-2" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Organizaciones</span></button>
      <button class="ux-sidebar__item"><iconify-icon icon="lucide:user" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Usuarios</span></button>

      <div class="ux-sidebar__group">Facturación</div>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20M6 15h2"/></svg><span class="ux-sidebar__label">Facturas</span><span class="ux-sidebar__badge ux-sidebar__badge--brand">3</span></button>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83"/></svg><span class="ux-sidebar__label">Planes</span></button>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z"/><path d="M12 7v5l3 3"/></svg><span class="ux-sidebar__label">Uso y consumo</span></button>

      <div class="ux-sidebar__group">Desarrollador</div>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m16 18 6-6-6-6M8 6l-6 6 6 6"/></svg><span class="ux-sidebar__label">API Tokens</span></button>
      <button class="ux-sidebar__item"><iconify-icon icon="lucide:file-text" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Logs</span></button>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/></svg><span class="ux-sidebar__label">Webhooks</span></button>
    </div>
    <div class="ux-sidebar__footer">
      <div class="ux-sidebar__user">
        <span class="ux-avatar ux-avatar--sm ux-avatar--brand">IB</span>
        <div class="ux-sidebar__user-info">
          <div class="ux-sidebar__user-name">Ioan Beilic</div>
          <div class="ux-sidebar__user-meta">ioan@acme.com</div>
        </div>
      </div>
    </div>
  </aside>

  <div class="ux-app__main">
    <header class="ux-topbar">
        <div class="ux-topbar__left">
          <button class="ux-topbar__back-btn" aria-label="Volver"
            data-on:click="history.length > 1 ? history.back() : null">
            <iconify-icon icon="lucide:arrow-left" width="2" height="2"></iconify-icon>
          </button>
        </div>
        <h1 class="ux-topbar__page-title">acme-prod · Configuración</h1>
        
        
        <div class="ux-topbar__actions">
          <button class="ux-icon-btn"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/></svg></button>
        <span class="ux-avatar ux-avatar--sm ux-avatar--brand">IB</span>
        </div>
        <button class="ux-topbar__menu-btn" aria-label="Menú"
            data-on:click="$sidebar = !$sidebar"
            data-attr:aria-expanded="$sidebar">
            <iconify-icon icon="lucide:menu" width="2" height="2"></iconify-icon>
          </button>
      </header>

    <div class="ux-app__body">
      <div class="ux-page-header">
        <div class="ux-page-header__title">
          <h1 class="ux-flex ux-items-center ux-gap-3">acme-prod · Configuración <span class="ux-badge ux-badge--ok"><span class="ux-badge__dot"></span>Producción · Activo</span></h1>
          <div class="ux-page-header__sub">acme.erplora.cloud · región EU-West-1 · plan Enterprise</div>
        </div>
        <div class="ux-page-header__actions">
          <button class="ux-btn ux-btn--ghost ux-btn--sm">Ver hub</button>
          <button class="ux-btn ux-btn--secondary ux-btn--sm">Reiniciar</button>
        </div>
      </div>

      <!-- Tabs -->
      <div class="ux-tabs ux-mb-5" role="tablist">
        <button class="ux-tab" data-on:click="$tab = 'general'" data-class:is-active="$tab === 'general'" data-attr:aria-selected="$tab === 'general' ? 'true' : 'false'">General</button>
        <button class="ux-tab" data-on:click="$tab = 'domains'" data-class:is-active="$tab === 'domains'" data-attr:aria-selected="$tab === 'domains' ? 'true' : 'false'">Dominios</button>
        <button class="ux-tab" data-on:click="$tab = 'integrations'" data-class:is-active="$tab === 'integrations'" data-attr:aria-selected="$tab === 'integrations' ? 'true' : 'false'">Integraciones</button>
        <button class="ux-tab" data-on:click="$tab = 'backups'" data-class:is-active="$tab === 'backups'" data-attr:aria-selected="$tab === 'backups' ? 'true' : 'false'">Backups</button>
        <button class="ux-tab" data-on:click="$tab = 'advanced'" data-class:is-active="$tab === 'advanced'" data-attr:aria-selected="$tab === 'advanced' ? 'true' : 'false'">Avanzado</button>
      </div>

      <div data-show="$tab === 'general'" style="display:flex;flex-direction:column;gap:18px;">

        <!-- General -->
        <section class="ux-panel">
          <div class="ux-panel__head">
            <div class="ux-panel__head-text">
              <div class="ux-panel__title">General</div>
              <div class="ux-panel__sub">Información básica del hub.</div>
            </div>
          </div>
          <div class="ux-panel__body">
            <div class="ux-row">
              <label class="ux-field ux-col-md-6">
                <span class="ux-field__label">Nombre del hub</span>
                <input class="ux-input" value="Acme Industries · Producción"/>
              </label>
              <label class="ux-field ux-col-md-6">
                <span class="ux-field__label">Identificador interno</span>
                <input class="ux-input ux-opacity-70" value="acme-prod" readonly/>
              </label>
            </div>
            <label class="ux-field ux-mt-3">
              <span class="ux-field__label">Descripción</span>
              <textarea class="ux-textarea" rows="3">Hub principal de Acme Industries S.L. para todas las tiendas físicas y el almacén central de Sant Cugat.</textarea>
            </label>
            <div class="ux-row ux-mt-3">
              <label class="ux-field ux-col-md-6">
                <span class="ux-field__label">Zona horaria</span>
                <select class="ux-select">
                  <option>Europe/Madrid (UTC+01:00)</option>
                  <option>Europe/Lisbon (UTC+00:00)</option>
                  <option>Europe/London (UTC+00:00)</option>
                </select>
              </label>
              <label class="ux-field ux-col-md-6">
                <span class="ux-field__label">Idioma por defecto</span>
                <select class="ux-select">
                  <option>Español (España)</option>
                  <option>Català</option>
                  <option>English (UK)</option>
                </select>
              </label>
            </div>
          </div>
        </section>

        <!-- URL & domains -->
        <section class="ux-panel">
          <div class="ux-panel__head">
            <div class="ux-panel__head-text">
              <div class="ux-panel__title">URL y dominios</div>
              <div class="ux-panel__sub">Subdominio gestionado por ERPlora y dominios personalizados.</div>
            </div>
          </div>
          <div class="ux-panel__body">
            <label class="ux-field ux-mb-4">
              <span class="ux-field__label">Subdominio principal</span>
              <div style="display:flex;gap:8px;align-items:stretch;">
                <input class="ux-input" value="acme.erplora.cloud" readonly style="opacity:0.85;flex:1;"/>
                <button class="ux-btn ux-btn--secondary ux-btn--sm" data-on:click="$copied = true" data-class:is-loading="$copied">
                  <span data-show="!$copied">Copiar</span>
                  <span data-show="$copied">Copiado ✓</span>
                </button>
              </div>
              <span class="ux-field__hint">El subdominio gestionado no se puede cambiar tras la creación.</span>
            </label>

            <div class="ux-field__label ux-mb-2">Dominios personalizados</div>
            <div style="display:flex;flex-direction:column;gap:8px;margin-bottom:12px;">
              <div data-show="$domains.includes('pos.acme.com')" style="display:flex;flex-wrap:wrap;gap:8px;align-items:center;padding:10px 12px;background:var(--ux-bg-1);border:1px solid var(--ux-line);border-radius:8px;">
                <span style="font-family:var(--ux-font-mono);font-size:13px;">pos.acme.com</span>
                <span class="ux-badge ux-badge--ok"><span class="ux-badge__dot"></span>SSL activo</span>
                <button class="ux-btn ux-btn--ghost ux-btn--sm ux-c-danger" data-on:click="$domains = $domains.filter(d => d !== 'pos.acme.com')">Quitar</button>
              </div>
              <div data-show="$domains.includes('tienda.acme.com')" style="display:flex;flex-wrap:wrap;gap:8px;align-items:center;padding:10px 12px;background:var(--ux-bg-1);border:1px solid var(--ux-line);border-radius:8px;">
                <span style="font-family:var(--ux-font-mono);font-size:13px;">tienda.acme.com</span>
                <span class="ux-badge ux-badge--warn"><span class="ux-badge__dot"></span>Esperando DNS</span>
                <button class="ux-btn ux-btn--ghost ux-btn--sm ux-c-danger" data-on:click="$domains = $domains.filter(d => d !== 'tienda.acme.com')">Quitar</button>
              </div>
              <template data-show="false"></template>
              <div data-show="$domains.length > 0 && !$domains.includes('pos.acme.com') && !$domains.includes('tienda.acme.com')" style="font-size:12px;color:var(--ux-ink-3);padding:6px 0;">+ <span data-text="$domains.length"></span> dominio(s) personalizado(s) añadido(s).</div>
              <div data-show="$domains.length === 0" style="font-size:12px;color:var(--ux-ink-3);padding:6px 0;">No hay dominios personalizados.</div>
            </div>
            <div style="display:flex;gap:8px;align-items:stretch;">
              <input class="ux-input ux-input--sm" placeholder="dominio.acme.com" data-bind:new-domain style="flex:1;max-width:280px;"/>
              <button class="ux-btn ux-btn--ghost ux-btn--sm" data-on:click="if ($newDomain) { $domains = [...$domains, $newDomain]; $newDomain = ''; }">+ Añadir dominio</button>
            </div>
          </div>
        </section>

        <!-- Contact -->
        <section class="ux-panel">
          <div class="ux-panel__head">
            <div class="ux-panel__head-text">
              <div class="ux-panel__title">Contacto</div>
              <div class="ux-panel__sub">Quién recibe alertas e incidencias del hub.</div>
            </div>
          </div>
          <div class="ux-panel__body">
            <div class="ux-row">
              <label class="ux-field ux-col-md-6">
                <span class="ux-field__label">Email del admin</span>
                <input class="ux-input" type="email" value="ioan@acme.com"/>
              </label>
              <label class="ux-field ux-col-md-6">
                <span class="ux-field__label">Contacto de incidencias</span>
                <input class="ux-input" type="email" value="incidencias@acme.com"/>
                <span class="ux-field__hint">Recibe alertas críticas las 24 h.</span>
              </label>
            </div>
          </div>
        </section>

        <!-- Notifications -->
        <section class="ux-panel">
          <div class="ux-panel__head">
            <div class="ux-panel__head-text">
              <div class="ux-panel__title">Notificaciones</div>
              <div class="ux-panel__sub">Qué emails envía ERPlora al equipo del hub.</div>
            </div>
          </div>
          <div class="ux-panel__body">
            <div class="ux-toggle-row">
              <div class="ux-toggle-row__text">
                <div class="ux-toggle-row__label">Alertas críticas</div>
                <div class="ux-toggle-row__desc">Hub caído, pago fallido, brechas de seguridad. No se puede desactivar.</div>
              </div>
              <label class="ux-toggle"><input type="checkbox" checked disabled/><span class="ux-toggle__track"></span></label>
            </div>
            <div class="ux-toggle-row">
              <div class="ux-toggle-row__text">
                <div class="ux-toggle-row__label">Resumen diario</div>
                <div class="ux-toggle-row__desc">Email cada mañana con KPIs del día anterior.</div>
              </div>
              <label class="ux-toggle"><input type="checkbox" data-bind:notif-daily/><span class="ux-toggle__track"></span></label>
            </div>
            <div class="ux-toggle-row">
              <div class="ux-toggle-row__text">
                <div class="ux-toggle-row__label">Métricas semanales</div>
                <div class="ux-toggle-row__desc">Tendencias y comparativa con la semana anterior, los lunes.</div>
              </div>
              <label class="ux-toggle"><input type="checkbox" data-bind:notif-weekly/><span class="ux-toggle__track"></span></label>
            </div>
            <div class="ux-toggle-row">
              <div class="ux-toggle-row__text">
                <div class="ux-toggle-row__label">Marketing y novedades</div>
                <div class="ux-toggle-row__desc">Nuevos módulos, casos de uso y eventos de ERPlora.</div>
              </div>
              <label class="ux-toggle"><input type="checkbox" data-bind:notif-marketing/><span class="ux-toggle__track"></span></label>
            </div>
          </div>
        </section>

        <!-- Maintenance window -->
        <section class="ux-panel">
          <div class="ux-panel__head">
            <div class="ux-panel__head-text">
              <div class="ux-panel__title">Mantenimiento</div>
              <div class="ux-panel__sub">Ventana programada para actualizaciones del hub.</div>
            </div>
          </div>
          <div class="ux-panel__body">
            <div class="ux-row">
              <label class="ux-field ux-col-md-6 ux-col-lg-4">
                <span class="ux-field__label">Día de la semana</span>
                <select class="ux-select">
                  <option>Domingo</option>
                  <option>Lunes</option>
                  <option>Martes</option>
                  <option>Miércoles</option>
                  <option>Jueves</option>
                  <option>Viernes</option>
                  <option>Sábado</option>
                </select>
              </label>
              <label class="ux-field ux-col-md-6 ux-col-lg-4">
                <span class="ux-field__label">Hora de inicio</span>
                <input class="ux-input" type="time" value="03:00"/>
              </label>
              <label class="ux-field ux-col-md-6 ux-col-lg-4">
                <span class="ux-field__label">Duración máxima</span>
                <select class="ux-select">
                  <option>30 minutos</option>
                  <option>1 hora</option>
                  <option>2 horas</option>
                </select>
              </label>
            </div>
            <div class="ux-callout ux-callout--info ux-mt-3">
              <span class="ux-callout__icon">
                <iconify-icon icon="lucide:info" width="2" height="2"></iconify-icon>
              </span>
              <div class="ux-callout__body">
                <div class="ux-callout__desc">Próxima ventana: <b>domingo 11 mayo 2026, 03:00</b>. Avisaremos por email 24 h antes.</div>
              </div>
            </div>
          </div>
        </section>

        <!-- Save bar -->
        <div style="position:sticky;bottom:0;background:var(--ux-bg-1);border-top:1px solid var(--ux-line);padding:14px 16px;display:flex;justify-content:flex-end;gap:8px;border-radius:8px;">
          <button class="ux-btn ux-btn--ghost ux-btn--sm">Descartar cambios</button>
          <button class="ux-btn ux-btn--primary ux-btn--sm">Guardar cambios</button>
        </div>

      </div>

      <!-- Dominios tab -->
      <div data-show="$tab === 'domains'" style="display:flex;flex-direction:column;gap:18px;">
        <section class="ux-panel">
          <div class="ux-panel__head">
            <div class="ux-panel__head-text">
              <div class="ux-panel__title">Dominios personalizados</div>
              <div class="ux-panel__sub">Añade tus propios dominios y configura el SSL automático.</div>
            </div>
          </div>
          <div class="ux-panel__body">
            <div style="display:flex;flex-direction:column;gap:8px;margin-bottom:12px;">
              <div data-show="$domains.includes('pos.acme.com')" style="display:flex;flex-wrap:wrap;gap:8px;align-items:center;padding:10px 12px;background:var(--ux-bg-1);border:1px solid var(--ux-line);border-radius:8px;">
                <span style="font-family:var(--ux-font-mono);font-size:13px;">pos.acme.com</span>
                <span class="ux-badge ux-badge--ok"><span class="ux-badge__dot"></span>SSL activo</span>
                <button class="ux-btn ux-btn--ghost ux-btn--sm ux-c-danger" data-on:click="$domains = $domains.filter(d => d !== 'pos.acme.com')">Quitar</button>
              </div>
              <div data-show="$domains.includes('tienda.acme.com')" style="display:flex;flex-wrap:wrap;gap:8px;align-items:center;padding:10px 12px;background:var(--ux-bg-1);border:1px solid var(--ux-line);border-radius:8px;">
                <span style="font-family:var(--ux-font-mono);font-size:13px;">tienda.acme.com</span>
                <span class="ux-badge ux-badge--warn"><span class="ux-badge__dot"></span>Esperando DNS</span>
                <button class="ux-btn ux-btn--ghost ux-btn--sm ux-c-danger" data-on:click="$domains = $domains.filter(d => d !== 'tienda.acme.com')">Quitar</button>
              </div>
              <div data-show="$domains.length === 0" style="font-size:12px;color:var(--ux-ink-3);padding:6px 0;">No hay dominios personalizados configurados.</div>
            </div>
            <div style="display:flex;gap:8px;align-items:stretch;">
              <input class="ux-input ux-input--sm" placeholder="dominio.acme.com" data-bind:new-domain style="flex:1;max-width:300px;"/>
              <button class="ux-btn ux-btn--secondary ux-btn--sm" data-on:click="if ($newDomain) { $domains = [...$domains, $newDomain]; $newDomain = ''; }">+ Añadir dominio</button>
            </div>
            <div class="ux-callout ux-callout--info ux-mt-3">
              <div class="ux-callout__body">
                <div class="ux-callout__desc">Añade un registro CNAME apuntando a <code>acme.erplora.cloud</code>. SSL se emite automáticamente vía Let's Encrypt.</div>
              </div>
            </div>
          </div>
        </section>
      </div>

      <!-- Integrations tab -->
      <div data-show="$tab === 'integrations'" style="display:flex;flex-direction:column;gap:18px;">
        <section class="ux-panel">
          <div class="ux-panel__head">
            <div class="ux-panel__head-text">
              <div class="ux-panel__title">Integraciones externas</div>
              <div class="ux-panel__sub">Conecta servicios de terceros con este hub.</div>
            </div>
          </div>
          <div class="ux-panel__body">
            <div class="ux-toggle-row">
              <div class="ux-toggle-row__text">
                <div class="ux-toggle-row__label">Stripe</div>
                <div class="ux-toggle-row__desc">Procesamiento de pagos y suscripciones.</div>
              </div>
              <label class="ux-toggle"><input type="checkbox" data-bind:int-stripe/><span class="ux-toggle__track"></span></label>
            </div>
            <div class="ux-toggle-row">
              <div class="ux-toggle-row__text">
                <div class="ux-toggle-row__label">Slack</div>
                <div class="ux-toggle-row__desc">Notificaciones de pedidos y alertas en canales.</div>
              </div>
              <label class="ux-toggle"><input type="checkbox" data-bind:int-slack/><span class="ux-toggle__track"></span></label>
            </div>
            <div class="ux-toggle-row">
              <div class="ux-toggle-row__text">
                <div class="ux-toggle-row__label">Google Calendar</div>
                <div class="ux-toggle-row__desc">Sincroniza eventos y reservas.</div>
              </div>
              <label class="ux-toggle"><input type="checkbox" data-bind:int-gcal/><span class="ux-toggle__track"></span></label>
            </div>
            <div class="ux-toggle-row">
              <div class="ux-toggle-row__text">
                <div class="ux-toggle-row__label">Zapier</div>
                <div class="ux-toggle-row__desc">Conecta con +5 000 apps mediante zaps.</div>
              </div>
              <label class="ux-toggle"><input type="checkbox" data-bind:int-zapier/><span class="ux-toggle__track"></span></label>
            </div>
          </div>
        </section>
      </div>

      <!-- Backups tab -->
      <div data-show="$tab === 'backups'" style="display:flex;flex-direction:column;gap:18px;">
        <section class="ux-panel">
          <div class="ux-panel__head">
            <div class="ux-panel__head-text">
              <div class="ux-panel__title">Copias de seguridad</div>
              <div class="ux-panel__sub">Snapshots diarios cifrados, retención 30 días.</div>
            </div>
          </div>
          <div class="ux-panel__body">
            <div class="ux-toggle-row">
              <div class="ux-toggle-row__text">
                <div class="ux-toggle-row__label">Backups automáticos</div>
                <div class="ux-toggle-row__desc">Snapshot diario a las 04:00 UTC.</div>
              </div>
              <label class="ux-toggle"><input type="checkbox" data-bind:auto-backup/><span class="ux-toggle__track"></span></label>
            </div>
            <div class="ux-toggle-row">
              <div class="ux-toggle-row__text">
                <div class="ux-toggle-row__label">Cifrado AES-256</div>
                <div class="ux-toggle-row__desc">Cifra los snapshots con tu propia clave KMS.</div>
              </div>
              <label class="ux-toggle"><input type="checkbox" data-bind:encrypt-backup/><span class="ux-toggle__track"></span></label>
            </div>
            <div class="ux-mt-3">
              <button class="ux-btn ux-btn--secondary ux-btn--sm">Crear snapshot manual</button>
              <button class="ux-btn ux-btn--ghost ux-btn--sm">Restaurar desde…</button>
            </div>
          </div>
        </section>
      </div>

      <!-- Advanced tab -->
      <div data-show="$tab === 'advanced'" style="display:flex;flex-direction:column;gap:18px;">
        <section class="ux-panel">
          <div class="ux-panel__head">
            <div class="ux-panel__head-text">
              <div class="ux-panel__title">Avanzado · zona de peligro</div>
              <div class="ux-panel__sub">Acciones irreversibles. Procede con precaución.</div>
            </div>
          </div>
          <div class="ux-panel__body ux-flex ux-col ux-gap-3">
            <div style="display:flex;justify-content:space-between;align-items:center;padding:12px;border:1px solid var(--ux-line);border-radius:8px;">
              <div><strong>Pausar hub</strong><div class="ux-text-xs ux-c-ink-3">El hub pasa a estado read-only.</div></div>
              <button class="ux-btn ux-btn--secondary ux-btn--sm">Pausar</button>
            </div>
            <div style="display:flex;justify-content:space-between;align-items:center;padding:12px;border:1px solid var(--ux-danger);border-radius:8px;">
              <div><strong class="ux-c-danger">Eliminar hub</strong><div class="ux-text-xs ux-c-ink-3">Borra todos los datos. No se puede deshacer.</div></div>
              <button class="ux-btn ux-btn--danger ux-btn--sm">Eliminar</button>
            </div>
          </div>
        </section>
      </div>

      <div style="height:32px;"></div>
    </div>
  </div>


  <!-- Bottom tab bar — mobile only via .ux-app__tabbar slot -->
  <nav class="ux-app__tabbar" aria-label="Navegación principal">
    <div class="ux-tabbar ux-tabbar--fixed ux-tabbar--icons">
