{% extends "_base_preview.html" %}

{% from "ui/button.jinja" import button %}
{% from "ui/badge.jinja" import badge %}
{% from "ui/card.jinja" import card, card_footer %}
{% from "ui/icon.jinja" import icon %}
{% from "ui/input.jinja" import input %}
{% from "ui/field.jinja" import field %}
{% from "ui/empty.jinja" import empty %}

{% block title %}ERPlora Cloud · acme-prod · Acceso QR{% endblock %}

{% block head_extra %}
<style>
  body { background: var(--ux-bg); margin: 0; }
</style>
{% endblock %}

{% block body %}
<div class="ux-app" data-signals="{sidebar: false, copied: false}" data-attr:data-sidebar="$sidebar ? 'open' : ''">
  <div class="ux-app__sidebar-overlay" data-on:click="$sidebar = false"></div>

  <aside class="ux-sidebar">
    <div class="ux-sidebar__brand">
      <div class="ux-sidebar__logo">EC</div>
      <div class="ux-sidebar__brand-text">
        <div class="ux-sidebar__brand-name">ERPlora Cloud</div>
        <div class="ux-sidebar__brand-meta">acme · ES</div>
      </div>
    </div>
    <div class="ux-sidebar__body">
      <div class="ux-sidebar__group">Principal</div>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="9"/><rect x="14" y="3" width="7" height="5"/><rect x="14" y="12" width="7" height="9"/><rect x="3" y="16" width="7" height="5"/></svg><span class="ux-sidebar__label">Vista general</span></button>
      <button class="ux-sidebar__item" aria-current="page"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg><span class="ux-sidebar__label">Hubs</span><span class="ux-sidebar__badge">7</span></button>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 21h18M5 21V7l7-4 7 4v14"/></svg><span class="ux-sidebar__label">Organizaciones</span></button>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg><span class="ux-sidebar__label">Usuarios</span></button>

      <div class="ux-sidebar__group">Facturación</div>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"/></svg><span class="ux-sidebar__label">Facturas</span><span class="ux-sidebar__badge ux-sidebar__badge--brand">3</span></button>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v4M12 18v4"/></svg><span class="ux-sidebar__label">Planes</span></button>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 1 1-18 0"/></svg><span class="ux-sidebar__label">Uso y consumo</span></button>

      <div class="ux-sidebar__group">Desarrollador</div>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m16 18 6-6-6-6M8 6l-6 6 6 6"/></svg><span class="ux-sidebar__label">API Tokens</span></button>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16"/></svg><span class="ux-sidebar__label">Logs</span></button>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/></svg><span class="ux-sidebar__label">Webhooks</span></button>
    </div>
    <div class="ux-sidebar__footer">
      <div class="ux-sidebar__user">
        <span class="ux-avatar ux-avatar--sm ux-avatar--brand">IB</span>
        <div class="ux-sidebar__user-info">
          <div class="ux-sidebar__user-name">Ioan Beilic</div>
          <div class="ux-sidebar__user-meta">ioan@acme.com</div>
        </div>
      </div>
    </div>
  </aside>

  <div class="ux-app__main">
    <header class="ux-topbar">
        <div class="ux-topbar__left">
          <button class="ux-topbar__back-btn" aria-label="Volver"
            data-on:click="history.length > 1 ? history.back() : null">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          </button>
        </div>
        <h1 class="ux-topbar__page-title">acme-prod · Acceso QR</h1>
        
        
        <div class="ux-topbar__actions">
          <span class="ux-avatar ux-avatar--sm ux-avatar--brand">IB</span>
        </div>
        <button class="ux-topbar__menu-btn" aria-label="Menú"
            data-on:click="$sidebar = !$sidebar"
            data-attr:aria-expanded="$sidebar">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
          </button>
      </header>

    <div class="ux-app__body">
      <div class="ux-page-header">
        <div class="ux-page-header__title">
          <h1>acme-prod · Acceso rápido</h1>
          <div class="ux-page-header__sub">Comparte el QR con tu equipo o imprímelo en el TPV.</div>
        </div>
      </div>

      <!-- Centered QR card -->
      <div style="display:flex;justify-content:center;margin-bottom:32px;">
        <article class="ux-card" style="max-width:600px;width:100%;">
          <div class="ux-card__body" style="display:flex;flex-direction:column;align-items:center;gap:16px;padding:32px 24px;">

            <div class="ux-qr ux-qr--lg ux-qr--bordered">
              <div class="ux-qr__img">
                <svg viewBox="0 0 29 29" xmlns="http://www.w3.org/2000/svg" shape-rendering="crispEdges">
                  <rect width="29" height="29" fill="#FFFFFF"/>
                  <g fill="#0B0A09">
                    <!-- Top-left finder -->
                    <rect x="0" y="0" width="7" height="7"/>
                    <rect x="1" y="1" width="5" height="5" fill="#FFFFFF"/>
                    <rect x="2" y="2" width="3" height="3"/>
                    <!-- Top-right finder -->
                    <rect x="22" y="0" width="7" height="7"/>
                    <rect x="23" y="1" width="5" height="5" fill="#FFFFFF"/>
                    <rect x="24" y="2" width="3" height="3"/>
                    <!-- Bottom-left finder -->
                    <rect x="0" y="22" width="7" height="7"/>
                    <rect x="1" y="23" width="5" height="5" fill="#FFFFFF"/>
                    <rect x="2" y="24" width="3" height="3"/>
                    <!-- Timing -->
                    <rect x="8" y="6" width="1" height="1"/><rect x="10" y="6" width="1" height="1"/><rect x="12" y="6" width="1" height="1"/><rect x="14" y="6" width="1" height="1"/><rect x="16" y="6" width="1" height="1"/><rect x="18" y="6" width="1" height="1"/><rect x="20" y="6" width="1" height="1"/>
                    <rect x="6" y="8" width="1" height="1"/><rect x="6" y="10" width="1" height="1"/><rect x="6" y="12" width="1" height="1"/><rect x="6" y="14" width="1" height="1"/><rect x="6" y="16" width="1" height="1"/><rect x="6" y="18" width="1" height="1"/><rect x="6" y="20" width="1" height="1"/>
                    <!-- Data modules (decorative pattern) -->
                    <rect x="9" y="2" width="2" height="2"/><rect x="13" y="1" width="1" height="2"/><rect x="15" y="2" width="2" height="1"/><rect x="18" y="1" width="2" height="2"/>
                    <rect x="9" y="4" width="1" height="2"/><rect x="11" y="4" width="2" height="2"/><rect x="14" y="4" width="1" height="1"/><rect x="16" y="4" width="3" height="1"/>
                    <rect x="8" y="8" width="2" height="2"/><rect x="11" y="8" width="1" height="2"/><rect x="13" y="8" width="3" height="1"/><rect x="17" y="8" width="2" height="2"/><rect x="20" y="8" width="2" height="1"/>
                    <rect x="9" y="10" width="1" height="2"/><rect x="12" y="10" width="2" height="2"/><rect x="15" y="10" width="1" height="3"/><rect x="17" y="11" width="2" height="2"/><rect x="20" y="10" width="2" height="2"/>
                    <rect x="8" y="12" width="2" height="1"/><rect x="11" y="13" width="2" height="2"/><rect x="14" y="13" width="1" height="2"/><rect x="16" y="13" width="3" height="2"/><rect x="20" y="13" width="2" height="2"/>
                    <rect x="9" y="15" width="2" height="1"/><rect x="12" y="15" width="1" height="3"/><rect x="14" y="16" width="2" height="2"/><rect x="17" y="16" width="2" height="1"/><rect x="20" y="16" width="2" height="2"/>
                    <rect x="8" y="17" width="2" height="2"/><rect x="11" y="17" width="1" height="2"/><rect x="13" y="18" width="2" height="1"/><rect x="16" y="18" width="1" height="2"/><rect x="18" y="18" width="2" height="2"/><rect x="21" y="18" width="1" height="2"/>
                    <rect x="9" y="20" width="2" height="2"/><rect x="12" y="20" width="1" height="2"/><rect x="14" y="20" width="3" height="1"/><rect x="18" y="20" width="2" height="2"/><rect x="21" y="20" width="2" height="2"/>
                    <rect x="8" y="22" width="2" height="2"/><rect x="11" y="22" width="2" height="2"/><rect x="14" y="23" width="2" height="2"/><rect x="17" y="22" width="3" height="2"/><rect x="21" y="23" width="2" height="2"/>
                    <rect x="8" y="25" width="1" height="2"/><rect x="10" y="25" width="2" height="2"/><rect x="13" y="25" width="3" height="2"/><rect x="17" y="25" width="2" height="2"/><rect x="20" y="25" width="2" height="2"/><rect x="23" y="25" width="3" height="2"/>
                  </g>
                </svg>
              </div>
              <div class="ux-qr__label">acme.erplora.cloud</div>
            </div>

            <div style="display:flex;align-items:center;gap:8px;background:var(--ux-bg-1);border:1px solid var(--ux-line);border-radius:8px;padding:8px 12px;font-family:var(--ux-font-mono);font-size:13px;width:100%;max-width:380px;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="ux-c-leaf"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              <span style="flex:1;color:var(--ux-ink);">https://acme.erplora.cloud</span>
              <button class="ux-btn ux-btn--ghost ux-btn--sm" data-on:click="$copied = true" style="padding:2px 8px;">
                <span data-show="!$copied">Copiar</span>
                <span data-show="$copied" class="ux-c-leaf">Copiado ✓</span>
              </button>
            </div>

            <div class="ux-flex ux-gap-2">
              <button class="ux-btn ux-btn--outline ux-btn--sm">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:6px;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>
                Descargar PNG
              </button>
              <button class="ux-btn ux-btn--outline ux-btn--sm">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:6px;"><path d="M6 9V2h12v7M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
                Imprimir
              </button>
            </div>

            <p style="font-size:12px;color:var(--ux-ink-3);text-align:center;max-width:380px;margin:0;">
              Escanea con tu móvil para acceder rápido al hub. El QR caduca cada 24 h.
            </p>

          </div>
        </article>
      </div>

      <!-- Tokens table -->
      <section class="ux-panel ux-mb-4">
        <div class="ux-panel__head">
          <div class="ux-panel__head-text">
            <div class="ux-panel__title">Tokens temporales</div>
            <div class="ux-panel__sub">Códigos de un solo uso para acceso desde dispositivos compartidos.</div>
          </div>
          <div class="ux-panel__actions">
            <button class="ux-btn ux-btn--primary ux-btn--sm">+ Generar token</button>
          </div>
        </div>
        <div class="ux-panel__body ux-p-0">
          <table class="ux-table">
            <thead>
              <tr>
                <th>Etiqueta</th>
                <th>Token</th>
                <th>Expira en</th>
                <th>Generado por</th>
                <th class="ux-text-right">Acciones</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>
                  <div class="ux-flex ux-items-center ux-gap-2">
                    <span class="ux-badge ux-badge--info"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:4px;"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>QR</span>
                    <span>TPV Cocina 1</span>
                  </div>
                </td>
                <td><code class="ux-code ux-code--inline">7K3X-29MD</code></td>
                <td class="ux-c-leaf">22 h 14 min</td>
                <td class="ux-c-ink-3">Ioan Beilic</td>
                <td class="ux-text-right"><button class="ux-btn ux-btn--ghost ux-btn--sm ux-c-danger">Revocar</button></td>
              </tr>
              <tr>
                <td>
                  <div class="ux-flex ux-items-center ux-gap-2">
                    <span class="ux-badge ux-badge--info"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:4px;"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>QR</span>
                    <span>Almacén Sant Cugat</span>
                  </div>
                </td>
                <td><code class="ux-code ux-code--inline">PL9Q-A1F2</code></td>
                <td class="ux-c-leaf">18 h 02 min</td>
                <td class="ux-c-ink-3">Marina Casals</td>
                <td class="ux-text-right"><button class="ux-btn ux-btn--ghost ux-btn--sm ux-c-danger">Revocar</button></td>
              </tr>
              <tr>
                <td>
                  <div class="ux-flex ux-items-center ux-gap-2">
                    <span class="ux-badge ux-badge--info"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:4px;"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>QR</span>
                    <span>Tablet inventario</span>
                  </div>
                </td>
                <td><code class="ux-code ux-code--inline">3R4N-K7B8</code></td>
                <td class="ux-c-warn">2 h 38 min</td>
                <td class="ux-c-ink-3">Jordi Roca</td>
                <td class="ux-text-right"><button class="ux-btn ux-btn--ghost ux-btn--sm ux-c-danger">Revocar</button></td>
              </tr>
              <tr>
                <td>
                  <div class="ux-flex ux-items-center ux-gap-2">
                    <span class="ux-badge ux-badge--info"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:4px;"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>QR</span>
                    <span>Auditor externo</span>
                  </div>
                </td>
                <td><code class="ux-code ux-code--inline">M5T6-DH9P</code></td>
                <td class="ux-c-leaf">5 d 11 h</td>
                <td class="ux-c-ink-3">Núria Ferrer</td>
                <td class="ux-text-right"><button class="ux-btn ux-btn--ghost ux-btn--sm ux-c-danger">Revocar</button></td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <!-- Recent scans / audit log -->
      <section class="ux-panel ux-mb-4">
        <div class="ux-panel__head">
          <div class="ux-panel__head-text">
            <div class="ux-panel__title">Escaneos recientes</div>
            <div class="ux-panel__sub">Últimos 7 días · cuentan solo accesos exitosos.</div>
          </div>
          <div class="ux-panel__actions">
            <button class="ux-btn ux-btn--ghost ux-btn--sm">Ver auditoría completa</button>
          </div>
        </div>
        <div class="ux-panel__body">
          <ul style="list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:8px;font-size:13px;">
            <li style="display:grid;grid-template-columns:auto 1fr auto;gap:12px;align-items:center;padding:8px 0;border-bottom:1px solid var(--ux-line);">
              <span class="ux-status-dot ux-status-dot--online"></span>
              <span><b class="ux-c-ink">7K3X-29MD</b> · TPV Cocina 1 · iPhone 15 Pro</span>
              <span class="ux-text-xs ux-c-ink-3">hace 4 min</span>
            </li>
            <li style="display:grid;grid-template-columns:auto 1fr auto;gap:12px;align-items:center;padding:8px 0;border-bottom:1px solid var(--ux-line);">
              <span class="ux-status-dot ux-status-dot--online"></span>
              <span><b class="ux-c-ink">PL9Q-A1F2</b> · Almacén Sant Cugat · Android · Samsung A54</span>
              <span class="ux-text-xs ux-c-ink-3">hace 38 min</span>
            </li>
            <li style="display:grid;grid-template-columns:auto 1fr auto;gap:12px;align-items:center;padding:8px 0;border-bottom:1px solid var(--ux-line);">
              <span class="ux-status-dot ux-status-dot--online"></span>
              <span><b class="ux-c-ink">3R4N-K7B8</b> · Tablet inventario · iPad Air</span>
              <span class="ux-text-xs ux-c-ink-3">hace 2 h</span>
            </li>
            <li style="display:grid;grid-template-columns:auto 1fr auto;gap:12px;align-items:center;padding:8px 0;">
              <span class="ux-status-dot ux-status-dot--offline"></span>
              <span><b class="ux-c-ink">M5T6-DH9P</b> · Auditor externo · MacBook Pro</span>
              <span class="ux-text-xs ux-c-ink-3">ayer · 17:21</span>
            </li>
          </ul>
        </div>
      </section>

      <div class="ux-callout ux-callout--info">
        <span class="ux-callout__icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
        </span>
        <div class="ux-callout__body">
          <div class="ux-callout__title">Renovación automática</div>
          <div class="ux-callout__desc">Los QR se renuevan automáticamente cada 24 h por seguridad. Los tokens temporales pueden tener una duración mayor pero siempre son revocables.</div>
        </div>
      </div>

      <div style="height:32px;"></div>
    </div>
  </div>


  <!-- Bottom tab bar — mobile only via .ux-app__tabbar slot -->
  <nav class="ux-app__tabbar" aria-label="Navegación principal">
    <div class="ux-tabbar ux-tabbar--fixed ux-tabbar--icons">
      <a class="ux-tabbar-item" href="#" aria-current="page">
        <span class="ux-tabbar-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12 5 10 12 3l7 7 2 2v9a2 2 0 0 1-2 2h-4v-7H10v7H6a2 2 0 0 1-2-2v-9z"/></svg></span>
        <span class="ux-tabbar-label">Inicio</span>
      </a>
      <a class="ux-tabbar-item" href="#">
        <span class="ux-tabbar-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8a4 4 0 0 1 4-4h10a4 4 0 0 1 4 4v8a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4z"/><path d="M7 12h.01M12 12h.01M17 12h.01"/></svg></span>
        <span class="ux-tabbar-label">Hubs</span>
        <span class="ux-tabbar-badge">7</span>
      </a>
      <a class="ux-tabbar-item" href="#">
        <span class="ux-tabbar-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg></span>
        <span class="ux-tabbar-label">Usuarios</span>
      </a>
      <a class="ux-tabbar-item" href="#">
        <span class="ux-tabbar-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v4M3 9l1.5-3h15L21 9M3 9h18v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2zM10 21V13h4v8"/></svg></span>
        <span class="ux-tabbar-label">Equipo</span>
      </a>
      <a class="ux-tabbar-item" href="#">
        <span class="ux-tabbar-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="10" r="3"/><path d="M7 19a5 5 0 0 1 10 0"/></svg></span>
        <span class="ux-tabbar-label">Perfil</span>
      </a>
    </div>
  </nav>
</div>
{% endblock %}
