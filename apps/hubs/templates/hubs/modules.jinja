{% extends "_base_preview.html" %}

{% from "ui/button.jinja" import button %}
{% from "ui/badge.jinja" import badge %}
{% from "ui/card.jinja" import card, card_footer %}
{% from "ui/icon.jinja" import icon %}
{% from "ui/input.jinja" import input %}
{% from "ui/field.jinja" import field %}
{% from "ui/empty.jinja" import empty %}

{% block title %}ERPlora Cloud · acme-prod · Módulos{% endblock %}

{% block head_extra %}
<style>
  body { background: var(--ux-bg); margin: 0; }
  .modcard__icon { width:42px;height:42px;border-radius:10px;display:grid;place-items:center;background:var(--ux-bg-3);color:var(--ux-ink-2);flex-shrink:0; }
  .modcard__icon svg { width:22px; height:22px; }
</style>
{% endblock %}

{% block body %}
<div class="ux-app" data-signals='{"sidebar": false, "tab": "installed", "q": "", "cat": "all"}' data-attr:data-sidebar="$sidebar ? 'open' : ''">
  <div class="ux-app__sidebar-overlay" data-on:click="$sidebar = false"></div>

  <aside class="ux-sidebar">
    <div class="ux-sidebar__brand">
      <div class="ux-sidebar__logo">EC</div>
      <div class="ux-sidebar__brand-text">
        <div class="ux-sidebar__brand-name">ERPlora Cloud</div>
        <div class="ux-sidebar__brand-meta">acme · ES</div>
      </div>
    </div>
    <div class="ux-sidebar__body">
      <div class="ux-sidebar__group">Principal</div>
      <button class="ux-sidebar__item"><iconify-icon icon="lucide:layout-dashboard" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Vista general</span></button>
      <button class="ux-sidebar__item" aria-current="page"><iconify-icon icon="lucide:package" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Hubs</span><span class="ux-sidebar__badge">7</span></button>
      <button class="ux-sidebar__item"><iconify-icon icon="lucide:building-2" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Organizaciones</span></button>
      <button class="ux-sidebar__item"><iconify-icon icon="lucide:user" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Usuarios</span></button>

      <div class="ux-sidebar__group">Facturación</div>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"/></svg><span class="ux-sidebar__label">Facturas</span><span class="ux-sidebar__badge ux-sidebar__badge--brand">3</span></button>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v4M12 18v4"/></svg><span class="ux-sidebar__label">Planes</span></button>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 1 1-18 0"/></svg><span class="ux-sidebar__label">Uso y consumo</span></button>

      <div class="ux-sidebar__group">Desarrollador</div>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m16 18 6-6-6-6M8 6l-6 6 6 6"/></svg><span class="ux-sidebar__label">API Tokens</span></button>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16"/></svg><span class="ux-sidebar__label">Logs</span></button>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/></svg><span class="ux-sidebar__label">Webhooks</span></button>
    </div>
    <div class="ux-sidebar__footer">
      <div class="ux-sidebar__user">
        <span class="ux-avatar ux-avatar--sm ux-avatar--brand">IB</span>
        <div class="ux-sidebar__user-info">
          <div class="ux-sidebar__user-name">Ioan Beilic</div>
          <div class="ux-sidebar__user-meta">ioan@acme.com</div>
        </div>
      </div>
    </div>
  </aside>

  <div class="ux-app__main">
    <header class="ux-topbar">
        <div class="ux-topbar__left">
          <button class="ux-topbar__back-btn" aria-label="Volver"
            data-on:click="history.length > 1 ? history.back() : null">
            <iconify-icon icon="lucide:arrow-left" width="2" height="2"></iconify-icon>
          </button>
        </div>
        <h1 class="ux-topbar__page-title">acme-prod · Módulos</h1>
        
        <div class="ux-topbar__search">
        <iconify-icon icon="lucide:search" width="14" height="14"></iconify-icon>
        <input placeholder="Buscar módulos…" data-bind:q/>
      </div>
        
        <div class="ux-topbar__actions">
          <span class="ux-avatar ux-avatar--sm ux-avatar--brand">IB</span>
        </div>
        <button class="ux-topbar__menu-btn" aria-label="Menú"
            data-on:click="$sidebar = !$sidebar"
            data-attr:aria-expanded="$sidebar">
            <iconify-icon icon="lucide:menu" width="2" height="2"></iconify-icon>
          </button>
      </header>

    <div class="ux-app__body">
      <div class="ux-page-header">
        <div class="ux-page-header__title">
          <h1>acme-prod · Módulos</h1>
          <div class="ux-page-header__sub">14 instalados · 87 disponibles en el marketplace</div>
        </div>
        <div class="ux-page-header__actions">
          <button class="ux-btn ux-btn--secondary ux-btn--sm">Marketplace</button>
          <button class="ux-btn ux-btn--primary ux-btn--sm">+ Instalar módulo</button>
        </div>
      </div>

      <!-- KPIs -->
      <div class="ux-grid-4 ux-mb-4">
        <div class="ux-kpi">
          <div class="ux-kpi__label">Total instalados</div>
          <div class="ux-kpi__value">14</div>
          <span class="ux-badge"><span class="ux-badge__dot"></span>+2 últimos 30 d</span>
        </div>
        <div class="ux-kpi">
          <div class="ux-kpi__label">Activos</div>
          <div class="ux-kpi__value">12</div>
          <span class="ux-badge ux-badge--ok"><span class="ux-badge__dot"></span>2 desactivados</span>
        </div>
        <div class="ux-kpi">
          <div class="ux-kpi__label">Actualizaciones</div>
          <div class="ux-kpi__value">3</div>
          <span class="ux-badge ux-badge--warn"><span class="ux-badge__dot"></span>disponibles</span>
        </div>
        <div class="ux-kpi">
          <div class="ux-kpi__label">Espacio usado</div>
          <div class="ux-kpi__value">1,4<span style="font-size:18px;color:var(--ux-ink-3);"> GB</span></div>
          <span class="ux-badge"><span class="ux-badge__dot"></span>de 10 GB</span>
        </div>
      </div>

      <!-- Tabs -->
      <div class="ux-tabs ux-mb-3" role="tablist">
        <button class="ux-tab" data-on:click="$tab = 'installed'" data-class:is-active="$tab === 'installed'" data-attr:aria-selected="$tab === 'installed' ? 'true' : 'false'">
          Instalados <span class="ux-tab-badge">14</span>
        </button>
        <button class="ux-tab" data-on:click="$tab = 'available'" data-class:is-active="$tab === 'available'" data-attr:aria-selected="$tab === 'available' ? 'true' : 'false'">
          Disponibles <span class="ux-tab-badge">87</span>
        </button>
        <button class="ux-tab" data-on:click="$tab = 'updates'" data-class:is-active="$tab === 'updates'" data-attr:aria-selected="$tab === 'updates' ? 'true' : 'false'">
          Actualizaciones <span class="ux-tab-badge">3</span>
        </button>
      </div>

      <!-- Category filter chips -->
      <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:18px;">
        <button class="ux-filter-chip" data-on:click="$cat = 'all'" data-class:is-active="$cat === 'all'">Todos</button>
        <button class="ux-filter-chip" data-on:click="$cat = 'core'" data-class:is-active="$cat === 'core'">Core</button>
        <button class="ux-filter-chip" data-on:click="$cat = 'verticales'" data-class:is-active="$cat === 'verticales'">Verticales</button>
        <button class="ux-filter-chip" data-on:click="$cat = 'sales'" data-class:is-active="$cat === 'sales'">Sales</button>
      </div>

      <!-- Module grid -->
      <div class="ux-grid-3">

        <!-- Module: POS -->
        <article class="ux-card" data-show="($tab === 'installed') && ($cat === 'all' || $cat === 'core') && ($q === '' || 'punto de venta tpv pos caja erplora core'.toLowerCase().includes($q.toLowerCase()))">
          <div class="ux-card__body ux-flex ux-col ux-gap-3">
            <div class="ux-flex ux-items-start ux-gap-3">
              <div class="modcard__icon" style="background:color-mix(in oklch, var(--ux-brand) 14%, var(--ux-bg-3));color:var(--ux-brand-3);">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="6" width="20" height="14" rx="2"/><path d="M2 10h20M6 15h2"/></svg>
              </div>
              <div class="ux-flex-1">
                <div class="ux-flex ux-wrap ux-items-center ux-gap-2">
                  <h3 class="ux-m-0 ux-font-display ux-text-base ux-font-semibold">Punto de venta</h3>
                  <span class="ux-badge ux-badge--ok"><span class="ux-badge__dot"></span>Instalado</span>
                </div>
                <div class="ux-text-2xs ux-c-ink-3 ux-mt-1">v3.4.1 · ERPlora Core</div>
              </div>
            </div>
            <p class="ux-text-sm ux-c-ink-2 ux-leading-normal ux-m-0">Caja registradora completa con soporte de turnos, devoluciones y reportes en tiempo real.</p>
            <div class="ux-flex ux-justify-between ux-items-center">
              <label class="ux-toggle"><input type="checkbox" data-bind:mod-pos checked/><span class="ux-toggle__track"></span></label>
              <button class="ux-btn ux-btn--ghost ux-btn--sm">Configurar</button>
            </div>
          </div>
        </article>

        <!-- Module: Stock -->
        <article class="ux-card" data-show="($tab === 'installed') && ($cat === 'all' || $cat === 'core') && ($q === '' || 'inventario stock almacen lotes caducidades erplora core'.toLowerCase().includes($q.toLowerCase()))">
          <div class="ux-card__body ux-flex ux-col ux-gap-3">
            <div class="ux-flex ux-items-start ux-gap-3">
              <div class="modcard__icon" style="background:color-mix(in oklch, var(--ux-leaf) 14%, var(--ux-bg-3));color:var(--ux-leaf);">
                <iconify-icon icon="lucide:package" width="2" height="2"></iconify-icon>
              </div>
              <div class="ux-flex-1">
                <div class="ux-flex ux-wrap ux-items-center ux-gap-2">
                  <h3 class="ux-m-0 ux-font-display ux-text-base ux-font-semibold">Inventario y stock</h3>
                  <span class="ux-badge ux-badge--ok"><span class="ux-badge__dot"></span>Instalado</span>
                </div>
                <div class="ux-text-2xs ux-c-ink-3 ux-mt-1">v2.8.0 · ERPlora Core</div>
              </div>
            </div>
            <p class="ux-text-sm ux-c-ink-2 ux-leading-normal ux-m-0">Control multi-almacén, transferencias, lotes y caducidades con alertas configurables.</p>
            <div class="ux-flex ux-justify-between ux-items-center">
              <label class="ux-toggle"><input type="checkbox" data-bind:mod-stock checked/><span class="ux-toggle__track"></span></label>
              <button class="ux-btn ux-btn--ghost ux-btn--sm">Configurar</button>
            </div>
          </div>
        </article>

        <!-- Module: Contabilidad -->
        <article class="ux-card" style="border-left:3px solid var(--ux-warn);" data-show="($tab === 'installed' || $tab === 'updates') && ($cat === 'all' || $cat === 'core') && ($q === '' || 'contabilidad plan general aeat modelo 303 390 erplora core'.toLowerCase().includes($q.toLowerCase()))">
          <div class="ux-card__body ux-flex ux-col ux-gap-3">
            <div class="ux-flex ux-items-start ux-gap-3">
              <div class="modcard__icon" style="background:color-mix(in oklch, var(--ux-info) 14%, var(--ux-bg-3));color:var(--ux-info);">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3v18h18"/><path d="M7 14l4-4 4 4 5-7"/></svg>
              </div>
              <div class="ux-flex-1">
                <div class="ux-flex ux-wrap ux-items-center ux-gap-2">
                  <h3 class="ux-m-0 ux-font-display ux-text-base ux-font-semibold">Contabilidad</h3>
                  <span class="ux-badge ux-badge--warn"><span class="ux-badge__dot"></span>Actualización</span>
                </div>
                <div class="ux-text-2xs ux-c-ink-3 ux-mt-1">v4.1.2 → 4.2.0 · ERPlora Core</div>
              </div>
            </div>
            <p class="ux-text-sm ux-c-ink-2 ux-leading-normal ux-m-0">Plan general adaptado a España. Modelo 303, 390 e integración con la AEAT.</p>
            <div class="ux-flex ux-justify-between ux-items-center">
              <label class="ux-toggle"><input type="checkbox" data-bind:mod-contabilidad checked/><span class="ux-toggle__track"></span></label>
              <button class="ux-btn ux-btn--secondary ux-btn--sm">Actualizar</button>
            </div>
          </div>
        </article>

        <!-- Module: Facturación -->
        <article class="ux-card" data-show="($tab === 'installed') && ($cat === 'all' || $cat === 'core') && ($q === '' || 'facturacion electronica verifactu facturae sii xml erplora core'.toLowerCase().includes($q.toLowerCase()))">
          <div class="ux-card__body ux-flex ux-col ux-gap-3">
            <div class="ux-flex ux-items-start ux-gap-3">
              <div class="modcard__icon" style="background:color-mix(in oklch, var(--ux-info) 14%, var(--ux-bg-3));color:var(--ux-info);">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6M16 13H8M16 17H8"/></svg>
              </div>
              <div class="ux-flex-1">
                <div class="ux-flex ux-wrap ux-items-center ux-gap-2">
                  <h3 class="ux-m-0 ux-font-display ux-text-base ux-font-semibold">Facturación electrónica</h3>
                  <span class="ux-badge ux-badge--ok"><span class="ux-badge__dot"></span>Instalado</span>
                </div>
                <div class="ux-text-2xs ux-c-ink-3 ux-mt-1">v1.9.4 · ERPlora Core</div>
              </div>
            </div>
            <p class="ux-text-sm ux-c-ink-2 ux-leading-normal ux-m-0">Verifactu, Facturae y SII. Validación XML automática y archivo legal 5 años.</p>
            <div class="ux-flex ux-justify-between ux-items-center">
              <label class="ux-toggle"><input type="checkbox" data-bind:mod-fac checked/><span class="ux-toggle__track"></span></label>
              <button class="ux-btn ux-btn--ghost ux-btn--sm">Configurar</button>
            </div>
          </div>
        </article>

        <!-- Module: RRHH -->
        <article class="ux-card" data-show="($tab === 'installed') && ($cat === 'all' || $cat === 'verticales') && ($q === '' || 'recursos humanos rrhh fichaje vacaciones nominas organigrama a3 sage erplora verticales'.toLowerCase().includes($q.toLowerCase()))">
          <div class="ux-card__body ux-flex ux-col ux-gap-3">
            <div class="ux-flex ux-items-start ux-gap-3">
              <div class="modcard__icon" style="background:color-mix(in oklch, var(--ux-warn) 14%, var(--ux-bg-3));color:var(--ux-warn);">
                <iconify-icon icon="lucide:user" width="2" height="2"></iconify-icon>
              </div>
              <div class="ux-flex-1">
                <div class="ux-flex ux-wrap ux-items-center ux-gap-2">
                  <h3 class="ux-m-0 ux-font-display ux-text-base ux-font-semibold">Recursos humanos</h3>
                  <span class="ux-badge ux-badge--ok"><span class="ux-badge__dot"></span>Instalado</span>
                </div>
                <div class="ux-text-2xs ux-c-ink-3 ux-mt-1">v2.3.0 · ERPlora Verticales</div>
              </div>
            </div>
            <p class="ux-text-sm ux-c-ink-2 ux-leading-normal ux-m-0">Fichaje, vacaciones, nóminas y organigrama. Integración con A3 y Sage.</p>
            <div class="ux-flex ux-justify-between ux-items-center">
              <label class="ux-toggle"><input type="checkbox" data-bind:mod-rrhh checked/><span class="ux-toggle__track"></span></label>
              <button class="ux-btn ux-btn--ghost ux-btn--sm">Configurar</button>
            </div>
          </div>
        </article>

        <!-- Module: Manufactura -->
        <article class="ux-card" style="border-left:3px solid var(--ux-warn);" data-show="($tab === 'installed' || $tab === 'updates') && ($cat === 'all' || $cat === 'verticales') && ($q === '' || 'manufactura ordenes fabricacion bom oee gantt erplora verticales'.toLowerCase().includes($q.toLowerCase()))">
          <div class="ux-card__body ux-flex ux-col ux-gap-3">
            <div class="ux-flex ux-items-start ux-gap-3">
              <div class="modcard__icon" style="background:color-mix(in oklch, var(--ux-info) 14%, var(--ux-bg-3));color:var(--ux-info);">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 20h20M5 20V8l5-4 5 4v12M14 12h6v8"/></svg>
              </div>
              <div class="ux-flex-1">
                <div class="ux-flex ux-wrap ux-items-center ux-gap-2">
                  <h3 class="ux-m-0 ux-font-display ux-text-base ux-font-semibold">Manufactura</h3>
                  <span class="ux-badge ux-badge--warn"><span class="ux-badge__dot"></span>Actualización</span>
                </div>
                <div class="ux-text-2xs ux-c-ink-3 ux-mt-1">v1.6.0 → 1.7.1 · ERPlora Verticales</div>
              </div>
            </div>
            <p class="ux-text-sm ux-c-ink-2 ux-leading-normal ux-m-0">Órdenes de fabricación, BOM, OEE y planificación con Gantt.</p>
            <div class="ux-flex ux-justify-between ux-items-center">
              <label class="ux-toggle"><input type="checkbox" data-bind:mod-manuf checked/><span class="ux-toggle__track"></span></label>
              <button class="ux-btn ux-btn--secondary ux-btn--sm">Actualizar</button>
            </div>
          </div>
        </article>

        <!-- Module: KDS -->
        <article class="ux-card" data-show="($tab === 'installed') && ($cat === 'all' || $cat === 'verticales') && ($q === '' || 'kitchen display kds cocina tickets erplora verticales'.toLowerCase().includes($q.toLowerCase()))">
          <div class="ux-card__body ux-flex ux-col ux-gap-3">
            <div class="ux-flex ux-items-start ux-gap-3">
              <div class="modcard__icon" style="background:color-mix(in oklch, var(--ux-leaf) 14%, var(--ux-bg-3));color:var(--ux-leaf);">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="14" rx="2"/><path d="M7 21h10M12 17v4"/></svg>
              </div>
              <div class="ux-flex-1">
                <div class="ux-flex ux-wrap ux-items-center ux-gap-2">
                  <h3 class="ux-m-0 ux-font-display ux-text-base ux-font-semibold">Kitchen Display (KDS)</h3>
                  <span class="ux-badge ux-badge--ok"><span class="ux-badge__dot"></span>Instalado</span>
                </div>
                <div class="ux-text-2xs ux-c-ink-3 ux-mt-1">v2.0.3 · ERPlora Verticales</div>
              </div>
            </div>
            <p class="ux-text-sm ux-c-ink-2 ux-leading-normal ux-m-0">Pantalla para cocina con tickets en tiempo real, prioridades y tiempos de servicio.</p>
            <div class="ux-flex ux-justify-between ux-items-center">
              <label class="ux-toggle"><input type="checkbox" data-bind:mod-kds checked/><span class="ux-toggle__track"></span></label>
              <button class="ux-btn ux-btn--ghost ux-btn--sm">Configurar</button>
            </div>
          </div>
        </article>

        <!-- Module: CRM (premium, not installed) -->
        <article class="ux-card" data-show="($tab === 'available') && ($cat === 'all' || $cat === 'sales') && ($q === '' || 'crm premium pipeline oportunidades clientes campañas ia sales'.toLowerCase().includes($q.toLowerCase()))">
          <div class="ux-card__body ux-flex ux-col ux-gap-3">
            <div class="ux-flex ux-items-start ux-gap-3">
              <div class="modcard__icon" style="background:color-mix(in oklch, var(--ux-brand) 14%, var(--ux-bg-3));color:var(--ux-brand-3);">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 11h-6M19 8v6"/></svg>
              </div>
              <div class="ux-flex-1">
                <div class="ux-flex ux-wrap ux-items-center ux-gap-2">
                  <h3 class="ux-m-0 ux-font-display ux-text-base ux-font-semibold">CRM Premium</h3>
                  <span class="ux-badge ux-badge--brand"><span class="ux-badge__dot"></span>Premium</span>
                </div>
                <div class="ux-text-2xs ux-c-ink-3 ux-mt-1">v3.0.0 · ERPlora Sales</div>
              </div>
            </div>
            <p class="ux-text-sm ux-c-ink-2 ux-leading-normal ux-m-0">Pipeline de oportunidades, segmentación de clientes y campañas con IA. <b>+19,90 €/mes</b>.</p>
            <div class="ux-flex ux-justify-between ux-items-center">
              <label class="ux-toggle"><input type="checkbox" data-bind:mod-crm/><span class="ux-toggle__track"></span></label>
              <button class="ux-btn ux-btn--primary ux-btn--sm">Instalar</button>
            </div>
          </div>
        </article>

        <!-- Module: Reservas -->
        <article class="ux-card" data-show="($tab === 'installed') && ($cat === 'all' || $cat === 'core') && ($q === '' || 'reservas citas calendario sms erplora core'.toLowerCase().includes($q.toLowerCase()))">
          <div class="ux-card__body ux-flex ux-col ux-gap-3">
            <div class="ux-flex ux-items-start ux-gap-3">
              <div class="modcard__icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
              </div>
              <div class="ux-flex-1">
