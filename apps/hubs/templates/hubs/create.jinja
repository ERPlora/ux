{% extends "_base_preview.html" %}

{% from "ui/button.jinja" import button %}
{% from "ui/badge.jinja" import badge %}
{% from "ui/card.jinja" import card, card_footer %}
{% from "ui/icon.jinja" import icon %}
{% from "ui/input.jinja" import input %}
{% from "ui/field.jinja" import field %}
{% from "ui/empty.jinja" import empty %}

{% block title %}ERPlora Cloud · Crear hub{% endblock %}

{% block head_extra %}
<style>
  body { background: var(--ux-bg); margin: 0; }
</style>
{% endblock %}

{% block body %}
<div class="ux-app" data-signals='{"sidebar": false, "slug": "acme-tienda-2", "valid": true, "htype": "prod", "region": "eu-west-1"}' data-attr:data-sidebar="$sidebar ? 'open' : ''">
  <div class="ux-app__sidebar-overlay" data-on:click="$sidebar = false"></div>

  <aside class="ux-sidebar">
    <div class="ux-sidebar__brand">
      <div class="ux-sidebar__logo">EC</div>
      <div class="ux-sidebar__brand-text">
        <div class="ux-sidebar__brand-name">ERPlora Cloud</div>
        <div class="ux-sidebar__brand-meta">acme · ES</div>
      </div>
    </div>
    <div class="ux-sidebar__body">
      <div class="ux-sidebar__group">Principal</div>
      <button class="ux-sidebar__item"><iconify-icon icon="lucide:layout-dashboard" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Vista general</span></button>
      <button class="ux-sidebar__item" aria-current="page"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><path d="M3.27 6.96 12 12.01l8.73-5.05M12 22.08V12"/></svg><span class="ux-sidebar__label">Hubs</span><span class="ux-sidebar__badge">7</span></button>
      <button class="ux-sidebar__item"><iconify-icon icon="lucide:building-2" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Organizaciones</span></button>
      <button class="ux-sidebar__item"><iconify-icon icon="lucide:user" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Usuarios</span></button>

      <div class="ux-sidebar__group">Facturación</div>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20M6 15h2"/></svg><span class="ux-sidebar__label">Facturas</span><span class="ux-sidebar__badge ux-sidebar__badge--brand">3</span></button>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4"/></svg><span class="ux-sidebar__label">Planes</span></button>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z"/><path d="M12 7v5l3 3"/></svg><span class="ux-sidebar__label">Uso y consumo</span></button>

      <div class="ux-sidebar__group">Desarrollador</div>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m16 18 6-6-6-6M8 6l-6 6 6 6"/></svg><span class="ux-sidebar__label">API Tokens</span></button>
      <button class="ux-sidebar__item"><iconify-icon icon="lucide:file-text" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Logs</span></button>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/></svg><span class="ux-sidebar__label">Webhooks</span></button>
    </div>
    <div class="ux-sidebar__footer">
      <div class="ux-sidebar__user">
        <span class="ux-avatar ux-avatar--sm ux-avatar--brand">IB</span>
        <div class="ux-sidebar__user-info">
          <div class="ux-sidebar__user-name">Ioan Beilic</div>
          <div class="ux-sidebar__user-meta">ioan@acme.com</div>
        </div>
      </div>
    </div>
  </aside>

  <div class="ux-app__main">
    <header class="ux-topbar">
        <div class="ux-topbar__left">
          <button class="ux-topbar__back-btn" aria-label="Volver"
            data-on:click="history.length > 1 ? history.back() : null">
            <iconify-icon icon="lucide:arrow-left" width="2" height="2"></iconify-icon>
          </button>
        </div>
        <h1 class="ux-topbar__page-title">Crear hub</h1>
        
        
        <div class="ux-topbar__actions">
          <button class="ux-icon-btn" aria-label="Notificaciones"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/></svg></button>
        <span class="ux-avatar ux-avatar--sm ux-avatar--brand">IB</span>
        </div>
        <button class="ux-topbar__menu-btn" aria-label="Menú"
            data-on:click="$sidebar = !$sidebar"
            data-attr:aria-expanded="$sidebar">
            <iconify-icon icon="lucide:menu" width="2" height="2"></iconify-icon>
          </button>
      </header>

    <div class="ux-app__body">
      <div class="ux-page-header">
        <div class="ux-page-header__title">
          <h1>Crear nuevo hub</h1>
          <div class="ux-page-header__sub">Paso 2 de 5 · Nombre y dominio</div>
        </div>
        <div class="ux-page-header__actions">
          <button class="ux-btn ux-btn--ghost ux-btn--sm">Cancelar</button>
          <button class="ux-btn ux-btn--secondary ux-btn--sm">Guardar borrador</button>
        </div>
      </div>

      <div class="ux-wizard ux-mb-4">
        <div class="ux-wizard__steps">
          <div class="ux-wizard__step ux-wizard__step--done">
            <div class="ux-wizard__step-num">✓</div>
            <div>
              <div class="ux-wizard__step-name">Organización</div>
              <div class="ux-wizard__step-sub">Acme Industries</div>
            </div>
          </div>
          <div class="ux-wizard__step ux-wizard__step--active">
            <div class="ux-wizard__step-num">2</div>
            <div>
              <div class="ux-wizard__step-name">Nombre y dominio</div>
              <div class="ux-wizard__step-sub">En curso</div>
            </div>
          </div>
          <div class="ux-wizard__step">
            <div class="ux-wizard__step-num">3</div>
            <div>
              <div class="ux-wizard__step-name">Plan</div>
              <div class="ux-wizard__step-sub">Pro · Enterprise</div>
            </div>
          </div>
          <div class="ux-wizard__step">
            <div class="ux-wizard__step-num">4</div>
            <div>
              <div class="ux-wizard__step-name">Módulos iniciales</div>
              <div class="ux-wizard__step-sub">POS · Stock · …</div>
            </div>
          </div>
          <div class="ux-wizard__step">
            <div class="ux-wizard__step-num">5</div>
            <div>
              <div class="ux-wizard__step-name">Pago</div>
              <div class="ux-wizard__step-sub">Confirmar</div>
            </div>
          </div>
        </div>

        <div class="ux-wizard__body">
          <div class="ux-row">

            <!-- LEFT: form -->
            <div class="ux-col-md-7 ux-col-lg-8">
              <h2 class="ux-wizard__title">Identifica tu nuevo hub</h2>
              <p class="ux-wizard__sub">Elige un nombre, un subdominio y la región donde se desplegará. Puedes añadir un dominio personalizado más adelante.</p>

              <div class="ux-form-section ux-mb-6">
                <div class="ux-form-row ux-row">
                  <label class="ux-field ux-col-md-6">
                    <span class="ux-field__label ux-field__label--req">Nombre del hub</span>
                    <input class="ux-input" value="Acme Tienda 2"/>
                    <span class="ux-field__hint">Visible en facturación y en el topbar.</span>
                  </label>
                  <label class="ux-field ux-col-md-6">
                    <span class="ux-field__label">Etiqueta interna</span>
                    <input class="ux-input" placeholder="opcional · ej. tienda-norte"/>
                    <span class="ux-field__hint">Solo visible para el equipo.</span>
                  </label>
                </div>
              </div>

              <div class="ux-form-section ux-mb-6">
                <label class="ux-field">
                  <span class="ux-field__label ux-field__label--req">Subdominio</span>
                  <div class="ux-input-group ux-input-group--with-left" style="display:flex;align-items:stretch;">
                    <input class="ux-input" data-bind:q="$slug" value="acme-tienda-2" style="border-top-right-radius:0;border-bottom-right-radius:0;"/>
                    <span class="ux-input-group__addon" style="border-top-left-radius:0;border-bottom-left-radius:0;">.erplora.cloud</span>
                  </div>
                  <span class="ux-field__hint" data-show="$valid" style="color:var(--ux-leaf);display:flex;align-items:center;gap:6px;">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M20 6 9 17l-5-5"/></svg>
                    Subdominio disponible
                  </span>
                  <span class="ux-field__error" data-show="!$valid">Subdominio ya en uso</span>
                </label>
              </div>

              <div class="ux-form-section ux-mb-6">
                <label class="ux-field">
                  <span class="ux-field__label">Dominio personalizado (opcional)</span>
                  <input class="ux-input" placeholder="ej. pos.acme.com"/>
                  <span class="ux-field__hint">Necesitarás añadir un registro CNAME apuntando a <code style="font-family:var(--ux-font-mono);background:var(--ux-bg-3);padding:1px 5px;border-radius:3px;font-size:11px;">cname.erplora.cloud</code>.</span>
                </label>
              </div>

              <div class="ux-form-section ux-mb-6">
                <label class="ux-field">
                  <span class="ux-field__label ux-field__label--req">Región</span>
                  <select class="ux-select" data-bind:q="$region">
                    <option value="eu-west-1">EU-West-1 · Irlanda (recomendado para España)</option>
                    <option value="eu-central-1">EU-Central-1 · Frankfurt</option>
                    <option value="eu-south-1">EU-South-1 · Milán</option>
                    <option value="us-east-1">US-East-1 · Virginia</option>
                    <option value="us-west-2">US-West-2 · Oregón</option>
                  </select>
                  <span class="ux-field__hint">La región no se puede cambiar tras la creación.</span>
                </label>
              </div>

              <div class="ux-form-section">
                <div class="ux-field__label ux-mb-2">Tipo de hub</div>
                <div class="ux-radio-group ux-row" style="gap:10px;">
                  <label class="ux-radio-card ux-col-md-6 ux-col-lg-4">
                    <input type="radio" name="htype" data-on:click="$htype = 'prod'" checked/>
                    <div>
                      <div class="ux-radio-card__title">Producción</div>
                      <div class="ux-radio-card__desc">SLA 99,9% · backups diarios · soporte 24h.</div>
                    </div>
                  </label>
                  <label class="ux-radio-card ux-col-md-6 ux-col-lg-4">
                    <input type="radio" name="htype" data-on:click="$htype = 'staging'"/>
                    <div>
                      <div class="ux-radio-card__title">Test / Staging</div>
                      <div class="ux-radio-card__desc">Entorno aislado para pruebas · sin SLA.</div>
                    </div>
                  </label>
                  <label class="ux-radio-card ux-col-md-6 ux-col-lg-4">
                    <input type="radio" name="htype" data-on:click="$htype = 'demo'"/>
                    <div>
                      <div class="ux-radio-card__title">Demo</div>
                      <div class="ux-radio-card__desc">Datos de ejemplo precargados · 30 días.</div>
                    </div>
                  </label>
                </div>
              </div>

            </div>

            <!-- RIGHT: preview & cost -->
            <aside class="ux-col-md-5 ux-col-lg-4 ux-col-sticky ux-flex ux-col ux-gap-4">
              <div class="ux-panel ux-panel--bordered">
                <div class="ux-panel__head">
                  <div class="ux-panel__head-text">
                    <div class="ux-panel__title">Vista previa de URL</div>
                    <div class="ux-panel__sub">Así verán el hub tus usuarios.</div>
                  </div>
                </div>
                <div class="ux-panel__body">
                  <div style="background:var(--ux-bg-1);border:1px solid var(--ux-line);border-radius:8px;padding:10px 12px;display:flex;align-items:center;gap:8px;font-family:var(--ux-font-mono);font-size:12px;">
                    <iconify-icon icon="lucide:lock" width="12" height="12"></iconify-icon>
                    <span class="ux-c-ink-3">https://</span><span style="color:var(--ux-brand-3);font-weight:600;" data-text="$slug">acme-tienda-2</span><span class="ux-c-ink-2">.erplora.cloud</span>
                  </div>
                  <div style="margin-top:10px;font-size:11px;color:var(--ux-ink-3);">
                    SSL automático · activo en menos de 2 minutos.
                  </div>
                </div>
              </div>

              <div class="ux-panel">
                <div class="ux-panel__head">
                  <div class="ux-panel__head-text">
                    <div class="ux-panel__title">Cambios estimados</div>
                    <div class="ux-panel__sub">Coste mensual del nuevo hub.</div>
                  </div>
                </div>
                <div class="ux-panel__body">
                  <div style="display:flex;flex-direction:column;gap:8px;font-size:13px;">
                    <div class="ux-flex ux-justify-between">
                      <span class="ux-c-ink-2">Plan Pro</span>
                      <span style="font-variant-numeric:tabular-nums;">49,00 €</span>
                    </div>
                    <div class="ux-flex ux-justify-between">
                      <span class="ux-c-ink-2">Terminales (1 incluido)</span>
                      <span style="font-variant-numeric:tabular-nums;color:var(--ux-leaf);">incluido</span>
                    </div>
                    <div class="ux-flex ux-justify-between">
                      <span class="ux-c-ink-2">Región EU-West-1</span>
                      <span style="font-variant-numeric:tabular-nums;color:var(--ux-leaf);">incluido</span>
                    </div>
                    <div class="ux-flex ux-justify-between">
                      <span class="ux-c-ink-2">Dominio personalizado</span>
                      <span style="font-variant-numeric:tabular-nums;">+ 4,00 €</span>
                    </div>
                    <div style="border-top:1px solid var(--ux-line);padding-top:10px;margin-top:6px;display:flex;justify-content:space-between;">
                      <span class="ux-font-semibold">Total mensual</span>
                      <span class="ux-font-display ux-text-lg ux-font-semibold ux-tabular">53,00 €</span>
                    </div>
                    <div class="ux-text-2xs ux-c-ink-3">IVA no incluido · facturación mensual.</div>
                  </div>
                </div>
              </div>

              <div class="ux-callout ux-callout--info ux-callout--compact">
                <span class="ux-callout__icon">
                  <iconify-icon icon="lucide:info" width="2" height="2"></iconify-icon>
                </span>
                <div class="ux-callout__body">
                  <div class="ux-callout__desc" style="font-size:12px;">El primer mes es gratuito. Puedes cancelar antes y no se cobrará nada.</div>
                </div>
              </div>
            </aside>

          </div>
        </div>

        <div class="ux-wizard__foot">
          <div class="ux-wizard__foot-meta">Paso 2 de 5 · acme-tienda-2.erplora.cloud</div>
          <div class="ux-wizard__foot-actions">
            <button class="ux-btn ux-btn--ghost">Atrás</button>
            <button class="ux-btn ux-btn--primary">Siguiente →</button>
          </div>
        </div>
      </div>

      <div style="height:32px;"></div>
    </div>
  </div>


  <!-- Bottom tab bar — mobile only via .ux-app__tabbar slot -->
  <nav class="ux-app__tabbar" aria-label="Navegación principal">
    <div class="ux-tabbar ux-tabbar--fixed ux-tabbar--icons">
      <a class="ux-tabbar-item" href="#" aria-current="page">
        <span class="ux-tabbar-icon"><iconify-icon icon="lucide:home" width="18" height="18"></iconify-icon></span>
        <span class="ux-tabbar-label">Inicio</span>
      </a>
      <a class="ux-tabbar-item" href="#">
        <span class="ux-tabbar-icon"><iconify-icon icon="lucide:credit-card" width="18" height="18"></iconify-icon></span>
        <span class="ux-tabbar-label">Hubs</span>
        <span class="ux-tabbar-badge">7</span>
      </a>
      <a class="ux-tabbar-item" href="#">
        <span class="ux-tabbar-icon"><iconify-icon icon="lucide:users" width="18" height="18"></iconify-icon></span>
        <span class="ux-tabbar-label">Usuarios</span>
      </a>
      <a class="ux-tabbar-item" href="#">
        <span class="ux-tabbar-icon"><iconify-icon icon="lucide:store" width="18" height="18"></iconify-icon></span>
        <span class="ux-tabbar-label">Equipo</span>
      </a>
      <a class="ux-tabbar-item" href="#">
        <span class="ux-tabbar-icon"><iconify-icon icon="lucide:user-circle" width="18" height="18"></iconify-icon></span>
        <span class="ux-tabbar-label">Perfil</span>
      </a>
    </div>
  </nav>
</div>
{% endblock %}
