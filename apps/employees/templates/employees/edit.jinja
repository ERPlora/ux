{% extends "_base_preview.html" %}

{% from "ui/button.jinja" import button %}
{% from "ui/badge.jinja" import badge %}
{% from "ui/card.jinja" import card, card_footer %}
{% from "ui/icon.jinja" import icon %}
{% from "ui/input.jinja" import input %}
{% from "ui/field.jinja" import field %}
{% from "ui/empty.jinja" import empty %}

{% block title %}Hub · Editar empleado{% endblock %}

{% block body %}
<div class="ux-app" id="app" data-tabbar="bottom" data-signals='{"sidebar": false}' data-attr:data-sidebar="$sidebar ? 'open' : ''">
  <aside class="ux-sidebar">
    <div class="ux-sidebar__brand">
      <div class="ux-sidebar__logo">LR</div>
      <div class="ux-sidebar__brand-text">
        <div class="ux-sidebar__brand-name">Cafetería La Rambla</div>
        <div class="ux-sidebar__brand-meta">5 empleados</div>
      </div>
    </div>
    <div class="ux-sidebar__body">
      <a class="ux-sidebar__item" href="#"><iconify-icon icon="lucide:layout-dashboard" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Inicio</span></a>
      <a class="ux-sidebar__item" aria-current="page" href="./employees-list.html"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="7" r="4"/><path d="M3 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/></svg><span class="ux-sidebar__label">Empleados</span></a>
      <a class="ux-sidebar__item" href="#"><iconify-icon icon="lucide:shield" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Roles</span></a>
    </div>
  </aside>

  <div class="ux-app__main">
    <header class="ux-topbar">
        <div class="ux-topbar__left">
          <button class="ux-topbar__back-btn" aria-label="Volver"
            data-on:click="history.length > 1 ? history.back() : null">
            <iconify-icon icon="lucide:arrow-left" width="2" height="2"></iconify-icon>
          </button>
        </div>
        <h1 class="ux-topbar__page-title">Página</h1>
        
        
        <button class="ux-topbar__menu-btn" aria-label="Menú"
            data-on:click="$sidebar = !$sidebar"
            data-attr:aria-expanded="$sidebar">
            <iconify-icon icon="lucide:menu" width="2" height="2"></iconify-icon>
          </button>
      </header>

    <div class="ux-app__body">
      <div class="ux-page-header">
        <div class="ux-page-header__title">
          <div class="ux-flex ux-items-center ux-gap-3">
            <span class="ux-avatar ux-avatar--lg">MR</span>
            <div>
              <h1>María Ruiz</h1>
              <div class="ux-page-header__sub">maria@larambla.es · Manager</div>
            </div>
          </div>
        </div>
        <div class="ux-page-header__actions">
          <a class="ux-btn ux-btn--ghost ux-btn--sm" href="./employees-list.html">Cancelar</a>
          <button class="ux-btn ux-btn--primary ux-btn--sm">Guardar cambios</button>
        </div>
      </div>

      <form class="ux-form" data-on:submit="event.preventDefault()" style="max-width:760px;">

        <div class="ux-form-section">
          <h3 class="ux-form-section__title">Información personal</h3>

          <div class="ux-form-row">
            <div class="ux-field">
              <label class="ux-field__label ux-field__label--req">Nombre completo</label>
              <input class="ux-input" value="María Ruiz"/>
            </div>
            <div class="ux-field">
              <label class="ux-field__label ux-field__label--req">Email</label>
              <input class="ux-input" type="email" value="maria@larambla.es"/>
            </div>
          </div>

          <div class="ux-form-row">
            <div class="ux-field">
              <label class="ux-field__label">Idioma de la interfaz</label>
              <select class="ux-select">
                <option>Català</option>
                <option selected>Español</option>
                <option>English</option>
              </select>
            </div>
            <div class="ux-field">
              <label class="ux-field__label">Rol</label>
              <select class="ux-select">
                <option>Admin</option>
                <option selected>Manager</option>
                <option>Cajero</option>
                <option>Cocinero</option>
              </select>
            </div>
          </div>

          <div class="ux-form-row">
            <div class="ux-field">
              <label class="ux-field__label">Foto de perfil</label>
              <div class="ux-flex ux-items-center ux-gap-3">
                <span class="ux-avatar ux-avatar--lg">MR</span>
                <label class="ux-btn ux-btn--secondary ux-btn--sm">
                  Cambiar foto
                  <input type="file" accept="image/*" hidden/>
                </label>
                <button type="button" class="ux-btn ux-btn--ghost ux-btn--sm">Eliminar</button>
              </div>
            </div>
          </div>
        </div>

        <div class="ux-form-section">
          <h3 class="ux-form-section__title">Estado de la cuenta</h3>

          <div class="ux-toggle-row">
            <div class="ux-toggle-row__text">
              <span class="ux-toggle-row__label">Cuenta activa</span>
              <span class="ux-toggle-row__desc">Si se desactiva, María no podrá iniciar sesión en el Hub.</span>
            </div>
            <label class="ux-toggle">
              <input type="checkbox" checked/>
              <span class="ux-toggle__track"></span>
            </label>
          </div>
        </div>

      </form>

      <!-- Zona peligro -->
      <article class="ux-card ux-card--danger" style="max-width:760px;margin-top:18px;border:1px solid var(--ux-danger);">
        <header class="ux-card__header" style="border-bottom:1px solid color-mix(in oklch, var(--ux-danger) 30%, transparent);">
          <h3 class="ux-card__title ux-c-danger">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-3px;margin-right:6px;"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            Zona peligro
          </h3>
        </header>
        <div class="ux-card__body">
          <div class="ux-flex ux-col ux-gap-3">
            <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;border-bottom:1px solid var(--ux-line);padding-bottom:12px;">
              <div>
                <div class="ux-font-medium">Restablecer PIN</div>
                <div class="ux-text-sm ux-c-ink-3">Genera un nuevo PIN aleatorio. María lo recibirá por email.</div>
              </div>
              <button class="ux-btn ux-btn--outline ux-btn--sm">Restablecer PIN</button>
            </div>

            <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;border-bottom:1px solid var(--ux-line);padding-bottom:12px;">
              <div>
                <div class="ux-font-medium">Cerrar todas las sesiones</div>
                <div class="ux-text-sm ux-c-ink-3">Cierra los 3 dispositivos donde María tiene la sesión abierta.</div>
              </div>
              <button class="ux-btn ux-btn--outline ux-btn--sm">Cerrar sesiones</button>
            </div>

            <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;">
              <div>
                <div style="font-weight:500;color:var(--ux-danger);">Eliminar empleado</div>
                <div class="ux-text-sm ux-c-ink-3">Borra permanentemente la cuenta y desvincula todos los registros. No se puede deshacer.</div>
              </div>
              <button class="ux-btn ux-btn--danger ux-btn--sm" data-on:click="$confirm = true">Eliminar empleado</button>
            </div>
          </div>
        </div>
      </article>

      <!-- Modal confirmar eliminación -->
      <div class="ux-modal-root" data-signals='{"confirm": false}' data-attr:data-state="$confirm ? 'open' : 'closed'" data-show="$confirm">
        <div class="ux-backdrop" data-on:click="$confirm = false"></div>
        <div class="ux-modal ux-modal--sm">
          <header class="ux-modal__header"><h3>¿Eliminar a María Ruiz?</h3></header>
          <div class="ux-modal__body">
            <p style="font-size:13.5px;margin:0 0 8px;">Se borrará la cuenta y se desvincularán los tickets y comandas que generó. Los registros históricos se conservarán como anónimos.</p>
            <p style="font-size:12.5px;color:var(--ux-ink-3);margin:0;">Esta acción no se puede deshacer.</p>
          </div>
          <footer class="ux-modal__footer">
            <button class="ux-btn ux-btn--ghost" data-on:click="$confirm = false">Cancelar</button>
            <button class="ux-btn ux-btn--danger">Sí, eliminar</button>
          </footer>
        </div>
      </div>
    </div>
  </div>

  <nav class="ux-tabbar ux-app__tabbar" aria-label="Navegación principal">
    <a class="ux-tabbar-item" href="#"><span class="ux-tabbar-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="9"/></svg></span><span class="ux-tabbar-label">Inicio</span></a>
    <a class="ux-tabbar-item" aria-current="page" href="#"><span class="ux-tabbar-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="7" r="4"/><path d="M3 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/></svg></span><span class="ux-tabbar-label">Empleados</span></a>
    <a class="ux-tabbar-item" href="#"><span class="ux-tabbar-icon"><iconify-icon icon="lucide:package" width="2" height="2"></iconify-icon></span><span class="ux-tabbar-label">Módulos</span></a>
    <a class="ux-tabbar-item" href="#"><span class="ux-tabbar-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"/></svg></span><span class="ux-tabbar-label">Facturas</span></a>
    <a class="ux-tabbar-item" href="#"><span class="ux-tabbar-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="5" cy="12" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="19" cy="12" r="1.5"/></svg></span><span class="ux-tabbar-label">Más</span></a>
  </nav>
</div>
{% endblock %}
