{% extends "_base_preview.html" %}

{% from "ui/button.jinja" import button %}
{% from "ui/badge.jinja" import badge %}
{% from "ui/card.jinja" import card, card_footer %}
{% from "ui/icon.jinja" import icon %}
{% from "ui/input.jinja" import input %}
{% from "ui/field.jinja" import field %}
{% from "ui/empty.jinja" import empty %}

{% block title %}Hub · Módulos{% endblock %}

{% block body %}
<div class="ux-app" id="app" data-tabbar="bottom" data-signals='{"sidebar": false}' data-attr:data-sidebar="$sidebar ? 'open' : ''">
  <aside class="ux-sidebar">
    <div class="ux-sidebar__brand">
      <div class="ux-sidebar__logo">LR</div>
      <div class="ux-sidebar__brand-text">
        <div class="ux-sidebar__brand-name">Cafetería La Rambla</div>
        <div class="ux-sidebar__brand-meta">8 módulos activos</div>
      </div>
    </div>
    <div class="ux-sidebar__body">
      <a class="ux-sidebar__item" href="#"><iconify-icon icon="lucide:layout-dashboard" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Inicio</span></a>
      <a class="ux-sidebar__item" href="#"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="7" r="4"/></svg><span class="ux-sidebar__label">Empleados</span></a>
      <a class="ux-sidebar__item" href="#"><iconify-icon icon="lucide:shield" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Roles</span></a>
      <a class="ux-sidebar__item" aria-current="page" href="#"><iconify-icon icon="lucide:package" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Módulos</span><span class="ux-sidebar__badge">8</span></a>
    </div>
  </aside>

  <div class="ux-app__main">
    <header class="ux-topbar">
        <div class="ux-topbar__left">
          <button class="ux-topbar__back-btn" aria-label="Volver"
            data-on:click="history.length > 1 ? history.back() : null">
            <iconify-icon icon="lucide:arrow-left" width="2" height="2"></iconify-icon>
          </button>
        </div>
        <h1 class="ux-topbar__page-title">Página</h1>
        
        
        <button class="ux-topbar__menu-btn" aria-label="Menú"
            data-on:click="$sidebar = !$sidebar"
            data-attr:aria-expanded="$sidebar">
            <iconify-icon icon="lucide:menu" width="2" height="2"></iconify-icon>
          </button>
      </header>

    <div class="ux-app__body" data-signals='{"tab": "active", "q": ""}'>
      <div class="ux-page-header">
        <div class="ux-page-header__title">
          <h1>Módulos del Hub</h1>
          <div class="ux-page-header__sub">8 instalados · 2 desactivados · 1 con error</div>
        </div>
        <div class="ux-page-header__actions">
          <button class="ux-btn ux-btn--secondary ux-btn--sm">Subir paquete</button>
          <a class="ux-btn ux-btn--primary ux-btn--sm" href="#">Ir al Marketplace</a>
        </div>
      </div>

      <!-- CTA Marketplace -->
      <div class="ux-banner ux-banner--brand ux-banner--inline ux-mb-4">
        <span class="ux-banner__icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3h18l-2 8H5L3 3z"/><path d="M5 11v9h14v-9"/></svg></span>
        <div class="ux-banner__body">
          <div class="ux-banner__title">Explora más módulos en el Marketplace</div>
          <div class="ux-banner__desc">Inventario avanzado, e-commerce, RRHH, contabilidad… 96 módulos disponibles para tu sector.</div>
        </div>
        <div class="ux-banner__actions">
          <button class="ux-banner__action ux-banner__action--primary">Ver Marketplace</button>
        </div>
      </div>

      <!-- Tabbar interno -->
      <div class="ux-tabs ux-mb-5" role="tablist">
        <button class="ux-tab" data-on:click="$tab = 'active'" data-attr:aria-selected="$tab === 'active'">
          <iconify-icon icon="lucide:check" width="2" height="2"></iconify-icon>
          Activos <span class="ux-tab-badge">8</span>
        </button>
        <button class="ux-tab" data-on:click="$tab = 'inactive'" data-attr:aria-selected="$tab === 'inactive'">
          <svg class="ux-tab-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
          Desactivados <span class="ux-tab-badge">2</span>
        </button>
        <button class="ux-tab" data-on:click="$tab = 'available'" data-attr:aria-selected="$tab === 'available'">
          <svg class="ux-tab-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Disponibles <span class="ux-tab-badge">88</span>
        </button>
      </div>

      <!-- Buscador -->
      <div style="margin-bottom:18px;max-width:380px;">
        <div class="ux-search">
          <svg class="ux-search__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>
          <input class="ux-input" placeholder="Buscar módulo (sales, pos, verifactu…)" data-bind:q/>
        </div>
      </div>

      <!-- Grid de módulos -->
      <div class="ux-grid-3" data-show="$tab === 'active'">
        <article class="ux-card">
          <div class="ux-card__body">
            <div class="ux-flex ux-items-start ux-gap-3">
              <div style="width:44px;height:44px;border-radius:10px;background:color-mix(in oklch, var(--ux-brand) 18%, transparent);color:var(--ux-brand);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3h18l-2 12H5L3 3z"/><circle cx="9" cy="20" r="1.5"/><circle cx="17" cy="20" r="1.5"/></svg>
              </div>
              <div class="ux-flex-1">
                <h3 style="font-family:var(--ux-font-display);font-size:15px;font-weight:600;margin:0;">Sales</h3>
                <div style="font-size:11.5px;color:var(--ux-ink-3);margin-top:2px;">ERPlora · v2.4.1</div>
                <span class="ux-badge ux-badge--ok ux-mt-1"><span class="ux-badge__dot"></span>Activo</span>
              </div>
              <label class="ux-toggle ux-toggle--sm">
                <input type="checkbox" checked/>
                <span class="ux-toggle__track"></span>
              </label>
            </div>
            <p style="font-size:13px;color:var(--ux-ink-3);margin:14px 0 0;line-height:1.45;">Motor universal de ventas. Tickets, pedidos, devoluciones, descuentos, tarifas.</p>
          </div>
          <footer class="ux-card__actions">
            <button class="ux-btn ux-btn--ghost ux-btn--sm">Configurar</button>
            <button class="ux-btn ux-btn--ghost ux-btn--sm ux-c-danger">Desinstalar</button>
          </footer>
        </article>

        <article class="ux-card">
          <div class="ux-card__body">
            <div class="ux-flex ux-items-start ux-gap-3">
              <div style="width:44px;height:44px;border-radius:10px;background:color-mix(in oklch, var(--ux-info) 18%, transparent);color:var(--ux-info);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M8 13h8M8 17h5"/></svg>
              </div>
              <div class="ux-flex-1">
                <h3 style="font-family:var(--ux-font-display);font-size:15px;font-weight:600;margin:0;">POS</h3>
                <div style="font-size:11.5px;color:var(--ux-ink-3);margin-top:2px;">ERPlora · v1.9.3</div>
                <span class="ux-badge ux-badge--ok ux-mt-1"><span class="ux-badge__dot"></span>Activo</span>
              </div>
              <label class="ux-toggle ux-toggle--sm"><input type="checkbox" checked/><span class="ux-toggle__track"></span></label>
            </div>
            <p style="font-size:13px;color:var(--ux-ink-3);margin:14px 0 0;line-height:1.45;">Terminal punto de venta para hostelería y retail. KDS, comandero, caja.</p>
          </div>
          <footer class="ux-card__actions">
            <button class="ux-btn ux-btn--ghost ux-btn--sm">Configurar</button>
            <button class="ux-btn ux-btn--ghost ux-btn--sm ux-c-danger">Desinstalar</button>
          </footer>
        </article>

        <article class="ux-card">
          <div class="ux-card__body">
            <div class="ux-flex ux-items-start ux-gap-3">
              <div style="width:44px;height:44px;border-radius:10px;background:color-mix(in oklch, var(--ux-leaf) 18%, transparent);color:var(--ux-leaf);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="7" r="4"/><path d="M3 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/></svg>
              </div>
              <div class="ux-flex-1">
                <h3 style="font-family:var(--ux-font-display);font-size:15px;font-weight:600;margin:0;">Employees</h3>
                <div style="font-size:11.5px;color:var(--ux-ink-3);margin-top:2px;">ERPlora · v1.4.0 · system</div>
                <span class="ux-badge ux-badge--ok ux-mt-1"><span class="ux-badge__dot"></span>Activo</span>
              </div>
              <label class="ux-toggle ux-toggle--sm"><input type="checkbox" checked disabled/><span class="ux-toggle__track"></span></label>
            </div>
            <p style="font-size:13px;color:var(--ux-ink-3);margin:14px 0 0;line-height:1.45;">Gestión de empleados, fichajes, turnos, vacaciones. Módulo del sistema.</p>
          </div>
          <footer class="ux-card__actions">
            <button class="ux-btn ux-btn--ghost ux-btn--sm">Configurar</button>
            <span class="ux-pill" style="margin-left:auto;">Sistema</span>
          </footer>
        </article>

        <article class="ux-card">
          <div class="ux-card__body">
            <div class="ux-flex ux-items-start ux-gap-3">
              <div style="width:44px;height:44px;border-radius:10px;background:color-mix(in oklch, var(--ux-brand) 18%, transparent);color:var(--ux-brand);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
              </div>
              <div class="ux-flex-1">
                <h3 style="font-family:var(--ux-font-display);font-size:15px;font-weight:600;margin:0;">Verifactu ES</h3>
                <div style="font-size:11.5px;color:var(--ux-ink-3);margin-top:2px;">ERPlora · v0.8.2</div>
                <span class="ux-badge ux-badge--ok ux-mt-1"><span class="ux-badge__dot"></span>Activo</span>
              </div>
              <label class="ux-toggle ux-toggle--sm"><input type="checkbox" checked/><span class="ux-toggle__track"></span></label>
            </div>
            <p style="font-size:13px;color:var(--ux-ink-3);margin:14px 0 0;line-height:1.45;">Cumplimiento Verifactu / AEAT. Remisión automática de facturas a Hacienda.</p>
          </div>
          <footer class="ux-card__actions">
            <button class="ux-btn ux-btn--ghost ux-btn--sm">Configurar</button>
            <button class="ux-btn ux-btn--ghost ux-btn--sm ux-c-danger">Desinstalar</button>
          </footer>
        </article>

        <article class="ux-card">
          <div class="ux-card__body">
            <div class="ux-flex ux-items-start ux-gap-3">
              <div style="width:44px;height:44px;border-radius:10px;background:color-mix(in oklch, var(--ux-warn) 18%, transparent);color:var(--ux-warn);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <iconify-icon icon="lucide:package" width="22" height="22"></iconify-icon>
              </div>
              <div class="ux-flex-1">
                <h3 style="font-family:var(--ux-font-display);font-size:15px;font-weight:600;margin:0;">Inventory</h3>
                <div style="font-size:11.5px;color:var(--ux-ink-3);margin-top:2px;">ERPlora · v3.0.0-beta.4</div>
                <span class="ux-badge ux-badge--danger ux-mt-1"><span class="ux-badge__dot"></span>Error de migración</span>
              </div>
              <label class="ux-toggle ux-toggle--sm"><input type="checkbox" checked/><span class="ux-toggle__track"></span></label>
            </div>
            <p style="font-size:13px;color:var(--ux-ink-3);margin:14px 0 0;line-height:1.45;">Stock, almacenes, lotes y trazabilidad. <b class="ux-c-danger">Falta migración 3.0.0.</b></p>
          </div>
          <footer class="ux-card__actions">
            <button class="ux-btn ux-btn--ghost ux-btn--sm">Ver log</button>
            <button class="ux-btn ux-btn--primary ux-btn--sm">Reintentar migración</button>
          </footer>
        </article>

        <article class="ux-card">
          <div class="ux-card__body">
            <div class="ux-flex ux-items-start ux-gap-3">
              <div style="width:44px;height:44px;border-radius:10px;background:color-mix(in oklch, var(--ux-info) 18%, transparent);color:var(--ux-info);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <iconify-icon icon="lucide:menu" width="22" height="22"></iconify-icon>
              </div>
              <div class="ux-flex-1">
                <h3 style="font-family:var(--ux-font-display);font-size:15px;font-weight:600;margin:0;">Orders</h3>
                <div style="font-size:11.5px;color:var(--ux-ink-3);margin-top:2px;">ERPlora · v1.2.5</div>
                <span class="ux-badge ux-badge--ok ux-mt-1"><span class="ux-badge__dot"></span>Activo</span>
              </div>
              <label class="ux-toggle ux-toggle--sm"><input type="checkbox" checked/><span class="ux-toggle__track"></span></label>
            </div>
            <p style="font-size:13px;color:var(--ux-ink-3);margin:14px 0 0;line-height:1.45;">Pedidos web, delivery, recogida y reservas integradas con sales.</p>
          </div>
          <footer class="ux-card__actions">
            <button class="ux-btn ux-btn--ghost ux-btn--sm">Configurar</button>
            <button class="ux-btn ux-btn--ghost ux-btn--sm ux-c-danger">Desinstalar</button>
          </footer>
        </article>
      </div>

      <div class="ux-grid-3 ux-hidden" data-show="$tab === 'inactive'">
        <article class="ux-card ux-opacity-70">
          <div class="ux-card__body">
            <div class="ux-flex ux-items-start ux-gap-3">
              <div style="width:44px;height:44px;border-radius:10px;background:var(--ux-bg-3);color:var(--ux-ink-3);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 11l18-6-3 18-6-7-9-5z"/></svg>
              </div>
              <div class="ux-flex-1">
                <h3 style="font-family:var(--ux-font-display);font-size:15px;font-weight:600;margin:0;">WhatsApp Inbox</h3>
                <div style="font-size:11.5px;color:var(--ux-ink-3);margin-top:2px;">ERPlora · v0.5.1</div>
                <span class="ux-badge ux-mt-1"><span class="ux-badge__dot"></span>Desactivado</span>
              </div>
              <label class="ux-toggle ux-toggle--sm"><input type="checkbox"/><span class="ux-toggle__track"></span></label>
            </div>
          </div>
        </article>
      </div>

      <div data-show="$tab === 'available'" style="display:none;text-align:center;padding:40px;">
        <p class="ux-c-ink-3">Ir al Marketplace para instalar nuevos módulos.</p>
        <button class="ux-btn ux-btn--primary ux-mt-3">Abrir Marketplace</button>
      </div>
    </div>
  </div>

  <nav class="ux-tabbar ux-app__tabbar" aria-label="Navegación principal">
    <a class="ux-tabbar-item" href="#"><span class="ux-tabbar-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="9"/></svg></span><span class="ux-tabbar-label">Inicio</span></a>
    <a class="ux-tabbar-item" href="#"><span class="ux-tabbar-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="7" r="4"/></svg></span><span class="ux-tabbar-label">Empleados</span></a>
    <a class="ux-tabbar-item" aria-current="page" href="#"><span class="ux-tabbar-icon"><iconify-icon icon="lucide:package" width="2" height="2"></iconify-icon></span><span class="ux-tabbar-label">Módulos</span></a>
    <a class="ux-tabbar-item" href="#"><span class="ux-tabbar-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"/></svg></span><span class="ux-tabbar-label">Facturas</span></a>
    <a class="ux-tabbar-item" href="#"><span class="ux-tabbar-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="5" cy="12" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="19" cy="12" r="1.5"/></svg></span><span class="ux-tabbar-label">Más</span></a>
  </nav>
</div>
{% endblock %}
