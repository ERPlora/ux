{% extends "_base_preview.html" %}

{% from "ui/button.jinja" import button %}
{% from "ui/badge.jinja" import badge %}
{% from "ui/card.jinja" import card, card_footer %}
{% from "ui/icon.jinja" import icon %}
{% from "ui/input.jinja" import input %}
{% from "ui/field.jinja" import field %}
{% from "ui/empty.jinja" import empty %}

{% block title %}ERPlora Cloud · Subir nuevo módulo{% endblock %}

{% block head_extra %}
<style>
  body { background: var(--ux-bg); margin: 0; }
</style>
{% endblock %}

{% block body %}
<div class="ux-app" data-signals='{"sidebar": false, "source": "github"}' data-attr:data-sidebar="$sidebar ? 'open' : ''">
  <div class="ux-app__sidebar-overlay" data-on:click="$sidebar = false"></div>

  <aside class="ux-sidebar">
    <div class="ux-sidebar__brand">
      <div class="ux-sidebar__logo">EX</div>
      <div class="ux-sidebar__brand-text">
        <div class="ux-sidebar__brand-name">ERPlora Cloud</div>
        <div class="ux-sidebar__brand-meta">Developer portal</div>
      </div>
    </div>
    <div class="ux-sidebar__body">
      <div class="ux-sidebar__group">Principal</div>
      <button class="ux-sidebar__item"><iconify-icon icon="lucide:layout-dashboard" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Vista general</span></button>
      <button class="ux-sidebar__item"><iconify-icon icon="lucide:building-2" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Organizaciones</span></button>
      <button class="ux-sidebar__item"><iconify-icon icon="lucide:package" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Hubs</span><span class="ux-sidebar__badge">7</span></button>
      <button class="ux-sidebar__item"><iconify-icon icon="lucide:user" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Usuarios</span></button>

      <div class="ux-sidebar__group">Facturación</div>
      <button class="ux-sidebar__item"><iconify-icon icon="lucide:file-text" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Facturas</span></button>
      <button class="ux-sidebar__item"><iconify-icon icon="lucide:menu" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Suscripciones</span></button>

      <div class="ux-sidebar__group is-active">Developer</div>
      <button class="ux-sidebar__item" aria-current="page"><iconify-icon icon="lucide:code" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Módulos</span><span class="ux-sidebar__badge">12</span></button>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg><span class="ux-sidebar__label">Repositorios</span></button>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 17l10 5 10-5M2 12l10 5 10-5M12 2 2 7l10 5 10-5z"/></svg><span class="ux-sidebar__label">Stripe Connect</span><span class="ux-sidebar__badge ux-sidebar__badge--leaf">OK</span></button>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6M16 13H8M16 17H8"/></svg><span class="ux-sidebar__label">Documentación</span></button>
    </div>
    <div class="ux-sidebar__footer">
      <div class="ux-sidebar__user">
        <span class="ux-avatar ux-avatar--sm ux-avatar--brand">IB</span>
        <div class="ux-sidebar__user-info">
          <div class="ux-sidebar__user-name">Ioan Beilic</div>
          <div class="ux-sidebar__user-meta">developer · @ioanb</div>
        </div>
      </div>
    </div>
  </aside>

  <div class="ux-app__main">
    <header class="ux-topbar">
        <div class="ux-topbar__left">
          <button class="ux-topbar__back-btn" aria-label="Volver"
            data-on:click="history.length > 1 ? history.back() : null">
            <iconify-icon icon="lucide:arrow-left" width="2" height="2"></iconify-icon>
          </button>
        </div>
        <h1 class="ux-topbar__page-title">Subir nuevo módulo</h1>
        
        
        <div class="ux-topbar__actions">
          <button class="ux-icon-btn" aria-label="Notificaciones"><iconify-icon icon="lucide:bell" width="14" height="14"></iconify-icon></button>
        <span class="ux-avatar ux-avatar--sm ux-avatar--brand">IB</span>
        </div>
        <button class="ux-topbar__menu-btn" aria-label="Menú"
            data-on:click="$sidebar = !$sidebar"
            data-attr:aria-expanded="$sidebar">
            <iconify-icon icon="lucide:menu" width="2" height="2"></iconify-icon>
          </button>
      </header>

    <div class="ux-app__body">
      <div class="ux-page-header">
        <div class="ux-page-header__title">
          <h1>Subir nuevo módulo</h1>
          <div class="ux-page-header__sub">Publica un módulo en el marketplace de ERPlora · disponible para 1 240 hubs</div>
        </div>
        <div class="ux-page-header__actions">
          <button class="ux-btn ux-btn--ghost">Cancelar</button>
        </div>
      </div>

      <div class="ux-wizard ux-mb-4">
        <div class="ux-wizard__steps">
          <div class="ux-wizard__step ux-wizard__step--active">
            <span class="ux-wizard__step-num">1</span>
            <div>
              <div class="ux-wizard__step-name">Origen</div>
              <div class="ux-wizard__step-sub">ZIP · GitHub · marketplace</div>
            </div>
          </div>
          <div class="ux-wizard__step">
            <span class="ux-wizard__step-num">2</span>
            <div>
              <div class="ux-wizard__step-name">Información</div>
              <div class="ux-wizard__step-sub">Nombre, slug, categoría</div>
            </div>
          </div>
          <div class="ux-wizard__step">
            <span class="ux-wizard__step-num">3</span>
            <div>
              <div class="ux-wizard__step-name">Detalles</div>
              <div class="ux-wizard__step-sub">Descripción, screenshots</div>
            </div>
          </div>
          <div class="ux-wizard__step">
            <span class="ux-wizard__step-num">4</span>
            <div>
              <div class="ux-wizard__step-name">Precio</div>
              <div class="ux-wizard__step-sub">Plan & comisión Stripe</div>
            </div>
          </div>
          <div class="ux-wizard__step">
            <span class="ux-wizard__step-num">5</span>
            <div>
              <div class="ux-wizard__step-name">Revisión</div>
              <div class="ux-wizard__step-sub">Confirmar y publicar</div>
            </div>
          </div>
        </div>
      </div>

      <div class="ux-row">
        <div class="ux-col-md-7 ux-col-lg-8">
          <article class="ux-card">
            <header class="ux-card__header">
              <div>
                <div class="ux-card__title">Origen del módulo</div>
                <div class="ux-card__sub">Elige cómo quieres importar tu módulo</div>
              </div>
            </header>
            <div class="ux-card__body" style="display:grid;grid-template-columns:1fr;gap:10px;">
              <label class="ux-radio-card">
                <input type="radio" name="src" data-on:change="$source = 'zip'"/>
                <div class="ux-flex ux-items-start ux-gap-3">
                  <span class="ux-app-icon ux-app-icon--info" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
                  </span>
                  <div>
                    <div class="ux-font-medium">Subir ZIP</div>
                    <div class="ux-text-sm ux-c-ink-3">Sube un archivo ZIP que contenga el manifest.yml, el código fuente y los assets. Tamaño máximo 50 MB.</div>
                  </div>
                </div>
              </label>

              <label class="ux-radio-card" style="border-color:var(--ux-brand);background:var(--ux-brand-soft);">
                <input type="radio" name="src" checked data-on:change="$source = 'github'"/>
                <div class="ux-flex ux-items-start ux-gap-3">
                  <span class="ux-app-icon ux-app-icon--brand" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
                  </span>
                  <div>
                    <div class="ux-font-medium">Conectar GitHub <span class="ux-badge ux-badge--brand ux-badge--sm">Recomendado</span></div>
                    <div class="ux-text-sm ux-c-ink-3">Sincroniza desde un repositorio. Cada push a la rama configurada genera una versión automática.</div>
                  </div>
                </div>
              </label>

              <label class="ux-radio-card">
                <input type="radio" name="src" data-on:change="$source = 'mp'"/>
                <div class="ux-flex ux-items-start ux-gap-3">
                  <span class="ux-app-icon ux-app-icon--leaf" aria-hidden="true">
                    <iconify-icon icon="lucide:package" width="2" height="2"></iconify-icon>
                  </span>
                  <div>
                    <div class="ux-font-medium">Importar desde marketplace existente</div>
                    <div class="ux-text-sm ux-c-ink-3">Clona un módulo público del marketplace como punto de partida. Puedes modificarlo y publicarlo bajo tu marca.</div>
                  </div>
                </div>
              </label>
            </div>
          </article>

          <article class="ux-card ux-mt-3" data-show="$source === 'github'">
            <header class="ux-card__header">
              <div>
                <div class="ux-card__title">Conectar repositorio GitHub</div>
                <div class="ux-card__sub">Acceso instalado · ERPlora-app · 3 repos sincronizados</div>
              </div>
              <a href="#" style="font-size:12.5px;color:var(--ux-info);">Ya conectado: 3 repos →</a>
            </header>
            <div class="ux-card__body">
              <div class="ux-form-row">
                <label class="ux-field">
                  <span class="ux-field__label">Organización / usuario</span>
                  <select class="ux-select">
                    <option>ioanb</option>
                    <option>erplora-developer</option>
                    <option>nordenbikes</option>
                  </select>
                </label>
                <label class="ux-field">
                  <span class="ux-field__label">Repositorio</span>
                  <select class="ux-select">
                    <option>pos-caja-pro</option>
                    <option>contabilidad-plus</option>
                    <option>sepa-recon</option>
                    <option>inventario-multi</option>
                  </select>
                </label>
              </div>
              <div class="ux-form-row ux-mt-2">
                <label class="ux-field">
                  <span class="ux-field__label">Rama</span>
                  <select class="ux-select">
                    <option>main</option>
                    <option>release</option>
                    <option>v3.x</option>
                  </select>
                </label>
                <label class="ux-field">
                  <span class="ux-field__label">Ruta del manifest</span>
                  <input class="ux-input" value="/erplora.yml"/>
                </label>
              </div>
              <div style="margin-top:14px;display:flex;flex-direction:column;gap:10px;">
                <label class="ux-toggle-row">
                  <span>
                    <strong>Auto-sync on push</strong>
                    <div class="ux-text-xs ux-c-ink-3">Genera una nueva versión cuando llegue un push a <code>main</code>.</div>
                  </span>
                  <span class="ux-toggle"><input type="checkbox" checked/><span class="ux-toggle__track"><span class="ux-toggle__thumb"></span></span></span>
                </label>
                <label class="ux-toggle-row">
                  <span>
                    <strong>Crear release como pre-release</strong>
                    <div class="ux-text-xs ux-c-ink-3">Visible solo para hubs con beta-channel activado.</div>
                  </span>
                  <span class="ux-toggle"><input type="checkbox"/><span class="ux-toggle__track"><span class="ux-toggle__thumb"></span></span></span>
                </label>
                <label class="ux-toggle-row">
                  <span>
                    <strong>Verificar firma GPG</strong>
                    <div class="ux-text-xs ux-c-ink-3">Solo permite tags firmados.</div>
                  </span>
                  <span class="ux-toggle"><input type="checkbox" checked/><span class="ux-toggle__track"><span class="ux-toggle__thumb"></span></span></span>
                </label>
              </div>
              <div class="ux-callout ux-callout--ok ux-callout--compact ux-mt-3">
                <div class="ux-callout__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg></div>
                <div class="ux-callout__body">
                  <div class="ux-callout__title">Manifest detectado</div>
                  <div class="ux-callout__desc">erplora.yml válido · v3.2.1 · POS · 14 archivos · 2.1 MB</div>
                </div>
              </div>
              <div style="margin-top:10px;font-size:12px;color:var(--ux-ink-3);display:flex;gap:14px;">
                <span>Última sincronización: <strong class="ux-c-ink-2">hace 4 min</strong></span>
                <span>Commit: <code class="ux-c-info">a8b2f1c</code></span>
                <span>Autor: <strong class="ux-c-ink-2">@ioanb</strong></span>
              </div>
            </div>
          </article>

          <article class="ux-card ux-mt-3" data-show="$source === 'zip'" data-style="display:none;">
            <header class="ux-card__header">
              <div class="ux-card__title">Subir archivo ZIP</div>
            </header>
            <div class="ux-card__body">
              <div class="ux-dropzone">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:32px;height:32px;color:var(--ux-ink-3);"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
                <div style="font-weight:500;margin-top:8px;">Arrastra el archivo aquí o haz clic para seleccionar</div>
                <div class="ux-text-xs ux-c-ink-3">ZIP · máx 50 MB · debe contener erplora.yml</div>
                <button class="ux-btn ux-btn--outline ux-btn--sm ux-mt-2">Seleccionar archivo</button>
              </div>
            </div>
          </article>

          <article class="ux-card ux-mt-3" data-show="$source === 'mp'" data-style="display:none;">
            <header class="ux-card__header">
              <div class="ux-card__title">Importar desde marketplace</div>
            </header>
            <div class="ux-card__body">
              <div class="ux-search">
                <svg class="ux-search__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>
                <input class="ux-input" placeholder="Buscar módulos públicos…"/>
              </div>
              <div style="margin-top:14px;color:var(--ux-ink-3);font-size:13px;">Selecciona un módulo de la lista para clonarlo bajo tu cuenta.</div>
            </div>
          </article>
        </div>

        <div class="ux-col-md-5 ux-col-lg-4 ux-col-sticky">
          <article class="ux-card">
            <header class="ux-card__header">
              <div>
                <div class="ux-card__title">Vista previa</div>
                <div class="ux-card__sub">Cómo se verá en el marketplace</div>
              </div>
              <span class="ux-badge">Borrador</span>
            </header>
            <div class="ux-card__body">
              <div style="border:1px dashed var(--ux-line);border-radius:12px;padding:16px;background:var(--ux-bg-1);">
                <div style="display:flex;gap:12px;align-items:center;margin-bottom:10px;">
                  <span class="ux-avatar ux-avatar--xl" style="background:#7B3F2A;color:#fff;border-radius:14px;">P</span>
                  <div>
                    <div style="font-weight:600;font-size:16px;">POS Caja Registradora Pro</div>
                    <div class="ux-text-xs ux-c-ink-3">@ioanb · POS · v3.2.1</div>
                  </div>
                </div>
                <div style="font-size:13px;color:var(--ux-ink-2);line-height:1.55;">
                  TPV completo con caja registradora, gestión de turnos, integración con cajón de monedas, impresora térmica ESC/POS y facturación electrónica TicketBAI / Verifactu.
                </div>
                <div style="display:flex;gap:6px;margin-top:10px;flex-wrap:wrap;">
                  <span class="ux-tag ux-tag--neutral ux-tag--sm">tpv</span>
                  <span class="ux-tag ux-tag--neutral ux-tag--sm">caja</span>
                  <span class="ux-tag ux-tag--neutral ux-tag--sm">verifactu</span>
                  <span class="ux-tag ux-tag--neutral ux-tag--sm">ticketbai</span>
                </div>
                <div style="display:flex;justify-content:space-between;align-items:center;margin-top:14px;padding-top:14px;border-top:1px solid var(--ux-line);">
                  <div>
                    <div class="ux-overline">Precio</div>
                    <div style="font-size:18px;font-weight:600;">€29 <span style="font-size:11px;font-weight:400;color:var(--ux-ink-3);">/mes</span></div>
                  </div>
                  <button class="ux-btn ux-btn--primary ux-btn--sm">Instalar</button>
                </div>
              </div>
              <div style="font-size:11.5px;color:var(--ux-ink-3);margin-top:10px;text-align:center;">
                La vista previa se actualizará automáticamente cuando completes los pasos 2 y 3.
              </div>
            </div>
            <footer class="ux-card__footer">
              <span class="ux-text-xs ux-c-ink-3">Borrador autoguardado · 14:32</span>
              <button class="ux-btn ux-btn--ghost ux-btn--sm">Guardar borrador</button>
            </footer>
          </article>
        </div>
      </div>

      <div class="ux-toolbar ux-toolbar--sticky" style="margin-top:18px;justify-content:flex-end;gap:8px;">
        <span style="font-size:12px;color:var(--ux-ink-3);margin-right:auto;">Paso 1 de 5 · Origen</span>
        <button class="ux-btn ux-btn--ghost" disabled>Atrás</button>
        <button class="ux-btn ux-btn--primary">Siguiente →</button>
      </div>
    </div>
  </div>


  <!-- Bottom tab bar — mobile only via .ux-app__tabbar slot -->
  <nav class="ux-app__tabbar" aria-label="Navegación principal">
    <div class="ux-tabbar ux-tabbar--fixed ux-tabbar--icons">
      <a class="ux-tabbar-item" href="#" aria-current="page">
        <span class="ux-tabbar-icon"><iconify-icon icon="lucide:home" width="18" height="18"></iconify-icon></span>
        <span class="ux-tabbar-label">Inicio</span>
      </a>
      <a class="ux-tabbar-item" href="#">
        <span class="ux-tabbar-icon"><iconify-icon icon="lucide:credit-card" width="18" height="18"></iconify-icon></span>
        <span class="ux-tabbar-label">Hubs</span>
        <span class="ux-tabbar-badge">7</span>
      </a>
      <a class="ux-tabbar-item" href="#">
        <span class="ux-tabbar-icon"><iconify-icon icon="lucide:users" width="18" height="18"></iconify-icon></span>
        <span class="ux-tabbar-label">Usuarios</span>
      </a>
      <a class="ux-tabbar-item" href="#">
        <span class="ux-tabbar-icon"><iconify-icon icon="lucide:store" width="18" height="18"></iconify-icon></span>
        <span class="ux-tabbar-label">Equipo</span>
      </a>
      <a class="ux-tabbar-item" href="#">
        <span class="ux-tabbar-icon"><iconify-icon icon="lucide:user-circle" width="18" height="18"></iconify-icon></span>
        <span class="ux-tabbar-label">Perfil</span>
      </a>
    </div>
  </nav>
</div>
{% endblock %}
