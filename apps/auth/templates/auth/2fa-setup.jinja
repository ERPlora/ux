            <button class="ux-btn ux-btn--outline ux-btn--sm" data-on:click="$showSecret = !$showSecret" data-text="$showSecret ? 'Ocultar clave manual' : 'Mostrar clave manual'">Mostrar clave manual</button>
          </div>
          <div class="cloud-secret ux-mt-1" data-show="$showSecret">
            <span>JBSW Y3DP EHPK 3PXP K7AB QXFR</span>
            <button class="ux-btn ux-btn--ghost ux-btn--sm">Copiar</button>
          </div>
        </div>
      </div>

      <div class="ux-card">
        <div class="ux-card__header">
          <div>
            <h2 class="ux-card__title">Pasos a seguir</h2>
            <p class="ux-card__sub">Necesitarás una app autenticadora compatible con TOTP</p>
          </div>
        </div>
        <div class="ux-card__body">
          <div class="cloud-instructions">

            <div class="cloud-step">
              <div class="cloud-step__num">1</div>
              <div>
                <div class="cloud-step__title">Instala una app autenticadora</div>
                <div class="cloud-step__desc">Recomendamos <strong>Google Authenticator</strong>, <strong>1Password</strong>, <strong>Authy</strong> o <strong>Microsoft Authenticator</strong>. Disponibles en iOS y Android.</div>
              </div>
            </div>

            <div class="cloud-step">
              <div class="cloud-step__num">2</div>
              <div>
                <div class="cloud-step__title">Escanea el código QR</div>
                <div class="cloud-step__desc">Abre la app y toca el botón <strong>+</strong> para añadir una nueva cuenta. Apunta la cámara al QR de la izquierda.</div>
                <div class="cloud-secret">
                  <span>JBSW Y3DP EHPK 3PXP K7AB QXFR</span>
                  <button class="ux-btn ux-btn--ghost ux-btn--sm">Copiar</button>
                </div>
              </div>
            </div>

          </div>
        </div>
      </div>

    </section>

    <!-- STEP 3: Verify -->
    <section class="ux-section" data-show="$step === 3">
      <div class="ux-card" style="max-width:520px;margin:0 auto;">
        <div class="ux-card__header">
          <div>
            <h2 class="ux-card__title">Verifica con un código de 6 dígitos</h2>
            <p class="ux-card__sub">Introduce el código que aparece en tu app autenticadora.</p>
          </div>
        </div>
        <div class="ux-card__body">
          <div class="ux-otp" role="group" aria-label="Código de verificación">
            <input class="ux-otp__cell" maxlength="1" inputmode="numeric"/>
            <input class="ux-otp__cell" maxlength="1" inputmode="numeric"/>
            <input class="ux-otp__cell" maxlength="1" inputmode="numeric"/>
            <span class="ux-otp__sep">·</span>
            <input class="ux-otp__cell" maxlength="1" inputmode="numeric"/>
            <input class="ux-otp__cell" maxlength="1" inputmode="numeric"/>
            <input class="ux-otp__cell" maxlength="1" inputmode="numeric"/>
          </div>
        </div>
      </div>
    </section>

    <!-- STEP 4: Backup codes -->
    <section class="ux-section" data-show="$step === 4">
      <div class="ux-section__head">
        <div>
          <div class="ux-section__title">Códigos de respaldo</div>
          <div class="ux-section__sub">Úsalos cuando no tengas acceso a tu app autenticadora. Cada código es de un solo uso.</div>
        </div>
      </div>

      <div class="ux-card">
        <div class="ux-card__header">
          <div>
