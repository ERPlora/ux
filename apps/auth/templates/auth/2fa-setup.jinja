{% extends "_base_preview.html" %}

{% from "ui/button.jinja" import button %}
{% from "ui/badge.jinja" import badge %}
{% from "ui/card.jinja" import card, card_footer %}
{% from "ui/icon.jinja" import icon %}
{% from "ui/input.jinja" import input %}
{% from "ui/field.jinja" import field %}
{% from "ui/empty.jinja" import empty %}

{% block title %}ERPlora Cloud · Activar 2FA{% endblock %}

{% block head_extra %}
<style>
body { background: var(--ux-bg); margin: 0; }
  .cloud-shell { min-height: 100vh; }
  .cloud-codes {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
    font-family: var(--ux-font-mono);
    font-size: var(--ux-text-sm);
  }
  .cloud-code {
    padding: 8px 10px;
    background: var(--ux-bg-1);
    border: 1px solid var(--ux-line);
    border-radius: var(--ux-radius-sm);
    color: var(--ux-ink);
    letter-spacing: 0.06em;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }
  .cloud-code__num { color: var(--ux-ink-4); font-size: var(--ux-text-xs); }
  .cloud-instructions { display: flex; flex-direction: column; gap: 14px; }
  .cloud-step { display: grid; grid-template-columns: 28px 1fr; gap: 12px; }
  .cloud-step__num {
    width: 26px; height: 26px; border-radius: 50%;
    background: var(--ux-brand-soft); color: var(--ux-brand-3);
    display: grid; place-items: center;
    font-family: var(--ux-font-display);
    font-weight: 600; font-size: 13px;
  }
  .cloud-step__title { font-weight: 500; color: var(--ux-ink); font-size: var(--ux-text-md); }
  .cloud-step__desc { font-size: var(--ux-text-xs); color: var(--ux-ink-3); margin-top: 2px; line-height: 1.5; }
  .cloud-secret {
    margin-top: 8px; padding: 8px 10px;
    background: var(--ux-bg-1);
    border: 1px solid var(--ux-line);
    border-radius: var(--ux-radius-sm);
    font-family: var(--ux-font-mono);
    font-size: var(--ux-text-sm);
    color: var(--ux-ink);
    letter-spacing: 0.04em;
    display: flex; align-items: center; justify-content: space-between; gap: 8px;
  }
  .qr-pattern rect { fill: #111; }
</style>
{% endblock %}

{% block body %}
<div class="ux-app cloud-shell" data-signals='{"sidebar": false}' data-attr:data-sidebar="$sidebar ? 'open' : ''">
<div class="ux-app__sidebar-overlay" data-on:click="$sidebar = false"></div>

<aside class="ux-sidebar">
  <div class="ux-sidebar__brand">
    <div class="ux-sidebar__logo">EX</div>
    <div class="ux-sidebar__brand-text">
      <div class="ux-sidebar__brand-name">ERPlora Cloud</div>
      <div class="ux-sidebar__brand-meta">Acme Industries</div>
    </div>
  </div>
  <div class="ux-sidebar__body">
    <div class="ux-sidebar__group">Principal</div>
    <a class="ux-sidebar__item" href="#"><iconify-icon icon="lucide:layout-dashboard" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Resumen</span></a>
    <a class="ux-sidebar__item" href="#"><iconify-icon icon="lucide:building-2" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Organizaciones</span></a>
    <a class="ux-sidebar__item" href="#"><iconify-icon icon="lucide:credit-card" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Hubs</span><span class="ux-sidebar__badge">7</span></a>
    <a class="ux-sidebar__item" href="#"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="7" r="4"/><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/></svg><span class="ux-sidebar__label">Usuarios</span></a>
    <a class="ux-sidebar__item" href="#"><iconify-icon icon="lucide:layers" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Equipamiento</span></a>
    <div class="ux-sidebar__group">Facturación</div>
    <a class="ux-sidebar__item" href="#"><iconify-icon icon="lucide:file-text" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Facturas</span></a>
    <a class="ux-sidebar__item" href="#"><iconify-icon icon="lucide:refresh-ccw" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Suscripciones</span></a>
    <a class="ux-sidebar__item" href="#"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="6" width="20" height="12" rx="2"/><path d="M2 10h20"/></svg><span class="ux-sidebar__label">Pagos</span></a>
    <div class="ux-sidebar__group">Cuenta</div>
    <a class="ux-sidebar__item" href="#" aria-current="page"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V7a4 4 0 1 1 8 0v4"/></svg><span class="ux-sidebar__label">Seguridad</span></a>
    <a class="ux-sidebar__item" href="#"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 21a8 8 0 0 1 16 0"/></svg><span class="ux-sidebar__label">Mi perfil</span></a>
  </div>
  <div class="ux-sidebar__footer">
    <div class="ux-sidebar__user">
      <span class="ux-avatar ux-avatar--sm ux-avatar--brand">IB</span>
      <div class="ux-sidebar__user-info">
        <div class="ux-sidebar__user-name">Ioan Beilic</div>
        <div class="ux-sidebar__user-meta">ioan@acme.com</div>
      </div>
    </div>
  </div>
</aside>

<div class="ux-app__main">

  <header class="ux-topbar">
        <div class="ux-topbar__left">
          <button class="ux-topbar__back-btn" aria-label="Volver"
            data-on:click="history.length > 1 ? history.back() : null">
            <iconify-icon icon="lucide:arrow-left" width="2" height="2"></iconify-icon>
          </button>
        </div>
        <h1 class="ux-topbar__page-title">Activar 2FA</h1>
        
        <div class="ux-topbar__search">
      <span class="ux-search__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg></span>
      <input type="search" placeholder="Buscar hubs, módulos, facturas…"/>
      <span class="ux-topbar__kbd">⌘K</span>
    </div>
        
        <div class="ux-topbar__actions">
          <button class="ux-icon-btn"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg></button>
      <span class="ux-avatar ux-avatar--sm ux-avatar--brand">IB</span>
        </div>
        <button class="ux-topbar__menu-btn" aria-label="Menú"
            data-on:click="$sidebar = !$sidebar"
            data-attr:aria-expanded="$sidebar">
            <iconify-icon icon="lucide:menu" width="2" height="2"></iconify-icon>
          </button>
      </header>

  <nav class="ux-tabs" aria-label="Sub-secciones de seguridad 2FA">
    <a class="ux-tab" href="2fa-setup.html" aria-current="page">Configurar 2FA</a>
    <a class="ux-tab" href="2fa-profile.html">Gestionar 2FA</a>
    <a class="ux-tab" href="2fa-disable.html">Desactivar 2FA</a>
  </nav>

  <div class="ux-app__body" data-signals='{"step": 2, "showSecret": false, "codesSaved": false}'>

    <!-- Stepper -->
    <div class="ux-stepper-progress" style="margin-bottom: var(--ux-space-5);">
      <span class="ux-stepper-progress__label" data-text="'Paso ' + $step + ' de 4'">Paso 2 de 4</span>
      <div class="ux-stepper-progress__bar">
        <div class="ux-stepper-progress__seg" data-class:ux-stepper-progress__seg--done="$step > 1" data-class:ux-stepper-progress__seg--active="$step === 1"></div>
        <div class="ux-stepper-progress__seg" data-class:ux-stepper-progress__seg--done="$step > 2" data-class:ux-stepper-progress__seg--active="$step === 2"></div>
        <div class="ux-stepper-progress__seg" data-class:ux-stepper-progress__seg--done="$step > 3" data-class:ux-stepper-progress__seg--active="$step === 3"></div>
        <div class="ux-stepper-progress__seg" data-class:ux-stepper-progress__seg--done="$step > 4" data-class:ux-stepper-progress__seg--active="$step === 4"></div>
      </div>
      <span class="ux-stepper-progress__step" data-text="$step === 1 ? 'Instalar app · QR escaneado · Verificado · Códigos guardados' : ($step === 2 ? 'Activado · QR escaneado · Verificado · Códigos guardados' : ($step === 3 ? 'Activado · QR escaneado · Verificado · Códigos guardados' : 'Activado · QR escaneado · Verificado · Códigos guardados'))">Activado · <strong class="ux-c-ink">QR escaneado</strong> · Verificado · Códigos guardados</span>
    </div>

    <!-- Header -->
    <header class="ux-page-header">
      <div class="ux-page-header__title">
        <h1>Activar verificación en dos pasos</h1>
        <p class="ux-page-header__sub">Añade una capa extra de seguridad a tu cuenta de ERPlora Cloud.</p>
      </div>
      <div class="ux-page-header__actions">
        <button class="ux-btn ux-btn--ghost" data-show="$step <= 1">Cancelar</button>
        <button class="ux-btn ux-btn--ghost" data-show="$step > 1" data-on:click="$step = Math.max(1, $step - 1)">
          <iconify-icon icon="lucide:arrow-left" width="2" height="2"></iconify-icon>
          Atrás
        </button>
        <button class="ux-btn ux-btn--primary"
          data-on:click="$step = Math.min(4, $step + 1)"
          data-show="$step < 4">
          Continuar
          <svg class="ux-btn__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </button>
        <button class="ux-btn ux-btn--primary" data-show="$step === 4" data-attr:disabled="!$codesSaved">
          Activar 2FA
          <svg class="ux-btn__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>
        </button>
      </div>
    </header>

    <!-- STEP 1: Install authenticator app -->
    <section class="ux-section" data-show="$step === 1">
      <div class="ux-card">
        <div class="ux-card__header">
          <div>
            <h2 class="ux-card__title">Instala una app autenticadora</h2>
            <p class="ux-card__sub">Necesitarás una app compatible con TOTP en tu móvil.</p>
          </div>
        </div>
        <div class="ux-card__body">
          <p style="margin:0 0 12px;color:var(--ux-ink-2);">Recomendamos cualquiera de estas opciones gratuitas:</p>
          <ul class="ux-list">
            <li class="ux-list__item"><div class="ux-list__body"><div class="ux-list__title">Google Authenticator</div><div class="ux-list__desc">iOS y Android</div></div></li>
            <li class="ux-list__item"><div class="ux-list__body"><div class="ux-list__title">1Password</div><div class="ux-list__desc">Multiplataforma</div></div></li>
            <li class="ux-list__item"><div class="ux-list__body"><div class="ux-list__title">Authy</div><div class="ux-list__desc">iOS, Android y Desktop</div></div></li>
            <li class="ux-list__item"><div class="ux-list__body"><div class="ux-list__title">Microsoft Authenticator</div><div class="ux-list__desc">iOS y Android</div></div></li>
          </ul>
        </div>
      </div>
    </section>

    <!-- STEP 2: Two-column QR + steps -->
    <section class="ux-grid-2" style="margin-bottom: var(--ux-space-6); align-items: start;" data-show="$step === 2">

      <div class="ux-card">
        <div class="ux-card__header">
          <div>
            <h2 class="ux-card__title">Escanea el código QR</h2>
            <p class="ux-card__sub">Apunta tu app autenticadora al QR</p>
          </div>
          <div class="ux-card__actions">
            <span class="ux-badge ux-badge--brand"><span class="ux-badge__dot"></span>TOTP</span>
          </div>
        </div>
        <div class="ux-card__body" style="display:grid;place-items:center;padding:24px;">
          <div class="ux-qr ux-qr--lg ux-qr--bordered">
            <div class="ux-qr__img">
              <svg class="qr-pattern" viewBox="0 0 25 25" shape-rendering="crispEdges" xmlns="http://www.w3.org/2000/svg">
                <!-- Position markers -->
                <rect x="0" y="0" width="7" height="7"/>
                <rect x="1" y="1" width="5" height="5" fill="#fff"/>
                <rect x="2" y="2" width="3" height="3"/>
                <rect x="18" y="0" width="7" height="7"/>
                <rect x="19" y="1" width="5" height="5" fill="#fff"/>
                <rect x="20" y="2" width="3" height="3"/>
                <rect x="0" y="18" width="7" height="7"/>
                <rect x="1" y="19" width="5" height="5" fill="#fff"/>
                <rect x="2" y="20" width="3" height="3"/>
                <!-- Random data modules -->
                <rect x="9" y="0" width="1" height="1"/><rect x="11" y="0" width="1" height="1"/><rect x="12" y="0" width="1" height="1"/><rect x="14" y="0" width="1" height="1"/><rect x="16" y="0" width="1" height="1"/>
                <rect x="9" y="2" width="1" height="1"/><rect x="10" y="2" width="1" height="1"/><rect x="13" y="2" width="1" height="1"/><rect x="15" y="2" width="1" height="1"/>
                <rect x="8" y="3" width="1" height="1"/><rect x="11" y="3" width="1" height="1"/><rect x="14" y="3" width="1" height="1"/><rect x="16" y="3" width="1" height="1"/>
                <rect x="9" y="4" width="1" height="1"/><rect x="10" y="4" width="1" height="1"/><rect x="12" y="4" width="1" height="1"/><rect x="13" y="4" width="1" height="1"/><rect x="15" y="4" width="1" height="1"/><rect x="16" y="4" width="1" height="1"/>
