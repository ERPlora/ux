{% extends "_base_preview.html" %}

{% from "ui/button.jinja" import button %}
{% from "ui/badge.jinja" import badge %}
{% from "ui/card.jinja" import card, card_footer %}
{% from "ui/icon.jinja" import icon %}
{% from "ui/input.jinja" import input %}
{% from "ui/field.jinja" import field %}
{% from "ui/empty.jinja" import empty %}

{% block title %}ERPlora Cloud · Dispositivos de confianza{% endblock %}

{% block head_extra %}
<style>
body { background: var(--ux-bg); margin: 0; }
</style>
{% endblock %}

{% block body %}
<div class="ux-app" id="app" data-tabbar="bottom" data-signals='{"sidebar": false, "revokedOpen": false}' data-attr:data-sidebar="$sidebar ? 'open' : ''">
  <div class="ux-app__sidebar-overlay" data-on:click="$sidebar = false"></div>

  <aside class="ux-sidebar">
    <div class="ux-sidebar__brand">
      <div class="ux-sidebar__logo">EC</div>
      <div class="ux-sidebar__brand-text">
        <div class="ux-sidebar__brand-name">ERPlora Cloud</div>
        <div class="ux-sidebar__brand-meta">acme · Madrid</div>
      </div>
    </div>
    <div class="ux-sidebar__body">
      <div class="ux-sidebar__group">Main</div>
      <button class="ux-sidebar__item"><iconify-icon icon="lucide:layout-dashboard" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Vista general</span></button>
      <button class="ux-sidebar__item"><iconify-icon icon="lucide:building-2" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Organizaciones</span><span class="ux-sidebar__badge">4</span></button>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 21v-1a8 8 0 0 1 16 0v1"/></svg><span class="ux-sidebar__label">Mi perfil</span></button>
      <button class="ux-sidebar__item" aria-current="page"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/></svg><span class="ux-sidebar__label">Seguridad</span></button>

      <div class="ux-sidebar__group">Billing</div>
      <button class="ux-sidebar__item"><iconify-icon icon="lucide:credit-card" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Plan & facturación</span></button>
      <button class="ux-sidebar__item"><iconify-icon icon="lucide:file-text" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Facturas</span><span class="ux-sidebar__badge ux-sidebar__badge--brand">2</span></button>
      <button class="ux-sidebar__item"><iconify-icon icon="lucide:clock" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Uso & cuotas</span></button>

      <div class="ux-sidebar__group">Developer</div>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m16 18 6-6-6-6M8 6l-6 6 6 6"/></svg><span class="ux-sidebar__label">API & tokens</span></button>
      <button class="ux-sidebar__item"><iconify-icon icon="lucide:package" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Webhooks</span></button>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 17v-6a4 4 0 0 1 4-4h12M20 7l-3-3M20 7l-3 3"/></svg><span class="ux-sidebar__label">Audit log</span></button>
    </div>
    <div class="ux-sidebar__footer">
      <div class="ux-sidebar__user">
        <span class="ux-avatar ux-avatar--sm ux-avatar--brand">IB</span>
        <div class="ux-sidebar__user-info">
          <div class="ux-sidebar__user-name">Ioan Beilic</div>
          <div class="ux-sidebar__user-meta">ioan@acme.com</div>
        </div>
      </div>
    </div>
  </aside>

  <div class="ux-app__main">
    <header class="ux-topbar">
        <div class="ux-topbar__left">
          <button class="ux-topbar__back-btn" aria-label="Volver"
            data-on:click="history.length > 1 ? history.back() : null">
            <iconify-icon icon="lucide:arrow-left" width="2" height="2"></iconify-icon>
          </button>
        </div>
        <h1 class="ux-topbar__page-title">Dispositivos de confianza</h1>
        
        <div class="ux-topbar__search">
        <iconify-icon icon="lucide:search" width="14" height="14"></iconify-icon>
        <input placeholder="Buscar en cuenta…"/>
        <span class="ux-topbar__kbd">⌘K</span>
      </div>
        
        <div class="ux-topbar__actions">
          <button class="ux-icon-btn" aria-label="Notificaciones"><iconify-icon icon="lucide:bell" width="14" height="14"></iconify-icon></button>
        <span class="ux-avatar ux-avatar--sm ux-avatar--brand">IB</span>
        </div>
        <button class="ux-topbar__menu-btn" aria-label="Menú"
            data-on:click="$sidebar = !$sidebar"
            data-attr:aria-expanded="$sidebar">
            <iconify-icon icon="lucide:menu" width="2" height="2"></iconify-icon>
          </button>
      </header>

    <nav class="ux-tabs" aria-label="Sub-secciones de seguridad de cuenta">
      <a class="ux-tab" href="change-password.html">Contraseña</a>
      <a class="ux-tab" href="sessions.html">Sesiones</a>
      <a class="ux-tab" href="trusted-devices.html" aria-current="page">Dispositivos</a>
      <a class="ux-tab" href="delete-account.html">Eliminar cuenta</a>
    </nav>

    <div class="ux-app__body">
      <div class="ux-page-header">
        <div class="ux-page-header__title">
          <h1>Dispositivos de confianza</h1>
          <div class="ux-page-header__sub">Equipos que pueden saltarse el 2FA durante 30 días tras una verificación válida.</div>
        </div>
        <div class="ux-page-header__actions">
          <span class="ux-text-xs ux-c-ink-3">Hasta 5 dispositivos · usa 3</span>
          <button class="ux-btn ux-btn--outline">
            <iconify-icon icon="lucide:plus" width="14" height="14"></iconify-icon>
            Añadir dispositivo
          </button>
        </div>
      </div>

      <div class="ux-callout ux-callout--info ux-mb-6">
        <span class="ux-callout__icon"><iconify-icon icon="lucide:info" width="14" height="14"></iconify-icon></span>
        <div class="ux-callout__body">
          <div class="ux-callout__title">Solo equipos personales</div>
          <div class="ux-callout__desc">Los dispositivos de confianza pueden saltarse el 2FA durante 30 días. No marques como confiable un equipo prestado o compartido.</div>
        </div>
      </div>

      <div class="ux-grid-3" style="margin-bottom:32px;">

        <article class="ux-card">
          <div class="ux-card__body ux-flex ux-col ux-gap-3">
            <div class="ux-flex ux-items-start ux-gap-3">
              <div style="width:44px;height:44px;border-radius:var(--ux-radius-md);background:var(--ux-brand-soft);color:var(--ux-brand-3);display:grid;place-items:center;flex-shrink:0;">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="13" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
              </div>
              <div class="ux-flex-1">
                <strong class="ux-text-md">MacBook Pro M4</strong>
                <div style="color:var(--ux-ink-3);font-size:var(--ux-text-sm);">Madrid · oficina</div>
                <span class="ux-badge ux-badge--ok ux-mt-1"><span class="ux-badge__dot"></span>Activo</span>
              </div>
            </div>

            <div style="display:flex;flex-direction:column;gap:6px;font-size:var(--ux-text-xs);color:var(--ux-ink-3);">
              <div class="ux-flex ux-justify-between"><span>Sistema</span><span class="ux-c-ink-2">macOS 15.4 · Chrome 142</span></div>
              <div class="ux-flex ux-justify-between"><span>Fingerprint</span><span style="color:var(--ux-ink-2);font-family:var(--ux-font-mono);font-size:11px;">a4:9c:21:fb…</span></div>
              <div class="ux-flex ux-justify-between"><span>Confiado desde</span><span class="ux-c-ink-2">12 abr 2026</span></div>
              <div class="ux-flex ux-justify-between"><span>Expira en</span><span class="ux-c-leaf">18 días</span></div>
              <div class="ux-flex ux-justify-between"><span>Última conexión</span><span class="ux-c-ink-2">hace 12 min</span></div>
            </div>
          </div>
          <footer class="ux-card__actions" style="display:flex;gap:8px;padding-top:0;">
            <button class="ux-btn ux-btn--outline ux-btn--sm ux-flex-1">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 1 1-3-6.7L21 8"/><path d="M21 3v5h-5"/></svg>
              Renovar 30 d
            </button>
            <button class="ux-btn ux-btn--ghost ux-btn--danger ux-btn--sm ux-flex-1">Revocar</button>
          </footer>
        </article>

        <article class="ux-card" style="border-color:color-mix(in oklch, var(--ux-warn) 40%, var(--ux-line));border-left-color:var(--ux-warn);border-left-width:3px;">
          <div class="ux-card__body ux-flex ux-col ux-gap-3">
            <div class="ux-flex ux-items-start ux-gap-3">
              <div style="width:44px;height:44px;border-radius:var(--ux-radius-md);background:color-mix(in oklch, var(--ux-warn) 18%, transparent);color:var(--ux-warn);display:grid;place-items:center;flex-shrink:0;">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="6" y="2" width="12" height="20" rx="2"/><path d="M11 18h2"/></svg>
              </div>
              <div class="ux-flex-1">
                <strong class="ux-text-md">iPhone 16 Pro</strong>
                <div style="color:var(--ux-ink-3);font-size:var(--ux-text-sm);">Personal · llevamos siempre</div>
                <span class="ux-badge ux-badge--warn ux-mt-1"><span class="ux-badge__dot"></span>Expira en 2 días</span>
              </div>
            </div>

            <div style="display:flex;flex-direction:column;gap:6px;font-size:var(--ux-text-xs);color:var(--ux-ink-3);">
              <div class="ux-flex ux-justify-between"><span>Sistema</span><span class="ux-c-ink-2">iOS 18.4 · ERPlora App 4.8.2</span></div>
              <div class="ux-flex ux-justify-between"><span>Fingerprint</span><span style="color:var(--ux-ink-2);font-family:var(--ux-font-mono);font-size:11px;">b1:38:d7:9e…</span></div>
              <div class="ux-flex ux-justify-between"><span>Confiado desde</span><span class="ux-c-ink-2">8 abr 2026</span></div>
              <div class="ux-flex ux-justify-between"><span>Expira en</span><span class="ux-c-warn ux-font-semibold">2 días · 10 may</span></div>
              <div class="ux-flex ux-justify-between"><span>Última conexión</span><span class="ux-c-ink-2">hace 1 h</span></div>
            </div>
          </div>
          <footer class="ux-card__actions" style="display:flex;gap:8px;padding-top:0;">
            <button class="ux-btn ux-btn--primary ux-btn--sm ux-flex-1">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 1 1-3-6.7L21 8"/><path d="M21 3v5h-5"/></svg>
              Renovar 30 d
            </button>
            <button class="ux-btn ux-btn--ghost ux-btn--danger ux-btn--sm ux-flex-1">Revocar</button>
          </footer>
        </article>

        <article class="ux-card">
          <div class="ux-card__body ux-flex ux-col ux-gap-3">
            <div class="ux-flex ux-items-start ux-gap-3">
              <div style="width:44px;height:44px;border-radius:var(--ux-radius-md);background:var(--ux-bg-3);color:var(--ux-ink-2);display:grid;place-items:center;flex-shrink:0;">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="2" width="16" height="20" rx="2"/><path d="M11 19h2"/></svg>
              </div>
              <div class="ux-flex-1">
                <strong class="ux-text-md">iPad Air</strong>
                <div style="color:var(--ux-ink-3);font-size:var(--ux-text-sm);">Oficina · sala de reuniones</div>
                <span class="ux-badge ux-badge--ok ux-mt-1"><span class="ux-badge__dot"></span>Activo</span>
              </div>
            </div>

            <div style="display:flex;flex-direction:column;gap:6px;font-size:var(--ux-text-xs);color:var(--ux-ink-3);">
              <div class="ux-flex ux-justify-between"><span>Sistema</span><span class="ux-c-ink-2">iPadOS 18.3 · Safari 18</span></div>
              <div class="ux-flex ux-justify-between"><span>Fingerprint</span><span style="color:var(--ux-ink-2);font-family:var(--ux-font-mono);font-size:11px;">7d:f0:4a:c8…</span></div>
              <div class="ux-flex ux-justify-between"><span>Confiado desde</span><span class="ux-c-ink-2">22 abr 2026</span></div>
              <div class="ux-flex ux-justify-between"><span>Expira en</span><span class="ux-c-leaf">28 días</span></div>
              <div class="ux-flex ux-justify-between"><span>Última conexión</span><span class="ux-c-ink-2">hace 2 días</span></div>
            </div>
          </div>
          <footer class="ux-card__actions" style="display:flex;gap:8px;padding-top:0;">
            <button class="ux-btn ux-btn--outline ux-btn--sm ux-flex-1">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 1 1-3-6.7L21 8"/><path d="M21 3v5h-5"/></svg>
              Renovar 30 d
            </button>
            <button class="ux-btn ux-btn--ghost ux-btn--danger ux-btn--sm ux-flex-1">Revocar</button>
          </footer>
        </article>

      </div>

      <div class="ux-section">
        <button data-on:click="$revokedOpen = !$revokedOpen" style="display:flex;width:100%;align-items:center;justify-content:space-between;background:var(--ux-bg-2);border:1px solid var(--ux-line);border-radius:var(--ux-radius-md);padding:14px 16px;cursor:pointer;color:inherit;font:inherit;text-align:left;">
          <div>
            <strong class="ux-text-md">Dispositivos revocados</strong>
            <span style="color:var(--ux-ink-3);font-size:var(--ux-text-sm);margin-left:8px;">últimos 90 días · 4 entradas</span>
          </div>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" data-attr:style="$revokedOpen ? 'transform: rotate(180deg); transition: transform 200ms;' : 'transition: transform 200ms;'"><path d="m6 9 6 6 6-6"/></svg>
        </button>

        <div data-show="$revokedOpen" class="ux-mt-2">
          <div class="ux-table-wrap">
            <table class="ux-table">
              <thead><tr>
                <th>Dispositivo</th>
                <th>Sistema</th>
                <th>Confiado</th>
                <th>Revocado</th>
                <th>Motivo</th>
              </tr></thead>
              <tbody>
                <tr>
                  <td><strong>Pixel 9</strong><div class="ux-text-xs ux-c-ink-3">Bilbao · backup</div></td>
                  <td>Android 15 · App 4.7</td>
                  <td class="ux-font-mono ux-text-xs">2026-03-14</td>
                  <td class="ux-font-mono ux-text-xs">2026-04-21</td>
                  <td><span class="ux-badge ux-badge--warn"><span class="ux-badge__dot"></span>Inactividad 30 d</span></td>
                </tr>
                <tr>
                  <td><strong>ThinkPad T14</strong><div class="ux-text-xs ux-c-ink-3">Sevilla · viaje</div></td>
                  <td>Ubuntu 24.04 · Firefox 128</td>
                  <td class="ux-font-mono ux-text-xs">2026-02-08</td>
                  <td class="ux-font-mono ux-text-xs">2026-04-02</td>
                  <td><span class="ux-badge ux-badge--info"><span class="ux-badge__dot"></span>Revocado por usuario</span></td>
                </tr>
                <tr>
                  <td><strong>iPhone 15</strong><div class="ux-text-xs ux-c-ink-3">Madrid · antiguo</div></td>
                  <td>iOS 17.6 · App 4.5</td>
                  <td class="ux-font-mono ux-text-xs">2025-12-10</td>
                  <td class="ux-font-mono ux-text-xs">2026-03-12</td>
                  <td><span class="ux-badge ux-badge--info"><span class="ux-badge__dot"></span>Reemplazado</span></td>
                </tr>
                <tr>
                  <td><strong>MacBook Air M2</strong><div class="ux-text-xs ux-c-ink-3">Barcelona · oficina</div></td>
                  <td>macOS 15.2 · Safari 18</td>
                  <td class="ux-font-mono ux-text-xs">2026-01-05</td>
                  <td class="ux-font-mono ux-text-xs">2026-02-18</td>
                  <td><span class="ux-badge ux-badge--danger"><span class="ux-badge__dot"></span>Pérdida de equipo</span></td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

    </div>
  </div>


  <!-- Bottom tab bar — mobile only via .ux-app__tabbar slot -->
  <nav class="ux-app__tabbar" aria-label="Navegación principal">
    <div class="ux-tabbar ux-tabbar--fixed ux-tabbar--icons">
      <a class="ux-tabbar-item" href="#" aria-current="page">
        <span class="ux-tabbar-icon"><iconify-icon icon="lucide:home" width="18" height="18"></iconify-icon></span>
        <span class="ux-tabbar-label">Inicio</span>
      </a>
      <a class="ux-tabbar-item" href="#">
        <span class="ux-tabbar-icon"><iconify-icon icon="lucide:credit-card" width="18" height="18"></iconify-icon></span>
        <span class="ux-tabbar-label">Hubs</span>
        <span class="ux-tabbar-badge">7</span>
      </a>
      <a class="ux-tabbar-item" href="#">
        <span class="ux-tabbar-icon"><iconify-icon icon="lucide:users" width="18" height="18"></iconify-icon></span>
        <span class="ux-tabbar-label">Usuarios</span>
      </a>
      <a class="ux-tabbar-item" href="#">
        <span class="ux-tabbar-icon"><iconify-icon icon="lucide:store" width="18" height="18"></iconify-icon></span>
        <span class="ux-tabbar-label">Equipo</span>
      </a>
      <a class="ux-tabbar-item" href="#">
        <span class="ux-tabbar-icon"><iconify-icon icon="lucide:user-circle" width="18" height="18"></iconify-icon></span>
        <span class="ux-tabbar-label">Perfil</span>
      </a>
    </div>
  </nav>
</div>
{% endblock %}
