{% extends "_base_preview.html" %}

{% from "ui/button.jinja" import button %}
{% from "ui/badge.jinja" import badge %}
{% from "ui/card.jinja" import card, card_footer %}
{% from "ui/icon.jinja" import icon %}
{% from "ui/input.jinja" import input %}
{% from "ui/field.jinja" import field %}
{% from "ui/empty.jinja" import empty %}

{% block title %}ERPlora Cloud · Iniciar sesión{% endblock %}

{% block head_extra %}
<style>
body { background: var(--ux-bg); margin: 0; }
  .cloud-shell { min-height: 100vh; }
  .cloud-auth {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: var(--ux-space-6) var(--ux-space-4);
    background:
      radial-gradient(ellipse at 25% -10%, color-mix(in oklch, var(--ux-brand) 18%, transparent), transparent 55%),
      radial-gradient(ellipse at 80% 110%, color-mix(in oklch, var(--ux-info) 14%, transparent), transparent 60%),
      var(--ux-bg);
  }
  .cloud-auth__card { width: 100%; max-width: 420px; display: flex; flex-direction: column; gap: var(--ux-space-4); }
  .cloud-auth__brand {
    display: flex; flex-direction: column; align-items: center;
    gap: 10px; margin-bottom: var(--ux-space-2);
  }
  .cloud-auth__logo {
    width: 44px; height: 44px; border-radius: 12px;
    background: linear-gradient(135deg, var(--ux-brand), var(--ux-brand-2));
    color: var(--ux-brand-fg);
    display: grid; place-items: center;
    font-family: var(--ux-font-display);
    font-weight: 700; font-size: 18px; letter-spacing: -0.04em;
    box-shadow: var(--ux-shadow-md);
  }
  .cloud-auth__name { font-family: var(--ux-font-display); font-size: 17px; font-weight: 600; letter-spacing: -0.02em; color: var(--ux-ink); }
  .cloud-auth__sub { font-size: var(--ux-text-sm); color: var(--ux-ink-3); }
  .cloud-auth__divider {
    display: flex; align-items: center; gap: 10px;
    font-size: var(--ux-text-xs); color: var(--ux-ink-4);
    text-transform: uppercase; letter-spacing: 0.08em;
    margin: var(--ux-space-1) 0;
  }
  .cloud-auth__divider::before,
  .cloud-auth__divider::after { content: ""; flex: 1; height: 1px; background: var(--ux-line); }
  .cloud-auth__oauth { display: grid; grid-template-columns: 1fr; gap: 8px; }
  .cloud-auth__foot { text-align: center; font-size: var(--ux-text-sm); color: var(--ux-ink-3); }
  .cloud-auth__foot a { color: var(--ux-brand-3); font-weight: 500; text-decoration: none; }
  .cloud-auth__foot a:hover { text-decoration: underline; }
  .cloud-otp { display: flex; flex-direction: column; gap: var(--ux-space-3); align-items: center; }
</style>
{% endblock %}

{% block body %}
<main class="cloud-auth" data-signals='{"step": "creds", "remember": true, "trust": false}'>

  <div class="cloud-auth__card">
    <div class="cloud-auth__brand">
      <div class="cloud-auth__logo">EX</div>
      <div class="cloud-auth__name">ERPlora Cloud</div>
      <div class="cloud-auth__sub">Plataforma de gestión multi-organización</div>
    </div>

    <!-- Step 1 — credenciales -->
    <section class="ux-card" data-show="$step === 'creds'">
      <div class="ux-card__header">
        <div>
          <h2 class="ux-card__title">Iniciar sesión</h2>
          <p class="ux-card__sub">Accede a tu panel de control de ERPlora</p>
        </div>
      </div>
      <div class="ux-card__body">
        <div class="ux-form">

          <div class="ux-field">
            <label class="ux-field__label ux-field__label--req" for="login-email">Correo electrónico</label>
            <div class="ux-input-group ux-input-group--with-left">
              <span class="ux-input-group__icon ux-input-group__icon--left">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
              </span>
              <input id="login-email" type="email" class="ux-input" placeholder="tu@empresa.com" autocomplete="email" value="ioan@acme.com"/>
            </div>
          </div>

          <div class="ux-field">
            <label class="ux-field__label ux-field__label--req" for="login-pwd">Contraseña</label>
            <div class="ux-input-group ux-input-group--with-left">
              <span class="ux-input-group__icon ux-input-group__icon--left">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V7a4 4 0 1 1 8 0v4"/></svg>
              </span>
              <input id="login-pwd" type="password" class="ux-input" placeholder="••••••••" autocomplete="current-password"/>
            </div>
            <a href="#" class="ux-field__hint" style="color:var(--ux-brand-3);text-decoration:none;align-self:flex-end;">¿Olvidaste tu contraseña?</a>
          </div>

          <div class="ux-toggle-row" style="border-bottom:none;padding:4px 0;">
            <div class="ux-toggle-row__text">
              <span class="ux-toggle-row__label">Recuérdame en este equipo</span>
              <span class="ux-toggle-row__desc">Guarda la sesión durante 30 días</span>
            </div>
            <label class="ux-toggle">
              <input type="checkbox" data-bind:remember/>
              <span class="ux-toggle__track"></span>
            </label>
          </div>

          <button type="button" class="ux-btn ux-btn--primary ux-btn--lg ux-btn--block" data-on:click="$step = '2fa'">
            Continuar
            <svg class="ux-btn__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </button>

        </div>
      </div>

      <div class="ux-card__footer" style="background:transparent;flex-direction:column;align-items:stretch;gap:10px;">
        <div class="cloud-auth__divider">o continúa con</div>
        <div class="cloud-auth__oauth">
          <button type="button" class="ux-btn ux-btn--outline">
            <svg class="ux-btn__icon" viewBox="0 0 24 24"><path fill="#4285F4" d="M22 12.2c0-.7-.06-1.4-.18-2.1H12v4h5.6a4.8 4.8 0 0 1-2.1 3.1v2.6h3.4c2-1.8 3.1-4.5 3.1-7.6z"/><path fill="#34A853" d="M12 22c2.8 0 5.2-.9 6.9-2.5l-3.4-2.6c-1 .6-2.2 1-3.5 1-2.7 0-5-1.8-5.8-4.3H2.7v2.7A10 10 0 0 0 12 22z"/><path fill="#FBBC05" d="M6.2 13.6a6 6 0 0 1 0-3.8V7H2.7a10 10 0 0 0 0 9l3.5-2.4z"/><path fill="#EA4335" d="M12 6c1.5 0 2.9.5 4 1.5l3-3A10 10 0 0 0 2.7 7l3.5 2.7C7 7.3 9.3 5.5 12 5.5z"/></svg>
            Continuar con Google
          </button>
          <button type="button" class="ux-btn ux-btn--outline">
            <svg class="ux-btn__icon" viewBox="0 0 24 24"><rect x="3" y="3" width="8" height="8" fill="#F25022"/><rect x="13" y="3" width="8" height="8" fill="#7FBA00"/><rect x="3" y="13" width="8" height="8" fill="#00A4EF"/><rect x="13" y="13" width="8" height="8" fill="#FFB900"/></svg>
            Continuar con Microsoft
          </button>
          <button type="button" class="ux-btn ux-btn--outline">
            <svg class="ux-btn__icon" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 0 0-3.16 19.49c.5.09.68-.22.68-.48v-1.7c-2.78.6-3.37-1.34-3.37-1.34-.45-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.04 1.53 1.04.89 1.53 2.34 1.09 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.94 0-1.09.39-1.99 1.03-2.69-.1-.25-.45-1.27.1-2.65 0 0 .84-.27 2.75 1.02a9.55 9.55 0 0 1 5 0c1.91-1.29 2.75-1.02 2.75-1.02.55 1.38.2 2.4.1 2.65.64.7 1.03 1.6 1.03 2.69 0 3.84-2.34 4.69-4.57 4.93.36.31.68.92.68 1.86v2.75c0 .27.18.58.69.48A10 10 0 0 0 12 2z"/></svg>
            Continuar con GitHub
          </button>
        </div>
      </div>
    </section>

    <!-- Step 2 — 2FA -->
    <section class="ux-card" data-show="$step === '2fa'">
      <div class="ux-card__header">
        <div>
          <h2 class="ux-card__title">Verificación en dos pasos</h2>
          <p class="ux-card__sub">Introduce el código de 6 dígitos de tu app autenticadora</p>
        </div>
      </div>
      <div class="ux-card__body">
        <div class="ux-form ux-items-center">

          <div class="cloud-otp">
            <div class="ux-otp ux-otp--lg" role="group" aria-label="Código de verificación de 6 dígitos">
              <input class="ux-otp__cell" maxlength="1" inputmode="numeric" autocomplete="one-time-code" value="4"/>
              <input class="ux-otp__cell" maxlength="1" inputmode="numeric" value="2"/>
              <input class="ux-otp__cell" maxlength="1" inputmode="numeric" value="9"/>
              <span class="ux-otp__sep">·</span>
              <input class="ux-otp__cell" maxlength="1" inputmode="numeric" value="1"/>
              <input class="ux-otp__cell" maxlength="1" inputmode="numeric"/>
              <input class="ux-otp__cell" maxlength="1" inputmode="numeric"/>
            </div>
            <p class="ux-field__hint" style="text-align:center;max-width:280px;">El código caduca en <strong style="color:var(--ux-ink);font-variant-numeric:tabular-nums;">00:42</strong>. Si no recibes nada, <a href="#" class="ux-c-brand-3">usa un código de respaldo</a>.</p>
          </div>

          <div class="ux-toggle-row" style="border-bottom:none;width:100%;padding:4px 0;">
            <div class="ux-toggle-row__text">
              <span class="ux-toggle-row__label">Confiar este dispositivo</span>
              <span class="ux-toggle-row__desc">No volverá a pedir 2FA durante 14 días</span>
            </div>
            <label class="ux-toggle">
              <input type="checkbox" data-bind:trust/>
              <span class="ux-toggle__track"></span>
            </label>
          </div>

          <div style="display:flex;gap:8px;width:100%;">
            <button type="button" class="ux-btn ux-btn--ghost ux-btn--lg" data-on:click="$step = 'creds'">
              <svg class="ux-btn__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M11 18l-6-6 6-6"/></svg>
              Volver
            </button>
            <button type="button" class="ux-btn ux-btn--primary ux-btn--lg ux-flex-1">
              Verificar y continuar
            </button>
          </div>

        </div>
      </div>
    </section>

    <p class="cloud-auth__foot">
      ¿No tienes cuenta? <a href="#">Regístrate gratis</a>
      <span style="display:block;margin-top:6px;color:var(--ux-ink-4);font-size:var(--ux-text-xs);">© 2026 ERPlora · <a href="#" class="ux-c-ink-3">Términos</a> · <a href="#" class="ux-c-ink-3">Privacidad</a></span>
    </p>

  </div>

</main>



  <!-- Bottom tab bar — mobile only via .ux-app__tabbar slot -->
  <nav class="ux-app__tabbar" aria-label="Navegación principal">
    <div class="ux-tabbar ux-tabbar--fixed ux-tabbar--icons">
      <a class="ux-tabbar-item" href="#" aria-current="page">
        <span class="ux-tabbar-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12 5 10 12 3l7 7 2 2v9a2 2 0 0 1-2 2h-4v-7H10v7H6a2 2 0 0 1-2-2v-9z"/></svg></span>
        <span class="ux-tabbar-label">Inicio</span>
      </a>
      <a class="ux-tabbar-item" href="#">
        <span class="ux-tabbar-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8a4 4 0 0 1 4-4h10a4 4 0 0 1 4 4v8a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4z"/><path d="M7 12h.01M12 12h.01M17 12h.01"/></svg></span>
        <span class="ux-tabbar-label">Hubs</span>
        <span class="ux-tabbar-badge">7</span>
      </a>
      <a class="ux-tabbar-item" href="#">
        <span class="ux-tabbar-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg></span>
        <span class="ux-tabbar-label">Usuarios</span>
      </a>
      <a class="ux-tabbar-item" href="#">
        <span class="ux-tabbar-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v4M3 9l1.5-3h15L21 9M3 9h18v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2zM10 21V13h4v8"/></svg></span>
        <span class="ux-tabbar-label">Equipo</span>
      </a>
      <a class="ux-tabbar-item" href="#">
        <span class="ux-tabbar-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="10" r="3"/><path d="M7 19a5 5 0 0 1 10 0"/></svg></span>
        <span class="ux-tabbar-label">Perfil</span>
      </a>
    </div>
  </nav>
</div>
{% endblock %}
