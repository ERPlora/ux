{% extends "_base_preview.html" %}

{% from "ui/button.jinja" import button %}
{% from "ui/badge.jinja" import badge %}
{% from "ui/card.jinja" import card, card_footer %}
{% from "ui/icon.jinja" import icon %}
{% from "ui/input.jinja" import input %}
{% from "ui/field.jinja" import field %}
{% from "ui/empty.jinja" import empty %}

{% block title %}Perfil del negocio · Cafetería La Rambla{% endblock %}

{% block body %}
<div class="ux-app" id="app" data-tabbar="bottom" data-signals='{"sidebar": false}' data-attr:data-sidebar="$sidebar ? 'open' : ''">
  <div class="ux-app__sidebar-overlay" data-on:click="$sidebar = false"></div>

  <aside class="ux-sidebar">
    <div class="ux-sidebar__brand">
      <div class="ux-sidebar__logo">CR</div>
      <div class="ux-sidebar__brand-text">
        <div class="ux-sidebar__brand-name">Cafetería La Rambla</div>
        <div class="ux-sidebar__brand-meta">Hub · v0.0.9</div>
      </div>
    </div>
    <div class="ux-sidebar__body">
      <div class="ux-sidebar__group">Plataforma</div>
      <button class="ux-sidebar__item" aria-current="page"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4"/></svg><span class="ux-sidebar__label">Configuración</span></button>
    </div>
    <div class="ux-sidebar__footer">
      <div class="ux-sidebar__user">
        <span class="ux-avatar ux-avatar--sm ux-avatar--brand">JC</span>
        <div class="ux-sidebar__user-info">
          <div class="ux-sidebar__user-name">Joan Castell</div>
          <div class="ux-sidebar__user-meta">joan@larambla.es</div>
        </div>
      </div>
    </div>
  </aside>

  <div class="ux-app__main">
    <header class="ux-topbar">
        <div class="ux-topbar__left">
          <button class="ux-topbar__back-btn" aria-label="Volver"
            data-on:click="history.length > 1 ? history.back() : null">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          </button>
        </div>
        <h1 class="ux-topbar__page-title">Página</h1>
        
        
        <button class="ux-topbar__menu-btn" aria-label="Menú"
            data-on:click="$sidebar = !$sidebar"
            data-attr:aria-expanded="$sidebar">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
          </button>
      </header>

    <nav class="ux-tabs" aria-label="Sub-secciones de perfil">
      <a class="ux-tab" href="saas.html">Perfil (SaaS)</a>
      <a class="ux-tab" href="hub.html" aria-current="page">Perfil (Hub)</a>
    </nav>

    <div class="ux-app__body">

      <div class="ux-page-header" style="border-bottom:1px solid var(--ux-line);margin-bottom:22px;">
        <div class="ux-page-header__title">
          <h1>Perfil del negocio</h1>
          <div class="ux-page-header__sub">Datos fiscales, contacto y preferencias regionales</div>
        </div>
        <div class="ux-page-header__actions">
          <a class="ux-btn ux-btn--ghost ux-btn--sm" href="index.html">Volver</a>
        </div>
      </div>

      <form class="ux-form" data-on:submit="event.preventDefault()" style="max-width:880px;"
            data-signals='{"profile": {"country": "ES", "currency": "EUR", "logoUrl": ""}}'>

        <div class="ux-form-section">
          <h3 class="ux-form-section__title">Datos fiscales</h3>
          <p class="ux-form-section__desc">Aparecen en facturas, tickets y verifactu (AEAT).</p>

          <div class="ux-form-row">
            <div class="ux-field">
              <label class="ux-field__label ux-field__label--req">Razón social</label>
              <input class="ux-input" value="Cafetería La Rambla SL"/>
            </div>
            <div class="ux-field">
              <label class="ux-field__label ux-field__label--req">CIF / NIF</label>
              <input class="ux-input" value="ES B12345678"/>
            </div>
          </div>

          <div class="ux-form-row">
            <div class="ux-field">
              <label class="ux-field__label">Régimen fiscal</label>
              <select class="ux-select">
                <option selected>General</option>
                <option>Recargo de equivalencia</option>
                <option>Exento</option>
                <option>Módulos</option>
              </select>
            </div>
            <div class="ux-field">
              <label class="ux-field__label">Sub-región</label>
              <input class="ux-input" value="ES-CT" maxlength="10" placeholder="ej. ES-CT"/>
              <span class="ux-field__hint">Déjalo en blanco si aplica todo el país.</span>
            </div>
          </div>
        </div>

        <div class="ux-form-section">
          <h3 class="ux-form-section__title">Dirección</h3>
          <p class="ux-form-section__desc">Domicilio fiscal y de operación principal.</p>

          <div class="ux-field">
            <label class="ux-field__label ux-field__label--req">Calle y número</label>
            <input class="ux-input" value="Calle Major 12"/>
          </div>

          <div class="ux-form-row">
            <div class="ux-field">
              <label class="ux-field__label ux-field__label--req">Código postal</label>
              <input class="ux-input" value="08001"/>
            </div>
            <div class="ux-field">
              <label class="ux-field__label ux-field__label--req">Ciudad</label>
              <input class="ux-input" value="Barcelona"/>
            </div>
            <div class="ux-field">
              <label class="ux-field__label">Provincia</label>
              <input class="ux-input" value="Barcelona"/>
            </div>
          </div>

          <div class="ux-field">
            <label class="ux-field__label ux-field__label--req">País</label>
            <select class="ux-select" data-bind="profile.country">
              <option value="ES" selected>España</option>
              <option value="PT">Portugal</option>
              <option value="FR">Francia</option>
              <option value="IT">Italia</option>
            </select>
          </div>
        </div>

        <div class="ux-form-section">
          <h3 class="ux-form-section__title">Contacto</h3>
          <p class="ux-form-section__desc">Cómo se pondrán en contacto tus clientes y proveedores.</p>

          <div class="ux-form-row">
            <div class="ux-field">
              <label class="ux-field__label ux-field__label--req">Email de contacto</label>
              <input class="ux-input" type="email" value="hola@larambla.es"/>
            </div>
            <div class="ux-field">
              <label class="ux-field__label">Teléfono</label>
              <input class="ux-input" type="tel" value="+34 933 456 789"/>
            </div>
          </div>

          <div class="ux-form-row">
            <div class="ux-field">
              <label class="ux-field__label">Web</label>
              <input class="ux-input" type="url" value="https://larambla.es"/>
            </div>
            <div class="ux-field">
              <label class="ux-field__label">Idioma de la interfaz</label>
              <select class="ux-select">
                <option selected>Español (es)</option>
                <option>Català (ca)</option>
                <option>English (en)</option>
              </select>
            </div>
          </div>
        </div>

        <div class="ux-form-section">
          <h3 class="ux-form-section__title">Identidad visual</h3>
          <p class="ux-form-section__desc">Logo que aparece en tickets, facturas y la cabecera del Hub.</p>

          <div class="ux-form-row" style="grid-template-columns: 96px 1fr; align-items:center; gap:16px;">
            <div style="width:96px;height:96px;border-radius:14px;background:var(--ux-bg-3);border:1px solid var(--ux-line);display:grid;place-items:center;color:var(--ux-ink-3);font-family:var(--ux-font-display);font-size:32px;font-weight:600;">CR</div>
            <div>
              <label class="ux-dropzone ux-m-0"
                data-signals='{"drag": false}'
                data-attr:data-state="$drag ? 'dragging' : ''"
                data-on:dragover__prevent="$drag = true"
                data-on:dragleave="$drag = false"
                data-on:drop__prevent="$drag = false">
                <input type="file" hidden accept="image/png,image/jpeg,image/svg+xml"/>
                <span class="ux-dropzone__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg></span>
                <div class="ux-dropzone__title">Arrastra o <b>elige el logo</b></div>
                <div class="ux-dropzone__hint">PNG, JPG o SVG · máximo 2 MB · cuadrado recomendado 512×512</div>
              </label>
            </div>
          </div>
        </div>

        <div class="ux-form-section">
          <h3 class="ux-form-section__title">Moneda y formato</h3>
          <p class="ux-form-section__desc">Cómo se muestran los precios en POS y facturas.</p>

          <div class="ux-form-row">
            <div class="ux-field">
              <label class="ux-field__label">Moneda</label>
              <select class="ux-select" data-bind="profile.currency">
                <option value="EUR" selected>EUR — Euro</option>
                <option value="USD">USD — Dólar</option>
                <option value="GBP">GBP — Libra</option>
              </select>
            </div>
            <div class="ux-field">
              <label class="ux-field__label">Zona horaria</label>
              <select class="ux-select">
                <option selected>Europe/Madrid (UTC+1)</option>
                <option>Europe/Lisbon</option>
                <option>UTC</option>
              </select>
            </div>
            <div class="ux-field">
              <label class="ux-field__label">Formato fecha</label>
              <select class="ux-select">
                <option selected>DD/MM/YYYY</option>
                <option>YYYY-MM-DD</option>
                <option>MM/DD/YYYY</option>
              </select>
            </div>
          </div>
        </div>

        <div class="ux-form-section">
          <h3 class="ux-form-section__title">Tipo de venta</h3>
          <div class="ux-toggle-row">
            <div class="ux-toggle-row__text">
              <span class="ux-toggle-row__label">Vendo a empresas (B2B)</span>
              <span class="ux-toggle-row__desc">Emites facturas a otras empresas o profesionales.</span>
            </div>
            <label class="ux-toggle"><input type="checkbox" checked/><span class="ux-toggle__track"></span></label>
          </div>
          <div class="ux-toggle-row">
            <div class="ux-toggle-row__text">
              <span class="ux-toggle-row__label">Vendo a consumidores (B2C)</span>
              <span class="ux-toggle-row__desc">Tickets a cliente final en POS.</span>
            </div>
            <label class="ux-toggle"><input type="checkbox" checked/><span class="ux-toggle__track"></span></label>
          </div>
        </div>

        <div style="display:flex;gap:8px;justify-content:flex-end;padding-top:12px;">
          <a class="ux-btn ux-btn--ghost" href="index.html">Cancelar</a>
          <button type="submit" class="ux-btn ux-btn--primary">Guardar perfil</button>
        </div>

      </form>

    </div>
  </div>
</div>
{% endblock %}
