{% extends "_base_preview.html" %}

{% from "ui/button.jinja" import button %}
{% from "ui/badge.jinja" import badge %}
{% from "ui/card.jinja" import card, card_footer %}
{% from "ui/icon.jinja" import icon %}
{% from "ui/input.jinja" import input %}
{% from "ui/field.jinja" import field %}
{% from "ui/empty.jinja" import empty %}

{% block title %}ERPlora Cloud · Mi perfil{% endblock %}

{% block head_extra %}
<style>
body { background: var(--ux-bg); margin: 0; }
  .cloud-shell { min-height: 100vh; }
  .profile-grid { display: grid; grid-template-columns: 320px 1fr; gap: var(--ux-space-4); align-items: start; }
  @media (max-width: 991px) { .profile-grid { grid-template-columns: 1fr; } }
  .profile-avatar {
    width: 96px; height: 96px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--ux-brand), var(--ux-brand-2));
    color: var(--ux-brand-fg);
    display: grid; place-items: center;
    font-family: var(--ux-font-display);
    font-weight: 700;
    font-size: 36px;
    letter-spacing: -0.04em;
    box-shadow: var(--ux-shadow-md);
    border: 4px solid var(--ux-bg-2);
  }
  .profile-name { font-family: var(--ux-font-display); font-size: 20px; font-weight: 600; letter-spacing: -0.03em; color: var(--ux-ink); margin: 0; }
  .profile-email { font-size: var(--ux-text-sm); color: var(--ux-ink-3); margin-top: 2px; }
  .security-item { display: flex; align-items: center; gap: 14px; padding: 14px 16px; }
  .security-item__icon {
    width: 36px; height: 36px;
    border-radius: var(--ux-radius-md);
    background: var(--ux-bg-3);
    color: var(--ux-ink-2);
    display: grid; place-items: center;
    flex-shrink: 0;
  }
  .security-item__icon svg { width: 16px; height: 16px; }
  .security-item__icon--brand { background: var(--ux-brand-soft); color: var(--ux-brand-3); }
  .security-item__icon--danger { background: var(--ux-danger-soft); color: var(--ux-danger); }
  .security-item__title { font-size: var(--ux-text-md); font-weight: 500; color: var(--ux-ink); }
  .security-item__desc { font-size: var(--ux-text-xs); color: var(--ux-ink-3); margin-top: 2px; line-height: 1.5; }
</style>
{% endblock %}

{% block body %}
<div class="ux-app cloud-shell" data-signals='{"sidebar": false}' data-attr:data-sidebar="$sidebar ? 'open' : ''">
<div class="ux-app__sidebar-overlay" data-on:click="$sidebar = false"></div>

<aside class="ux-sidebar">
  <div class="ux-sidebar__brand">
    <div class="ux-sidebar__logo">EX</div>
    <div class="ux-sidebar__brand-text">
      <div class="ux-sidebar__brand-name">ERPlora Cloud</div>
      <div class="ux-sidebar__brand-meta">Acme Industries</div>
    </div>
  </div>
  <div class="ux-sidebar__body">
    <div class="ux-sidebar__group">Principal</div>
    <a class="ux-sidebar__item" href="#"><iconify-icon icon="lucide:layout-dashboard" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Resumen</span></a>
    <a class="ux-sidebar__item" href="#"><iconify-icon icon="lucide:building-2" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Organizaciones</span></a>
    <a class="ux-sidebar__item" href="#"><iconify-icon icon="lucide:credit-card" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Hubs</span><span class="ux-sidebar__badge">7</span></a>
    <a class="ux-sidebar__item" href="#"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="7" r="4"/><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/></svg><span class="ux-sidebar__label">Usuarios</span></a>
    <a class="ux-sidebar__item" href="#"><iconify-icon icon="lucide:layers" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Equipamiento</span></a>
    <div class="ux-sidebar__group">Facturación</div>
    <a class="ux-sidebar__item" href="#"><iconify-icon icon="lucide:file-text" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Facturas</span></a>
    <a class="ux-sidebar__item" href="#"><iconify-icon icon="lucide:refresh-ccw" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Suscripciones</span></a>
    <a class="ux-sidebar__item" href="#"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="6" width="20" height="12" rx="2"/><path d="M2 10h20"/></svg><span class="ux-sidebar__label">Pagos</span></a>
    <div class="ux-sidebar__group">Cuenta</div>
    <a class="ux-sidebar__item" href="2fa-profile.html"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V7a4 4 0 1 1 8 0v4"/></svg><span class="ux-sidebar__label">Seguridad</span></a>
    <a class="ux-sidebar__item" href="#" aria-current="page"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 21a8 8 0 0 1 16 0"/></svg><span class="ux-sidebar__label">Mi perfil</span></a>
  </div>
  <div class="ux-sidebar__footer">
    <div class="ux-sidebar__user">
      <span class="ux-avatar ux-avatar--sm ux-avatar--brand">IB</span>
      <div class="ux-sidebar__user-info">
        <div class="ux-sidebar__user-name">Ioan Beilic</div>
        <div class="ux-sidebar__user-meta">ioan@acme.com</div>
      </div>
    </div>
  </div>
</aside>

<div class="ux-app__main">

  <header class="ux-topbar">
        <div class="ux-topbar__left">
          <button class="ux-topbar__back-btn" aria-label="Volver"
            data-on:click="history.length > 1 ? history.back() : null">
            <iconify-icon icon="lucide:arrow-left" width="2" height="2"></iconify-icon>
          </button>
        </div>
        <h1 class="ux-topbar__page-title">Mi perfil</h1>
        
        <div class="ux-topbar__search">
      <span class="ux-search__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg></span>
      <input type="search" placeholder="Buscar hubs, módulos, facturas…"/>
      <span class="ux-topbar__kbd">⌘K</span>
    </div>
        
        <div class="ux-topbar__actions">
          <button class="ux-icon-btn"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg></button>
      <span class="ux-avatar ux-avatar--sm ux-avatar--brand">IB</span>
        </div>
        <button class="ux-topbar__menu-btn" aria-label="Menú"
            data-on:click="$sidebar = !$sidebar"
            data-attr:aria-expanded="$sidebar">
            <iconify-icon icon="lucide:menu" width="2" height="2"></iconify-icon>
          </button>
      </header>

  <nav class="ux-tabs" aria-label="Sub-secciones de perfil">
    <a class="ux-tab" href="saas.html" aria-current="page">Perfil (SaaS)</a>
    <a class="ux-tab" href="hub.html">Perfil (Hub)</a>
  </nav>

  <div class="ux-app__body" data-signals='{"firstName":"Ioan", "lastName":"Beilic", "lang":"es", "tz":"Europe/Madrid", "themePref":"auto"}'>

    <header class="ux-page-header">
      <div class="ux-page-header__title">
        <h1>Mi perfil</h1>
        <p class="ux-page-header__sub">Datos personales, idioma y preferencias visuales de tu cuenta de ERPlora Cloud.</p>
      </div>
      <div class="ux-page-header__actions">
        <button class="ux-btn ux-btn--ghost">Cancelar</button>
        <button class="ux-btn ux-btn--primary">Guardar cambios</button>
      </div>
    </header>

    <!-- Avatar + form -->
    <section class="profile-grid" style="margin-bottom: var(--ux-space-6);">

      <!-- Avatar card -->
      <div class="ux-card">
        <div class="ux-card__body" style="display:flex;flex-direction:column;align-items:center;text-align:center;gap:14px;padding:24px 18px;">
          <div class="profile-avatar">IB</div>
          <div>
            <h2 class="profile-name">Ioan Beilic</h2>
            <div class="profile-email">ioan@acme.com</div>
            <div style="margin-top: 10px; display:flex; gap:6px; justify-content:center; flex-wrap:wrap;">
              <span class="ux-chip" data-active="true">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                Administrador
              </span>
              <span class="ux-chip">Acme Industries</span>
            </div>
          </div>
          <div class="ux-divider" style="width:100%;margin:8px 0;"></div>
          <div style="display:flex;flex-direction:column;gap:6px;width:100%;">
            <button class="ux-btn ux-btn--outline ux-btn--block">
              <svg class="ux-btn__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.1-3.1a2 2 0 0 0-2.8 0L6 21"/></svg>
              Cambiar foto
            </button>
            <button class="ux-btn ux-btn--ghost ux-btn--block ux-c-ink-3">
              Eliminar foto
            </button>
          </div>
          <div style="font-size:var(--ux-text-xs);color:var(--ux-ink-4);text-align:center;line-height:1.5;">
            JPG, PNG o GIF · máx 2 MB · cuadrada recomendada
          </div>
        </div>
      </div>

      <!-- Personal data -->
      <div class="ux-card">
        <div class="ux-card__header">
          <div>
            <h2 class="ux-card__title">Datos personales</h2>
            <p class="ux-card__sub">Esta información aparece en facturas, comentarios y notificaciones.</p>
          </div>
        </div>
        <div class="ux-card__body">
          <div class="ux-form">

            <div class="ux-form-row">
              <div class="ux-field">
                <label class="ux-field__label" for="p-first">Nombre</label>
                <input id="p-first" type="text" class="ux-input" value="Ioan" data-bind:firstName/>
              </div>
              <div class="ux-field">
                <label class="ux-field__label" for="p-last">Apellidos</label>
                <input id="p-last" type="text" class="ux-input" value="Beilic" data-bind:lastName/>
              </div>
            </div>

            <div class="ux-field">
              <label class="ux-field__label" for="p-email">Correo electrónico</label>
              <div class="ux-input-group ux-input-group--with-left">
                <span class="ux-input-group__icon ux-input-group__icon--left">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
                </span>
                <input id="p-email" type="email" class="ux-input" value="ioan@acme.com"/>
              </div>
              <span class="ux-field__hint">El cambio de email requerirá verificación en la nueva dirección.</span>
            </div>

            <div class="ux-form-row">
              <div class="ux-field">
                <label class="ux-field__label" for="p-lang">Idioma</label>
                <select id="p-lang" class="ux-select" data-bind:lang>
                  <option value="es" selected>Español (España)</option>
                  <option value="en">English (US)</option>
                  <option value="fr">Français</option>
                  <option value="de">Deutsch</option>
                </select>
              </div>
              <div class="ux-field">
                <label class="ux-field__label" for="p-tz">Zona horaria</label>
                <select id="p-tz" class="ux-select" data-bind:tz>
                  <option value="Europe/Madrid" selected>Europe/Madrid (UTC+2)</option>
                  <option value="Europe/Lisbon">Europe/Lisbon (UTC+1)</option>
                  <option value="Europe/London">Europe/London (UTC+1)</option>
                  <option value="America/New_York">America/New_York (UTC−4)</option>
                  <option value="America/Mexico_City">America/Mexico_City (UTC−6)</option>
                </select>
              </div>
            </div>

            <div class="ux-form-row">
              <div class="ux-field">
                <label class="ux-field__label" for="p-theme">Tema preferido</label>
                <select id="p-theme" class="ux-select" data-bind:themePref>
                  <option value="auto" selected>Automático (sistema)</option>
                  <option value="dark">Oscuro · ERPlora</option>
                  <option value="light">Claro · ERPlora Light</option>
                  <option value="ocean">Ocean · cian</option>
                  <option value="forest">Forest · verde</option>
                </select>
              </div>
              <div class="ux-field">
                <label class="ux-field__label" for="p-currency">Moneda</label>
                <select id="p-currency" class="ux-select">
                  <option value="EUR" selected>EUR · Euro (€)</option>
                  <option value="USD">USD · Dólar ($)</option>
                  <option value="GBP">GBP · Libra (£)</option>
                </select>
              </div>
            </div>

            <div class="ux-field">
              <label class="ux-field__label" for="p-bio">Biografía corta</label>
              <textarea id="p-bio" class="ux-textarea" placeholder="Cuéntanos brevemente tu rol en la organización…">Líder de plataforma en Acme Industries. Coordino la implantación de ERPlora Cloud en los 7 hubs operativos del grupo.</textarea>
              <span class="ux-field__hint">Visible para otros administradores de tu organización.</span>
            </div>

          </div>
        </div>
        <div class="ux-card__footer">
          <span class="ux-field__hint">Guardado automático en cada cambio · última edición: hace 14 min</span>
          <button class="ux-btn ux-btn--primary">Guardar cambios</button>
        </div>
      </div>

    </section>

    <!-- Security -->
    <section class="ux-section">
      <div class="ux-section__head">
        <div>
          <div class="ux-section__title">Seguridad de la cuenta</div>
          <div class="ux-section__sub">Contraseña, sesiones activas y eliminación de cuenta.</div>
        </div>
      </div>

      <div class="ux-grid-3">

        <div class="ux-card">
          <div class="security-item">
            <div class="security-item__icon security-item__icon--brand">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V7a4 4 0 1 1 8 0v4"/></svg>
            </div>
            <div class="ux-flex-1">
              <div class="security-item__title">Cambiar contraseña</div>
              <div class="security-item__desc">Última actualización: 11 enero 2026 · 117 días</div>
            </div>
            <button class="ux-btn ux-btn--ghost ux-btn--sm">
              Cambiar
              <svg class="ux-btn__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 6l6 6-6 6"/></svg>
            </button>
          </div>
        </div>

        <div class="ux-card">
          <div class="security-item">
            <div class="security-item__icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="13" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
            </div>
            <div class="ux-flex-1">
              <div class="security-item__title">Sesiones activas</div>
              <div class="security-item__desc">3 dispositivos · Madrid, Barcelona, Sevilla</div>
            </div>
            <button class="ux-btn ux-btn--ghost ux-btn--sm">
              Ver detalles
              <svg class="ux-btn__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 6l6 6-6 6"/></svg>
            </button>
          </div>
        </div>

        <div class="ux-card" style="border-color: color-mix(in oklch, var(--ux-danger) 25%, var(--ux-line));">
          <div class="security-item">
            <div class="security-item__icon security-item__icon--danger">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2m3 0v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/></svg>
            </div>
            <div class="ux-flex-1">
              <div class="security-item__title ux-c-danger">Eliminar cuenta</div>
              <div class="security-item__desc">Borrado permanente · sin recuperación posible</div>
            </div>
            <button class="ux-btn ux-btn--ghost ux-btn--sm ux-c-danger">
              Eliminar
              <svg class="ux-btn__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 6l6 6-6 6"/></svg>
            </button>
          </div>
        </div>

      </div>

      <div style="margin-top: var(--ux-space-3);">
        <div class="ux-callout ux-callout--info">
          <span class="ux-callout__icon">
            <iconify-icon icon="lucide:info" width="2" height="2"></iconify-icon>
          </span>
          <div class="ux-callout__body">
            <p class="ux-callout__title">Recomendación de seguridad</p>
            <p class="ux-callout__desc">Activa la <a href="2fa-profile.html" class="ux-c-brand-3">verificación en dos pasos</a> para proteger tu cuenta. Tienes 4 dispositivos autorizados y 3 sesiones activas en este momento.</p>
          </div>
        </div>
      </div>
    </section>

  </div>
</div>


  <!-- Bottom tab bar — mobile only via .ux-app__tabbar slot -->
  <nav class="ux-app__tabbar" aria-label="Navegación principal">
    <div class="ux-tabbar ux-tabbar--fixed ux-tabbar--icons">
      <a class="ux-tabbar-item" href="#" aria-current="page">
        <span class="ux-tabbar-icon"><iconify-icon icon="lucide:home" width="18" height="18"></iconify-icon></span>
        <span class="ux-tabbar-label">Inicio</span>
      </a>
      <a class="ux-tabbar-item" href="#">
        <span class="ux-tabbar-icon"><iconify-icon icon="lucide:credit-card" width="18" height="18"></iconify-icon></span>
        <span class="ux-tabbar-label">Hubs</span>
        <span class="ux-tabbar-badge">7</span>
      </a>
      <a class="ux-tabbar-item" href="#">
        <span class="ux-tabbar-icon"><iconify-icon icon="lucide:users" width="18" height="18"></iconify-icon></span>
        <span class="ux-tabbar-label">Usuarios</span>
      </a>
      <a class="ux-tabbar-item" href="#">
        <span class="ux-tabbar-icon"><iconify-icon icon="lucide:store" width="18" height="18"></iconify-icon></span>
        <span class="ux-tabbar-label">Equipo</span>
      </a>
      <a class="ux-tabbar-item" href="#">
        <span class="ux-tabbar-icon"><iconify-icon icon="lucide:user-circle" width="18" height="18"></iconify-icon></span>
        <span class="ux-tabbar-label">Perfil</span>
      </a>
    </div>
  </nav>
</div>
{% endblock %}
