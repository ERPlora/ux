{% extends "_base_preview.html" %}

{% block title %}Sistema · Hardware · Cafetería La Rambla{% endblock %}

{% block body %}
<div class="ux-app" id="app" data-tabbar="bottom"
     data-signals='{"sidebar": false, "bridge": {"connected": true, "port": 9100, "autoPrint": true}}'
     data-attr:data-sidebar="$sidebar ? 'open' : ''">
  <div class="ux-app__sidebar-overlay" data-on:click="$sidebar = false"></div>

  <aside class="ux-sidebar">
    <div class="ux-sidebar__brand">
      <div class="ux-sidebar__logo">CR</div>
      <div class="ux-sidebar__brand-text">
        <div class="ux-sidebar__brand-name">Cafetería La Rambla</div>
        <div class="ux-sidebar__brand-meta">Hub · v0.0.9</div>
      </div>
    </div>
    <div class="ux-sidebar__body">
      <div class="ux-sidebar__group">Plataforma</div>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83"/></svg><span class="ux-sidebar__label">Configuración</span></button>
      <button class="ux-sidebar__item" aria-current="page"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M6 8h.01M10 8h.01"/></svg><span class="ux-sidebar__label">Sistema</span></button>
    </div>
    <div class="ux-sidebar__footer">
      <div class="ux-sidebar__user">
        <span class="ux-avatar ux-avatar--sm ux-avatar--brand">JC</span>
        <div class="ux-sidebar__user-info">
          <div class="ux-sidebar__user-name">Joan Castell</div>
          <div class="ux-sidebar__user-meta">joan@larambla.es</div>
        </div>
      </div>
    </div>
  </aside>

  <div class="ux-app__main">
    <header class="ux-topbar">
        <div class="ux-topbar__left">
          <button class="ux-topbar__back-btn" aria-label="Volver"
            data-on:click="history.length > 1 ? history.back() : null">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          </button>
        </div>
        <h1 class="ux-topbar__page-title">Página</h1>
        
        
        <button class="ux-topbar__menu-btn" aria-label="Menú"
            data-on:click="$sidebar = !$sidebar"
            data-attr:aria-expanded="$sidebar">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
          </button>
      </header>

    <div class="ux-app__body">

      <div class="ux-page-header" style="border-bottom:1px solid var(--ux-line);margin-bottom:18px;">
        <div class="ux-page-header__title">
          <h1>Hardware del TPV</h1>
          <div class="ux-page-header__sub">Bridge, periféricos POS y dispositivos detectados</div>
        </div>
        <div class="ux-page-header__actions">
          <a class="ux-btn ux-btn--secondary ux-btn--sm" href="bridge-setup.html">↻ Re-detectar</a>
          <a class="ux-btn ux-btn--primary ux-btn--sm" href="bridge-setup.html">Configurar Bridge</a>
        </div>
      </div>

      <!-- Bridge status (header) -->
      <article class="ux-card ux-card--glass ux-mb-4">
        <div class="ux-card__body" style="display:flex;align-items:center;gap:16px;">
          <div style="width:56px;height:56px;border-radius:14px;background:color-mix(in oklch, var(--ux-leaf) 14%, transparent);color:var(--ux-leaf);display:grid;place-items:center;">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="4" width="16" height="16" rx="2"/><path d="M9 9h6v6H9z"/><path d="M9 1v3M15 1v3M9 20v3M15 20v3M1 9h3M1 15h3M20 9h3M20 15h3"/></svg>
          </div>
          <div class="ux-flex-1">
            <div class="ux-flex ux-items-center ux-gap-2">
              <h3 style="font-family:var(--ux-font-display);font-size:18px;font-weight:600;margin:0;">ERPlora Bridge</h3>
              <span class="ux-pill ux-pill--ok" data-show="$bridge.connected"><span class="ux-pill__dot"></span>Conectado</span>
              <span class="ux-pill ux-pill--danger" data-show="!$bridge.connected"><span class="ux-pill__dot"></span>No detectado</span>
            </div>
            <p style="font-size:12px;color:var(--ux-ink-3);margin:4px 0 0;">
              <span data-show="$bridge.connected">v1.4.2 · puerto <span data-text="$bridge.port"></span> · 5 dispositivos detectados · auto-print ON</span>
              <span data-show="!$bridge.connected">Asegúrate de que ERPlora Bridge esté arrancado en este equipo.</span>
            </p>
          </div>
          <div class="ux-flex ux-gap-1">
            <button class="ux-btn ux-btn--ghost ux-btn--sm">Logs</button>
            <button class="ux-btn ux-btn--secondary ux-btn--sm">Reiniciar</button>
          </div>
        </div>
      </article>

      <!-- Devices grid -->
      <h3 style="font-family:var(--ux-font-display);font-size:14px;font-weight:600;margin:0 0 10px;color:var(--ux-ink-2);text-transform:uppercase;letter-spacing:0.06em;">Periféricos POS</h3>

      <div class="ux-grid-3" style="gap:14px;margin-bottom:22px;">

        <article class="ux-card">
          <header class="ux-card__header">
            <div class="ux-flex ux-items-center ux-gap-2">
              <div style="width:36px;height:36px;border-radius:10px;background:color-mix(in oklch, var(--ux-brand) 14%, transparent);color:var(--ux-brand);display:grid;place-items:center;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
              </div>
              <div>
                <h3 class="ux-card__title">Impresora térmica</h3>
                <p class="ux-card__sub">Epson TM-T20III</p>
              </div>
            </div>
            <span class="ux-status-dot ux-status-dot--online"></span>
          </header>
          <div class="ux-card__body ux-text-xs ux-c-ink-3">
            <div class="ux-flex ux-justify-between"><span>Conexión</span><span style="color:var(--ux-ink);font-family:var(--ux-font-mono);">192.168.1.220:9100</span></div>
            <div style="display:flex;justify-content:space-between;margin-top:4px;"><span>Papel</span><span class="ux-c-ink">80 mm · OK</span></div>
          </div>
          <footer class="ux-card__footer" style="display:flex;justify-content:flex-end;gap:6px;">
            <button class="ux-btn ux-btn--ghost ux-btn--sm">Test</button>
          </footer>
        </article>

        <article class="ux-card">
          <header class="ux-card__header">
            <div class="ux-flex ux-items-center ux-gap-2">
              <div style="width:36px;height:36px;border-radius:10px;background:color-mix(in oklch, var(--ux-leaf) 14%, transparent);color:var(--ux-leaf);display:grid;place-items:center;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="8" width="18" height="13" rx="2"/><path d="M7 8V5a3 3 0 0 1 6 0v3"/><circle cx="12" cy="14" r="2"/></svg>
              </div>
              <div>
                <h3 class="ux-card__title">Cajón monedas</h3>
                <p class="ux-card__sub">APG Vasario · USB pulse</p>
              </div>
            </div>
            <span class="ux-status-dot ux-status-dot--online"></span>
          </header>
          <div class="ux-card__body ux-text-xs ux-c-ink-3">
            <div class="ux-flex ux-justify-between"><span>Conexión</span><span class="ux-c-ink">Vinculado a Epson TM-T20III</span></div>
            <div style="display:flex;justify-content:space-between;margin-top:4px;"><span>Aperturas hoy</span><span class="ux-c-ink">142</span></div>
          </div>
          <footer class="ux-card__footer" style="display:flex;justify-content:flex-end;gap:6px;">
            <button class="ux-btn ux-btn--ghost ux-btn--sm">Abrir cajón</button>
          </footer>
        </article>

        <article class="ux-card">
          <header class="ux-card__header">
            <div class="ux-flex ux-items-center ux-gap-2">
              <div style="width:36px;height:36px;border-radius:10px;background:color-mix(in oklch, var(--ux-info) 14%, transparent);color:var(--ux-info);display:grid;place-items:center;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 5h2v14H3zM7 5h1v14H7zM10 5h2v14h-2zM14 5h1v14h-1zM17 5h1v14h-1zM20 5h1v14h-1z"/></svg>
              </div>
              <div>
                <h3 class="ux-card__title">Scanner código barras</h3>
                <p class="ux-card__sub">Honeywell Voyager 1450g</p>
              </div>
            </div>
            <span class="ux-status-dot ux-status-dot--online"></span>
          </header>
          <div class="ux-card__body ux-text-xs ux-c-ink-3">
            <div class="ux-flex ux-justify-between"><span>Conexión</span><span class="ux-c-ink">USB HID · /dev/hidraw1</span></div>
            <div style="display:flex;justify-content:space-between;margin-top:4px;"><span>Lecturas hoy</span><span class="ux-c-ink">88</span></div>
          </div>
          <footer class="ux-card__footer" style="display:flex;justify-content:flex-end;gap:6px;">
            <button class="ux-btn ux-btn--ghost ux-btn--sm">Test</button>
          </footer>
        </article>

        <article class="ux-card">
          <header class="ux-card__header">
            <div class="ux-flex ux-items-center ux-gap-2">
              <div style="width:36px;height:36px;border-radius:10px;background:color-mix(in oklch, var(--ux-warn) 14%, transparent);color:var(--ux-warn);display:grid;place-items:center;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 7h18l-2 12a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2L3 7z"/><path d="M8 7V5a4 4 0 0 1 8 0v2"/></svg>
              </div>
              <div>
                <h3 class="ux-card__title">Balanza</h3>
                <p class="ux-card__sub">Mettler ICS425 · serie</p>
              </div>
            </div>
            <span class="ux-status-dot ux-status-dot--busy"></span>
          </header>
          <div class="ux-card__body ux-text-xs ux-c-ink-3">
            <div class="ux-flex ux-justify-between"><span>Conexión</span><span style="color:var(--ux-ink);font-family:var(--ux-font-mono);">/dev/ttyUSB0 · 9600 8N1</span></div>
            <div style="display:flex;justify-content:space-between;margin-top:4px;"><span>Última lectura</span><span class="ux-c-ink">0,000 kg · estable</span></div>
            <div class="ux-banner ux-banner--warn ux-mt-2">
              <div class="ux-banner__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg></div>
              <div class="ux-banner__body"><div class="ux-banner__desc">Calibración pendiente (último ajuste hace 6 meses).</div></div>
            </div>
          </div>
          <footer class="ux-card__footer" style="display:flex;justify-content:flex-end;gap:6px;">
            <button class="ux-btn ux-btn--ghost ux-btn--sm">Calibrar</button>
            <button class="ux-btn ux-btn--ghost ux-btn--sm">Tare</button>
          </footer>
        </article>

        <article class="ux-card">
          <header class="ux-card__header">
            <div class="ux-flex ux-items-center ux-gap-2">
              <div style="width:36px;height:36px;border-radius:10px;background:color-mix(in oklch, var(--ux-brand) 14%, transparent);color:var(--ux-brand);display:grid;place-items:center;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="14" rx="2"/><path d="M2 8h20M6 18v3M18 18v3"/></svg>
              </div>
              <div>
                <h3 class="ux-card__title">Mostrador cliente</h3>
                <p class="ux-card__sub">VFD 2x20 · Posiflex PD-2607</p>
              </div>
            </div>
            <span class="ux-status-dot ux-status-dot--online"></span>
          </header>
          <div class="ux-card__body ux-text-xs ux-c-ink-3">
            <div class="ux-flex ux-justify-between"><span>Conexión</span><span style="color:var(--ux-ink);font-family:var(--ux-font-mono);">/dev/ttyUSB1 · 9600 8N1</span></div>
            <div style="display:flex;justify-content:space-between;margin-top:4px;"><span>Mensaje actual</span><span class="ux-c-ink">"Bienvenido"</span></div>
          </div>
          <footer class="ux-card__footer" style="display:flex;justify-content:flex-end;gap:6px;">
            <button class="ux-btn ux-btn--ghost ux-btn--sm">Enviar mensaje</button>
          </footer>
        </article>

        <article class="ux-card">
          <header class="ux-card__header">
            <div class="ux-flex ux-items-center ux-gap-2">
              <div style="width:36px;height:36px;border-radius:10px;background:color-mix(in oklch, var(--ux-ink-3) 18%, transparent);color:var(--ux-ink-3);display:grid;place-items:center;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="6" width="20" height="12" rx="2"/><path d="M6 10h.01M10 10h.01M14 10h.01M18 10h.01"/></svg>
              </div>
              <div>
                <h3 class="ux-card__title">TPV pago</h3>
                <p class="ux-card__sub">Sin emparejar</p>
              </div>
            </div>
            <span class="ux-status-dot ux-status-dot--offline"></span>
          </header>
          <div class="ux-card__body ux-text-xs ux-c-ink-3">
            <p class="ux-m-0">Conecta un datáfono compatible (Stripe Terminal, SumUp, Redsys) para cobrar con tarjeta integrado en el ticket.</p>
          </div>
          <footer class="ux-card__footer" style="display:flex;justify-content:flex-end;gap:6px;">
            <button class="ux-btn ux-btn--primary ux-btn--sm">Vincular datáfono</button>
          </footer>
        </article>

      </div>

      <!-- Bridge tweaks -->
      <article class="ux-card">
        <header class="ux-card__header">
          <div>
            <h3 class="ux-card__title">Ajustes del Bridge</h3>
            <p class="ux-card__sub">Conexión local entre el navegador y los periféricos</p>
          </div>
        </header>
        <div class="ux-card__body">
          <div class="ux-form-row">
            <div class="ux-field">
              <label class="ux-field__label">Puerto local</label>
              <input class="ux-input" type="number" min="1024" max="65535" data-bind="bridge.port"/>
              <span class="ux-field__hint">Por defecto 9100. Reinicia el Bridge si cambias este valor.</span>
            </div>
            <div class="ux-field">
              <label class="ux-field__label">Host del Bridge</label>
              <input class="ux-input" value="127.0.0.1"/>
            </div>
          </div>
          <div class="ux-toggle-row">
            <div class="ux-toggle-row__text">
              <span class="ux-toggle-row__label">Auto-print de tickets</span>
              <span class="ux-toggle-row__desc">Al cobrar, imprime automáticamente en la impresora predeterminada.</span>
            </div>
            <label class="ux-toggle"><input type="checkbox" data-bind="bridge.autoPrint"/><span class="ux-toggle__track"></span></label>
          </div>
          <div style="display:flex;justify-content:flex-end;padding-top:12px;">
            <button class="ux-btn ux-btn--secondary ux-btn--sm">Guardar ajustes</button>
          </div>
        </div>
      </article>

    </div>
  </div>
</div>
{% endblock %}
