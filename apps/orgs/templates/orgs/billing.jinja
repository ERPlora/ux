{% extends "_base_preview.html" %}

{% from "ui/button.jinja" import button %}
{% from "ui/badge.jinja" import badge %}
{% from "ui/card.jinja" import card, card_footer %}
{% from "ui/icon.jinja" import icon %}
{% from "ui/input.jinja" import input %}
{% from "ui/field.jinja" import field %}
{% from "ui/empty.jinja" import empty %}

{% block title %}ERPlora Cloud · Facturación · Acme Industries{% endblock %}

{% block head_extra %}
<style>
  body { background: var(--ux-bg); margin: 0; }
</style>
{% endblock %}

{% block body %}
<div class="ux-app" data-signals='{"sidebar": false, "regimen": "general"}' data-attr:data-sidebar="$sidebar ? 'open' : ''">
  <div class="ux-app__sidebar-overlay" data-on:click="$sidebar = false"></div>

  <aside class="ux-sidebar">
    <div class="ux-sidebar__brand">
      <div class="ux-sidebar__logo">EX</div>
      <div class="ux-sidebar__brand-text">
        <div class="ux-sidebar__brand-name">ERPlora Cloud</div>
        <div class="ux-sidebar__brand-meta">Panel global</div>
      </div>
    </div>
    <div class="ux-sidebar__body">
      <div class="ux-sidebar__group">Principal</div>
      <button class="ux-sidebar__item"><iconify-icon icon="lucide:layout-dashboard" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Vista general</span></button>
      <button class="ux-sidebar__item" aria-current="page"><iconify-icon icon="lucide:building-2" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Organizaciones</span></button>
      <button class="ux-sidebar__item"><iconify-icon icon="lucide:package" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Hubs</span><span class="ux-sidebar__badge">7</span></button>
      <button class="ux-sidebar__item"><iconify-icon icon="lucide:user" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Usuarios</span></button>
      <button class="ux-sidebar__item"><iconify-icon icon="lucide:credit-card" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Equipamiento</span></button>

      <div class="ux-sidebar__group">Facturación</div>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/></svg><span class="ux-sidebar__label">Facturas</span></button>
      <button class="ux-sidebar__item"><iconify-icon icon="lucide:menu" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Suscripciones</span></button>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"/></svg><span class="ux-sidebar__label">Pagos</span></button>

      <div class="ux-sidebar__group">Desarrollador</div>
      <button class="ux-sidebar__item"><iconify-icon icon="lucide:code" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Módulos</span></button>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 19c-5 1.5-5-2.5-7-3"/></svg><span class="ux-sidebar__label">Repositorios</span></button>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 17l10 5 10-5"/></svg><span class="ux-sidebar__label">Stripe Connect</span></button>
    </div>
    <div class="ux-sidebar__footer">
      <div class="ux-sidebar__user">
        <span class="ux-avatar ux-avatar--sm ux-avatar--brand">IB</span>
        <div class="ux-sidebar__user-info">
          <div class="ux-sidebar__user-name">Ioan Beilic</div>
          <div class="ux-sidebar__user-meta">ioan@acme.com</div>
        </div>
      </div>
    </div>
  </aside>

  <div class="ux-app__main">
    <header class="ux-topbar">
        <div class="ux-topbar__left">
          <button class="ux-topbar__back-btn" aria-label="Volver"
            data-on:click="history.length > 1 ? history.back() : null">
            <iconify-icon icon="lucide:arrow-left" width="2" height="2"></iconify-icon>
          </button>
        </div>
        <h1 class="ux-topbar__page-title">Facturación · Acme Industries</h1>
        
        <div class="ux-topbar__search">
        <iconify-icon icon="lucide:search" width="14" height="14"></iconify-icon>
        <input placeholder="Buscar facturas…"/>
        <span class="ux-topbar__kbd">⌘K</span>
      </div>
        
        <div class="ux-topbar__actions">
          <button class="ux-icon-btn" aria-label="Notificaciones"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/></svg></button>
        <span class="ux-avatar ux-avatar--sm ux-avatar--brand">IB</span>
        </div>
        <button class="ux-topbar__menu-btn" aria-label="Menú"
            data-on:click="$sidebar = !$sidebar"
            data-attr:aria-expanded="$sidebar">
            <iconify-icon icon="lucide:menu" width="2" height="2"></iconify-icon>
          </button>
      </header>

    <div class="ux-app__body">
      <div class="ux-page-header">
        <div class="ux-page-header__title">
          <h1>Facturación · Acme Industries</h1>
          <div class="ux-page-header__sub">Datos fiscales y método de cobro · CIF B-87654321</div>
        </div>
        <div class="ux-page-header__actions">
          <button class="ux-btn ux-btn--ghost">Cancelar</button>
          <button class="ux-btn ux-btn--primary">Guardar cambios</button>
        </div>
      </div>

      <div class="ux-banner ux-banner--info ux-mb-4">
        <span class="ux-banner__icon"><iconify-icon icon="lucide:info" width="16" height="16"></iconify-icon></span>
        <div class="ux-banner__body">
          <div class="ux-banner__title">Próxima factura: €890 con vencimiento el 15 may 2026</div>
          <div class="ux-banner__desc">Cualquier cambio en estos datos se aplicará a las facturas generadas desde mañana.</div>
        </div>
      </div>

      <div class="ux-grid-2 ux-mb-5">
        <article class="ux-card">
          <header class="ux-card__header">
            <div>
              <h3 class="ux-card__title">Datos fiscales</h3>
              <div class="ux-card__sub">Aparecen en cada factura emitida</div>
            </div>
          </header>
          <div class="ux-card__body">
            <div class="ux-form">
              <label class="ux-field">
                <span class="ux-field__label ux-field__label--req">Razón social</span>
                <input class="ux-input" value="Acme Industries SL"/>
              </label>
              <div class="ux-form-row">
                <label class="ux-field">
                  <span class="ux-field__label ux-field__label--req">CIF / NIF</span>
                  <input class="ux-input" value="B-87654321"/>
                </label>
                <label class="ux-field">
                  <span class="ux-field__label">IBAN para SEPA</span>
                  <input class="ux-input" value="ES76 0049 1500 0512 3456 7890"/>
                </label>
              </div>
              <label class="ux-field">
                <span class="ux-field__label ux-field__label--req">Dirección fiscal</span>
                <input class="ux-input" value="C/ Industria 24, nave 7"/>
              </label>
              <div class="ux-form-row">
                <label class="ux-field">
                  <span class="ux-field__label">Código postal</span>
                  <input class="ux-input" value="08940"/>
                </label>
                <label class="ux-field">
                  <span class="ux-field__label">Ciudad</span>
                  <input class="ux-input" value="Cornellà de Llobregat"/>
                </label>
              </div>
              <div class="ux-form-row">
                <label class="ux-field">
                  <span class="ux-field__label">Provincia</span>
                  <input class="ux-input" value="Barcelona"/>
                </label>
                <label class="ux-field">
                  <span class="ux-field__label ux-field__label--req">País</span>
                  <select class="ux-select">
                    <option selected>España</option>
                    <option>Portugal</option>
                    <option>Francia</option>
                    <option>Andorra</option>
                    <option>Italia</option>
                    <option>Alemania</option>
                  </select>
                </label>
              </div>
            </div>
          </div>
        </article>

        <article class="ux-card">
          <header class="ux-card__header">
            <div>
              <h3 class="ux-card__title">Contacto de facturación</h3>
              <div class="ux-card__sub">Persona que recibirá facturas y avisos de cobro</div>
            </div>
          </header>
          <div class="ux-card__body">
            <div class="ux-form">
              <label class="ux-field">
                <span class="ux-field__label ux-field__label--req">Nombre completo</span>
                <input class="ux-input" value="Anna Calvet i Roca"/>
              </label>
              <label class="ux-field">
                <span class="ux-field__label ux-field__label--req">Email</span>
                <input class="ux-input" type="email" value="facturacion@acme.com"/>
                <span class="ux-field__hint">Recibirá las facturas en PDF y avisos de cobro fallidos.</span>
              </label>
              <label class="ux-field">
                <span class="ux-field__label">Teléfono</span>
                <input class="ux-input" value="+34 933 21 04 87"/>
              </label>
              <label class="ux-field">
                <span class="ux-field__label">Idioma de la factura</span>
                <select class="ux-select">
                  <option selected>Español (España)</option>
                  <option>Català</option>
                  <option>English</option>
                  <option>Português</option>
                  <option>Français</option>
                </select>
              </label>
              <label class="ux-toggle-row">
                <div class="ux-toggle-row__text">
                  <span class="ux-toggle-row__label">Enviar copia a contabilidad</span>
                  <span class="ux-toggle-row__desc">contabilidad@acme.com recibirá copia automáticamente</span>
                </div>
                <span class="ux-toggle"><input type="checkbox" checked/><span class="ux-toggle__track"></span></span>
              </label>
            </div>
          </div>
        </article>
      </div>

      <div class="ux-section">
        <div class="ux-section__head">
          <div>
            <div class="ux-section__title">Método de pago por defecto</div>
            <div class="ux-section__sub">Se usará para los cobros recurrentes</div>
          </div>
          <button class="ux-btn ux-btn--secondary ux-btn--sm">+ Añadir método</button>
        </div>
        <article class="ux-card">
          <div class="ux-card__body" style="display:flex;justify-content:space-between;align-items:center;gap:18px;">
            <div style="display:flex;gap:14px;align-items:center;">
              <div style="width:54px;height:36px;border-radius:6px;background:linear-gradient(135deg,#1a1f71,#3548a8);display:grid;place-items:center;color:#fff;font-family:var(--ux-font-display);font-weight:700;letter-spacing:0.05em;font-size:11px;">VISA</div>
              <div>
                <div style="font-weight:500;color:var(--ux-ink);font-family:var(--ux-font-mono);letter-spacing:0.06em;">•••• •••• •••• 4242</div>
                <div style="font-size:12px;color:var(--ux-ink-3);margin-top:3px;">Vence 09/27 · Anna Calvet · <span class="ux-tag ux-tag--leaf ux-tag--xs">Predeterminada</span></div>
              </div>
            </div>
            <div class="ux-flex ux-gap-2">
              <button class="ux-btn ux-btn--ghost ux-btn--sm">Ver historial</button>
              <button class="ux-btn ux-btn--outline ux-btn--sm">Cambiar</button>
            </div>
          </div>
        </article>
      </div>

      <div class="ux-section">
        <div class="ux-section__head">
          <div>
            <div class="ux-section__title">Información fiscal extra</div>
            <div class="ux-section__sub">Configura regímenes especiales si aplican</div>
          </div>
        </div>
        <article class="ux-card">
          <div class="ux-card__body">
            <div class="ux-form">
              <label class="ux-field">
                <span class="ux-field__label">Régimen de IVA</span>
                <select class="ux-select">
                  <option selected>General — 21%</option>
                  <option>Reducido — 10%</option>
                  <option>Superreducido — 4%</option>
                  <option>Exento</option>
                  <option>Recargo de equivalencia</option>
                </select>
              </label>
              <div class="ux-field">
                <span class="ux-field__label">Régimen especial</span>
                <div class="ux-radio-group ux-radio-group--inline" style="gap:8px;">
                  <label class="ux-radio-card ux-flex-1">
                    <input type="radio" name="reg" data-on:click="$regimen = 'general'" checked/>
                    <div>
                      <div class="ux-radio-card__title">Régimen general</div>
                      <div class="ux-radio-card__desc">El más común para PYMEs.</div>
                    </div>
                  </label>
                  <label class="ux-radio-card ux-flex-1">
                    <input type="radio" name="reg" data-on:click="$regimen = 'rec'"/>
                    <div>
                      <div class="ux-radio-card__title">Recargo de equivalencia</div>
                      <div class="ux-radio-card__desc">Solo comercio minorista persona física.</div>
                    </div>
                  </label>
                  <label class="ux-radio-card ux-flex-1">
                    <input type="radio" name="reg" data-on:click="$regimen = 'rev'"/>
                    <div>
                      <div class="ux-radio-card__title">Inversión sujeto pasivo</div>
                      <div class="ux-radio-card__desc">Operaciones intracomunitarias.</div>
                    </div>
                  </label>
                  <label class="ux-radio-card ux-flex-1">
                    <input type="radio" name="reg" data-on:click="$regimen = 'rec_ag'"/>
                    <div>
                      <div class="ux-radio-card__title">Régimen agrario</div>
                      <div class="ux-radio-card__desc">Productores de origen agrícola.</div>
                    </div>
                  </label>
                </div>
              </div>
              <label class="ux-field">
                <span class="ux-field__label">Número EORI (opcional)</span>
                <input class="ux-input" value="ESB87654321" placeholder="ej. ESB12345678"/>
                <span class="ux-field__hint">Necesario para importaciones/exportaciones fuera de la UE.</span>
              </label>
            </div>
          </div>
          <footer class="ux-card__footer">
            <span class="ux-text-xs ux-c-ink-3">Cambios guardados automáticamente en el borrador</span>
            <div class="ux-flex ux-gap-2">
              <button class="ux-btn ux-btn--ghost">Restablecer</button>
              <button class="ux-btn ux-btn--primary">Guardar</button>
            </div>
          </footer>
        </article>
      </div>
    </div>
  </div>


  <!-- Bottom tab bar — mobile only via .ux-app__tabbar slot -->
  <nav class="ux-app__tabbar" aria-label="Navegación principal">
    <div class="ux-tabbar ux-tabbar--fixed ux-tabbar--icons">
      <a class="ux-tabbar-item" href="#" aria-current="page">
        <span class="ux-tabbar-icon"><iconify-icon icon="lucide:home" width="18" height="18"></iconify-icon></span>
        <span class="ux-tabbar-label">Inicio</span>
      </a>
      <a class="ux-tabbar-item" href="#">
        <span class="ux-tabbar-icon"><iconify-icon icon="lucide:credit-card" width="18" height="18"></iconify-icon></span>
        <span class="ux-tabbar-label">Hubs</span>
        <span class="ux-tabbar-badge">7</span>
      </a>
      <a class="ux-tabbar-item" href="#">
        <span class="ux-tabbar-icon"><iconify-icon icon="lucide:users" width="18" height="18"></iconify-icon></span>
        <span class="ux-tabbar-label">Usuarios</span>
      </a>
      <a class="ux-tabbar-item" href="#">
        <span class="ux-tabbar-icon"><iconify-icon icon="lucide:store" width="18" height="18"></iconify-icon></span>
        <span class="ux-tabbar-label">Equipo</span>
      </a>
      <a class="ux-tabbar-item" href="#">
        <span class="ux-tabbar-icon"><iconify-icon icon="lucide:user-circle" width="18" height="18"></iconify-icon></span>
        <span class="ux-tabbar-label">Perfil</span>
      </a>
    </div>
  </nav>
</div>
{% endblock %}
