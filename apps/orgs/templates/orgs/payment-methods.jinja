              </div>
            </div>
          </div>

          <div style="display:flex;flex-direction:column;gap:10px;opacity:0.6;">
            <div class="ux-loyalty ux-loyalty--gold is-disabled" style="--_w:100%;filter:grayscale(0.5);">
