{% extends "_base_preview.html" %}

{% from "ui/button.jinja" import button %}
{% from "ui/badge.jinja" import badge %}
{% from "ui/card.jinja" import card, card_footer %}
{% from "ui/icon.jinja" import icon %}
{% from "ui/input.jinja" import input %}
{% from "ui/field.jinja" import field %}
{% from "ui/empty.jinja" import empty %}

{% block title %}ERPlora Cloud · Organizaciones{% endblock %}

{% block head_extra %}
<style>
  body { background: var(--ux-bg); margin: 0; }
</style>
{% endblock %}

{% block body %}
<div class="ux-app" data-signals='{"sidebar": false, "view": "list"}' data-attr:data-sidebar="$sidebar ? 'open' : ''">
  <div class="ux-app__sidebar-overlay" data-on:click="$sidebar = false"></div>

  <aside class="ux-sidebar">
    <div class="ux-sidebar__brand">
      <div class="ux-sidebar__logo">EX</div>
      <div class="ux-sidebar__brand-text">
        <div class="ux-sidebar__brand-name">ERPlora Cloud</div>
        <div class="ux-sidebar__brand-meta">Panel global</div>
      </div>
    </div>
    <div class="ux-sidebar__body">
      <div class="ux-sidebar__group">Principal</div>
      <button class="ux-sidebar__item"><iconify-icon icon="lucide:layout-dashboard" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Vista general</span></button>
      <button class="ux-sidebar__item" aria-current="page"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 21h18M5 21V7l7-4 7 4v14M9 9h.01M9 13h.01M9 17h.01M15 9h.01M15 13h.01M15 17h.01"/></svg><span class="ux-sidebar__label">Organizaciones</span></button>
      <button class="ux-sidebar__item"><iconify-icon icon="lucide:package" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Hubs</span><span class="ux-sidebar__badge">7</span></button>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg><span class="ux-sidebar__label">Usuarios</span></button>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="6" width="20" height="14" rx="2"/><path d="M2 10h20"/></svg><span class="ux-sidebar__label">Equipamiento</span></button>

      <div class="ux-sidebar__group">Facturación</div>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6M16 13H8M16 17H8M10 9H8"/></svg><span class="ux-sidebar__label">Facturas</span></button>
      <button class="ux-sidebar__item"><iconify-icon icon="lucide:menu" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Suscripciones</span></button>
      <button class="ux-sidebar__item"><iconify-icon icon="lucide:credit-card" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Pagos</span></button>

      <div class="ux-sidebar__group">Desarrollador</div>
      <button class="ux-sidebar__item"><iconify-icon icon="lucide:code" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Módulos</span></button>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg><span class="ux-sidebar__label">Repositorios</span></button>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 17l10 5 10-5M2 12l10 5 10-5M12 2 2 7l10 5 10-5z"/></svg><span class="ux-sidebar__label">Stripe Connect</span></button>
    </div>
    <div class="ux-sidebar__footer">
      <div class="ux-sidebar__user">
        <span class="ux-avatar ux-avatar--sm ux-avatar--brand">IB</span>
        <div class="ux-sidebar__user-info">
          <div class="ux-sidebar__user-name">Ioan Beilic</div>
          <div class="ux-sidebar__user-meta">ioan@acme.com</div>
        </div>
      </div>
    </div>
  </aside>

  <div class="ux-app__main">
    <header class="ux-topbar">
        <div class="ux-topbar__left">
          <button class="ux-topbar__back-btn" aria-label="Volver"
            data-on:click="history.length > 1 ? history.back() : null">
            <iconify-icon icon="lucide:arrow-left" width="2" height="2"></iconify-icon>
          </button>
        </div>
        <h1 class="ux-topbar__page-title">Organizaciones</h1>
        
        <div class="ux-topbar__search">
        <iconify-icon icon="lucide:search" width="14" height="14"></iconify-icon>
        <input placeholder="Buscar organizaciones, hubs…"/>
        <span class="ux-topbar__kbd">⌘K</span>
      </div>
        
        <div class="ux-topbar__actions">
          <button class="ux-icon-btn" aria-label="Notificaciones"><iconify-icon icon="lucide:bell" width="14" height="14"></iconify-icon></button>
        <span class="ux-avatar ux-avatar--sm ux-avatar--brand">IB</span>
        </div>
        <button class="ux-topbar__menu-btn" aria-label="Menú"
            data-on:click="$sidebar = !$sidebar"
            data-attr:aria-expanded="$sidebar">
            <iconify-icon icon="lucide:menu" width="2" height="2"></iconify-icon>
          </button>
      </header>

    <div class="ux-app__body">
      <div class="ux-page-header">
        <div class="ux-page-header__title">
          <h1>Organizaciones</h1>
          <div class="ux-page-header__sub">4 organizaciones · 28 miembros · 12 hubs</div>
        </div>
        <div class="ux-page-header__actions">
          <button class="ux-btn ux-btn--ghost"><svg class="ux-btn__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>Exportar</button>
          <button class="ux-btn ux-btn--primary">+ Crear organización</button>
        </div>
      </div>

      <div class="ux-grid-3 ux-mb-4">
        <div class="ux-kpi">
          <div class="ux-kpi__label">Total organizaciones</div>
          <div class="ux-kpi__value">4</div>
          <div class="ux-kpi__delta ux-kpi__delta--up">+1 en mayo</div>
        </div>
        <div class="ux-kpi">
          <div class="ux-kpi__label">Total miembros</div>
          <div class="ux-kpi__value">28</div>
          <div class="ux-kpi__delta ux-kpi__delta--up">+4 esta semana</div>
        </div>
        <div class="ux-kpi">
          <div class="ux-kpi__label">Total hubs</div>
          <div class="ux-kpi__value">12</div>
          <div class="ux-kpi__delta">7 activos · 5 staging</div>
        </div>
      </div>

      <div class="ux-toolbar ux-mb-3">
        <div class="ux-search" style="flex:1;min-width:240px;max-width:360px;">
          <iconify-icon icon="lucide:search" width="2" height="2"></iconify-icon>
          <input class="ux-input" placeholder="Filtrar por nombre, sector, plan…"/>
        </div>
        <div class="ux-toolbar__spacer"></div>
        <div class="ux-toggle-group ux-toggle-group--sm">
          <button class="ux-toggle-group__option" data-on:click="$view = 'list'" data-class:is-selected="$view === 'list'">
            <iconify-icon icon="lucide:menu" width="2" height="2"></iconify-icon>Lista
          </button>
          <button class="ux-toggle-group__option" data-on:click="$view = 'grid'" data-class:is-selected="$view === 'grid'">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>Cuadrícula
          </button>
        </div>
        <button class="ux-btn ux-btn--secondary ux-btn--sm">
          <svg class="ux-btn__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 3H2l8 9.46V19l4 2v-8.54z"/></svg>Filtros
        </button>
        <select class="ux-select ux-select--sm ux-w-auto">
          <option>Más recientes</option>
          <option>A-Z</option>
          <option>Z-A</option>
          <option>Por plan</option>
          <option>Por miembros</option>
        </select>
      </div>

      <div class="ux-list ux-list--separated" data-show="$view === 'list'">
        <a class="ux-list__item" href="#" style="border-left:3px solid var(--ux-leaf);">
          <span class="ux-avatar ux-avatar--lg ux-avatar--brand">AC</span>
          <div class="ux-list__body">
            <div class="ux-list__title">
              Acme Industries SL
              <span class="ux-tag ux-tag--leaf ux-tag--sm">Tu organización</span>
              <span class="ux-badge ux-badge--brand">Owner</span>
            </div>
            <div class="ux-list__desc">Manufactura ligera · 12 miembros · 5 hubs</div>
          </div>
          <div class="ux-list__aside">
            <span class="ux-badge ux-badge--info">Business</span>
            <button class="ux-btn ux-btn--outline ux-btn--sm">Abrir</button>
          </div>
        </a>
        <a class="ux-list__item" href="#">
          <span class="ux-avatar ux-avatar--lg" style="background:#7B3F2A;color:#fff;">BC</span>
          <div class="ux-list__body">
            <div class="ux-list__title">
              Bodegas Casadejus
              <span class="ux-badge ux-badge--info">Admin</span>
            </div>
            <div class="ux-list__desc">Vinos y crianza · 7 miembros · 3 hubs</div>
          </div>
          <div class="ux-list__aside">
            <span class="ux-badge ux-badge--brand">Pro</span>
            <button class="ux-btn ux-btn--outline ux-btn--sm">Abrir</button>
          </div>
        </a>
        <a class="ux-list__item" href="#">
          <span class="ux-avatar ux-avatar--lg" style="background:#C7407A;color:#fff;">PM</span>
          <div class="ux-list__body">
            <div class="ux-list__title">
              Pastelerías Mariola
              <span class="ux-badge">Member</span>
            </div>
            <div class="ux-list__desc">Repostería artesanal · 6 miembros · 2 hubs</div>
          </div>
          <div class="ux-list__aside">
            <span class="ux-badge ux-badge--brand">Pro</span>
            <button class="ux-btn ux-btn--outline ux-btn--sm">Abrir</button>
          </div>
        </a>
        <a class="ux-list__item" href="#">
          <span class="ux-avatar ux-avatar--lg" style="background:#2A6B7B;color:#fff;">LP</span>
          <div class="ux-list__body">
            <div class="ux-list__title">
              Logística Peninsular
              <span class="ux-badge ux-badge--info">Admin</span>
            </div>
            <div class="ux-list__desc">Transporte y almacén · 3 miembros · 2 hubs</div>
          </div>
          <div class="ux-list__aside">
            <span class="ux-badge ux-badge--solid">Enterprise</span>
            <button class="ux-btn ux-btn--outline ux-btn--sm">Abrir</button>
          </div>
        </a>
      </div>

      <div class="ux-grid-2 ux-hidden" data-show="$view === 'grid'">
        <article class="ux-card">
          <header class="ux-card__header">
            <div style="display:flex;gap:12px;align-items:center;">
              <span class="ux-avatar ux-avatar--xl ux-avatar--brand">AC</span>
              <div>
                <div class="ux-card__title">Acme Industries SL</div>
                <div class="ux-card__sub">Manufactura ligera</div>
              </div>
            </div>
            <span class="ux-badge ux-badge--info">Business</span>
          </header>
          <div class="ux-card__body" style="display:flex;gap:16px;font-size:13px;color:var(--ux-ink-3);">
            <span><b class="ux-c-ink">12</b> miembros</span>
            <span><b class="ux-c-ink">5</b> hubs</span>
            <span class="ux-tag ux-tag--brand ux-tag--sm">Owner</span>
          </div>
          <footer class="ux-card__footer"><span class="ux-text-xs ux-c-ink-3">Última actividad hace 2 h</span><button class="ux-btn ux-btn--outline ux-btn--sm">Abrir</button></footer>
        </article>
        <article class="ux-card">
          <header class="ux-card__header">
            <div style="display:flex;gap:12px;align-items:center;">
              <span class="ux-avatar ux-avatar--xl" style="background:#7B3F2A;color:#fff;">BC</span>
              <div>
                <div class="ux-card__title">Bodegas Casadejus</div>
                <div class="ux-card__sub">Vinos y crianza</div>
              </div>
            </div>
            <span class="ux-badge ux-badge--brand">Pro</span>
          </header>
          <div class="ux-card__body" style="display:flex;gap:16px;font-size:13px;color:var(--ux-ink-3);">
            <span><b class="ux-c-ink">7</b> miembros</span>
            <span><b class="ux-c-ink">3</b> hubs</span>
            <span class="ux-tag ux-tag--info ux-tag--sm">Admin</span>
          </div>
          <footer class="ux-card__footer"><span class="ux-text-xs ux-c-ink-3">Última actividad hace 1 d</span><button class="ux-btn ux-btn--outline ux-btn--sm">Abrir</button></footer>
        </article>
      </div>
    </div>
  </div>


  <!-- Bottom tab bar — mobile only via .ux-app__tabbar slot -->
  <nav class="ux-app__tabbar" aria-label="Navegación principal">
    <div class="ux-tabbar ux-tabbar--fixed ux-tabbar--icons">
      <a class="ux-tabbar-item" href="#" aria-current="page">
        <span class="ux-tabbar-icon"><iconify-icon icon="lucide:home" width="18" height="18"></iconify-icon></span>
        <span class="ux-tabbar-label">Inicio</span>
      </a>
      <a class="ux-tabbar-item" href="#">
        <span class="ux-tabbar-icon"><iconify-icon icon="lucide:credit-card" width="18" height="18"></iconify-icon></span>
        <span class="ux-tabbar-label">Hubs</span>
        <span class="ux-tabbar-badge">7</span>
      </a>
      <a class="ux-tabbar-item" href="#">
        <span class="ux-tabbar-icon"><iconify-icon icon="lucide:users" width="18" height="18"></iconify-icon></span>
        <span class="ux-tabbar-label">Usuarios</span>
      </a>
      <a class="ux-tabbar-item" href="#">
        <span class="ux-tabbar-icon"><iconify-icon icon="lucide:store" width="18" height="18"></iconify-icon></span>
        <span class="ux-tabbar-label">Equipo</span>
      </a>
      <a class="ux-tabbar-item" href="#">
        <span class="ux-tabbar-icon"><iconify-icon icon="lucide:user-circle" width="18" height="18"></iconify-icon></span>
        <span class="ux-tabbar-label">Perfil</span>
      </a>
    </div>
  </nav>
</div>
{% endblock %}
