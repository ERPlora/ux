{% extends "_base_preview.html" %}

{% from "ui/button.jinja" import button %}
{% from "ui/badge.jinja" import badge %}
{% from "ui/card.jinja" import card, card_footer %}
{% from "ui/icon.jinja" import icon %}
{% from "ui/input.jinja" import input %}
{% from "ui/field.jinja" import field %}
{% from "ui/empty.jinja" import empty %}

{% block title %}ERPlora Cloud · Invitar miembros{% endblock %}

{% block head_extra %}
<style>
  body { background: var(--ux-bg); margin: 0; }
</style>
{% endblock %}

{% block body %}
<div class="ux-app" data-signals='{"sidebar": false, "emails": ['ana@ejemplo.com', 'bruno@ejemplo.com'], "current": ""}' data-attr:data-sidebar="$sidebar ? 'open' : ''">
  <div class="ux-app__sidebar-overlay" data-on:click="$sidebar = false"></div>

  <aside class="ux-sidebar">
    <div class="ux-sidebar__brand">
      <div class="ux-sidebar__logo">EX</div>
      <div class="ux-sidebar__brand-text">
        <div class="ux-sidebar__brand-name">ERPlora Cloud</div>
        <div class="ux-sidebar__brand-meta">Panel global</div>
      </div>
    </div>
    <div class="ux-sidebar__body">
      <div class="ux-sidebar__group">Principal</div>
      <button class="ux-sidebar__item"><iconify-icon icon="lucide:layout-dashboard" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Vista general</span></button>
      <button class="ux-sidebar__item" aria-current="page"><iconify-icon icon="lucide:building-2" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Organizaciones</span></button>
      <button class="ux-sidebar__item"><iconify-icon icon="lucide:package" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Hubs</span><span class="ux-sidebar__badge">7</span></button>
      <button class="ux-sidebar__item"><iconify-icon icon="lucide:user" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Usuarios</span></button>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="6" width="20" height="14" rx="2"/><path d="M2 10h20"/></svg><span class="ux-sidebar__label">Equipamiento</span></button>

      <div class="ux-sidebar__group">Facturación</div>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/></svg><span class="ux-sidebar__label">Facturas</span></button>
      <button class="ux-sidebar__item"><iconify-icon icon="lucide:menu" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Suscripciones</span></button>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"/></svg><span class="ux-sidebar__label">Pagos</span></button>

      <div class="ux-sidebar__group">Desarrollador</div>
      <button class="ux-sidebar__item"><iconify-icon icon="lucide:code" width="2" height="2"></iconify-icon><span class="ux-sidebar__label">Módulos</span></button>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 19c-5 1.5-5-2.5-7-3"/></svg><span class="ux-sidebar__label">Repositorios</span></button>
      <button class="ux-sidebar__item"><svg class="ux-sidebar__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 17l10 5 10-5"/></svg><span class="ux-sidebar__label">Stripe Connect</span></button>
    </div>
    <div class="ux-sidebar__footer">
      <div class="ux-sidebar__user">
        <span class="ux-avatar ux-avatar--sm ux-avatar--brand">IB</span>
        <div class="ux-sidebar__user-info">
          <div class="ux-sidebar__user-name">Ioan Beilic</div>
          <div class="ux-sidebar__user-meta">ioan@acme.com</div>
        </div>
      </div>
    </div>
  </aside>

  <div class="ux-app__main">
    <header class="ux-topbar">
        <div class="ux-topbar__left">
          <button class="ux-topbar__back-btn" aria-label="Volver"
            data-on:click="history.length > 1 ? history.back() : null">
            <iconify-icon icon="lucide:arrow-left" width="2" height="2"></iconify-icon>
          </button>
        </div>
        <h1 class="ux-topbar__page-title">Invitar miembros</h1>
        
        <div class="ux-topbar__search">
        <iconify-icon icon="lucide:search" width="14" height="14"></iconify-icon>
        <input placeholder="Buscar miembros…"/>
        <span class="ux-topbar__kbd">⌘K</span>
      </div>
        
        <div class="ux-topbar__actions">
          <button class="ux-icon-btn" aria-label="Notificaciones"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/></svg></button>
        <span class="ux-avatar ux-avatar--sm ux-avatar--brand">IB</span>
        </div>
        <button class="ux-topbar__menu-btn" aria-label="Menú"
            data-on:click="$sidebar = !$sidebar"
            data-attr:aria-expanded="$sidebar">
            <iconify-icon icon="lucide:menu" width="2" height="2"></iconify-icon>
          </button>
      </header>

    <div class="ux-app__body">
      <div class="ux-page-header">
        <div class="ux-page-header__title">
          <h1>Invitar a Acme Industries</h1>
          <div class="ux-page-header__sub">12 miembros actuales · 3 invitaciones pendientes</div>
        </div>
        <div class="ux-page-header__actions">
          <button class="ux-btn ux-btn--ghost">← Volver a la organización</button>
          <button class="ux-btn ux-btn--secondary">Importar CSV</button>
        </div>
      </div>

      <div class="ux-row ux-mb-5">
        <article class="ux-card ux-col-md-7 ux-col-lg-8">
          <header class="ux-card__header">
            <h3 class="ux-card__title">Nueva invitación</h3>
            <span class="ux-badge ux-badge--info"><span class="ux-badge__dot"></span>Hasta 50/día</span>
          </header>
          <div class="ux-card__body">
            <div class="ux-form">
              <label class="ux-field">
                <span class="ux-field__label ux-field__label--req">Direcciones de correo</span>
                <div class="ux-tag-input">
                  <template data-for="email in $emails" data-key="email">
                    <span class="ux-tag ux-tag--brand is-removable">
                      <span data-text="email">ana@ejemplo.com</span>
                      <button class="ux-tag__remove" data-on:click="$emails = $emails.filter(e => e !== email)" aria-label="Quitar">×</button>
                    </span>
                  </template>
                  <span class="ux-tag ux-tag--brand is-removable">
                    ana@ejemplo.com
                    <button class="ux-tag__remove" data-on:click="$emails = $emails.filter(e => e !== 'ana@ejemplo.com')" aria-label="Quitar">×</button>
                  </span>
                  <span class="ux-tag ux-tag--brand is-removable">
                    bruno@ejemplo.com
                    <button class="ux-tag__remove" data-on:click="$emails = $emails.filter(e => e !== 'bruno@ejemplo.com')" aria-label="Quitar">×</button>
                  </span>
                  <input data-bind:current placeholder="Escribe un email y pulsa Enter…"/>
                </div>
                <span class="ux-field__hint">Pega varios separados por comas. Soportamos hasta 200 invitaciones por lote.</span>
              </label>

              <label class="ux-field">
                <span class="ux-field__label">Rol</span>
                <select class="ux-select">
                  <option>Owner — control total, facturación incluida</option>
                  <option>Admin — administra equipo, hubs y permisos</option>
                  <option selected>Editor — crea y edita datos del negocio</option>
                  <option>Viewer — solo lectura</option>
                </select>
              </label>

              <label class="ux-field">
                <span class="ux-field__label">Mensaje opcional</span>
                <textarea class="ux-textarea" placeholder="Hola! Te invito a unirte a Acme Industries en ERPlora para que coordinemos la producción de mayo…"></textarea>
                <span class="ux-field__hint">Se incluirá en el correo de invitación junto a un enlace de aceptación.</span>
              </label>

              <label class="ux-toggle-row">
                <div class="ux-toggle-row__text">
                  <span class="ux-toggle-row__label">Forzar 2FA al unirse</span>
                  <span class="ux-toggle-row__desc">Se exige verificación en dos pasos antes del primer acceso</span>
                </div>
                <span class="ux-toggle"><input type="checkbox" checked/><span class="ux-toggle__track"></span></span>
              </label>
            </div>
          </div>
          <footer class="ux-card__footer">
            <span class="ux-text-xs ux-c-ink-3">Las invitaciones expiran en 7 días</span>
            <div class="ux-flex ux-gap-2">
              <button class="ux-btn ux-btn--ghost">Cancelar</button>
              <button class="ux-btn ux-btn--primary">
                <svg class="ux-btn__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 2 11 13M22 2l-7 20-4-9-9-4 20-7z"/></svg>
                Enviar invitación
              </button>
            </div>
          </footer>
        </article>

        <article class="ux-card ux-col-md-5 ux-col-lg-4">
          <header class="ux-card__header">
            <div>
              <h3 class="ux-card__title">Roles disponibles</h3>
              <div class="ux-card__sub">Permisos por defecto</div>
            </div>
          </header>
          <div class="ux-card__body ux-flex ux-col ux-gap-2">
            <div style="display:flex;gap:10px;align-items:flex-start;padding:10px;background:var(--ux-bg-3);border-radius:8px;">
              <span class="ux-badge ux-badge--brand ux-mt-1">Owner</span>
              <div style="font-size:12px;color:var(--ux-ink-2);">Control total, gestiona facturación y miembros. Solo 1 owner activo por organización.</div>
            </div>
            <div style="display:flex;gap:10px;align-items:flex-start;padding:10px;background:var(--ux-bg-3);border-radius:8px;">
              <span class="ux-badge ux-badge--info ux-mt-1">Admin</span>
              <div style="font-size:12px;color:var(--ux-ink-2);">Configura hubs, invita miembros, accede a todos los módulos. No facturación.</div>
            </div>
            <div style="display:flex;gap:10px;align-items:flex-start;padding:10px;background:var(--ux-bg-3);border-radius:8px;">
              <span class="ux-badge ux-mt-1">Editor</span>
              <div style="font-size:12px;color:var(--ux-ink-2);">Crea y edita datos operativos: productos, pedidos, partes de trabajo.</div>
            </div>
            <div style="display:flex;gap:10px;align-items:flex-start;padding:10px;background:var(--ux-bg-3);border-radius:8px;">
              <span class="ux-badge ux-mt-1">Viewer</span>
              <div style="font-size:12px;color:var(--ux-ink-2);">Solo lectura, ideal para auditores externos o partners.</div>
            </div>
          </div>
        </article>
      </div>

      <div class="ux-section">
        <div class="ux-section__head">
          <div>
            <div class="ux-section__title">Invitaciones pendientes</div>
            <div class="ux-section__sub">5 invitaciones gestionadas en los últimos 30 días</div>
          </div>
          <div class="ux-flex ux-gap-2">
            <button class="ux-btn ux-btn--ghost ux-btn--sm">Reenviar todas</button>
            <button class="ux-btn ux-btn--secondary ux-btn--sm">Exportar</button>
          </div>
        </div>

        <div class="ux-table-wrap">
          <div class="ux-table-scroll">
            <table class="ux-table">
              <thead>
                <tr>
                  <th>Email</th>
                  <th>Rol</th>
                  <th>Invitado el</th>
                  <th>Estado</th>
                  <th class="ux-text-right">Acciones</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>
                    <div class="ux-cell-rich">
                      <span class="ux-avatar" style="background:#7B3F2A;color:#fff;">CR</span>
                      <div class="ux-cell-rich__main">
                        <div class="ux-cell-rich__title">carla.ruiz@partner.es</div>
                        <div class="ux-cell-rich__sub">Invitada por Ioan Beilic</div>
                      </div>
                    </div>
                  </td>
                  <td><span class="ux-badge ux-badge--info">Admin</span></td>
                  <td class="ux-td--mono">02 may 2026</td>
                  <td><span class="ux-badge ux-badge--ok"><span class="ux-badge__dot"></span>Aceptada</span></td>
                  <td class="ux-text-right"><button class="ux-btn ux-btn--ghost ux-btn--sm">Ver perfil</button></td>
                </tr>
                <tr>
                  <td>
                    <div class="ux-cell-rich">
                      <span class="ux-avatar" style="background:#2A6B7B;color:#fff;">DG</span>
                      <div class="ux-cell-rich__main">
                        <div class="ux-cell-rich__title">david.guerrero@externo.com</div>
                        <div class="ux-cell-rich__sub">Invitado por Anna Calvet</div>
                      </div>
                    </div>
                  </td>
                  <td><span class="ux-badge">Editor</span></td>
                  <td class="ux-td--mono">04 may 2026</td>
                  <td><span class="ux-badge ux-badge--warn"><span class="ux-badge__dot"></span>Pendiente</span></td>
                  <td class="ux-text-right"><button class="ux-btn ux-btn--ghost ux-btn--sm">Reenviar</button> <button class="ux-btn ux-btn--ghost ux-btn--sm">Cancelar</button></td>
                </tr>
                <tr>
                  <td>
                    <div class="ux-cell-rich">
                      <span class="ux-avatar" style="background:#C7407A;color:#fff;">MS</span>
                      <div class="ux-cell-rich__main">
                        <div class="ux-cell-rich__title">marta.sanchez@auditoria.es</div>
                        <div class="ux-cell-rich__sub">Invitada por María Rovira</div>
                      </div>
                    </div>
                  </td>
                  <td><span class="ux-badge">Viewer</span></td>
                  <td class="ux-td--mono">05 may 2026</td>
                  <td><span class="ux-badge ux-badge--warn"><span class="ux-badge__dot"></span>Pendiente</span></td>
                  <td class="ux-text-right"><button class="ux-btn ux-btn--ghost ux-btn--sm">Reenviar</button> <button class="ux-btn ux-btn--ghost ux-btn--sm">Cancelar</button></td>
                </tr>
                <tr>
                  <td>
                    <div class="ux-cell-rich">
                      <span class="ux-avatar" style="background:#6E4DC4;color:#fff;">RV</span>
                      <div class="ux-cell-rich__main">
                        <div class="ux-cell-rich__title">raul.vidal@gmail.com</div>
                        <div class="ux-cell-rich__sub">Invitado por Ioan Beilic</div>
                      </div>
                    </div>
                  </td>
                  <td><span class="ux-badge">Editor</span></td>
                  <td class="ux-td--mono">28 abr 2026</td>
                  <td><span class="ux-badge ux-badge--danger"><span class="ux-badge__dot"></span>Rechazada</span></td>
                  <td class="ux-text-right"><button class="ux-btn ux-btn--ghost ux-btn--sm">Volver a invitar</button></td>
                </tr>
                <tr>
                  <td>
                    <div class="ux-cell-rich">
                      <span class="ux-avatar" style="background:#4F9D6E;color:#fff;">EP</span>
                      <div class="ux-cell-rich__main">
                        <div class="ux-cell-rich__title">elisabeth.puig@asesoria.cat</div>
                        <div class="ux-cell-rich__sub">Invitada por Anna Calvet</div>
                      </div>
                    </div>
                  </td>
                  <td><span class="ux-badge">Viewer</span></td>
                  <td class="ux-td--mono">12 abr 2026</td>
                  <td><span class="ux-badge"><span class="ux-badge__dot"></span>Expirada</span></td>
                  <td class="ux-text-right"><button class="ux-btn ux-btn--ghost ux-btn--sm">Reenviar</button></td>
                </tr>
              </tbody>
            </table>
          </div>
          <div class="ux-table-footer">
            <span>5 de 5 · página 1 de 1</span>
            <div class="ux-pagination">
              <button class="ux-pagination__btn" disabled>‹</button>
              <button class="ux-pagination__btn" aria-current="page">1</button>
              <button class="ux-pagination__btn" disabled>›</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>


  <!-- Bottom tab bar — mobile only via .ux-app__tabbar slot -->
  <nav class="ux-app__tabbar" aria-label="Navegación principal">
    <div class="ux-tabbar ux-tabbar--fixed ux-tabbar--icons">
      <a class="ux-tabbar-item" href="#" aria-current="page">
        <span class="ux-tabbar-icon"><iconify-icon icon="lucide:home" width="18" height="18"></iconify-icon></span>
        <span class="ux-tabbar-label">Inicio</span>
      </a>
      <a class="ux-tabbar-item" href="#">
        <span class="ux-tabbar-icon"><iconify-icon icon="lucide:credit-card" width="18" height="18"></iconify-icon></span>
        <span class="ux-tabbar-label">Hubs</span>
        <span class="ux-tabbar-badge">7</span>
      </a>
      <a class="ux-tabbar-item" href="#">
        <span class="ux-tabbar-icon"><iconify-icon icon="lucide:users" width="18" height="18"></iconify-icon></span>
        <span class="ux-tabbar-label">Usuarios</span>
      </a>
      <a class="ux-tabbar-item" href="#">
        <span class="ux-tabbar-icon"><iconify-icon icon="lucide:store" width="18" height="18"></iconify-icon></span>
        <span class="ux-tabbar-label">Equipo</span>
      </a>
      <a class="ux-tabbar-item" href="#">
        <span class="ux-tabbar-icon"><iconify-icon icon="lucide:user-circle" width="18" height="18"></iconify-icon></span>
        <span class="ux-tabbar-label">Perfil</span>
      </a>
    </div>
  </nav>
</div>
{% endblock %}
