{
  "name": "@erplora/ux",
  "version": "2.2.0",
  "description": "ERPlora UX · CSS-only semantic component library. Zero build for consumers, optional Datastar interactivity.",
  "type": "module",
  "main": "dist/erplora-ux.css",
  "style": "dist/erplora-ux.css",
  "exports": {
    ".": "./dist/erplora-ux.css",
    "./min": "./dist/erplora-ux.min.css",
    "./src": "./lib/css/ux.css"
  },
  "files": [
    "dist",
    "lib"
  ],
  "scripts": {
    "build": "node build.mjs",
    "watch": "node build.mjs --watch",
    "build:lightning": "node build.mjs && npx lightningcss --minify dist/erplora-ux.css -o dist/erplora-ux.min.css"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ERPlora/ux.git"
  },
  "homepage": "https://erplora.github.io/ux/",
  "license": "MIT",
  "keywords": ["css", "ui", "components", "erp", "pos", "datastar", "htmx"],
  "devDependencies": {
    "lightningcss-cli": "^1.30.0"
  }
}
