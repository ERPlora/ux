{% from "ui/card.jinja" import card, card_footer %}
{% from "ui/button.jinja" import button %}
{% from "ui/badge.jinja" import badge %}

{# Dashboard example page — uses ux-jinja macros. #}
{# Consumers can either include this file directly, or extend it through #}
{# the named block ``dashboard_content`` from a project-specific layout.  #}
{% block dashboard_content %}
<section class="ux-stack">
  <header>
    <h1>Dashboard</h1>
    <p>Sample landing page composed from ux-jinja macros.</p>
  </header>

  <div class="ux-grid-auto ux-grid-auto--lg">
    {% call card() %}
      <p>Active users</p>
      <p style="font-size:2rem;font-weight:700;margin:.25rem 0">1,284</p>
      <p>+12% vs last month</p>
    {% endcall %}

    {% call card() %}
      <p>Monthly revenue</p>
      <p style="font-size:2rem;font-weight:700;margin:.25rem 0">42,910 EUR</p>
      <p>+3.4% vs last month</p>
    {% endcall %}

    {% call card() %}
      <p>Open tickets</p>
      <p style="font-size:2rem;font-weight:700;margin:.25rem 0">17</p>
      <p>3 high priority</p>
    {% endcall %}
  </div>

  {% call card(title="Recent activity", subtitle="Last events across the workspace") %}
    <ul class="ux-list">
      <li class="ux-list__item">
        <span class="ux-list__body">Order #4821 paid</span>
        {{ badge("Paid", variant="ok") }}
      </li>
      <li class="ux-list__item">
        <span class="ux-list__body">Inventory low: SKU-114</span>
        {{ badge("Low stock", variant="warn") }}
      </li>
      <li class="ux-list__item">
        <span class="ux-list__body">Invoice INV-2031 issued</span>
        {{ badge("Issued", variant="info") }}
      </li>
      <li class="ux-list__item">
        <span class="ux-list__body">Refund processed for #4790</span>
        {{ badge("Refund", variant="danger") }}
      </li>
    </ul>
    {% call card_footer() %}
      {{ button("View all", variant="secondary") }}
      {{ button("Export", variant="ghost") }}
    {% endcall %}
  {% endcall %}
</section>
{% endblock %}
