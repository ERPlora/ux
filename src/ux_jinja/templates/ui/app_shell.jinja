{# app_shell(sidebar_signal, attrs)

   CSS root: .ux-app (lib/css/components/app-shell.css)
   The single, responsive outermost shell. Renders a left sidebar that is
   sticky on desktop and an offcanvas drawer on mobile (≤ 767 px), plus a
   right `.ux-app__main` column where a `page_shell()` belongs.

   The "mobile shell" pattern is the same component — there is no separate
   `mobile_shell` macro; this one is responsive via the library's CSS.

   Use as a block:

     {% call app_shell() %}
       {{ sidebar(...) }}
       <main class="ux-app__main">
         {% call page_shell(title="Sales", tabs=...) %}
           {% call content_shell() %}…{% endcall %}
         {% endcall %}
       </main>
     {% endcall %}

   Args:
     - sidebar_signal   Datastar signal name for the offcanvas state
                        (default "sidebar"). The companion `menu_btn`
                        inside `page_shell` toggles this signal.
     - sidebar_state    initial state — ""|"collapsed"|"hidden"
     - tabbar           when True reserves bottom padding for the
                        legacy mobile fixed tabbar (.ux-app__tabbar).
                        Most consumers will use `page_shell` with its
                        own inset tabbar instead and leave this False.
     - attrs            extra HTML attributes on the .ux-app root
#}
{% macro app_shell(sidebar_signal="sidebar", sidebar_state="", tabbar=False, attrs={}) %}
{%- set _sig = sidebar_signal -%}
<div class="ux-app"
  data-signals='{"{{ _sig }}": false}'
  data-attr:data-sidebar='{{ "$" ~ _sig }} ? "open" : "{{ sidebar_state|e }}"'
  {%- if tabbar %} data-tabbar="bottom"{% endif -%}
  {%- for k, v in attrs.items() %} {{ k }}="{{ v|e }}"{% endfor -%}>
  <div class="ux-app__sidebar-overlay" data-on:click="{{ '$' ~ _sig }} = false"></div>
  {%- if caller is defined %}{{ caller() }}{% endif -%}
</div>
{% endmacro %}
