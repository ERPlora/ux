{# spacer(size, block, divider, attrs)

   Flex spacer matching `.ux-spacer` in lib/css/components/layout-extra.css.
   Sizes: xs | sm | md (default) | lg | xl.
   `block=True`   -> adds `.ux-spacer--block` (full-width vertical spacing).
   `divider=True` -> adds `.ux-spacer--divider` (horizontal line spacer).
#}
{% macro spacer(size="md", block=False, divider=False, attrs={}) %}
{%- set classes = ["ux-spacer", "ux-spacer--" ~ size] -%}
{%- if block %}{%- do classes.append("ux-spacer--block") -%}{%- endif -%}
{%- if divider %}{%- do classes.append("ux-spacer--divider") -%}{%- endif -%}
<span class="{{ classes | join(' ') }}"
{%- for k, v in attrs.items() %} {{ k }}="{{ v|e }}"{% endfor -%} aria-hidden="true"></span>
{% endmacro %}
