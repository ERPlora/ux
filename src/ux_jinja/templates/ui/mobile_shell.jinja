{# mobile_shell(brand_initials, brand_name, brand_meta, nav_items, current_path, signals, attrs)
   Mobile app shell — ux-app with sidebar offcanvas + ux-tabbar bottom nav.

   Arguments:
     brand_initials -- 2-letter brand mark shown in .ux-sidebar__logo
     brand_name     -- app / company name
     brand_meta     -- small subtitle under the brand name
     nav_items      -- list of dicts: [{label, href, icon_svg, badge}]
                       badge is an optional count string
     current_path   -- marks the matching tabbar item with aria-current="page"
     signals        -- JSON-safe string for data-signals (controls sidebar open)
     attrs          -- escape-hatch dict on .ux-app

   Body content goes inside the {% call mobile_shell(...) %}...{% endcall %} block
   and is rendered inside .ux-app__body.
#}
{% macro mobile_shell(brand_initials="", brand_name="", brand_meta="",
                       nav_items=[], current_path="",
                       signals='{"sidebar": false}', attrs={}) %}
<div class='ux-app'
  data-signals='{{ signals }}'
  data-attr:data-sidebar='$sidebar ? "open" : ""'
  {%- for k, v in attrs.items() %} {{ k }}="{{ v|e }}"{% endfor -%}>
  <div class='ux-app__sidebar-overlay' data-on:click='$sidebar = false'></div>
  <aside class='ux-sidebar'>
    <div class='ux-sidebar__brand'>
      <div class='ux-sidebar__logo'>{{ brand_initials|e }}</div>
      <div class='ux-sidebar__brand-text'>
        <div class='ux-sidebar__brand-name'>{{ brand_name|e }}</div>
        <div class='ux-sidebar__brand-meta'>{{ brand_meta|e }}</div>
      </div>
    </div>
    <div class='ux-sidebar__body'>
      {%- for item in nav_items %}
      <button class='ux-sidebar__item'{% if item.href == current_path %} aria-current="page"{% endif %}>
        <span class='ux-sidebar__label'>{{ item.label|e }}</span>
        {%- if item.get("badge") %}<span class='ux-sidebar__badge'>{{ item.badge|e }}</span>{% endif %}
      </button>
      {%- endfor %}
    </div>
  </aside>
  <div class='ux-app__main'>
    <div class='ux-app__body'>
      {%- if caller is defined %}{{ caller() }}{% endif %}
    </div>
  </div>
  <nav class='ux-tabbar ux-app__tabbar ux-flex' aria-label='Nav principal'>
    {%- for item in nav_items %}
    <a class='ux-tabbar-item'{% if item.href == current_path %} aria-current="page"{% endif %}
       href='{{ item.href|e }}'>
      <span class='ux-tabbar-icon'>
        {{ item.get("icon_svg", "") }}
        {%- if item.get("badge") %}<span class='ux-tabbar-badge'>{{ item.badge|e }}</span>{% endif %}
      </span>
      <span class='ux-tabbar-label'>{{ item.label|e }}</span>
    </a>
    {%- endfor %}
  </nav>
</div>
{% endmacro %}
