{# chat(attrs)

   CSS from lib/css/components/chat.css:
     - ux-chat
   Children:
     list pane  : ux-chat__list, ux-chat__search, ux-chat__convs,
                  ux-chat__conv (--active, --unread),
                  ux-chat__conv-avatar (ux-chat__conv-online),
                  ux-chat__conv-body, ux-chat__conv-name,
                  ux-chat__conv-preview, ux-chat__conv-meta,
                  ux-chat__conv-time, ux-chat__conv-badge
     thread pane: ux-chat__thread, ux-chat__head, ux-chat__head-avatar,
                  ux-chat__head-info, ux-chat__head-name,
                  ux-chat__head-status (--online), ux-chat__head-actions,
                  ux-chat__messages, ux-chat__day, ux-chat__msg (--mine)

   Shell macro: pass the two panes via `caller is defined`.
#}
{% macro chat(attrs={}) %}
<div class="ux-chat"
{%- for k, v in attrs.items() %} {{ k }}="{{ v|e }}"{% endfor -%}>
{%- if caller is defined %}{{ caller() }}{% endif %}
</div>
{% endmacro %}
