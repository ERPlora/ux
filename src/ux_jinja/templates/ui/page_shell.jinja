{# page_shell(title, tabs, active_tab, content_id, sidebar_signal, back_href, attrs)

   CSS root: .ux-page-shell (lib/css/components/app-shell.css)
   Per-module shell loaded inside the right side of an `app_shell`. Built
   from three vertically-stacked layers:

     ┌─────────────────────────────────────────────┐
     │ topbar  (☰ menu_btn · ← back · title · …)   │
     ├─────────────────────────────────────────────┤
     │ content_shell  (id="content", swappable)    │
     ├─────────────────────────────────────────────┤
     │ tabbar  (secondary nav per module, inset)   │
     └─────────────────────────────────────────────┘

   Click handlers:
     - menu_btn (left)  toggles `$sidebar_signal` on the parent app_shell
     - back btn         goes back in history
     - tabbar items     fire Datastar `@get('/<module>/<tab>',
                        {target: '#<content_id>'})` so only the content
                        and the active tab refresh — the sidebar +
                        topbar header stay put. The active title is
                        bound to `$active_tab` and re-derived from the
                        tabs list.

   Args:
     - title         module title shown in the topbar
     - tabs          list of {key, label, icon, href}
     - active_tab    initial active key — also accepts `value_signal` form
                     ("$tab") if you want a live signal
     - content_id    id of the content_shell div (default "content")
     - sidebar_signal name of the signal exposed by the parent app_shell
                     (default "sidebar")
     - back_href     when set renders a back arrow that links here
     - actions       raw HTML rendered in topbar right slot
     - attrs         extra HTML attributes on the .ux-page-shell wrapper

   Use as a block — the caller body lands inside the content_shell.
#}
{% macro page_shell(title="", tabs=[], active_tab=None, content_id="content",
                    sidebar_signal="sidebar", back_href=None, actions=None, attrs={}) %}
{%- set _tabkey = "tab_" ~ content_id -%}
{%- set _initial = active_tab if active_tab is not none else (tabs[0].key if tabs else "") -%}
<section class="ux-page-shell"
  data-signals='{"{{ _tabkey }}": {{ _initial|tojson }}}'
{%- for k, v in attrs.items() %} {{ k }}="{{ v|e }}"{% endfor -%}>
  <header class="ux-topbar">
    <div class="ux-topbar__left">
      <button class="ux-menu-btn" type="button" aria-label="Menú lateral"
              data-on:click="{{ '$' ~ sidebar_signal }} = !{{ '$' ~ sidebar_signal }}">
        <span class="ux-menu-btn-lines">
          <span class="ux-menu-btn-line"></span>
          <span class="ux-menu-btn-line"></span>
          <span class="ux-menu-btn-line"></span>
        </span>
      </button>
      {%- if back_href -%}
      <a class="ux-topbar__back-btn" href="{{ back_href|e }}" aria-label="Volver">
        <iconify-icon icon="lucide:arrow-left" width="18" height="18"></iconify-icon>
      </a>
      {%- endif -%}
    </div>
    <h1 class="ux-topbar__page-title">{{ title|e }}</h1>
    <div class="ux-topbar__actions">
      {%- if actions %}{{ actions|safe }}{% endif -%}
    </div>
  </header>
  <div class="ux-content-shell" id="{{ content_id|e }}">
    {%- if caller is defined %}{{ caller() }}{% endif -%}
  </div>
  {%- if tabs -%}
  <nav class="ux-tabbar" aria-label="Navegación del módulo">
    {%- for t in tabs -%}
    <a class="ux-tabbar-item"
       {%- if t.href %} href="{{ t.href|e }}"{% endif %}
       data-on:click="{{ '$' ~ _tabkey }} = {{ t.key|tojson }}{% if t.href %}; @get({{ t.href|tojson }}, {target: '#{{ content_id|e }}'})
       {%- endif -%}"
       data-attr:aria-current='({{ "$" ~ _tabkey }} === {{ t.key|tojson }}) ? "page" : null'>
      {%- if t.icon -%}
      <span class="ux-tabbar-icon">
        {%- if t.icon.startswith("<") -%}{{ t.icon|safe }}
        {%- else -%}<iconify-icon icon="{{ t.icon|e }}" width="20" height="20"></iconify-icon>
        {%- endif -%}
        {%- if t.badge %}<span class="ux-tabbar-badge">{{ t.badge|e }}</span>{% endif -%}
      </span>
      {%- endif -%}
      <span class="ux-tabbar-label">{{ t.label|e }}</span>
    </a>
    {%- endfor -%}
  </nav>
  {%- endif -%}
</section>
{% endmacro %}
