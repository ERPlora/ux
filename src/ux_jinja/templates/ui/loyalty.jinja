{# loyalty(brand, name, num, tier, points, expires, variant, size, attrs)

   CSS root: .ux-loyalty (lib/css/components/commerce.css)
   Loyalty / membership card. Variants change the gradient.

   Variants: "" | brand | gold | silver | platinum
   Sizes:    "" | sm | lg
#}
{% macro loyalty(brand="ERPlora Cafe", name="", num="•••• 0184", tier="Member", points="0", expires=None, variant="brand", size="", attrs={}) %}
{%- set classes = ["ux-loyalty"] -%}
{%- if variant %}{%- do classes.append("ux-loyalty--" ~ variant) -%}{%- endif -%}
{%- if size %}{%- do classes.append("ux-loyalty--" ~ size) -%}{%- endif -%}
<div class="{{ classes | join(' ') }}"
{%- for k, v in attrs.items() %} {{ k }}="{{ v|e }}"{% endfor -%}>
  <div class="ux-loyalty__head">
    <span class="ux-loyalty__brand">{{ brand|e }}</span>
    <span class="ux-loyalty__tier-badge">{{ tier|e }}</span>
  </div>
  <div class="ux-loyalty__row">
    <div class="ux-loyalty__name">{{ name|e }}</div>
    <div class="ux-loyalty__points">
      <span class="ux-loyalty__points-value">{{ points|e }}</span>
      <span class="ux-loyalty__points-label">pts</span>
    </div>
  </div>
  <div class="ux-loyalty__row">
    <span class="ux-loyalty__num">{{ num|e }}</span>
    {%- if expires %}<span class="ux-loyalty__expires">vence {{ expires|e }}</span>{% endif -%}
  </div>
</div>
{% endmacro %}
