{# timeline(items, dense, attrs)

   Vertical timeline matching lib/css/components/timeline.css:

     <ul class="ux-timeline">
       <li class="ux-timeline__item">
         <span class="ux-timeline__dot ux-timeline__dot--brand"></span>
         <div class="ux-timeline__body">
           <div class="ux-timeline__head">
             <h5 class="ux-timeline__title">...</h5>
             <span class="ux-timeline__time">...</span>
           </div>
           <p class="ux-timeline__desc">...</p>
         </div>
       </li>
     </ul>

   `items` is a list of dicts. Recognised keys: `title`, `time` (or `date`),
   `desc` (or `description`), `variant` (brand|leaf|warn|danger|info).
#}
{% macro timeline(items=[], dense=False, attrs={}) %}
{%- set classes = ["ux-timeline"] -%}
{%- if dense %}{%- do classes.append("ux-timeline--dense") -%}{%- endif -%}
<ul class="{{ classes | join(' ') }}" style="list-style:none;padding:0;margin:0"
{%- for k, v in attrs.items() %} {{ k }}="{{ v|e }}"{% endfor -%}>
{%- for it in items -%}
  {%- set variant = it.get('variant') -%}
  {%- set time = it.get('time', it.get('date')) -%}
  {%- set desc = it.get('desc', it.get('description')) -%}
  {%- set dot_classes = ["ux-timeline__dot"] -%}
  {%- if variant %}{%- do dot_classes.append("ux-timeline__dot--" ~ variant) -%}{%- endif -%}
  <li class="ux-timeline__item">
    <span class="{{ dot_classes | join(' ') }}"></span>
    <div class="ux-timeline__body">
      <div class="ux-timeline__head">
        <h5 class="ux-timeline__title">{{ it.get('title', '')|e }}</h5>
{%- if time %}
        <span class="ux-timeline__time">{{ time|e }}</span>
{%- endif %}
      </div>
{%- if desc %}
      <p class="ux-timeline__desc">{{ desc|e }}</p>
{%- endif %}
    </div>
  </li>
{%- endfor %}
</ul>
{% endmacro %}
