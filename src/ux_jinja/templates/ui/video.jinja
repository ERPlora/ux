{# video(poster, title, duration, position, progress, size, attrs)

   CSS root: .ux-video (lib/css/components/multimedia.css)
   Custom video player chrome — poster image, play overlay, progress bar.
#}
{% macro video(poster=None, title="", duration="0:00", position="0:00", progress=0, size="", attrs={}) %}
{%- set classes = ["ux-video"] -%}
{%- if size %}{%- do classes.append("ux-video--" ~ size) -%}{%- endif -%}
<div class="{{ classes | join(' ') }}"
{%- for k, v in attrs.items() %} {{ k }}="{{ v|e }}"{% endfor -%}>
  {%- if poster -%}<div class="ux-video__poster" style="background-image:url('{{ poster|e }}');"></div>{%- endif -%}
  <button type="button" class="ux-video__play-overlay" aria-label="Reproducir">
    <iconify-icon icon="lucide:play" width="32" height="32"></iconify-icon>
  </button>
  <div class="ux-video__controls">
    <button type="button" class="ux-video__btn" aria-label="Reproducir"><iconify-icon icon="lucide:play" width="14" height="14"></iconify-icon></button>
    <div class="ux-video__progress"><div class="ux-video__progress-fill" style="width:{{ progress }}%;"></div></div>
    <span class="ux-video__time">{{ position|e }} / {{ duration|e }}</span>
    <button type="button" class="ux-video__fullscreen" aria-label="Pantalla completa"><iconify-icon icon="lucide:maximize-2" width="14" height="14"></iconify-icon></button>
  </div>
</div>
{% endmacro %}
