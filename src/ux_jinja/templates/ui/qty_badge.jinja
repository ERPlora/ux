{# qty_badge(label, variant, size, attrs)

   CSS root: .ux-qty-badge (lib/css/components/forms-extra.css)
   Numeric pill — smaller and more "tabular" than `badge`. Designed to sit
   on top of icons (cart count, inbox unread, tabbar item).

   Args:
     - label    text/number to display
     - variant  "" (default brand) | "leaf" | "warn" | "danger"
     - size     "" | "xs" | "sm"
     - attrs    extra HTML attributes
#}
{% macro qty_badge(label, variant="", size="", attrs={}) %}
{%- set classes = ["ux-qty-badge"] -%}
{%- if variant %}{%- do classes.append("ux-qty-badge--" ~ variant) -%}{%- endif -%}
{%- if size %}{%- do classes.append("ux-qty-badge--" ~ size) -%}{%- endif -%}
<span class="{{ classes | join(' ') }}"
{%- for k, v in attrs.items() %} {{ k }}="{{ v|e }}"{% endfor -%}>{{ label|e }}</span>
{% endmacro %}
