{# icon(name, size, attrs)

   Iconify wrapper — emits `<iconify-icon>` declaratively. The host page is
   expected to load Iconify (CDN or vendored) so the custom element resolves.

   `name`  : Iconify identifier, e.g. "ion:home-outline".
   `size`  : pixel size (number) applied to width/height; defaults to 20.
#}
{% macro icon(name, size=20, attrs={}) %}
<iconify-icon icon="{{ name|e }}" width="{{ size }}" height="{{ size }}"
{%- for k, v in attrs.items() %} {{ k }}="{{ v|e }}"{% endfor -%}></iconify-icon>
{% endmacro %}
