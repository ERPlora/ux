{# pill(label, variant, attrs)

   CSS root from lib/css/components/avatar.css:  .ux-pill
   Status tag with a leading coloured dot. Lighter than .ux-badge — no solid fill.

   Variants (verified dot colours in avatar.css):
     - ok      green dot (leaf token)
     - warn    amber dot
     - danger  red dot
     - brand   brand dot
     - info    info dot
     (default: neutral grey dot)

   Args:
     - label    text displayed after the dot
     - variant  tone string from list above (default: "")
     - dot      when False suppresses the dot span (default True)
     - attrs    extra HTML attributes on the root span
#}
{% macro pill(label="", variant="", dot=True, attrs={}) %}
{%- set classes = ["ux-pill"] -%}
{%- if variant %}{%- do classes.append("ux-pill--" ~ variant) -%}{%- endif -%}
<span class="{{ classes | join(' ') }}"
{%- for k, v in attrs.items() %} {{ k }}="{{ v|e }}"{% endfor -%}>
{%- if dot %}<span class="ux-pill__dot"></span>{%- endif -%}
{{ label|e -}}
</span>
{% endmacro %}
