{# datepicker(name, value, min, max, value_signal, disabled, attrs)

   Date input — uses native `<input type="date">` so it stays accessible and
   testable. The `.ux-datepicker` token from lib/css/components/forms-advanced.css
   is applied to a wrapping span so the existing field/popover styling can be
   layered later without changing the macro contract.
#}
{% macro datepicker(name, value=None, min=None, max=None, value_signal=None, disabled=False, attrs={}) %}
<span class="ux-datepicker">
  <input class="ux-input"
    type="date"
    name="{{ name|e }}"
{%- if value is not none and value != "" %} value="{{ value|e }}"{% endif -%}
{%- if min %} min="{{ min|e }}"{% endif -%}
{%- if max %} max="{{ max|e }}"{% endif -%}
{%- if disabled %} disabled{% endif -%}
{%- if value_signal %} data-bind="{{ value_signal|e }}"{% endif -%}
{%- for k, v in attrs.items() %} {{ k }}="{{ v|e }}"{% endfor -%}/>
</span>
{% endmacro %}
