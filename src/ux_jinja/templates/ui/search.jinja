{# search(name, value, placeholder, value_signal, on_input, kbd, attrs)

   Search input wrapper matching lib/css/components/forms.css:

     <div class="ux-search">
       <svg class="ux-search__icon"/>
       <input class="ux-input"/>
       <kbd class="ux-search__kbd">⌘K</kbd>      (optional)
     </div>

   `kbd` overrides the keyboard hint label; pass an empty string to hide it.
#}
{% macro search(name="q", value="", placeholder="Search...", value_signal=None, on_input=None, kbd=None, attrs={}) %}
<div class="ux-search"
{%- for k, v in attrs.items() %} {{ k }}="{{ v|e }}"{% endfor -%}>
  <svg class="ux-search__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>
  <input class="ux-input"
    type="search"
    name="{{ name|e }}"
{%- if value %} value="{{ value|e }}"{% endif -%}
{%- if placeholder %} placeholder="{{ placeholder|e }}"{% endif -%}
{%- if value_signal %} data-bind="{{ value_signal|e }}"{% endif -%}
{%- if on_input %} data-on:input="{{ on_input|e }}"{% endif -%}/>
{%- if kbd %}
  <kbd class="ux-search__kbd">{{ kbd|e }}</kbd>
{%- endif %}
</div>
{% endmacro %}
