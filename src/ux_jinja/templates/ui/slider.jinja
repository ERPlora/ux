{# slider(name, value, min, max, step, variant, value_signal, disabled, attrs)

   Rich slider styled by `.ux-slider` in lib/css/components/forms-extra.css.
   Variants: leaf | warn | danger (no class for default).
   `value_signal` -> Datastar `data-bind="$signal"` two-way binding.
#}
{% macro slider(name, value=None, min=0, max=100, step=1, variant=None, value_signal=None, disabled=False, attrs={}) %}
{%- set classes = ["ux-slider"] -%}
{%- if variant %}{%- do classes.append("ux-slider--" ~ variant) -%}{%- endif -%}
<input class="{{ classes | join(' ') }}"
  type="range"
  name="{{ name|e }}"
  min="{{ min }}"
  max="{{ max }}"
  step="{{ step }}"
{%- if value is not none %} value="{{ value }}"{% endif -%}
{%- if disabled %} disabled{% endif -%}
{%- if value_signal %} data-bind="{{ value_signal|e }}"{% endif -%}
{%- for k, v in attrs.items() %} {{ k }}="{{ v|e }}"{% endfor -%}/>
{% endmacro %}
