{# menu_btn(label, on_click, mobile_only, attrs)

   CSS root: .ux-menu-btn (lib/css/components/menu-btn.css)
   Three-line burger toggle. Pair with a Datastar signal to drive a sidebar
   or drawer (e.g. on_click="$sidebar = !$sidebar").

   Args:
     - label        aria-label (default "Menu")
     - on_click     Datastar expression for data-on:click
     - mobile_only  add .ux-menu-btn--mobile-only modifier
     - pressed      sets aria-pressed="true"
     - attrs        extra HTML attributes
#}
{% macro menu_btn(label="Menu", on_click=None, mobile_only=False, pressed=False, attrs={}) %}
{%- set classes = ["ux-menu-btn"] -%}
{%- if mobile_only %}{%- do classes.append("ux-menu-btn--mobile-only") -%}{%- endif -%}
<button class="{{ classes | join(' ') }}" type="button"
  aria-label="{{ label|e }}"
{%- if pressed %} aria-pressed="true"{%- endif -%}
{%- if on_click %} data-on:click="{{ on_click|e }}"{%- endif -%}
{%- for k, v in attrs.items() %} {{ k }}="{{ v|e }}"{% endfor -%}>
  <span class="ux-menu-btn-lines">
    <span class="ux-menu-btn-line"></span>
    <span class="ux-menu-btn-line"></span>
    <span class="ux-menu-btn-line"></span>
  </span>
</button>
{% endmacro %}
