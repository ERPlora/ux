{# tabbar(items, signal=None, current_path=None, variant=None, fixed=False,
           inset=False, attrs={})

   CSS root from lib/css/components/tab-bar.css: .ux-tabbar
   Mobile-first bottom navigation. Matches previews/components/tabbar.html
   exactly.

   Variants (verified in tab-bar.css):
     - indicator   .ux-tabbar--indicator   iOS-style top indicator on active item
     - pill        .ux-tabbar--pill        Material-style pill background on active
     - icons       .ux-tabbar--icons       icons only, labels hidden
   Modifiers:
     - fixed       .ux-tabbar--fixed       sticks the bar to the bottom of viewport
     - inset       .ux-tabbar--inset       extra padding for safe-area inset

   Two activation modes:

   1. Signal-driven (default — same as the public preview):
      Pass `signal="$tab"` and each item carries a `key` value. Click toggles
      the signal; aria-current is reactive.

      tabbar(signal="$tab", items=[
          {"key": "inicio", "label": "Inicio", "icon": "..."},
          {"key": "cobros", "label": "Cobros", "icon": "...", "badge": "3"},
      ])

   2. Route-driven (for full-page apps):
      Pass `current_path` and each item carries `href`. The matching item gets
      aria-current="page" statically; the click navigates via history push.

      tabbar(current_path="/billing", items=[
          {"label": "Inicio", "href": "/", "icon": "..."},
          ...
      ])

   Item shape (signal mode):  {key, label, icon, badge}
   Item shape (route  mode):  {label, href, icon, badge}

   `icon` is either an Iconify identifier (rendered as <iconify-icon>) OR an
   inline SVG markup string (rendered as Markup). Inline SVGs match the
   public preview byte-for-byte.
#}
{% macro tabbar(items=[], signal=None, current_path=None, variant=None,
                fixed=False, inset=False, attrs={}) %}
{%- set classes = ["ux-tabbar"] -%}
{%- if variant %}{%- do classes.append("ux-tabbar--" ~ variant) -%}{%- endif -%}
{%- if fixed %}{%- do classes.append("ux-tabbar--fixed") -%}{%- endif -%}
{%- if inset %}{%- do classes.append("ux-tabbar--inset") -%}{%- endif -%}
<nav class="{{ classes | join(' ') }}" aria-label="Main navigation"
{%- for k, v in attrs.items() %} {{ k }}="{{ v|e }}"{% endfor -%}>
{%- for item in items %}
  {%- set is_current = (current_path is not none and item.href is defined and item.href == current_path) -%}
  <a class="ux-tabbar-item"
    {%- if signal and item.key is defined %}
     data-on:click='{{ signal }} = "{{ item.key|e }}"'
     data-attr:aria-current='{{ signal }} === "{{ item.key|e }}" ? "page" : null'
    {%- elif item.href is defined %}
     href="{{ item.href|e }}"
     data-on:click="@get('{{ item.href|e }}', {history: 'push'})"
     {%- if is_current %} aria-current="page"{% endif -%}
    {%- endif -%}>
    <span class="ux-tabbar-icon">
      {%- if item.icon is defined and item.icon -%}
        {%- if "<svg" in item.icon -%}
          {{ item.icon|safe }}
        {%- else -%}
          <iconify-icon icon="{{ item.icon|e }}" width="22" height="22"></iconify-icon>
        {%- endif -%}
      {%- endif -%}
      {%- if item.badge is defined and item.badge %}<span class="ux-tabbar-badge">{{ item.badge|e }}</span>{% endif %}
    </span>
    <span class="ux-tabbar-label">{{ item.label|e }}</span>
  </a>
{%- endfor %}
</nav>
{% endmacro %}
