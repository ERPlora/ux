{# signature(label, hint, attrs)

   CSS root: .ux-signature (lib/css/components/feedback-extra.css)
   Signature pad shell — the SVG capture surface plus a "Limpiar" / "Aceptar"
   action row. The actual stroke-capture JS is left to the consumer.

   Args:
     - label  caption text under the line
     - hint   small text shown below
#}
{% macro signature(label="Firma del cliente", hint="Firma con el dedo o el ratón.", attrs={}) %}
<div class="ux-signature"
{%- for k, v in attrs.items() %} {{ k }}="{{ v|e }}"{% endfor -%}>
  <svg class="ux-signature__svg" viewBox="0 0 600 200" preserveAspectRatio="none" aria-hidden="true">
    <line class="ux-signature__line" x1="40" y1="160" x2="560" y2="160"
          stroke="currentColor" stroke-dasharray="4 4" opacity="0.4"/>
    <text class="ux-signature__hint-x" x="40" y="180" font-size="12">×</text>
  </svg>
  <div class="ux-signature__hint">
    <span>{{ label|e }}</span>
    {%- if hint %}<span style="opacity:0.6;">{{ hint|e }}</span>{% endif -%}
  </div>
  <div class="ux-signature__actions">
    <button type="button" class="ux-btn ux-btn--ghost ux-btn--sm">Limpiar</button>
    <button type="button" class="ux-btn ux-btn--primary ux-btn--sm">Aceptar</button>
  </div>
</div>
{% endmacro %}
