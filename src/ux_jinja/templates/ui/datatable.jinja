{# datatable(id, columns, rows, search, search_placeholder, filters, date_range,
            page_sizes, page_size, view_toggle, io_icons, primary_action,
            pagination, grid_template, attrs)

   Full-featured datatable macro matching previews/components/datatable.html.

   columns  — list of strings or dicts {key, label, sortable=False, align=None}
   rows     — list of dicts keyed by column key, or list of lists

   filters  — list of {name, label, options=[], value=None}
              renders as <select> elements in the toolbar

   date_range — {label, from_label, to_label}
                renders the .ux-date-range label with calendar icon

   page_sizes — list of ints for the per-page select (default [10, 25, 50, 100])
   page_size  — currently selected value (default 25)

   view_toggle    — adds table/grid toggle buttons; binds $<id>_view signal
   io_icons       — adds Import / Export / More icon buttons
   primary_action — {label, on_click=None, href=None, icon=None}

   pagination — renders .ux-table-footer with dummy pagination controls

   grid_template — caller block; if provided, the grid view iterates rows and
                   calls this block once per row passing the row as `row`.
                   If not provided, a simple card with key/value fields is used.

   Datastar signals initialised:
     $<id>_q     (when search=True)
     $<id>_view  (when view_toggle=True, default "table")
     $<id>_<filter.name> for each filter entry
#}
{% macro datatable(
    id,
    columns=[],
    rows=[],
    search=True,
    search_placeholder="Buscar...",
    filters=[],
    date_range=None,
    page_sizes=[10, 25, 50, 100],
    page_size=25,
    view_toggle=True,
    io_icons=True,
    primary_action=None,
    pagination=True,
    grid_template=None,
    attrs={}
) %}
{%- set view_signal  = "$" ~ id ~ "_view" -%}
{%- set q_signal     = "$" ~ id ~ "_q" -%}
{%- set norm_cols = [] -%}
{%- for col in columns -%}
  {%- if col is mapping -%}
    {%- do norm_cols.append({
      "key":      col.key    | default(loop.index0),
      "label":    col.label  | default(""),
      "sortable": col.sortable | default(false),
      "align":    col.align  | default(None),
    }) -%}
  {%- else -%}
    {%- do norm_cols.append({"key": loop.index0, "label": col, "sortable": false, "align": None}) -%}
  {%- endif -%}
{%- endfor -%}
{%- set sig_parts = [] -%}
{%- if search -%}{%- do sig_parts.append('"' ~ id ~ '_q": ""') -%}{%- endif -%}
{%- if view_toggle -%}{%- do sig_parts.append('"' ~ id ~ '_view": "table"') -%}{%- endif -%}
{%- for f in filters -%}
  {%- do sig_parts.append('"' ~ id ~ '_' ~ f.name ~ '": "' ~ (f.value | default("")) ~ '"') -%}
{%- endfor -%}
<div class="ux-table-wrap" id="{{ id | e }}"
  {%- if sig_parts %} data-signals='{ {{ sig_parts | join(", ") }} }'{% endif -%}
  {%- for k, v in attrs.items() %} {{ k }}="{{ v | e }}"{% endfor -%}>

  <!-- Toolbar -->
  <div class="ux-dt-toolbar">
    {%- if search %}
    <div class="ux-search" style="flex:1 1 220px;max-width:300px">
      <svg class="ux-search__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>
      <input class="ux-input ux-input--sm" type="search" placeholder="{{ search_placeholder | e }}" data-bind="{{ q_signal | e }}"/>
    </div>
    {%- endif %}
    {%- for f in filters %}
    <select class="ux-select ux-select--sm" style="width:auto;min-width:130px" data-bind='${{ id }}_{{ f.name }}'>
      <option value="">{{ f.label | e }}</option>
      {%- for opt in f.options %}
      <option value="{{ opt.value | default(opt) | e }}"{% if f.value and (opt.value | default(opt)) == f.value %} selected{% endif %}>{{ opt.label | default(opt) | e }}</option>
      {%- endfor %}
    </select>
    {%- endfor %}
    {%- if date_range %}
    <label class="ux-date-range" title="{{ date_range.label | default('Rango de fechas') | e }}">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
      <span>{{ date_range.from_label | e }}</span>
      <span class="ux-date-range__sep">→</span>
      <span>{{ date_range.to_label | e }}</span>
    </label>
    {%- endif %}
    <div class="ux-dt-toolbar__spacer"></div>
    <select class="ux-select ux-select--sm" style="width:auto;min-width:64px" title="Por página">
      {%- for ps in page_sizes %}
      <option{% if ps == page_size %} selected{% endif %}>{{ ps }}</option>
      {%- endfor %}
    </select>
    {%- if view_toggle %}
    <div class="ux-dt-toolbar__divider"></div>
    <div class="ux-view-toggle" role="tablist" aria-label="Vista">
      <button type="button" class="ux-view-toggle__btn" data-on:click='{{ view_signal }} = "table"' data-attr:aria-pressed='{{ view_signal }} === "table"' title="Vista tabla">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
      </button>
      <button type="button" class="ux-view-toggle__btn" data-on:click='{{ view_signal }} = "grid"' data-attr:aria-pressed='{{ view_signal }} === "grid"' title="Vista cuadrícula">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
      </button>
    </div>
    {%- endif %}
    {%- if io_icons %}
    <div class="ux-dt-toolbar__divider"></div>
    <button type="button" class="ux-icon-btn" title="Importar">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
    </button>
    <button type="button" class="ux-icon-btn" title="Exportar">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
    </button>
    <button type="button" class="ux-icon-btn" title="Mas opciones">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/></svg>
    </button>
    {%- endif %}
    {%- if primary_action %}
    <div class="ux-dt-toolbar__divider"></div>
    {%- if primary_action.href %}
    <a href="{{ primary_action.href | e }}" class="ux-btn ux-btn--primary ux-btn--sm">{{ primary_action.label | e }}</a>
    {%- else %}
    <button type="button" class="ux-btn ux-btn--primary ux-btn--sm"
      {%- if primary_action.on_click %} data-on:click="{{ primary_action.on_click | e }}"{% endif %}>{{ primary_action.label | e }}</button>
    {%- endif %}
    {%- endif %}
  </div>

  <!-- Vista tabla -->
  <div class="ux-table-scroll"{% if view_toggle %} data-show='{{ view_signal }} === "table"'{% endif %}>
    <table class="ux-table">
      <thead>
        <tr>
          {%- for col in norm_cols %}
          {%- set th_classes = [] -%}
          {%- if col.sortable -%}{%- do th_classes.append("ux-th--sortable") -%}{%- endif -%}
          {%- if col.align == "right" -%}{%- do th_classes.append("ux-td--right") -%}{%- endif -%}
          <th{% if th_classes %} class="{{ th_classes | join(' ') }}"{% endif %}>{{ col.label | e }}</th>
          {%- endfor %}
        </tr>
      </thead>
      <tbody>
        {%- for row in rows %}
        <tr>
          {%- for col in norm_cols -%}
          {%- if row is mapping -%}
            {%- set cell = row.get(col.key, "") -%}
          {%- else -%}
            {%- set cell = row[loop.index0] if loop.index0 < (row | length) else "" -%}
          {%- endif -%}
          {%- set td_classes = [] -%}
          {%- if col.align == "right" -%}{%- do td_classes.append("ux-td--right") -%}{%- endif -%}
          <td{% if td_classes %} class="{{ td_classes | join(' ') }}"{% endif %}>
            {%- if cell is mapping and cell.badge is defined -%}
              <span class="ux-badge{% if cell.variant %} ux-badge--{{ cell.variant | e }}{% endif %}">{{ cell.label | e }}</span>
            {%- elif cell is string -%}
              {{ cell | e }}
            {%- else -%}
              {{ cell | e }}
            {%- endif -%}
          </td>
          {%- endfor %}
        </tr>
        {%- endfor %}
      </tbody>
    </table>
  </div>

  <!-- Vista grid -->
  {%- if view_toggle %}
  <div class="ux-dt-grid" data-show='{{ view_signal }} === "grid"'>
    {%- if grid_template %}
      {%- for row in rows %}{{ grid_template(row) }}{%- endfor %}
    {%- else %}
      {%- for row in rows %}
      <article class="ux-dt-card">
        <header class="ux-dt-card__head">
          <div class="ux-dt-card__title">{{ (row[norm_cols[0].key] if norm_cols else "") | e }}</div>
        </header>
        <div class="ux-dt-card__body">
          {%- for col in norm_cols %}
          <div class="ux-dt-card__field">
            <span>{{ col.label | e }}</span>
            <strong>
              {%- if row is mapping -%}
                {%- set cell = row.get(col.key, "") -%}
              {%- else -%}
                {%- set cell = row[loop.index0] if loop.index0 < (row | length) else "" -%}
              {%- endif -%}
              {{ cell | e }}
            </strong>
          </div>
          {%- endfor %}
        </div>
      </article>
      {%- endfor %}
    {%- endif %}
  </div>
  {%- endif %}

  {%- if pagination %}
  <div class="ux-table-footer">
    <div></div>
    <nav class="ux-pagination" aria-label="Paginacion">
      <button class="ux-pagination__btn" disabled>‹</button>
      <button class="ux-pagination__btn" aria-current="page">1</button>
      <button class="ux-pagination__btn">2</button>
      <button class="ux-pagination__btn">3</button>
      <span class="ux-pagination__ellipsis">…</span>
      <button class="ux-pagination__btn">›</button>
    </nav>
  </div>
  {%- endif %}
</div>
{% endmacro %}
