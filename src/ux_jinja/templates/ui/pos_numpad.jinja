{# pos_numpad(label, value, layout, attrs)
   Numeric entry pad for POS cash / quantity input.

   Arguments:
     label   -- display label above the value (e.g. "A cobrar · €19,40")
     value   -- current display value string (e.g. "€20,00")
     layout  -- "standard" (1-2-3 … 0) or "calc" (7-8-9 … double-zero),
                default "standard"
     attrs   -- escape-hatch dict

   The buttons emit no logic by default — wire data-on:click on the
   container or override individual buttons via the slot.
#}
{% macro pos_numpad(label="", value="0,00", layout="standard", attrs={}) %}
<div class='ux-numpad-display'
  {%- for k, v in attrs.items() %} {{ k }}="{{ v|e }}"{% endfor -%}>
  {%- if label %}<div class='ux-numpad-display__label'>{{ label|e }}</div>{% endif %}
  <div class='ux-numpad-display__value'>{{ value|e }}</div>
</div>
<div class='ux-numpad'>
{%- if layout == "calc" %}
  <button class='ux-numpad__btn'>7</button>
  <button class='ux-numpad__btn'>8</button>
  <button class='ux-numpad__btn'>9</button>
  <button class='ux-numpad__btn'>4</button>
  <button class='ux-numpad__btn'>5</button>
  <button class='ux-numpad__btn'>6</button>
  <button class='ux-numpad__btn'>1</button>
  <button class='ux-numpad__btn'>2</button>
  <button class='ux-numpad__btn'>3</button>
  <button class='ux-numpad__btn ux-numpad__btn--double'>0</button>
  <button class='ux-numpad__btn ux-numpad__btn--ghost'>,</button>
{%- else %}
  <button class='ux-numpad__btn'>1</button>
  <button class='ux-numpad__btn'>2</button>
  <button class='ux-numpad__btn'>3</button>
  <button class='ux-numpad__btn'>4</button>
  <button class='ux-numpad__btn'>5</button>
  <button class='ux-numpad__btn'>6</button>
  <button class='ux-numpad__btn'>7</button>
  <button class='ux-numpad__btn'>8</button>
  <button class='ux-numpad__btn'>9</button>
  <button class='ux-numpad__btn ux-numpad__btn--ghost'>,</button>
  <button class='ux-numpad__btn'>0</button>
  <button class='ux-numpad__btn ux-numpad__btn--ghost'>&#9003;</button>
{%- endif %}
</div>
{% endmacro %}
