{# check(name, label, checked, value, value_signal, disabled, attrs)

   Checkbox matching lib/css/components/forms.css:

     <label class="ux-check">
       <input type="checkbox" name="..." />
       <span class="ux-check__box"></span>
       Label text
     </label>

   `value_signal` -> Datastar `data-bind="$signal"` two-way binding.
#}
{% macro check(name, label="", checked=False, value=None, value_signal=None, disabled=False, attrs={}) %}
<label class="ux-check"
{%- for k, v in attrs.items() %} {{ k }}="{{ v|e }}"{% endfor -%}>
  <input type="checkbox" name="{{ name|e }}"
{%- if value is not none %} value="{{ value|e }}"{% endif -%}
{%- if checked %} checked{% endif -%}
{%- if disabled %} disabled{% endif -%}
{%- if value_signal %} data-bind="{{ value_signal|e }}"{% endif -%}/>
  <span class="ux-check__box"></span>
{%- if caller is defined %}{{ caller() }}{% else %}{{ label|e }}{% endif -%}
</label>
{% endmacro %}
