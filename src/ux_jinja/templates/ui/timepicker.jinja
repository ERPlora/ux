{# timepicker(name, value, value_signal, disabled, attrs)

   Time input — native `<input type="time">` wrapped in `.ux-timepicker`
   matching lib/css/components/forms-advanced.css.
#}
{% macro timepicker(name, value=None, value_signal=None, disabled=False, attrs={}) %}
<span class="ux-timepicker">
  <input class="ux-input"
    type="time"
    name="{{ name|e }}"
{%- if value is not none and value != "" %} value="{{ value|e }}"{% endif -%}
{%- if disabled %} disabled{% endif -%}
{%- if value_signal %} data-bind="{{ value_signal|e }}"{% endif -%}
{%- for k, v in attrs.items() %} {{ k }}="{{ v|e }}"{% endfor -%}/>
</span>
{% endmacro %}
