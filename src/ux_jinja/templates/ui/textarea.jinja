{# textarea(name, value, placeholder, rows, invalid, disabled, value_signal, attrs)

   Emits `<textarea class="ux-textarea">` matching lib/css/components/forms.css.
   Invalid state -> ux-textarea--invalid.
   `value_signal` -> Datastar `data-bind="$signal"` two-way binding.
#}
{% macro textarea(name, value="", placeholder=None, rows=4, invalid=False, disabled=False, value_signal=None, attrs={}) %}
{%- set classes = ["ux-textarea"] -%}
{%- if invalid %}{%- do classes.append("ux-textarea--invalid") -%}{%- endif -%}
<textarea class="{{ classes | join(' ') }}"
  name="{{ name|e }}"
  rows="{{ rows }}"
{%- if placeholder %} placeholder="{{ placeholder|e }}"{% endif -%}
{%- if disabled %} disabled{% endif -%}
{%- if value_signal %} data-bind="{{ value_signal|e }}"{% endif -%}
{%- for k, v in attrs.items() %} {{ k }}="{{ v|e }}"{% endfor -%}>{{ value|e }}</textarea>
{% endmacro %}
