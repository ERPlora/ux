{# toggle(name, checked, value_signal, size, disabled, attrs)

   iOS-style switch matching lib/css/components/forms.css:

     <label class="ux-toggle">
       <input type="checkbox" name="..." />
       <span class="ux-toggle__track"></span>
     </label>

   Sizes: sm | md (default, no class) | lg.
   `value_signal` -> Datastar `data-bind="$signal"` two-way binding.
#}
{% macro toggle(name, checked=False, value_signal=None, size=None, disabled=False, attrs={}) %}
{%- set classes = ["ux-toggle"] -%}
{%- if size %}{%- do classes.append("ux-toggle--" ~ size) -%}{%- endif -%}
<label class="{{ classes | join(' ') }}"
{%- for k, v in attrs.items() %} {{ k }}="{{ v|e }}"{% endfor -%}>
  <input type="checkbox" name="{{ name|e }}"
{%- if checked %} checked{% endif -%}
{%- if disabled %} disabled{% endif -%}
{%- if value_signal %} data-bind="{{ value_signal|e }}"{% endif -%}/>
  <span class="ux-toggle__track"></span>
</label>
{% endmacro %}
