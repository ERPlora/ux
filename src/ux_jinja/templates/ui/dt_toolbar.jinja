{# dt_toolbar(attrs)

   CSS root from lib/css/components/table.css:  .ux-dt-toolbar
   Consolidated DataTable toolbar row — wraps search, filters, date range,
   view toggle and icon buttons in a single flex line.

   Sub-classes (verified in table.css):
     - ux-dt-toolbar__spacer    flex: 1 separator (pushes right-side items right)
     - ux-dt-toolbar__divider   1px vertical rule between control groups

   The toolbar auto-sizes its direct .ux-search and .ux-select children.

   Args:
     - attrs   extra HTML attributes on the toolbar div

   Slot via {% call dt_toolbar() %}...{% endcall %} renders all toolbar children.
   Typical children: search(), select(), date_range(), view_toggle(), icon_btn(),
   plus plain <div class="ux-dt-toolbar__spacer"> / __divider as needed.
#}
{% macro dt_toolbar(attrs={}) %}
<div class="ux-dt-toolbar"
{%- for k, v in attrs.items() %} {{ k }}="{{ v|e }}"{% endfor -%}>
{%- if caller is defined %}{{ caller() }}{%- endif %}
</div>
{% endmacro %}
